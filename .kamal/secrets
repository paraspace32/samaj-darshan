# Rails master key for decrypting credentials
RAILS_MASTER_KEY=$(cat config/master.key)

# GitHub Container Registry — uses your gh CLI token
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# Database password — generate a strong one for production
SAMAJ_DARSHAN_DATABASE_PASSWORD=${SAMAJ_DARSHAN_DATABASE_PASSWORD:-$(openssl rand -hex 32)}

# Google Cloud Storage
GCS_PROJECT_ID=samaj-darshan
GCS_BUCKET=samaj-darshan-media
GCS_CREDENTIALS=$(cat /tmp/gcs-key.json | tr -d '\n')
