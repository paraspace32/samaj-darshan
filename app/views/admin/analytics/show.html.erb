<% content_for(:page_title, "Visitor Analytics") %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-extrabold text-white">Visitor Analytics</h1>
  <%= link_to "Daily Reports", admin_analytics_reports_path, class: "px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-lg text-sm font-medium transition" %>
</div>

<%# Summary cards %>
<div class="grid grid-cols-3 gap-4 mb-8">
  <% [
    ["Today", @stats[:today]],
    ["This Week", @stats[:week]],
    ["This Month", @stats[:month]]
  ].each do |label, data| %>
    <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-5">
      <p class="text-gray-400 text-xs uppercase tracking-wider mb-1"><%= label %></p>
      <p class="text-2xl font-bold text-white"><%= number_with_delimiter(data[:unique]) %></p>
      <p class="text-gray-500 text-xs"><%= number_with_delimiter(data[:views]) %> page views</p>
    </div>
  <% end %>
</div>

<%# Filters %>
<div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-5 mb-6">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-sm font-semibold text-gray-300">Filters</h3>
    <% if @filter_active %>
      <%= link_to "Clear all", admin_analytics_path, class: "text-orange-400 text-xs hover:text-orange-300" %>
    <% end %>
  </div>
  <%= form_tag admin_analytics_path, method: :get, class: "grid grid-cols-2 lg:grid-cols-5 gap-3" do %>
    <div>
      <label class="text-xs text-gray-400 block mb-1">Date Range</label>
      <select name="range" class="w-full bg-gray-900 border border-gray-700 text-white text-sm rounded-lg px-3 py-2">
        <% [["This Month", "this_month"], ["Today", "today"], ["Yesterday", "yesterday"], ["This Week", "this_week"], ["Last 7 Days", "last_7"], ["Last 30 Days", "last_30"], ["Last 90 Days", "last_90"]].each do |label, val| %>
          <option value="<%= val %>" <%= "selected" if @date_range == val %>><%= label %></option>
        <% end %>
      </select>
    </div>
    <div>
      <label class="text-xs text-gray-400 block mb-1">City</label>
      <select name="city" class="w-full bg-gray-900 border border-gray-700 text-white text-sm rounded-lg px-3 py-2">
        <option value="">All Cities</option>
        <% @available_cities.each do |city| %>
          <option value="<%= city %>" <%= "selected" if params[:city] == city %>><%= city %></option>
        <% end %>
      </select>
    </div>
    <div>
      <label class="text-xs text-gray-400 block mb-1">Device</label>
      <select name="device" class="w-full bg-gray-900 border border-gray-700 text-white text-sm rounded-lg px-3 py-2">
        <option value="">All Devices</option>
        <% @available_devices.each do |dev| %>
          <option value="<%= dev %>" <%= "selected" if params[:device] == dev %>><%= dev.capitalize %></option>
        <% end %>
      </select>
    </div>
    <div>
      <label class="text-xs text-gray-400 block mb-1">Page Path</label>
      <input type="text" name="path" value="<%= params[:path] %>" placeholder="/news/..." class="w-full bg-gray-900 border border-gray-700 text-white text-sm rounded-lg px-3 py-2">
    </div>
    <div class="flex items-end">
      <button type="submit" class="w-full bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium rounded-lg px-4 py-2 transition">Apply Filters</button>
    </div>
  <% end %>
</div>

<%# Filtered stats %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-4">
    <p class="text-gray-400 text-xs">Unique Visitors</p>
    <p class="text-xl font-bold text-white"><%= number_with_delimiter(@filtered_unique) %></p>
  </div>
  <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-4">
    <p class="text-gray-400 text-xs">Page Views</p>
    <p class="text-xl font-bold text-white"><%= number_with_delimiter(@filtered_views) %></p>
  </div>
  <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-4">
    <p class="text-gray-400 text-xs">New / Returning</p>
    <p class="text-xl font-bold text-white"><%= @new_visitors %> / <%= @returning_visitors %></p>
  </div>
  <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-4">
    <p class="text-gray-400 text-xs">Avg Duration</p>
    <p class="text-xl font-bold text-white"><%= @avg_duration %>s</p>
  </div>
</div>

<%# Top pages %>
<div class="grid lg:grid-cols-2 gap-6 mb-8">
  <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-5">
    <h3 class="text-sm font-semibold text-gray-300 mb-3">Top Pages</h3>
    <% @top_pages.each do |page| %>
      <div class="flex justify-between items-center py-2 border-b border-gray-700/30 last:border-0">
        <span class="text-sm text-gray-300 truncate mr-2"><%= page[:path] %></span>
        <span class="text-xs text-gray-500 whitespace-nowrap"><%= page[:uniques] %> unique / <%= page[:views] %> views</span>
      </div>
    <% end %>
    <% if @top_pages.empty? %>
      <p class="text-gray-500 text-sm">No data</p>
    <% end %>
  </div>

  <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-5">
    <h3 class="text-sm font-semibold text-gray-300 mb-3">Top Cities</h3>
    <% @top_cities.each do |city| %>
      <div class="flex justify-between items-center py-2 border-b border-gray-700/30 last:border-0">
        <span class="text-sm text-gray-300"><%= city[:city] %></span>
        <span class="text-xs text-gray-500"><%= city[:count] %> visitors</span>
      </div>
    <% end %>
    <% if @top_cities.empty? %>
      <p class="text-gray-500 text-sm">No data</p>
    <% end %>
  </div>
</div>

<%# Device / Browser / OS %>
<div class="grid lg:grid-cols-3 gap-6">
  <% [["Devices", @device_stats, :type], ["Browsers", @browser_stats, :name], ["OS", @os_stats, :name]].each do |title, data, key| %>
    <div class="bg-gray-800/50 border border-gray-700/50 rounded-xl p-5">
      <h3 class="text-sm font-semibold text-gray-300 mb-3"><%= title %></h3>
      <% data.each do |item| %>
        <div class="flex justify-between items-center py-1.5">
          <span class="text-sm text-gray-300"><%= item[key]&.capitalize %></span>
          <span class="text-xs text-gray-500"><%= item[:count] %></span>
        </div>
      <% end %>
      <% if data.empty? %>
        <p class="text-gray-500 text-sm">No data</p>
      <% end %>
    </div>
  <% end %>
</div>
