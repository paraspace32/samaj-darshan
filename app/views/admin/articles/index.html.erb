<% content_for(:page_title, "Articles") %>

<%# Header %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <div>
    <p class="text-sm text-gray-500"><%= @total_count %> article<%= @total_count == 1 ? "" : "s" %> total</p>
  </div>
  <% if current_user.can_create_articles? %>
    <%= link_to new_admin_article_path, class: "inline-flex items-center gap-2 rounded-xl gradient-brand px-5 py-2.5 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all self-start" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4v16m8-8H4"/></svg>
      New Article
    <% end %>
  <% end %>
</div>

<%# Filters %>
<%= form_with url: admin_articles_path, method: :get, class: "bg-white rounded-2xl border border-gray-200/60 p-5 mb-6 shadow-sm", data: { turbo_frame: "_top" } do %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
    <div>
      <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search title..."
             class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
    </div>
    <div>
      <select name="status" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Statuses</option>
        <% Article.statuses.each_key do |s| %>
          <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.humanize %></option>
        <% end %>
      </select>
    </div>
    <div>
      <select name="region_id" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Regions</option>
        <% Region.active.ordered.each do |r| %>
          <option value="<%= r.id %>" <%= "selected" if params[:region_id] == r.id.to_s %>><%= r.name_en %></option>
        <% end %>
      </select>
    </div>
    <div>
      <select name="category_id" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Categories</option>
        <% Category.active.ordered.each do |c| %>
          <option value="<%= c.id %>" <%= "selected" if params[:category_id] == c.id.to_s %>><%= c.name_en %></option>
        <% end %>
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="flex-1 rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors cursor-pointer">Filter</button>
      <%= link_to "Clear", admin_articles_path, class: "flex-1 rounded-xl bg-gray-100 px-4 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors text-center" %>
    </div>
  </div>
<% end %>

<%# Table %>
<div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
  <% if @articles.any? %>
    <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[640px]">
      <thead>
        <tr class="text-left text-xs text-gray-500 uppercase tracking-wider border-b border-gray-100 bg-gray-50/50">
          <th class="px-6 py-3.5 font-semibold">Title</th>
          <th class="px-6 py-3.5 font-semibold hidden sm:table-cell">Region</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Category</th>
          <th class="px-6 py-3.5 font-semibold hidden lg:table-cell">Author</th>
          <th class="px-6 py-3.5 font-semibold">Status</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Date</th>
          <th class="px-6 py-3.5 font-semibold w-20"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @articles.each do |article| %>
          <tr class="hover:bg-orange-50/30 transition-colors">
            <td class="px-6 py-4">
              <%= link_to admin_article_path(article), class: "font-semibold text-gray-900 hover:text-orange-600 transition-colors line-clamp-1" do %>
                <%= article.title_en %>
              <% end %>
              <p class="text-xs text-gray-400 mt-0.5 line-clamp-1"><%= article.title_hi %></p>
            </td>
            <td class="px-6 py-4 text-gray-500 hidden sm:table-cell"><%= article.region.name_en %></td>
            <td class="px-6 py-4 hidden md:table-cell">
              <span class="inline-flex items-center gap-1.5 text-gray-600">
                <span class="w-2 h-2 rounded-full" style="background-color: <%= article.category.color %>"></span>
                <%= article.category.name_en %>
              </span>
            </td>
            <td class="px-6 py-4 text-gray-500 hidden lg:table-cell"><%= article.author.name %></td>
            <td class="px-6 py-4"><%= article_status_badge(article.status) %></td>
            <td class="px-6 py-4 text-gray-400 text-xs hidden md:table-cell"><%= article.created_at.strftime("%d %b %Y") %></td>
            <td class="px-6 py-4 text-right">
              <%= link_to edit_admin_article_path(article), class: "inline-flex items-center gap-1 text-xs text-orange-600 hover:text-orange-700 font-semibold" do %>
                Edit
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>

    <%# Pagination %>
    <% total_pages = (@total_count.to_f / @per_page).ceil %>
    <% if total_pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between bg-gray-50/30">
        <p class="text-xs text-gray-500 font-medium">Page <%= @page %> of <%= total_pages %></p>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to "Previous", admin_articles_path(request.query_parameters.merge(page: @page - 1)), class: "px-3.5 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition-colors" %>
          <% end %>
          <% if @page < total_pages %>
            <%= link_to "Next", admin_articles_path(request.query_parameters.merge(page: @page + 1)), class: "px-3.5 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition-colors" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="px-6 py-16 text-center">
      <div class="w-14 h-14 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
      </div>
      <p class="text-gray-400 mb-3">No articles found.</p>
      <%= link_to "Create your first article", new_admin_article_path, class: "text-sm text-orange-600 hover:text-orange-700 font-semibold" %>
    </div>
  <% end %>
</div>
