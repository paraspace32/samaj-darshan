<% content_for(:page_title, "Article ##{@article.id}") %>

<%# Action bar %>
<div class="bg-white rounded-2xl border border-gray-200/60 p-4 sm:p-5 mb-6 shadow-sm">
  <div class="flex items-center justify-between mb-3">
    <span><%= article_status_badge(@article.status) %></span>
    <% if current_user.can_edit_article?(@article) %>
      <%= link_to edit_admin_article_path(@article), class: "inline-flex items-center gap-2 rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      <% end %>
    <% end %>
  </div>

  <div class="flex flex-wrap gap-2">
    <% if (@article.draft? || @article.rejected?) && current_user.can_create_articles? %>
      <%= button_to submit_for_review_admin_article_path(@article), method: :patch, class: "inline-flex items-center gap-1.5 rounded-xl bg-amber-500 px-3 py-2 text-xs sm:text-sm font-semibold text-white hover:bg-amber-600 transition-colors shadow-sm cursor-pointer" do %>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        Submit for Review
      <% end %>
    <% end %>

    <% if @article.pending_review? && current_user.can_review? %>
      <%= button_to approve_admin_article_path(@article), method: :patch, class: "inline-flex items-center gap-1.5 rounded-xl bg-blue-600 px-3 py-2 text-xs sm:text-sm font-semibold text-white hover:bg-blue-700 transition-colors shadow-sm cursor-pointer" do %>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4"/></svg>
        Approve
      <% end %>
    <% end %>

    <% if (@article.pending_review? || @article.approved?) && current_user.can_publish? %>
      <%= button_to publish_admin_article_path(@article), method: :patch, class: "inline-flex items-center gap-1.5 rounded-xl bg-emerald-600 px-3 py-2 text-xs sm:text-sm font-semibold text-white hover:bg-emerald-700 transition-colors shadow-sm cursor-pointer" do %>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M5 13l4 4L19 7"/></svg>
        Publish
      <% end %>
    <% end %>
  </div>

  <% if @article.pending_review? && current_user.can_review? %>
    <div class="mt-3 pt-3 border-t border-gray-100">
      <%= form_with url: reject_admin_article_path(@article), method: :patch, class: "flex flex-col sm:flex-row items-stretch sm:items-center gap-2" do |f| %>
        <%= f.text_field :rejection_reason, placeholder: "Rejection reason...", required: true, class: "rounded-xl border border-gray-200 px-4 py-2 text-sm flex-1 focus:border-red-500 focus:ring-2 focus:ring-red-500/20 focus:outline-none bg-gray-50/50" %>
        <%= f.submit "Reject", class: "rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700 transition-colors cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <% if current_user.can_delete_articles? %>
    <div class="flex items-center gap-3 mt-3 pt-3 border-t border-gray-100">
      <%= button_to admin_article_path(@article), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this article?" }, class: "inline-flex items-center gap-1.5 text-xs text-red-500 hover:text-red-700 font-medium transition-colors cursor-pointer" do %>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete Article
      <% end %>
    </div>
  <% end %>
</div>

<%# Rejection reason %>
<% if @article.rejected? && @article.rejection_reason.present? %>
  <div class="rounded-2xl bg-red-50 border border-red-200/60 px-5 py-4 mb-6">
    <div class="flex items-center gap-2 mb-1">
      <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      <p class="text-sm font-bold text-red-800">Rejection Reason</p>
    </div>
    <p class="text-sm text-red-700 ml-6"><%= @article.rejection_reason %></p>
  </div>
<% end %>

<%# Meta info %>
<div class="bg-white rounded-2xl border border-gray-200/60 p-6 mb-6 shadow-sm">
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-5 text-sm">
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Region</p>
      <p class="font-semibold text-gray-900"><%= @article.region.name_en %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Category</p>
      <p class="font-semibold text-gray-900 inline-flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= @article.category.color %>"></span>
        <%= @article.category.name_en %>
      </p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Author</p>
      <p class="font-semibold text-gray-900"><%= @article.author.name %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Type</p>
      <p class="font-semibold text-gray-900"><%= @article.article_type.humanize %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Created</p>
      <p class="font-semibold text-gray-900"><%= @article.created_at.strftime("%d %b %Y") %></p>
    </div>
    <% if @article.published_at %>
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Published</p>
        <p class="font-semibold text-gray-900"><%= @article.published_at.strftime("%d %b %Y") %></p>
      </div>
    <% end %>
  </div>
</div>

<%# Cover image %>
<% if @article.cover_image.attached? %>
  <div class="mb-6">
    <%= optimized_image_tag @article.cover_image, variant: :card, class: "max-h-72 rounded-2xl object-cover border border-gray-200/60 shadow-sm" %>
  </div>
<% end %>

<%# Additional images %>
<% if @article.images.attached? %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 mb-6 shadow-sm">
    <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Images (<%= @article.images.count %>)
    </h3>
    <div class="flex flex-wrap gap-3">
      <% @article.images.each do |img| %>
        <%= optimized_image_tag img, variant: :thumb, class: "h-32 w-auto rounded-xl object-cover border border-gray-200/60 shadow-sm" %>
      <% end %>
    </div>
  </div>
<% end %>

<%# Content (bilingual side by side) %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <%# English %>
  <div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
    <div class="px-6 py-3 bg-gray-50/50 border-b border-gray-100">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">English</span>
    </div>
    <div class="p-6">
      <h2 class="text-xl font-extrabold text-gray-900 mb-4"><%= @article.title_en %></h2>
      <div class="prose prose-sm text-gray-600 max-w-none"><%= simple_format(@article.content_en) %></div>
    </div>
  </div>

  <%# Hindi %>
  <div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm" dir="auto">
    <div class="px-6 py-3 bg-orange-50/50 border-b border-orange-100/50">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-orange-100 text-orange-700">हिंदी</span>
    </div>
    <div class="p-6">
      <h2 class="text-xl font-extrabold text-gray-900 mb-4"><%= @article.title_hi %></h2>
      <div class="prose prose-sm text-gray-600 max-w-none"><%= simple_format(@article.content_hi) %></div>
    </div>
  </div>
</div>
