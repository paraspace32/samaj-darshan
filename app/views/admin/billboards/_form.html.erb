<%= form_with model: [:admin, billboard], class: "max-w-2xl space-y-6" do |f| %>
  <% if billboard.errors.any? %>
    <div class="rounded-2xl bg-red-50 border border-red-200/60 p-5 animate-fade-in">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <h3 class="text-sm font-bold text-red-800"><%= pluralize(billboard.errors.count, "error") %> found:</h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1 ml-7">
        <% billboard.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm space-y-5">
    <h2 class="text-sm font-bold text-gray-900 flex items-center gap-2">
      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Billboard Details
    </h2>

    <div>
      <label class="block text-sm font-semibold text-gray-600 mb-1.5">Title (internal name)</label>
      <%= f.text_field :title, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "e.g. Diwali Sale Banner" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">Type</label>
        <%= f.select :billboard_type, Billboard.billboard_types.keys.map { |k| [k.humanize, k] }, {}, { class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50" } %>
        <p class="text-xs text-gray-400 mt-1">
          <strong>Top banner</strong> — below navbar &nbsp;|&nbsp;
          <strong>Feed inline</strong> — between articles &nbsp;|&nbsp;
          <strong>Fullscreen splash</strong> — covers homepage &nbsp;|&nbsp;
          <strong>Article top</strong> — above article images &nbsp;|&nbsp;
          <strong>Article mid</strong> — between content & share &nbsp;|&nbsp;
          <strong>Marriage ad</strong> — crossfade slideshow on homepage
        </p>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">Link URL (optional)</label>
        <%= f.url_field :link_url, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "https://example.com" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">Priority</label>
        <%= f.number_field :priority, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", min: 0 %>
        <p class="text-xs text-gray-400 mt-1">Higher = shown first</p>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">Start Date</label>
        <%= f.date_field :start_date, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50" %>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">End Date</label>
        <%= f.date_field :end_date, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50" %>
        <p class="text-xs text-gray-400 mt-1">Leave blank = runs forever</p>
      </div>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-600 mb-2">Banner Image</label>
      <% if billboard.persisted? && billboard.image.attached? %>
        <div class="mb-3">
          <%= optimized_image_tag billboard.image, variant: :thumb, class: "h-24 w-auto rounded-xl object-cover border border-gray-200/60 shadow-sm" %>
        </div>
      <% end %>
      <%= f.file_field :image, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-5 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100 file:cursor-pointer file:transition-colors" %>
      <p class="text-xs text-gray-400 mt-1">Recommended: 1200×400 for banners, 1200×900 for splash</p>
    </div>

    <div class="flex items-center gap-3">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.check_box :active, class: "w-4 h-4 rounded border-gray-300 text-orange-600 focus:ring-orange-500" %>
        <span class="text-sm font-medium text-gray-700">Active</span>
      </label>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit billboard.persisted? ? "Update Billboard" : "Create Billboard", class: "rounded-xl gradient-brand px-6 py-3 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all cursor-pointer" %>
    <%= link_to "Cancel", admin_billboards_path, class: "rounded-xl bg-gray-100 px-5 py-3 text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
