<% content_for(:page_title, "Billboards") %>

<%# Header %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <p class="text-sm text-gray-500"><%= @billboards.count %> billboard<%= @billboards.count == 1 ? "" : "s" %></p>
  <%= link_to new_admin_billboard_path, class: "inline-flex items-center gap-2 rounded-xl gradient-brand px-5 py-2.5 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all self-start" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4v16m8-8H4"/></svg>
    New Billboard
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
  <% if @billboards.any? %>
    <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[640px]">
      <thead>
        <tr class="text-left text-xs text-gray-500 uppercase tracking-wider border-b border-gray-100 bg-gray-50/50">
          <th class="px-6 py-3.5 font-semibold">Preview</th>
          <th class="px-6 py-3.5 font-semibold">Title</th>
          <th class="px-6 py-3.5 font-semibold">Type</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Schedule</th>
          <th class="px-6 py-3.5 font-semibold hidden sm:table-cell">Priority</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Stats</th>
          <th class="px-6 py-3.5 font-semibold">Status</th>
          <th class="px-6 py-3.5 font-semibold w-36"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @billboards.each do |bb| %>
          <tr class="hover:bg-orange-50/30 transition-colors">
            <td class="px-6 py-4">
              <% if bb.image.attached? %>
                <%= optimized_image_tag bb.image, variant: :thumb, class: "h-14 w-auto rounded-lg object-cover border border-gray-200/60 shadow-sm" %>
              <% else %>
                <div class="h-14 w-24 bg-gray-100 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <p class="font-semibold text-gray-900"><%= bb.title %></p>
              <% if bb.link_url.present? %>
                <p class="text-xs text-gray-400 truncate max-w-[200px]"><%= bb.link_url %></p>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <% type_colors = { "top_banner" => "bg-blue-50 text-blue-700", "feed_inline" => "bg-amber-50 text-amber-700", "fullscreen_splash" => "bg-purple-50 text-purple-700", "article_top" => "bg-cyan-50 text-cyan-700", "article_mid" => "bg-emerald-50 text-emerald-700" } %>
              <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold <%= type_colors[bb.billboard_type] %>">
                <%= bb.billboard_type.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 text-xs text-gray-500 hidden md:table-cell">
              <% if bb.start_date || bb.end_date %>
                <%= bb.start_date&.strftime("%d %b") || "—" %> → <%= bb.end_date&.strftime("%d %b") || "∞" %>
              <% else %>
                <span class="text-gray-400">Always</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-gray-500 hidden sm:table-cell"><%= bb.priority %></td>
            <td class="px-6 py-4 text-xs text-gray-500 hidden md:table-cell">
              <span title="Impressions"><%= bb.impressions_count %> views</span><br>
              <span title="Clicks"><%= bb.clicks_count %> clicks</span>
            </td>
            <td class="px-6 py-4">
              <% if bb.live? %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>Live
                </span>
              <% elsif bb.active? %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>Scheduled
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-50 text-gray-500 border border-gray-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Inactive
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right space-x-2">
              <%= link_to "Edit", edit_admin_billboard_path(bb), class: "text-xs text-orange-600 hover:text-orange-700 font-semibold" %>
              <%= button_to bb.active? ? "Off" : "On", toggle_active_admin_billboard_path(bb), method: :patch, class: "text-xs #{bb.active? ? 'text-red-500 hover:text-red-700' : 'text-emerald-600 hover:text-emerald-700'} font-medium cursor-pointer", form: { class: "inline" } %>
              <%= button_to "Delete", admin_billboard_path(bb), method: :delete, data: { turbo_confirm: "Delete '#{bb.title}'?" }, class: "text-xs text-red-500 hover:text-red-700 font-medium cursor-pointer", form: { class: "inline" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  <% else %>
    <div class="px-6 py-16 text-center">
      <div class="w-14 h-14 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-gray-400 mb-3">No billboards yet.</p>
      <%= link_to "Create your first billboard", new_admin_billboard_path, class: "text-sm text-orange-600 hover:text-orange-700 font-semibold" %>
    </div>
  <% end %>
</div>
