<% color_map = {
  "blue"    => { bg: "bg-blue-50", text: "text-blue-700", icon_bg: "bg-blue-100", icon_text: "text-blue-600" },
  "emerald" => { bg: "bg-emerald-50", text: "text-emerald-700", icon_bg: "bg-emerald-100", icon_text: "text-emerald-600" },
  "amber"   => { bg: "bg-amber-50", text: "text-amber-700", icon_bg: "bg-amber-100", icon_text: "text-amber-600" },
  "gray"    => { bg: "bg-gray-50", text: "text-gray-700", icon_bg: "bg-gray-100", icon_text: "text-gray-500" },
  "violet"  => { bg: "bg-violet-50", text: "text-violet-700", icon_bg: "bg-violet-100", icon_text: "text-violet-600" },
  "orange"  => { bg: "bg-orange-50", text: "text-orange-700", icon_bg: "bg-orange-100", icon_text: "text-orange-600" },
  "cyan"    => { bg: "bg-cyan-50", text: "text-cyan-700", icon_bg: "bg-cyan-100", icon_text: "text-cyan-600" }
} %>
<% c = color_map.fetch(color, color_map["gray"]) %>
<div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200/60 p-3 sm:p-5 shadow-sm hover:shadow-md transition-shadow">
  <div class="flex items-center justify-between mb-2 sm:mb-3">
    <p class="text-xs sm:text-sm font-medium text-gray-500 truncate mr-2"><%= label %></p>
    <div class="w-7 h-7 sm:w-9 sm:h-9 rounded-lg sm:rounded-xl <%= c[:icon_bg] %> flex items-center justify-center shrink-0">
      <% icon_map = {
        "Total Articles" => '<path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>',
        "Published" => '<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>',
        "Pending Review" => '<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>',
        "Drafts" => '<path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>',
        "Regions" => '<path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>',
        "Categories" => '<path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>',
        "Users" => '<path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>',
        "Billboards" => '<path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>'
      } %>
      <svg class="w-4.5 h-4.5 <%= c[:icon_text] %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><%= (icon_map[label] || "").html_safe %></svg>
    </div>
  </div>
  <p class="text-2xl sm:text-3xl font-extrabold <%= c[:text] %>"><%= value %></p>
</div>
