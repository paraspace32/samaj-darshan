<% content_for(:page_title, "Job Posts") %>

<%# Header %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <div>
    <p class="text-sm text-gray-500"><%= @total_count %> post<%= @total_count == 1 ? "" : "s" %> total</p>
  </div>
  <%= link_to new_admin_job_post_path, class: "inline-flex items-center gap-2 rounded-xl gradient-brand px-5 py-2.5 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all self-start" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4v16m8-8H4"/></svg>
    New Job Post
  <% end %>
</div>

<%# Filters %>
<%= form_with url: admin_job_posts_path, method: :get, class: "bg-white rounded-2xl border border-gray-200/60 p-5 mb-6 shadow-sm", data: { turbo_frame: "_top" } do %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div>
      <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search title or company..."
             class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
    </div>
    <div>
      <select name="status" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Statuses</option>
        <% JobPost.statuses.each_key do |s| %>
          <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.humanize %></option>
        <% end %>
      </select>
    </div>
    <div>
      <select name="category" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Categories</option>
        <% JobPost.categories.each_key do |c| %>
          <option value="<%= c %>" <%= "selected" if params[:category] == c %>><%= c.humanize %></option>
        <% end %>
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="flex-1 rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors cursor-pointer">Filter</button>
      <%= link_to "Clear", admin_job_posts_path, class: "flex-1 rounded-xl bg-gray-100 px-4 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors text-center" %>
    </div>
  </div>
<% end %>

<%# Table %>
<div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
  <% if @job_posts.any? %>
    <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[640px]">
      <thead>
        <tr class="text-left text-xs text-gray-500 uppercase tracking-wider border-b border-gray-100 bg-gray-50/50">
          <th class="px-6 py-3.5 font-semibold">Title</th>
          <th class="px-6 py-3.5 font-semibold hidden sm:table-cell">Company</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Category</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Deadline</th>
          <th class="px-6 py-3.5 font-semibold">Status</th>
          <th class="px-6 py-3.5 font-semibold w-20"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @job_posts.each do |post| %>
          <tr class="hover:bg-orange-50/30 transition-colors">
            <td class="px-6 py-4">
              <%= link_to admin_job_post_path(post), class: "font-semibold text-gray-900 hover:text-orange-600 transition-colors line-clamp-1" do %>
                <%= post.title_en %>
              <% end %>
              <p class="text-xs text-gray-400 mt-0.5 line-clamp-1"><%= post.title_hi %></p>
            </td>
            <td class="px-6 py-4 text-gray-500 hidden sm:table-cell"><%= post.company_name %></td>
            <td class="px-6 py-4 hidden md:table-cell">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-600"><%= post.category_label %></span>
            </td>
            <td class="px-6 py-4 text-gray-500 text-xs hidden md:table-cell">
              <%= post.deadline&.strftime("%d %b %Y") || "—" %>
            </td>
            <td class="px-6 py-4">
              <% if post.draft? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-600">Draft</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-100 text-emerald-700">Published</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right space-x-3">
              <%= link_to "Edit", edit_admin_job_post_path(post), class: "text-xs text-orange-600 hover:text-orange-700 font-semibold" %>
              <%= button_to admin_job_post_path(post), method: :delete, data: { turbo_confirm: "Delete this post?" }, class: "text-xs text-red-500 hover:text-red-700 font-medium cursor-pointer", form: { class: "inline" } do %>
                Delete
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>

    <%# Pagination %>
    <% total_pages = (@total_count.to_f / @per_page).ceil %>
    <% if total_pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between bg-gray-50/30">
        <p class="text-xs text-gray-500 font-medium">Page <%= @page %> of <%= total_pages %></p>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to "Previous", admin_job_posts_path(request.query_parameters.merge(page: @page - 1)), class: "px-3.5 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition-colors" %>
          <% end %>
          <% if @page < total_pages %>
            <%= link_to "Next", admin_job_posts_path(request.query_parameters.merge(page: @page + 1)), class: "px-3.5 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition-colors" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="px-6 py-16 text-center">
      <div class="w-14 h-14 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-gray-400 mb-3">No job posts yet.</p>
      <%= link_to "Create your first job post", new_admin_job_post_path, class: "text-sm text-orange-600 hover:text-orange-700 font-semibold" %>
    </div>
  <% end %>
</div>
