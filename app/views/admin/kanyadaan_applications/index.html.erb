<% content_for(:page_title, "Kanyadaan Applications") %>

<%# Header %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <div>
    <h1 class="text-xl font-black text-gray-900">Kanyadaan Yojna Applications</h1>
    <p class="text-sm text-gray-500 mt-0.5"><%= @applications.count %> total applications</p>
  </div>
</div>

<%# Status filter tabs %>
<div class="flex items-center gap-2 mb-5 overflow-x-auto">
  <% statuses = [["All", nil], ["Pending", "pending"], ["Reviewed", "reviewed"], ["Approved", "approved"], ["Rejected", "rejected"]] %>
  <% statuses.each do |label, value| %>
    <% active = params[:status] == value || (value.nil? && params[:status].blank?) %>
    <%= link_to label, admin_kanyadaan_applications_path(status: value),
          class: "px-3 py-1.5 rounded-lg text-xs font-bold whitespace-nowrap transition-all #{active ? 'bg-orange-600 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
  <% end %>
</div>

<%# Table %>
<div class="bg-white rounded-2xl border border-gray-200/70 shadow-sm overflow-hidden">
  <% if @applications.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50/80 border-b border-gray-100">
            <th class="text-left px-4 py-3 font-bold text-gray-500 text-xs uppercase tracking-wider">Girl Name</th>
            <th class="text-left px-4 py-3 font-bold text-gray-500 text-xs uppercase tracking-wider">Parent Name</th>
            <th class="text-left px-4 py-3 font-bold text-gray-500 text-xs uppercase tracking-wider">Contact</th>
            <th class="text-left px-4 py-3 font-bold text-gray-500 text-xs uppercase tracking-wider">Location</th>
            <th class="text-left px-4 py-3 font-bold text-gray-500 text-xs uppercase tracking-wider">Status</th>
            <th class="text-left px-4 py-3 font-bold text-gray-500 text-xs uppercase tracking-wider">Date</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @applications.each do |app| %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-4 py-3 font-semibold text-gray-900"><%= app.girl_name %></td>
              <td class="px-4 py-3 text-gray-700"><%= app.parent_name %></td>
              <td class="px-4 py-3 text-gray-700">
                <a href="tel:<%= app.contact %>" class="text-orange-600 hover:text-orange-700 font-medium"><%= app.contact %></a>
              </td>
              <td class="px-4 py-3 text-gray-700"><%= app.location %></td>
              <td class="px-4 py-3">
                <% badge_colors = { "pending" => "bg-amber-100 text-amber-700", "reviewed" => "bg-blue-100 text-blue-700", "approved" => "bg-green-100 text-green-700", "rejected" => "bg-red-100 text-red-700" } %>
                <span class="inline-flex px-2 py-0.5 rounded-full text-[11px] font-bold <%= badge_colors[app.status] %>">
                  <%= app.status.capitalize %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-500 text-xs"><%= app.created_at.strftime("%d %b %Y") %></td>
              <td class="px-4 py-3 text-right">
                <%= link_to "View", admin_kanyadaan_application_path(app), class: "text-xs font-bold text-orange-600 hover:text-orange-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-gray-400 text-sm">No applications found.</p>
    </div>
  <% end %>
</div>
