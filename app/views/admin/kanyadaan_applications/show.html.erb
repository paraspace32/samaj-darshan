<% content_for(:page_title, "Application ##{@application.id}") %>

<div class="max-w-2xl">
  <%# Back link %>
  <div class="mb-5">
    <%= link_to admin_kanyadaan_applications_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-orange-600 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
      Back to applications
    <% end %>
  </div>

  <%# Application details card %>
  <div class="bg-white rounded-2xl border border-gray-200/70 shadow-sm overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-lg font-black text-gray-900"><%= @application.girl_name %></h2>
      <% badge_colors = { "pending" => "bg-amber-100 text-amber-700", "reviewed" => "bg-blue-100 text-blue-700", "approved" => "bg-green-100 text-green-700", "rejected" => "bg-red-100 text-red-700" } %>
      <span class="inline-flex px-3 py-1 rounded-full text-xs font-bold <%= badge_colors[@application.status] %>">
        <%= @application.status.capitalize %>
      </span>
    </div>

    <div class="px-6 py-5 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Girl Name</p>
          <p class="text-sm font-semibold text-gray-900"><%= @application.girl_name %></p>
        </div>
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Parent Name</p>
          <p class="text-sm font-semibold text-gray-900"><%= @application.parent_name %></p>
        </div>
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Contact</p>
          <p class="text-sm font-semibold text-gray-900">
            <a href="tel:<%= @application.contact %>" class="text-orange-600 hover:text-orange-700"><%= @application.contact %></a>
          </p>
        </div>
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Location</p>
          <p class="text-sm font-semibold text-gray-900"><%= @application.location %></p>
        </div>
      </div>

      <% if @application.notes.present? %>
        <div>
          <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Notes</p>
          <p class="text-sm text-gray-700 leading-relaxed"><%= @application.notes %></p>
        </div>
      <% end %>

      <div>
        <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Submitted</p>
        <p class="text-sm text-gray-700"><%= @application.created_at.strftime("%d %b %Y, %I:%M %p") %></p>
      </div>
    </div>
  </div>

  <%# Update status %>
  <div class="bg-white rounded-2xl border border-gray-200/70 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h3 class="text-sm font-black text-gray-900">Update Status</h3>
    </div>
    <div class="px-6 py-5">
      <%= form_with model: [:admin, @application], method: :patch, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1.5">Status</label>
          <%= f.select :status, KanyadaanApplication.statuses.keys.map { |s| [s.capitalize, s] },
                {}, class: "w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none" %>
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-1.5">Admin Notes</label>
          <%= f.text_area :notes, rows: 3, class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none resize-none" %>
        </div>
        <%= f.submit "Update", class: "px-6 py-2.5 rounded-xl text-white font-bold text-sm cursor-pointer transition-all active:scale-[0.98]", style: "background: linear-gradient(135deg, #f97316, #dc2626)" %>
      <% end %>
    </div>
  </div>
</div>
