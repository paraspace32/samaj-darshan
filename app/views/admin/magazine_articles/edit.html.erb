<% content_for(:page_title, "Edit Article — #{@magazine.display_issue}") %>

<div class="mb-4">
  <%= link_to admin_magazine_path(@magazine), class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-orange-600 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
    Back to <%= @magazine.display_issue %>
  <% end %>
</div>

<%= render "form", article: @article %>
