<%= form_with model: [:admin, magazine], class: "space-y-6" do |f| %>
  <% if magazine.errors.any? %>
    <div class="rounded-2xl bg-red-50 border border-red-200/60 p-5 animate-fade-in">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <h3 class="text-sm font-bold text-red-800"><%= pluralize(magazine.errors.count, "error") %> found:</h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1 ml-7">
        <% magazine.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title (bilingual) %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm">
    <h2 class="text-sm font-bold text-gray-900 mb-4">Title</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">English</label>
        <%= f.text_field :title_en, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "Issue title in English" %>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">हिंदी</label>
        <%= f.text_field :title_hi, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "अंक का शीर्षक हिंदी में", dir: "auto" %>
      </div>
    </div>
  </div>

  <%# Description (bilingual) %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm">
    <h2 class="text-sm font-bold text-gray-900 mb-4">Description (optional)</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">English</label>
        <%= f.text_area :description_en, rows: 4, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50 resize-y", placeholder: "Brief description of this issue..." %>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">हिंदी</label>
        <%= f.text_area :description_hi, rows: 4, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50 resize-y", placeholder: "इस अंक का संक्षिप्त विवरण...", dir: "auto" %>
      </div>
    </div>
  </div>

  <%# Issue details %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm">
    <h2 class="text-sm font-bold text-gray-900 mb-4">Issue Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">Issue Number</label>
        <%= f.number_field :issue_number, min: 1, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "e.g. 1, 2, 3..." %>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">Volume (optional)</label>
        <%= f.text_field :volume, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "e.g. 1, 2, A..." %>
      </div>
    </div>

    <div class="mt-5 pt-5 border-t border-gray-100">
      <label class="block text-sm font-semibold text-gray-600 mb-2">Cover Image</label>
      <% if magazine.persisted? && magazine.cover_image.attached? %>
        <div class="mb-3">
          <%= optimized_image_tag magazine.cover_image, variant: :thumb, class: "h-40 w-auto rounded-xl object-cover border border-gray-200/60 shadow-sm" %>
        </div>
      <% end %>
      <%= f.file_field :cover_image, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-5 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100 file:cursor-pointer file:transition-colors" %>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-3">
    <%= f.submit magazine.persisted? ? "Update Magazine" : "Create Magazine", class: "rounded-xl gradient-brand px-6 py-3 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all cursor-pointer" %>
    <%= link_to "Cancel", magazine.persisted? ? admin_magazine_path(magazine) : admin_magazines_path, class: "rounded-xl bg-gray-100 px-5 py-3 text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
