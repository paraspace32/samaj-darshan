<% content_for(:page_title, "#{@magazine.display_issue} — #{@magazine.title_en}") %>

<div class="mb-4">
  <%= link_to admin_magazines_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-orange-600 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
    Back to Magazines
  <% end %>
</div>

<%# Action bar %>
<div class="bg-white rounded-2xl border border-gray-200/60 p-5 mb-6 shadow-sm">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider <%= @magazine.published? ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-100 text-gray-500' %>">
        <%= @magazine.status %>
      </span>
      <span class="text-sm font-mono font-bold text-orange-600"><%= @magazine.display_issue %></span>
    </div>
    <div class="flex items-center gap-2">
      <% if @magazine.published? %>
        <%= link_to magazine_path(@magazine), target: "_blank", class: "inline-flex items-center gap-1.5 rounded-xl bg-emerald-50 border border-emerald-200 px-3 py-2 text-sm font-medium text-emerald-700 hover:bg-emerald-100 transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          View Live
        <% end %>
      <% end %>
      <% if @magazine.draft? %>
        <%= button_to publish_admin_magazine_path(@magazine), method: :patch, data: { turbo_confirm: "Publish this issue?" }, class: "inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700 transition-colors cursor-pointer" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Publish
        <% end %>
      <% end %>
      <%= link_to edit_admin_magazine_path(@magazine), class: "inline-flex items-center gap-2 rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      <% end %>
      <%= button_to admin_magazine_path(@magazine), method: :delete, data: { turbo_confirm: "Delete this magazine issue? This will also delete all articles in it." }, class: "inline-flex items-center gap-2 rounded-xl bg-red-50 border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 hover:bg-red-100 transition-colors cursor-pointer" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete
      <% end %>
    </div>
  </div>
</div>

<%# Details card %>
<div class="bg-white rounded-2xl border border-gray-200/60 p-6 mb-6 shadow-sm">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% if @magazine.cover_image.attached? %>
      <div>
        <%= optimized_image_tag @magazine.cover_image, variant: :card, class: "w-full rounded-xl object-cover shadow-sm border border-gray-200/60" %>
      </div>
    <% end %>
    <div>
      <h2 class="text-xl font-extrabold text-gray-900 mb-1"><%= @magazine.title_en %></h2>
      <p class="text-sm text-gray-500 mb-4"><%= @magazine.title_hi %></p>

      <div class="space-y-3 text-sm">
        <% if @magazine.description_en.present? %>
          <div>
            <span class="font-semibold text-gray-700">Description (EN):</span>
            <p class="text-gray-500 mt-0.5"><%= @magazine.description_en %></p>
          </div>
        <% end %>
        <% if @magazine.description_hi.present? %>
          <div>
            <span class="font-semibold text-gray-700">Description (HI):</span>
            <p class="text-gray-500 mt-0.5"><%= @magazine.description_hi %></p>
          </div>
        <% end %>
        <div class="flex items-center gap-4 pt-2 text-gray-500">
          <span>Created: <%= @magazine.created_at.strftime("%d %b %Y") %></span>
          <% if @magazine.published_at %>
            <span>Published: <%= @magazine.published_at.strftime("%d %b %Y") %></span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Articles section %>
<div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
  <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
    <h3 class="text-sm font-bold text-gray-900">Articles (<%= @articles.count %>)</h3>
    <%= link_to new_admin_magazine_magazine_article_path(@magazine), class: "inline-flex items-center gap-1.5 rounded-xl gradient-brand px-4 py-2 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md transition-all" do %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4v16m8-8H4"/></svg>
      Add Article
    <% end %>
  </div>

  <% if @articles.any? %>
    <div class="divide-y divide-gray-50">
      <% @articles.each do |article| %>
        <div class="flex items-center gap-4 px-6 py-4 hover:bg-orange-50/30 transition-colors">
          <span class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-500"><%= article.position + 1 %></span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-gray-900 text-sm line-clamp-1"><%= article.title_en %></p>
            <p class="text-xs text-gray-400 line-clamp-1"><%= article.title_hi %></p>
          </div>
          <span class="text-xs text-gray-400 hidden sm:block"><%= article.author.name %></span>
          <div class="flex items-center gap-2">
            <%= link_to edit_admin_magazine_magazine_article_path(@magazine, article), class: "text-xs text-orange-600 hover:text-orange-700 font-semibold" do %>
              Edit
            <% end %>
            <%= button_to admin_magazine_magazine_article_path(@magazine, article), method: :delete, data: { turbo_confirm: "Remove this article?" }, class: "text-xs text-red-500 hover:text-red-700 font-semibold cursor-pointer" do %>
              Delete
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-gray-400 text-sm mb-2">No articles in this issue yet.</p>
      <%= link_to "Add the first article", new_admin_magazine_magazine_article_path(@magazine), class: "text-sm text-orange-600 hover:text-orange-700 font-semibold" %>
    </div>
  <% end %>
</div>
