<% content_for(:page_title, "Push Notifications") %>

<%# ── Subscriber stats ──────────────────────────────────────────────────────── %>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
  <div class="bg-white rounded-2xl border border-gray-200/60 p-5 shadow-sm col-span-2 sm:col-span-1">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Total</p>
    <p class="text-3xl font-black text-gray-900"><%= number_with_delimiter(@total_subscriptions) %></p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-5 shadow-sm">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Browser</p>
    <p class="text-3xl font-black text-blue-600"><%= number_with_delimiter(@web_count) %></p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-5 shadow-sm">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">PWA (App)</p>
    <p class="text-3xl font-black text-purple-600"><%= number_with_delimiter(@pwa_count) %></p>
  </div>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-5 shadow-sm">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Status</p>
    <% if @total_subscriptions > 0 %>
      <p class="text-sm font-black text-emerald-600 flex items-center gap-1.5 mt-1">
        <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span> Active
      </p>
    <% else %>
      <p class="text-sm font-semibold text-gray-400 mt-1">No subscribers yet</p>
    <% end %>
  </div>
</div>

<%# ── OS / auth breakdown ───────────────────────────────────────────────────── %>
<div class="grid grid-cols-3 sm:grid-cols-5 gap-3 mb-6">
  <% {
    "Android"   => [@android_count,    "🤖", "text-green-700",  "bg-green-50"],
    "iOS"       => [@ios_count,        "🍎", "text-gray-700",   "bg-gray-50"],
    "Desktop"   => [@desktop_count,    "💻", "text-indigo-700", "bg-indigo-50"],
    "Logged in" => [@logged_in_count,  "👤", "text-orange-700", "bg-orange-50"],
    "Anonymous" => [@anonymous_count,  "👻", "text-gray-500",   "bg-gray-50"],
  }.each do |label, (count, icon, text, bg)| %>
    <div class="<%= bg %> rounded-xl border border-gray-100 px-4 py-3 text-center">
      <p class="text-lg mb-0.5"><%= icon %></p>
      <p class="text-xl font-black <%= text %>"><%= count %></p>
      <p class="text-[10px] font-semibold text-gray-500 uppercase tracking-wide"><%= label %></p>
    </div>
  <% end %>
</div>

<%# ── Send custom notification ─────────────────────────────────────────────── %>
<div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm mb-6">
  <h2 class="text-base font-black text-gray-900 mb-4">Send Custom Notification</h2>

  <%= form_with url: send_notification_admin_push_notifications_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :title, "Title", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.text_field :title, placeholder: "समाज दर्शन",
            class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none" %>
    </div>
    <div>
      <%= f.label :url, "Link URL (optional)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.url_field :url, placeholder: "https://...",
            class: "w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none" %>
    </div>
    <div class="flex items-center justify-between pt-2">
      <p class="text-xs text-gray-500">Will send to <strong><%= @total_subscriptions %></strong> subscribers</p>
      <%= f.submit "Send Notification →",
            class: "inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-black text-white cursor-pointer transition-all hover:opacity-90 active:scale-95",
            style: "background:linear-gradient(135deg,#f97316,#dc2626)" %>
    </div>
  <% end %>
</div>

<%# ── Recent subscriptions ─────────────────────────────────────────────────── %>
<% if @recent.any? %>
  <div class="bg-white rounded-2xl border border-gray-200/60 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="text-base font-black text-gray-900">Recent Subscriptions</h2>
    </div>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-100 bg-gray-50/50">
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500">Identity</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500">User</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500">Token</th>
          <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500">Subscribed</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100/80">
        <% @recent.each do |sub| %>
          <tr class="hover:bg-gray-50/50 transition-colors">
            <td class="px-5 py-3">
              <div class="flex flex-wrap gap-1">
                <span class="inline-flex items-center text-xs font-semibold px-2 py-0.5 rounded-full
                             <%= sub.platform == 'pwa' ? 'bg-purple-50 text-purple-700' : 'bg-blue-50 text-blue-700' %>">
                  <%= sub.platform %>
                </span>
                <% if sub.os.present? && sub.os != "unknown" %>
                  <span class="inline-flex items-center text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">
                    <%= sub.os %>
                  </span>
                <% end %>
                <% if sub.display_mode == "standalone" %>
                  <span class="inline-flex items-center text-xs font-medium px-2 py-0.5 rounded-full bg-green-50 text-green-700">
                    installed
                  </span>
                <% end %>
              </div>
            </td>
            <td class="px-5 py-3 text-gray-600"><%= sub.user&.name || "Anonymous" %></td>
            <td class="px-5 py-3 font-mono text-[11px] text-gray-400 max-w-[180px] truncate"><%= sub.token %></td>
            <td class="px-5 py-3 text-gray-500 text-xs"><%= time_ago_in_words(sub.created_at) %> ago</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
