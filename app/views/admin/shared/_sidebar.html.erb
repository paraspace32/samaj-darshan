<aside class="w-64 bg-gray-900 text-gray-300 flex flex-col min-h-screen shrink-0">
  <%# Brand %>
  <div class="px-5 h-16 flex items-center border-b border-gray-800/50">
    <%= link_to admin_root_path, class: "flex items-center gap-2.5 group" do %>
      <div class="w-8 h-8 gradient-brand rounded-xl flex items-center justify-center shadow-sm shadow-orange-600/30 group-hover:shadow-md group-hover:shadow-orange-600/40 transition-shadow">
        <span class="text-white font-extrabold text-sm">स</span>
      </div>
      <div>
        <span class="font-bold text-white text-sm">Samaj Darshan</span>
      </div>
    <% end %>
    <span class="ml-auto text-[10px] bg-orange-600/20 text-orange-400 px-2 py-0.5 rounded-full font-semibold">Admin</span>
  </div>

  <%# Nav links %>
  <nav class="flex-1 px-3 py-5 space-y-1">
    <p class="px-3 text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-3">Main</p>
    <%= admin_nav_link "Dashboard", admin_root_path, "home" %>
    <% if current_user.has_section_access?("news") %>
      <%= admin_nav_link "News", admin_news_index_path, "newspaper" %>
    <% end %>
    <% if current_user.can_manage_magazines? %>
      <%= admin_nav_link "Magazine", admin_magazines_path, "book-open" %>
    <% end %>
    <% if current_user.can_manage_webinars? %>
      <%= admin_nav_link "Webinars", admin_webinars_path, "video" %>
    <% end %>
    <% if current_user.can_manage_education? %>
      <%= admin_nav_link "Education", admin_education_posts_path, "academic-cap" %>
    <% end %>
    <% if current_user.can_manage_jobs? %>
      <%= admin_nav_link "Jobs", admin_job_posts_path, "briefcase" %>
    <% end %>
    <% if current_user.can_review_biodatas? %>
      <% active = current_page?(admin_biodatas_path) || request.path.start_with?("/admin/biodatas") %>
      <% base = "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all" %>
      <%= link_to admin_biodatas_path, class: "#{base} #{active ? 'bg-white/10 text-white shadow-sm' : 'text-gray-400 hover:bg-white/5 hover:text-gray-200'}" do %>
        <%= admin_icon("heart") %>
        <span>Marriage</span>
        <% if @marriage_consent_count.to_i > 0 %>
          <span class="ml-auto inline-flex items-center justify-center min-w-[20px] h-5 px-1 rounded-full bg-orange-500 text-white text-[10px] font-black"><%= @marriage_consent_count %></span>
        <% end %>
      <% end %>
    <% end %>

    <% if current_user.can_manage_regions? || current_user.can_manage_categories? || current_user.can_manage_users? || current_user.can_manage_billboards? %>
      <p class="px-3 text-[10px] font-bold text-gray-600 uppercase tracking-widest mb-3 mt-6">Manage</p>
      <% if current_user.can_manage_regions? %>
        <%= admin_nav_link "Regions", admin_regions_path, "map-pin" %>
      <% end %>
      <% if current_user.can_manage_categories? %>
        <%= admin_nav_link "Categories", admin_categories_path, "tag" %>
      <% end %>
      <% if current_user.can_manage_users? %>
        <%= admin_nav_link "Users", admin_users_path, "users" %>
      <% end %>
      <% if current_user.can_manage_billboards? %>
        <%= admin_nav_link "Billboards", admin_billboards_path, "billboard" %>
      <% end %>
      <% if current_user.super_admin? %>
        <%= admin_nav_link "Push Notifications", admin_push_notifications_path, "bell" %>
      <% end %>
    <% end %>
  </nav>

  <%# User info %>
  <div class="px-4 py-4 border-t border-gray-800/50">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full gradient-brand flex items-center justify-center">
        <span class="text-white font-bold text-xs"><%= current_user.name[0] %></span>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-white truncate"><%= current_user.name %></p>
        <p class="text-xs text-gray-500"><%= current_user.role.humanize %></p>
      </div>
    </div>
  </div>
</aside>
