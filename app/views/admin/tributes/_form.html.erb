<%= form_with model: [:admin, tribute], class: "max-w-2xl space-y-6" do |f| %>
  <% if tribute.errors.any? %>
    <div class="rounded-2xl bg-red-50 border border-red-200/60 p-5">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <h3 class="text-sm font-bold text-red-800"><%= pluralize(tribute.errors.count, "error") %> found:</h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1 ml-7">
        <% tribute.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm space-y-5">
    <h2 class="text-sm font-bold text-gray-900">Tribute Details</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Name (English) <span class="text-red-500">*</span></label>
        <%= f.text_field :name_en, class: "w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none", placeholder: "Person's name" %>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Name (Hindi)</label>
        <%= f.text_field :name_hi, class: "w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none", placeholder: "व्यक्ति का नाम" %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Description (English) <span class="text-red-500">*</span></label>
      <%= f.text_area :description_en, rows: 3, class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none resize-none", placeholder: "A short tribute description..." %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Description (Hindi)</label>
      <%= f.text_area :description_hi, rows: 3, class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-400 outline-none resize-none", placeholder: "श्रद्धांजलि विवरण..." %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Photo <span class="text-red-500">*</span></label>
      <% if tribute.image.attached? %>
        <div class="mb-3">
          <%= image_tag tribute.image.variant(:thumb), class: "w-24 h-24 rounded-xl object-cover border border-gray-200" %>
        </div>
      <% end %>
      <%= f.file_field :image, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100 cursor-pointer" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit tribute.persisted? ? "Update Tribute" : "Create Tribute",
          class: "inline-flex items-center gap-2 rounded-xl px-6 py-2.5 text-sm font-bold text-white cursor-pointer transition-all hover:opacity-90 active:scale-95",
          style: "background: linear-gradient(135deg, #f97316, #dc2626)" %>
    <%= link_to "Cancel", admin_tributes_path, class: "text-sm font-semibold text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
