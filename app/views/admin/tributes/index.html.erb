<% content_for(:page_title, "Tributes") %>

<%# Header %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <p class="text-sm text-gray-500"><%= @tributes.count %> tribute<%= @tributes.count == 1 ? "" : "s" %></p>
  <%= link_to new_admin_tribute_path, class: "inline-flex items-center gap-2 rounded-xl gradient-brand px-5 py-2.5 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all self-start" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4v16m8-8H4"/></svg>
    New Tribute
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
  <% if @tributes.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs text-gray-500 uppercase tracking-wider border-b border-gray-100 bg-gray-50/50">
            <th class="px-6 py-3.5 font-semibold">Image</th>
            <th class="px-6 py-3.5 font-semibold">Name</th>
            <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Description</th>
            <th class="px-6 py-3.5 font-semibold">Flowers</th>
            <th class="px-6 py-3.5 font-semibold">Created</th>
            <th class="px-6 py-3.5 font-semibold w-28"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @tributes.each do |tribute| %>
            <tr class="hover:bg-orange-50/30 transition-colors">
              <td class="px-6 py-3">
                <% if tribute.image.attached? %>
                  <%= image_tag tribute.image.variant(:thumb), class: "w-12 h-12 rounded-xl object-cover" %>
                <% else %>
                  <div class="w-12 h-12 rounded-xl bg-gray-100 flex items-center justify-center">
                    <span class="text-gray-400 text-lg">🕊</span>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-3 font-semibold text-gray-900"><%= tribute.display_name %></td>
              <td class="px-6 py-3 text-gray-500 text-xs hidden md:table-cell max-w-[200px] truncate"><%= tribute.display_description.truncate(60) %></td>
              <td class="px-6 py-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-bold bg-pink-50 text-pink-700">
                  🌸 <%= tribute.flowers_count %>
                </span>
              </td>
              <td class="px-6 py-3 text-gray-500 text-xs"><%= tribute.created_at.strftime("%d %b %Y") %></td>
              <td class="px-6 py-3 text-right">
                <div class="flex items-center gap-3 justify-end">
                  <%= link_to "Edit", edit_admin_tribute_path(tribute), class: "text-xs font-bold text-orange-600 hover:text-orange-700" %>
                  <%= button_to "Delete", admin_tribute_path(tribute), method: :delete, class: "text-xs font-bold text-red-500 hover:text-red-700", data: { turbo_confirm: "Delete this tribute?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-gray-400 text-sm">No tributes yet. Create one to get started.</p>
    </div>
  <% end %>
</div>
