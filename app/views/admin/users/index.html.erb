<% content_for(:page_title, "Users") %>

<%# Header %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <p class="text-sm text-gray-500"><%= @users.count %> user<%= @users.count == 1 ? "" : "s" %></p>
  <%= link_to new_admin_user_path, class: "inline-flex items-center gap-2 rounded-xl gradient-brand px-5 py-2.5 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all self-start" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4v16m8-8H4"/></svg>
    New User
  <% end %>
</div>

<%# Filters %>
<%= form_with url: admin_users_path, method: :get, class: "bg-white rounded-2xl border border-gray-200/60 p-5 mb-6 shadow-sm", data: { turbo_frame: "_top" } do %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
    <div>
      <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search name, phone, email..."
             class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
    </div>
    <div>
      <select name="role" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Roles</option>
        <% User.roles.each_key do |r| %>
          <option value="<%= r %>" <%= "selected" if params[:role] == r %>><%= r.humanize %></option>
        <% end %>
      </select>
    </div>
    <div>
      <select name="status" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Statuses</option>
        <% User.statuses.each_key do |s| %>
          <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.humanize %></option>
        <% end %>
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="flex-1 rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors cursor-pointer">Filter</button>
      <%= link_to "Clear", admin_users_path, class: "flex-1 rounded-xl bg-gray-100 px-4 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors text-center" %>
    </div>
  </div>
<% end %>

<%# Table %>
<div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
  <% if @users.any? %>
    <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[700px]">
      <thead>
        <tr class="text-left text-xs text-gray-500 uppercase tracking-wider border-b border-gray-100 bg-gray-50/50">
          <th class="px-6 py-3.5 font-semibold">Name</th>
          <th class="px-6 py-3.5 font-semibold">Phone</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Email</th>
          <th class="px-6 py-3.5 font-semibold">Role</th>
          <th class="px-6 py-3.5 font-semibold hidden sm:table-cell">News</th>
          <th class="px-6 py-3.5 font-semibold">Status</th>
          <th class="px-6 py-3.5 font-semibold w-36"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @users.each do |user| %>
          <tr class="hover:bg-orange-50/30 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full gradient-brand flex items-center justify-center shrink-0">
                  <span class="text-white font-bold text-xs"><%= user.name[0] %></span>
                </div>
                <span class="font-semibold text-gray-900"><%= user.name %></span>
              </div>
            </td>
            <td class="px-6 py-4 text-gray-600 font-mono text-xs"><%= user.phone %></td>
            <td class="px-6 py-4 text-gray-500 text-xs hidden md:table-cell"><%= user.email.presence || "—" %></td>
            <td class="px-6 py-4"><%= user_role_badge(user.role) %></td>
            <td class="px-6 py-4 text-gray-500 hidden sm:table-cell"><%= user.news.count %></td>
            <td class="px-6 py-4">
              <% if user.account_active? %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>Active
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-700 border border-red-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>Blocked
                </span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right space-x-3">
              <%= link_to "Edit", edit_admin_user_path(user), class: "text-xs text-orange-600 hover:text-orange-700 font-semibold" %>
              <% unless user == current_user %>
                <%= button_to user.account_active? ? "Block" : "Unblock", toggle_status_admin_user_path(user), method: :patch, class: "text-xs #{user.account_active? ? 'text-red-500 hover:text-red-700' : 'text-emerald-600 hover:text-emerald-700'} font-medium cursor-pointer", form: { class: "inline" } %>
                <%= button_to admin_user_path(user), method: :delete, data: { turbo_confirm: "Delete user #{user.name}? This cannot be undone." }, class: "text-xs text-red-500 hover:text-red-700 font-medium cursor-pointer", form: { class: "inline" } do %>
                  Delete
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  <% else %>
    <div class="px-6 py-16 text-center">
      <div class="w-12 h-12 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-3">
        <svg class="w-5 h-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197"/></svg>
      </div>
      <p class="text-gray-400 text-sm">No users found.</p>
    </div>
  <% end %>
</div>
