<%= form_with model: [:admin, webinar], class: "space-y-6" do |f| %>
  <% if webinar.errors.any? %>
    <div class="rounded-2xl bg-red-50 border border-red-200/60 p-5 animate-fade-in">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <h3 class="text-sm font-bold text-red-800"><%= pluralize(webinar.errors.count, "error") %> found:</h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1 ml-7">
        <% webinar.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title (bilingual) %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm">
    <h2 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
      Title
    </h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label for="webinar_title_en" class="block text-sm font-semibold text-gray-600 mb-1.5">English</label>
        <%= f.text_field :title_en, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "Webinar title in English" %>
      </div>
      <div>
        <label for="webinar_title_hi" class="block text-sm font-semibold text-gray-600 mb-1.5">हिंदी</label>
        <%= f.text_field :title_hi, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "वेबिनार शीर्षक हिंदी में", dir: "auto" %>
      </div>
    </div>
  </div>

  <%# Description (bilingual) %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm">
    <h2 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Description
    </h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label for="webinar_description_en" class="block text-sm font-semibold text-gray-600 mb-1.5">English</label>
        <%= f.text_area :description_en, rows: 8, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50 resize-y", placeholder: "Describe the webinar in English..." %>
      </div>
      <div>
        <label for="webinar_description_hi" class="block text-sm font-semibold text-gray-600 mb-1.5">हिंदी</label>
        <%= f.text_area :description_hi, rows: 8, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50 resize-y", placeholder: "वेबिनार का विवरण हिंदी में लिखें...", dir: "auto" %>
      </div>
    </div>
  </div>

  <%# Speaker & Schedule %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 shadow-sm">
    <h2 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Details
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label for="webinar_speaker_name" class="block text-sm font-semibold text-gray-600 mb-1.5">Speaker Name</label>
        <%= f.text_field :speaker_name, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "Speaker's full name" %>
      </div>
      <div>
        <label for="webinar_platform" class="block text-sm font-semibold text-gray-600 mb-1.5">Platform</label>
        <%= f.select :platform, Webinar.platforms.keys.map { |k| [k.humanize, k] }, {}, { class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50" } %>
      </div>
      <div>
        <label for="webinar_meeting_url" class="block text-sm font-semibold text-gray-600 mb-1.5">Meeting URL</label>
        <%= f.url_field :meeting_url, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50", placeholder: "https://..." %>
      </div>
      <div>
        <label for="webinar_starts_at" class="block text-sm font-semibold text-gray-600 mb-1.5">Start Date & Time</label>
        <%= f.datetime_local_field :starts_at, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50" %>
      </div>
      <div>
        <label for="webinar_duration_minutes" class="block text-sm font-semibold text-gray-600 mb-1.5">Duration (minutes)</label>
        <%= f.number_field :duration_minutes, min: 5, max: 480, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50" %>
      </div>
    </div>

    <div class="mt-4">
      <label for="webinar_speaker_bio" class="block text-sm font-semibold text-gray-600 mb-1.5">Speaker Bio (optional)</label>
      <%= f.text_area :speaker_bio, rows: 3, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50 resize-y", placeholder: "Brief bio of the speaker..." %>
    </div>

    <div class="mt-5 pt-5 border-t border-gray-100">
      <label for="webinar_cover_image" class="block text-sm font-semibold text-gray-600 mb-2">Cover Image</label>
      <% if webinar.persisted? && webinar.cover_image.attached? %>
        <div class="mb-3">
          <%= image_tag url_for(webinar.cover_image.variant(:thumb)), class: "h-32 w-auto rounded-xl object-cover border border-gray-200/60 shadow-sm" %>
        </div>
      <% end %>
      <%= f.file_field :cover_image, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-5 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100 file:cursor-pointer file:transition-colors" %>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-3">
    <%= f.submit webinar.persisted? ? "Update Webinar" : "Create Webinar", class: "rounded-xl gradient-brand px-6 py-3 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all cursor-pointer" %>
    <%= link_to "Cancel", webinar.persisted? ? admin_webinar_path(webinar) : admin_webinars_path, class: "rounded-xl bg-gray-100 px-5 py-3 text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors" %>
  </div>
<% end %>
