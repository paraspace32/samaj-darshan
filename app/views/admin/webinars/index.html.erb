<% content_for(:page_title, "Webinars") %>

<%# Header %>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
  <div>
    <p class="text-sm text-gray-500"><%= @total_count %> webinar<%= @total_count == 1 ? "" : "s" %> total</p>
  </div>
  <%= link_to new_admin_webinar_path, class: "inline-flex items-center gap-2 rounded-xl gradient-brand px-5 py-2.5 text-sm font-bold text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-all self-start" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4v16m8-8H4"/></svg>
    New Webinar
  <% end %>
</div>

<%# Filters %>
<%= form_with url: admin_webinars_path, method: :get, class: "bg-white rounded-2xl border border-gray-200/60 p-5 mb-6 shadow-sm", data: { turbo_frame: "_top" } do %>
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    <div>
      <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search title or speaker..."
             class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
    </div>
    <div>
      <select name="status" class="block w-full rounded-xl border border-gray-200 px-4 py-2.5 text-sm focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-gray-50/50">
        <option value="">All Statuses</option>
        <% Webinar.statuses.each_key do |s| %>
          <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.humanize %></option>
        <% end %>
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="flex-1 rounded-xl bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors cursor-pointer">Filter</button>
      <%= link_to "Clear", admin_webinars_path, class: "flex-1 rounded-xl bg-gray-100 px-4 py-2.5 text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors text-center" %>
    </div>
  </div>
<% end %>

<%# Table %>
<div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
  <% if @webinars.any? %>
    <div class="overflow-x-auto">
    <table class="w-full text-sm min-w-[640px]">
      <thead>
        <tr class="text-left text-xs text-gray-500 uppercase tracking-wider border-b border-gray-100 bg-gray-50/50">
          <th class="px-6 py-3.5 font-semibold">Title</th>
          <th class="px-6 py-3.5 font-semibold hidden sm:table-cell">Speaker</th>
          <th class="px-6 py-3.5 font-semibold hidden md:table-cell">Platform</th>
          <th class="px-6 py-3.5 font-semibold">Date & Time</th>
          <th class="px-6 py-3.5 font-semibold">Status</th>
          <th class="px-6 py-3.5 font-semibold w-20"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @webinars.each do |webinar| %>
          <tr class="hover:bg-orange-50/30 transition-colors">
            <td class="px-6 py-4">
              <%= link_to admin_webinar_path(webinar), class: "font-semibold text-gray-900 hover:text-orange-600 transition-colors line-clamp-1" do %>
                <%= webinar.title_en %>
              <% end %>
              <p class="text-xs text-gray-400 mt-0.5 line-clamp-1"><%= webinar.title_hi %></p>
            </td>
            <td class="px-6 py-4 text-gray-500 hidden sm:table-cell"><%= webinar.speaker_name %></td>
            <td class="px-6 py-4 hidden md:table-cell">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-600"><%= webinar.platform_label %></span>
            </td>
            <td class="px-6 py-4 text-gray-500 text-xs">
              <%= webinar.starts_at.strftime("%d %b %Y") %><br>
              <span class="text-gray-400"><%= webinar.starts_at.strftime("%I:%M %p") %></span>
            </td>
            <td class="px-6 py-4">
              <% case webinar.status %>
              <% when "draft" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-600">Draft</span>
              <% when "published" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-100 text-emerald-700">Published</span>
              <% when "cancelled" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-100 text-red-700">Cancelled</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right space-x-3">
              <%= link_to "Edit", edit_admin_webinar_path(webinar), class: "text-xs text-orange-600 hover:text-orange-700 font-semibold" %>
              <%= button_to admin_webinar_path(webinar), method: :delete, data: { turbo_confirm: "Delete this webinar?" }, class: "text-xs text-red-500 hover:text-red-700 font-medium cursor-pointer", form: { class: "inline" } do %>
                Delete
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>

    <%# Pagination %>
    <% total_pages = (@total_count.to_f / @per_page).ceil %>
    <% if total_pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between bg-gray-50/30">
        <p class="text-xs text-gray-500 font-medium">Page <%= @page %> of <%= total_pages %></p>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to "Previous", admin_webinars_path(request.query_parameters.merge(page: @page - 1)), class: "px-3.5 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition-colors" %>
          <% end %>
          <% if @page < total_pages %>
            <%= link_to "Next", admin_webinars_path(request.query_parameters.merge(page: @page + 1)), class: "px-3.5 py-1.5 text-xs font-medium rounded-lg border border-gray-200 bg-white hover:bg-gray-50 transition-colors" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="px-6 py-16 text-center">
      <div class="w-14 h-14 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-gray-400 mb-3">No webinars yet.</p>
      <%= link_to "Create your first webinar", new_admin_webinar_path, class: "text-sm text-orange-600 hover:text-orange-700 font-semibold" %>
    </div>
  <% end %>
</div>
