<% content_for(:page_title, "Webinar ##{@webinar.id}") %>

<%# Back navigation %>
<div class="mb-4">
  <%= link_to admin_webinars_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-orange-600 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
    Back to Webinars
  <% end %>
</div>

<%# Action bar %>
<div class="bg-white rounded-2xl border border-gray-200/60 p-4 sm:p-5 mb-6 shadow-sm">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      <% case @webinar.status %>
      <% when "draft" %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-gray-100 text-gray-600">Draft</span>
      <% when "published" %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700">Published</span>
      <% when "cancelled" %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-700">Cancelled</span>
      <% end %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-700"><%= @webinar.platform_label %></span>
    </div>
    <div class="flex items-center gap-2">
      <% if @webinar.published? %>
        <%= link_to webinar_path(@webinar), target: "_blank", class: "inline-flex items-center gap-1.5 rounded-xl bg-emerald-50 border border-emerald-200 px-3 py-2 text-sm font-medium text-emerald-700 hover:bg-emerald-100 transition-colors" do %>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          View Live
        <% end %>
      <% end %>
      <%= link_to edit_admin_webinar_path(@webinar), class: "inline-flex items-center gap-2 rounded-xl bg-gray-900 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      <% end %>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <% if @webinar.draft? %>
      <%= button_to publish_admin_webinar_path(@webinar), method: :patch, class: "inline-flex items-center gap-1.5 rounded-xl bg-emerald-600 px-3 py-2 text-xs sm:text-sm font-semibold text-white hover:bg-emerald-700 transition-colors shadow-sm cursor-pointer" do %>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M5 13l4 4L19 7"/></svg>
        Publish
      <% end %>
    <% end %>

    <% unless @webinar.cancelled? %>
      <%= button_to cancel_admin_webinar_path(@webinar), method: :patch, data: { turbo_confirm: "Cancel this webinar?" }, class: "inline-flex items-center gap-1.5 rounded-xl bg-red-50 border border-red-200 px-3 py-2 text-xs sm:text-sm font-semibold text-red-700 hover:bg-red-100 transition-colors cursor-pointer" do %>
        Cancel Webinar
      <% end %>
    <% end %>
  </div>

  <div class="flex items-center gap-3 mt-3 pt-3 border-t border-gray-100">
    <%= button_to admin_webinar_path(@webinar), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this webinar?" }, class: "inline-flex items-center gap-1.5 text-xs text-red-500 hover:text-red-700 font-medium transition-colors cursor-pointer" do %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      Delete Webinar
    <% end %>
  </div>
</div>

<%# Meta info %>
<div class="bg-white rounded-2xl border border-gray-200/60 p-6 mb-6 shadow-sm">
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-5 text-sm">
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Speaker</p>
      <p class="font-semibold text-gray-900"><%= @webinar.speaker_name %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Platform</p>
      <p class="font-semibold text-gray-900"><%= @webinar.platform_label %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Duration</p>
      <p class="font-semibold text-gray-900"><%= @webinar.duration_minutes %> minutes</p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Date & Time</p>
      <p class="font-semibold text-gray-900"><%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></p>
    </div>
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Host</p>
      <p class="font-semibold text-gray-900"><%= @webinar.host.name %></p>
    </div>
    <% if @webinar.meeting_url.present? %>
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Meeting URL</p>
        <%= link_to truncate(@webinar.meeting_url, length: 40), sanitize_url(@webinar.meeting_url), target: "_blank", rel: "noopener noreferrer", class: "text-sm text-orange-600 hover:text-orange-700 font-medium break-all" %>
      </div>
    <% end %>
  </div>
  <% if @webinar.speaker_bio.present? %>
    <div class="mt-4 pt-4 border-t border-gray-100">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Speaker Bio</p>
      <p class="text-sm text-gray-700"><%= @webinar.speaker_bio %></p>
    </div>
  <% end %>
</div>

<%# Cover image %>
<% if @webinar.cover_image.attached? %>
  <div class="mb-6">
    <%= image_tag url_for(@webinar.cover_image.variant(:card)), class: "max-h-72 rounded-2xl object-cover border border-gray-200/60 shadow-sm" %>
  </div>
<% end %>

<%# Content (bilingual side by side) %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm">
    <div class="px-6 py-3 bg-gray-50/50 border-b border-gray-100">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">English</span>
    </div>
    <div class="p-6">
      <h2 class="text-xl font-extrabold text-gray-900 mb-4"><%= @webinar.title_en %></h2>
      <div class="prose prose-sm text-gray-600 max-w-none"><%= simple_format(@webinar.description_en) %></div>
    </div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm" dir="auto">
    <div class="px-6 py-3 bg-orange-50/50 border-b border-orange-100/50">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-orange-100 text-orange-700">हिंदी</span>
    </div>
    <div class="p-6">
      <h2 class="text-xl font-extrabold text-gray-900 mb-4"><%= @webinar.title_hi %></h2>
      <div class="prose prose-sm text-gray-600 max-w-none"><%= simple_format(@webinar.description_hi) %></div>
    </div>
  </div>
</div>
