<%# Category pills — horizontal scroll on mobile %>
<div class="mb-8">
  <div class="flex items-center gap-2 overflow-x-auto pb-2 -mx-1 px-1 scrollbar-hide">
    <%= link_to root_path, class: "shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium transition-all #{ @region.nil? && @category.nil? ? 'gradient-brand text-white shadow-sm shadow-orange-200' : 'bg-white text-gray-600 border border-gray-200 hover:border-orange-200 hover:text-orange-600' }" do %>
      <%= t("feed.all_regions") %>
    <% end %>
    <% @categories.each do |c| %>
      <%= link_to category_feed_path(slug: c.slug), class: "shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium transition-all #{ @category&.id == c.id ? 'gradient-brand text-white shadow-sm shadow-orange-200' : 'bg-white text-gray-600 border border-gray-200 hover:border-orange-200 hover:text-orange-600' }" do %>
        <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= c.color %>"></span>
        <%= c.display_name %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Page header for filtered views %>
<% if @region || @category %>
  <div class="mb-8">
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-2">
      <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-600"><%= (@region || @category).display_name %></span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900"><%= (@region || @category).display_name %></h1>
    <p class="text-gray-500 mt-1">
      <% if @region %>
        <%= t("feed.news_from", name: @region.display_name) %>
      <% else %>
        <%= t("feed.articles_in", name: @category.display_name) %>
      <% end %>
    </p>
  </div>
<% end %>

<div class="flex flex-col lg:flex-row gap-8">
  <%# Main content %>
  <div class="flex-1 min-w-0">
    <% if @featured.present? && @region.nil? && @category.nil? %>
      <%# Hero featured article %>
      <div class="mb-8 animate-fade-in">
        <%= link_to article_path(@featured), class: "group block relative rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow" do %>
          <div class="aspect-[16/8] sm:aspect-[16/7]">
            <% if @featured.cover_image.attached? %>
              <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover", loading: "eager" %>
            <% else %>
              <div class="w-full h-full gradient-hero flex items-center justify-center">
                <span class="text-5xl text-white/20 font-extrabold"><%= t("brand.logo_letter") %></span>
              </div>
            <% end %>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-white/20 text-white backdrop-blur-sm">
                <span class="w-1.5 h-1.5 rounded-full" style="background-color: <%= @featured.category.color %>"></span>
                <%= @featured.category.display_name %>
              </span>
              <span class="text-xs text-white/70"><%= @featured.region.display_name %></span>
            </div>
            <h2 class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-white leading-tight group-hover:text-orange-200 transition-colors line-clamp-2">
              <%= @featured.display_title %>
            </h2>
            <p class="text-sm text-white/70 mt-2 line-clamp-2 hidden sm:block"><%= truncate(strip_tags(@featured.display_content), length: 160) %></p>
            <div class="flex items-center gap-3 mt-4">
              <div class="w-7 h-7 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                <span class="text-white font-semibold text-xs"><%= @featured.author.name[0] %></span>
              </div>
              <span class="text-sm text-white/80"><%= @featured.author.name %></span>
              <span class="text-white/40">&middot;</span>
              <span class="text-sm text-white/60"><%= t("feed.ago", time: time_ago_in_words(@featured.published_at)) %></span>
            </div>
          </div>
        <% end %>
      </div>

      <% unless @region || @category %>
        <h2 class="text-lg font-bold text-gray-900 mb-5"><%= t("feed.title") %></h2>
      <% end %>
    <% elsif @articles.empty? && @featured.blank? %>
      <div class="bg-white rounded-2xl border border-gray-200/60 px-6 py-20 text-center">
        <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        </div>
        <p class="text-gray-400"><%= t("feed.no_articles") %></p>
      </div>
    <% end %>

    <% if @articles.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <% @articles.each_with_index do |article, idx| %>
          <% if idx == 4 %>
            <%= render "shared/billboard_feed" %>
          <% end %>
          <div class="animate-fade-in" style="animation-delay: <%= idx * 50 %>ms">
            <%= link_to article_path(article), class: "group block bg-white rounded-2xl border border-gray-200/60 overflow-hidden card-hover" do %>
              <div class="relative">
                <% if article.cover_image.attached? %>
                  <%= optimized_image_tag article.cover_image, variant: :card, class: "w-full h-48 object-cover", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-48 bg-gradient-to-br from-orange-50 via-orange-100 to-amber-50 flex items-center justify-center">
                    <span class="text-3xl text-orange-200 font-extrabold"><%= t("brand.logo_letter") %></span>
                  </div>
                <% end %>
                <div class="absolute top-3 left-3">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-white/90 backdrop-blur-sm text-gray-700 shadow-sm">
                    <span class="w-2 h-2 rounded-full" style="background-color: <%= article.category.color %>"></span>
                    <%= article.category.display_name %>
                  </span>
                </div>
              </div>

              <div class="p-5">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs font-medium text-orange-600"><%= article.region.display_name %></span>
                  <span class="text-xs text-gray-300">&middot;</span>
                  <span class="text-xs text-gray-400"><%= t("feed.ago", time: time_ago_in_words(article.published_at)) %></span>
                </div>

                <h2 class="font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 mb-2 text-[15px] leading-snug">
                  <%= article.display_title %>
                </h2>

                <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed"><%= truncate(strip_tags(article.display_content), length: 120) %></p>

                <div class="flex items-center gap-2 mt-4 pt-3 border-t border-gray-100">
                  <div class="w-6 h-6 rounded-full bg-orange-100 flex items-center justify-center">
                    <span class="text-orange-700 font-semibold text-[10px]"><%= article.author.name[0] %></span>
                  </div>
                  <span class="text-xs text-gray-500"><%= article.author.name %></span>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Pagination %>
      <% total_pages = (@total_count.to_f / @per_page).ceil %>
      <% if total_pages > 1 %>
        <div class="flex items-center justify-center gap-3 mt-10">
          <% if @page > 1 %>
            <%= link_to url_for(request.query_parameters.merge(page: @page - 1)), class: "inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium rounded-xl border border-gray-200 bg-white text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
              <%= t("feed.previous") %>
            <% end %>
          <% end %>
          <span class="px-4 py-2.5 text-sm text-gray-400 font-medium"><%= t("feed.page_info", current: @page, total: total_pages) %></span>
          <% if @page < total_pages %>
            <%= link_to url_for(request.query_parameters.merge(page: @page + 1)), class: "inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium rounded-xl gradient-brand text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-shadow" do %>
              <%= t("feed.next") %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Sidebar %>
  <aside class="lg:w-72 shrink-0 space-y-6">
    <%# Regions %>
    <div class="bg-white rounded-2xl border border-gray-200/60 p-5 shadow-sm">
      <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <%= t("feed.regions") %>
      </h3>
      <ul class="space-y-0.5">
        <li>
          <%= link_to root_path, class: "flex items-center gap-2 px-3 py-2 text-sm rounded-xl transition-all #{@region.nil? && @category.nil? ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
            <%= t("feed.all_regions") %>
          <% end %>
        </li>
        <% @regions.each do |r| %>
          <li>
            <%= link_to r.display_name, region_feed_path(slug: r.slug), class: "block px-3 py-2 text-sm rounded-xl transition-all #{@region&.id == r.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" %>
          </li>
        <% end %>
      </ul>
    </div>

    <%# Categories — visible on desktop only (pills are mobile-friendly) %>
    <div class="hidden lg:block bg-white rounded-2xl border border-gray-200/60 p-5 shadow-sm">
      <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
        <%= t("feed.categories") %>
      </h3>
      <ul class="space-y-0.5">
        <% @categories.each do |c| %>
          <li>
            <%= link_to category_feed_path(slug: c.slug), class: "flex items-center gap-2.5 px-3 py-2 text-sm rounded-xl transition-all #{@category&.id == c.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
              <span class="w-2.5 h-2.5 rounded-full shrink-0 ring-2 ring-white shadow-sm" style="background-color: <%= c.color %>"></span>
              <%= c.display_name %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </aside>
</div>
