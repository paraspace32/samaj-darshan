<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
  <div style="height:2px;width:24px;background:linear-gradient(90deg,#d97706,#f59e0b);border-radius:2px;flex-shrink:0;"></div>
  <h3 style="font-size:12px;font-weight:900;color:#92400e;text-transform:uppercase;letter-spacing:0.12em;white-space:nowrap;"><%= title %></h3>
  <div style="height:2px;flex:1;background:linear-gradient(90deg,#f59e0b,transparent);border-radius:2px;"></div>
</div>
