<% content_for(:title, t("biodata.title")) %>
<% content_for :head do %>
<script>
function stepAge(id, delta) {
  var el = document.getElementById(id);
  var val = parseInt(el.value) || (id === 'age_min' ? 18 : 45);
  val = Math.min(60, Math.max(18, val + delta));
  el.value = val;
}
</script>
<% end %>

<%# Header %>
<div class="mb-3 animate-fade-in text-center">
  <h1 class="text-xl font-black tracking-tight">
    <span class="text-gradient"><%= t("biodata.title") %></span>
  </h1>
  <p class="text-xs text-gray-400 hidden sm:block"><%= t("biodata.subtitle") %></p>
</div>

<%# Filters %>
<%= form_with url: biodatas_path, method: :get, class: "card-premium rounded-2xl p-2.5 sm:p-4 mb-3 shadow-sm", data: { turbo_frame: "biodata_grid", controller: "filter", filter_target: "form" } do |f| %>
  <%# 2×2 grid on mobile, 5-col on desktop %>
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 sm:gap-3">
    <%# Gender %>
    <div>
      <label class="hidden sm:block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5"><%= t("biodata.filter_gender") %></label>
      <select name="gender" aria-label="<%= t('biodata.filter_gender') %>" class="input-premium block w-full !py-1.5 !text-xs sm:!py-2 sm:!text-sm">
        <option value=""><%= t("biodata.all_genders") %></option>
        <option value="male"   <%= "selected" if params[:gender] == "male"   %>><%= t("biodata.gender_male") %></option>
        <option value="female" <%= "selected" if params[:gender] == "female" %>><%= t("biodata.gender_female") %></option>
      </select>
    </div>

    <%# Age Range %>
    <div>
      <label class="hidden sm:block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5"><%= t("biodata.filter_age") %></label>
      <div class="flex items-center gap-1">
        <div class="flex items-center input-premium !p-0 !gap-0 overflow-hidden w-full">
          <button type="button" onclick="stepAge('age_min',-1)" class="px-1.5 py-1.5 sm:py-2 text-gray-400 hover:text-orange-500 text-sm font-bold cursor-pointer select-none">−</button>
          <input type="number" name="age_min" id="age_min" value="<%= params[:age_min] %>" placeholder="18"
                 min="18" max="60" class="w-full !text-xs sm:!text-sm text-center bg-transparent border-0 outline-none !py-1.5 sm:!py-2 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
          <button type="button" onclick="stepAge('age_min',1)" class="px-1.5 py-1.5 sm:py-2 text-gray-400 hover:text-orange-500 text-sm font-bold cursor-pointer select-none">+</button>
        </div>
        <span class="text-gray-300 text-xs shrink-0 mx-0.5">–</span>
        <div class="flex items-center input-premium !p-0 !gap-0 overflow-hidden w-full">
          <button type="button" onclick="stepAge('age_max',-1)" class="px-1.5 py-1.5 sm:py-2 text-gray-400 hover:text-orange-500 text-sm font-bold cursor-pointer select-none">−</button>
          <input type="number" name="age_max" id="age_max" value="<%= params[:age_max] %>" placeholder="45"
                 min="18" max="60" class="w-full !text-xs sm:!text-sm text-center bg-transparent border-0 outline-none !py-1.5 sm:!py-2 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
          <button type="button" onclick="stepAge('age_max',1)" class="px-1.5 py-1.5 sm:py-2 text-gray-400 hover:text-orange-500 text-sm font-bold cursor-pointer select-none">+</button>
        </div>
      </div>
    </div>

    <%# City %>
    <div>
      <label class="hidden sm:block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5"><%= t("biodata.filter_city") %></label>
      <input type="text" name="city" value="<%= params[:city] %>" placeholder="<%= t('biodata.city_placeholder') %>"
             aria-label="<%= t('biodata.filter_city') %>" list="city_list"
             class="input-premium block w-full !py-1.5 !text-xs sm:!py-2 sm:!text-sm"
             data-filter-target="city" data-action="input->filter#cityInput">
      <datalist id="city_list">
        <% @cities.each do |c| %><option value="<%= c %>"><% end %>
      </datalist>
    </div>

    <%# Occupation %>
    <div>
      <label class="hidden sm:block text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5"><%= t("biodata.filter_occupation") %></label>
      <input type="text" name="occupation" value="<%= params[:occupation] %>" placeholder="<%= t('biodata.occupation_placeholder') %>"
             aria-label="<%= t('biodata.filter_occupation') %>" list="occupation_list"
             class="input-premium block w-full !py-1.5 !text-xs sm:!py-2 sm:!text-sm">
      <datalist id="occupation_list">
        <% @occupations.each do |o| %><option value="<%= o %>"><% end %>
      </datalist>
    </div>

    <%# Actions %>
    <div class="col-span-2 sm:col-span-1 flex gap-2 items-end">
      <button type="submit" class="flex-1 rounded-xl gradient-brand px-2 py-1.5 sm:py-2 text-xs sm:text-sm font-bold text-white shadow-sm hover:shadow-md transition-all cursor-pointer"><%= t("biodata.filter_apply") %></button>
      <%= link_to t("biodata.filter_clear"), biodatas_path, class: "flex-1 rounded-xl bg-gray-100 px-2 py-1.5 sm:py-2 text-xs sm:text-sm font-medium text-gray-600 hover:bg-gray-200 transition-colors text-center" %>
    </div>
  </div>
<% end %>

<%# Biodata Grid %>
<%= turbo_frame_tag "biodata_grid" do %>
  <% if @total_count > 0 %>
    <p class="text-xs text-gray-400 font-medium mb-3">
      <%= t("biodata.results_count", count: @total_count) %>
    </p>
  <% end %>

  <% if @biodatas.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-5 animate-fade-up">
      <% @biodatas.each do |biodata| %>
        <%= link_to biodata_path(biodata), class: "group card-premium rounded-2xl border border-gray-200/40 block overflow-hidden", data: { turbo_frame: "_top" } do %>
          <%# Photo — square on mobile %>
          <div class="aspect-square sm:aspect-[4/5] bg-gradient-to-br from-orange-100/90 via-amber-50 to-rose-100/80 relative overflow-hidden">
            <% if biodata.photo.attached? %>
              <%= optimized_image_tag biodata.photo, variant: :card, class: "img-zoom w-full h-full object-cover", loading: "lazy",
                  onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
            <% end %>
            <div class="w-full h-full flex items-center justify-center" style="<%= biodata.photo.attached? ? 'display:none' : '' %>">
              <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-full gradient-brand flex items-center justify-center shadow-lg">
                <span class="text-white font-black text-xl sm:text-2xl"><%= biodata.avatar_initial %></span>
              </div>
            </div>
            <%# Gender badge %>
            <span class="absolute top-2 left-2 text-[10px] font-bold px-2 py-0.5 rounded-full <%= biodata.female? ? 'bg-pink-100 text-pink-700' : 'bg-blue-100 text-blue-700' %>">
              <%= t("biodata.gender_#{biodata.gender}") %>
            </span>
          </div>

          <div class="p-2.5 sm:p-3">
            <h3 class="font-bold tracking-tight text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-1 text-sm leading-snug">
              <%= biodata.display_name %>
            </h3>
            <div class="flex items-center justify-between text-[11px] text-gray-400 mt-1">
              <span class="font-semibold text-gray-500"><%= biodata.age %> yrs</span>
              <span class="truncate ml-1.5 text-right"><%= biodata.city.presence || biodata.state %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Pagination %>
    <% total_pages = (@total_count.to_f / @per_page).ceil %>
    <% if total_pages > 1 %>
      <div class="mt-10 flex items-center justify-between">
        <p class="text-sm text-gray-500"><%= t("feed.page_info", current: @page, total: total_pages) %></p>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to t("feed.previous"), biodatas_path(request.query_parameters.merge(page: @page - 1)), class: "btn-ghost !py-2 !px-4 !text-sm" %>
          <% end %>
          <% if @page < total_pages %>
            <%= link_to t("feed.next"), biodatas_path(request.query_parameters.merge(page: @page + 1)), class: "btn-primary !py-2 !px-4 !text-sm" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="surface-elevated rounded-3xl border border-gray-200/40 px-8 py-20 sm:py-24 text-center shadow-xl animate-fade-in">
      <div class="w-20 h-20 rounded-3xl bg-gradient-to-br from-orange-100 to-rose-100 flex items-center justify-center mx-auto mb-6 border border-orange-200/40 shadow-inner">
        <svg class="w-10 h-10 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      </div>
      <p class="text-gray-500 font-medium mb-4"><%= t("biodata.no_biodatas") %></p>
      <% if logged_in? && current_user.biodata.nil? %>
        <%= link_to t("biodata.create_my_biodata"), new_my_biodata_path, class: "btn-primary !inline-flex" %>
      <% end %>
    </div>
  <% end %>
<% end %>
