<% content_for(:title, t("biodata.title")) %>
<% content_for :head do %>
<script>
function stepAge(id, delta) {
  var el = document.getElementById(id);
  var val = parseInt(el.value) || (id === 'age_min' ? 18 : 45);
  val = Math.min(60, Math.max(18, val + delta));
  el.value = val;
}
function selectGender(val) {
  document.getElementById('gender_field').value = val;
  document.querySelectorAll('[data-gender-card]').forEach(function(c) {
    c.setAttribute('data-selected', c.getAttribute('data-gender-card') === val ? 'true' : 'false');
  });
  var form = document.getElementById('biodata_filter_form');
  if (!form) return;
  if (form.requestSubmit) form.requestSubmit();
  else form.submit();
}
function toggleMoreFilters() {
  var el = document.getElementById('more-filters');
  var btn = document.getElementById('more-filters-btn');
  var open = el.classList.toggle('hidden') === false;
  btn.querySelector('[data-more-label]').textContent = open
    ? btn.getAttribute('data-label-less')
    : btn.getAttribute('data-label-more');
  btn.querySelector('[data-more-chevron]').style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
}
function openFilters() {
  document.getElementById('filter-summary').classList.add('hidden');
  document.getElementById('biodata_filter_form').classList.remove('hidden');
}
function closeFilters() {
  updateFilterSummary();
  document.getElementById('biodata_filter_form').classList.add('hidden');
  document.getElementById('filter-summary').classList.remove('hidden');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
function updateFilterSummary() {
  var I18N = window.__filterI18n || {};
  var parts = [];
  var g = (document.getElementById('gender_field') || {}).value;
  if (g === 'female') parts.push(I18N.bride);
  else if (g === 'male') parts.push(I18N.groom);
  var ageMin = (document.getElementById('age_min') || {}).value;
  var ageMax = (document.getElementById('age_max') || {}).value;
  if (ageMin && ageMax) parts.push(ageMin + '–' + ageMax + ' ' + I18N.years);
  else if (ageMin) parts.push(ageMin + '+ ' + I18N.years);
  else if (ageMax) parts.push('≤' + ageMax + ' ' + I18N.years);
  var citySel = document.querySelector('select[name="city"]');
  if (citySel && citySel.value) parts.push(citySel.value);
  var stateSel = document.querySelector('select[name="state"]');
  if (stateSel && stateSel.value) parts.push(stateSel.value);
  var eduSel = document.querySelector('select[name="education"]');
  if (eduSel && eduSel.value) parts.push(eduSel.value);
  var occSel = document.querySelector('select[name="occupation"]');
  if (occSel && occSel.value) parts.push(occSel.value);
  var text = parts.length ? parts.join(' • ') : I18N.none;
  var el = document.getElementById('filter-summary-text');
  if (el) el.textContent = text;
}
document.addEventListener('turbo:submit-end', function(e) {
  if (e.target && e.target.id === 'biodata_filter_form') closeFilters();
});
</script>
<style>
  .gender-card {
    background: #fff;
    border: 1.5px solid #e7e5e4;
    border-radius: 10px;
    padding: 8px 6px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    transition: all 0.15s ease;
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
  }
  .gender-card:hover { border-color: #fdba74; }
  .gender-card[data-selected="true"] {
    border-color: #ea580c;
    background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
  }
  .gender-card-icon { font-size: 18px; line-height: 1; }
  .gender-card-label {
    font-size: 12px;
    font-weight: 700;
    color: #1c1917;
    letter-spacing: -0.01em;
  }
  .gender-card[data-selected="true"] .gender-card-label { color: #c2410c; }

  .filter-label {
    font-size: 10px;
    font-weight: 700;
    color: #78716c;
    margin-bottom: 3px;
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .big-select {
    width: 100%;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 600;
    color: #1c1917;
    background: #fff;
    border: 1.5px solid #e7e5e4;
    border-radius: 8px;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke='%23ea580c' stroke-width='3'%3E%3Cpath stroke-linecap='round' d='M19 9l-7 7-7-7'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 8px center;
    background-size: 11px;
    padding-right: 24px;
    cursor: pointer;
    height: 32px;
  }
  .big-select:focus { outline: none; border-color: #ea580c; }

  .age-stepper {
    display: flex;
    align-items: center;
    background: #fff;
    border: 1.5px solid #e7e5e4;
    border-radius: 8px;
    overflow: hidden;
    height: 32px;
  }
  .age-stepper:focus-within { border-color: #ea580c; }
  .age-stepper button {
    width: 26px;
    height: 100%;
    font-size: 14px;
    font-weight: 800;
    color: #ea580c;
    background: #fff7ed;
    border: none;
    cursor: pointer;
    user-select: none;
  }
  .age-stepper button:active { background: #ffedd5; }
  .age-stepper input {
    flex: 1;
    min-width: 0;
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #1c1917;
    background: transparent;
    border: 0;
    outline: none;
    -moz-appearance: textfield;
  }
  .age-stepper input::-webkit-outer-spin-button,
  .age-stepper input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .show-btn {
    width: 100%;
    padding: 8px 14px;
    background: linear-gradient(90deg, #c2410c, #ea580c);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.01em;
    border: none;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(234,88,12,0.28);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    transition: transform 0.1s ease, box-shadow 0.15s ease;
  }
  .show-btn:active { transform: scale(0.98); box-shadow: 0 1px 4px rgba(234,88,12,0.22); }

  .clear-link {
    display: block;
    text-align: center;
    padding: 4px;
    margin-top: 4px;
    font-size: 11px;
    font-weight: 600;
    color: #78716c;
    text-decoration: none;
  }
  .clear-link:hover { color: #c2410c; text-decoration: underline; }

  .more-btn {
    width: 100%;
    background: transparent;
    border: 1px dashed #d6d3d1;
    border-radius: 8px;
    padding: 5px;
    font-size: 11px;
    font-weight: 600;
    color: #78716c;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
  .more-btn:hover { border-color: #fdba74; color: #c2410c; }

  .filter-summary-bar {
    width: 100%;
    background: #fff;
    border: 1.5px solid #fed7aa;
    border-radius: 10px;
    padding: 7px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    text-align: left;
    -webkit-tap-highlight-color: transparent;
    transition: border-color 0.15s ease, background 0.15s ease;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
  }
  .filter-summary-bar:hover { border-color: #fdba74; background: #fffbf5; }
  .filter-summary-bar:active { background: #fff7ed; }
  .filter-summary-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    background: linear-gradient(135deg, #fff7ed, #ffedd5);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ea580c;
  }
  .filter-summary-text {
    flex: 1;
    min-width: 0;
    font-size: 12px;
    font-weight: 700;
    color: #1c1917;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .filter-summary-cta {
    flex-shrink: 0;
    font-size: 10px;
    font-weight: 700;
    color: #ea580c;
    background: #fff7ed;
    padding: 3px 7px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 3px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
</style>
<% end %>

<%# Header %>
<div class="mb-4 animate-fade-in text-center">
  <h1 class="text-xl font-black tracking-tight">
    <span class="text-gradient"><%= t("biodata.title") %></span>
  </h1>
  <p class="text-xs text-gray-400 hidden sm:block"><%= t("biodata.subtitle") %></p>
</div>

<%# Filters — simplified for non-technical users %>
<%
  has_filters = params[:gender].present? || params[:age_min].present? || params[:age_max].present? ||
                params[:city].present? || params[:state].present? ||
                params[:education].present? || params[:occupation].present?
  summary_parts = []
  summary_parts << t("biodata.filter_bride") if params[:gender] == "female"
  summary_parts << t("biodata.filter_groom") if params[:gender] == "male"
  if params[:age_min].present? && params[:age_max].present?
    summary_parts << "#{params[:age_min]}–#{params[:age_max]} #{t('biodata.filter_years')}"
  elsif params[:age_min].present?
    summary_parts << "#{params[:age_min]}+ #{t('biodata.filter_years')}"
  elsif params[:age_max].present?
    summary_parts << "≤#{params[:age_max]} #{t('biodata.filter_years')}"
  end
  summary_parts << params[:city]       if params[:city].present?
  summary_parts << params[:state]      if params[:state].present?
  summary_parts << params[:education]  if params[:education].present?
  summary_parts << params[:occupation] if params[:occupation].present?
  summary_text = summary_parts.any? ? summary_parts.join(" • ") : t("biodata.filter_summary_none")
%>

<%# i18n payload so JS can rebuild summary on client-side after submits %>
<script>
  window.__filterI18n = {
    bride: <%= raw t("biodata.filter_bride").to_json %>,
    groom: <%= raw t("biodata.filter_groom").to_json %>,
    years: <%= raw t("biodata.filter_years").to_json %>,
    none:  <%= raw t("biodata.filter_summary_none").to_json %>
  };
</script>

<%# Collapsed summary — visible when filters are applied %>
<div id="filter-summary" class="<%= 'hidden' unless has_filters %> mb-4" onclick="openFilters()" role="button" tabindex="0" aria-label="<%= t('biodata.filter_edit') %>">
  <div class="filter-summary-bar">
    <span class="filter-summary-icon">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <circle cx="11" cy="11" r="7"/>
        <path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
      </svg>
    </span>
    <span class="filter-summary-text" id="filter-summary-text"><%= summary_text %></span>
    <span class="filter-summary-cta">
      <%= t("biodata.filter_edit") %>
      <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" d="M9 5l7 7-7 7"/>
      </svg>
    </span>
  </div>
</div>

<%= form_with url: biodatas_path, method: :get,
      id: "biodata_filter_form",
      class: "card-premium rounded-xl p-3 mb-4 shadow-sm #{'hidden' if has_filters}",
      data: { turbo_frame: "biodata_grid", controller: "filter", filter_target: "form" } do |f| %>

  <%# Hidden gender field (populated by gender cards) %>
  <input type="hidden" name="gender" id="gender_field" value="<%= params[:gender] %>">

  <%# Row 1: Gender cards (2 columns, compact, horizontal icon+label) %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px;">
    <div class="gender-card"
         data-gender-card="female"
         data-selected="<%= params[:gender] == 'female' ? 'true' : 'false' %>"
         onclick="selectGender(this.getAttribute('data-gender-card') === document.getElementById('gender_field').value ? '' : this.getAttribute('data-gender-card'))"
         role="button"
         tabindex="0"
         aria-label="<%= t('biodata.filter_bride') %>">
      <span class="gender-card-icon">👰</span>
      <span class="gender-card-label"><%= t("biodata.filter_bride") %></span>
    </div>
    <div class="gender-card"
         data-gender-card="male"
         data-selected="<%= params[:gender] == 'male' ? 'true' : 'false' %>"
         onclick="selectGender(this.getAttribute('data-gender-card') === document.getElementById('gender_field').value ? '' : this.getAttribute('data-gender-card'))"
         role="button"
         tabindex="0"
         aria-label="<%= t('biodata.filter_groom') %>">
      <span class="gender-card-icon">🤵</span>
      <span class="gender-card-label"><%= t("biodata.filter_groom") %></span>
    </div>
  </div>

  <%# Row 2: Age + City side-by-side on desktop, stacked on mobile %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-2">
    <div>
      <label class="filter-label"><%= t("biodata.filter_age") %></label>
      <div style="display:flex;align-items:center;gap:4px;">
        <div class="age-stepper" style="flex:1;">
          <button type="button" onclick="stepAge('age_min',-1)" aria-label="−">−</button>
          <input type="number" name="age_min" id="age_min" value="<%= params[:age_min] %>" placeholder="18" min="18" max="60" inputmode="numeric">
          <button type="button" onclick="stepAge('age_min',1)" aria-label="+">+</button>
        </div>
        <span style="color:#a8a29e;font-size:11px;font-weight:600;flex-shrink:0;"><%= t("biodata.filter_age_to") %></span>
        <div class="age-stepper" style="flex:1;">
          <button type="button" onclick="stepAge('age_max',-1)" aria-label="−">−</button>
          <input type="number" name="age_max" id="age_max" value="<%= params[:age_max] %>" placeholder="45" min="18" max="60" inputmode="numeric">
          <button type="button" onclick="stepAge('age_max',1)" aria-label="+">+</button>
        </div>
      </div>
    </div>

    <div>
      <label class="filter-label"><%= t("biodata.filter_city") %></label>
      <select name="city" class="big-select" aria-label="<%= t('biodata.filter_city') %>">
        <option value=""><%= t("biodata.filter_any_city") %></option>
        <% @cities.each do |c| %>
          <option value="<%= c %>" <%= "selected" if params[:city] == c %>><%= c %></option>
        <% end %>
      </select>
    </div>
  </div>

  <%# Secondary: State + Education + Occupation — hidden behind "More options" %>
  <% more_open = params[:state].present? || params[:education].present? || params[:occupation].present? %>
  <div id="more-filters" class="<%= "hidden" unless more_open %>" style="margin-bottom:8px;">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
      <% if @states.any? %>
        <div>
          <label class="filter-label"><%= t("biodata.filter_state") %></label>
          <select name="state" class="big-select" aria-label="<%= t('biodata.filter_state') %>">
            <option value=""><%= t("biodata.filter_any_state") %></option>
            <% @states.each do |s| %>
              <option value="<%= s %>" <%= "selected" if params[:state] == s %>><%= s %></option>
            <% end %>
          </select>
        </div>
      <% end %>
      <% if @educations.any? %>
        <div>
          <label class="filter-label"><%= t("biodata.filter_education") %></label>
          <select name="education" class="big-select" aria-label="<%= t('biodata.filter_education') %>">
            <option value=""><%= t("biodata.filter_any_education") %></option>
            <% @educations.each do |e| %>
              <option value="<%= e %>" <%= "selected" if params[:education] == e %>><%= e %></option>
            <% end %>
          </select>
        </div>
      <% end %>
      <% if @occupations.any? %>
        <div>
          <label class="filter-label"><%= t("biodata.filter_occupation") %></label>
          <select name="occupation" class="big-select" aria-label="<%= t('biodata.filter_occupation') %>">
            <option value=""><%= t("biodata.filter_any_occupation") %></option>
            <% @occupations.each do |o| %>
              <option value="<%= o %>" <%= "selected" if params[:occupation] == o %>><%= o %></option>
            <% end %>
          </select>
        </div>
      <% end %>
    </div>
  </div>

  <%# "More options" toggle %>
  <% if @states.any? || @educations.any? || @occupations.any? %>
    <div style="margin-bottom:8px;">
      <button type="button"
              id="more-filters-btn"
              class="more-btn"
              onclick="toggleMoreFilters()"
              data-label-more="<%= t('biodata.filter_more') %>"
              data-label-less="<%= t('biodata.filter_less') %>">
        <span data-more-label><%= more_open ? t("biodata.filter_less") : t("biodata.filter_more") %></span>
        <svg data-more-chevron width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" style="transition:transform 0.2s;<%= "transform:rotate(180deg);" if more_open %>">
          <path stroke-linecap="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    </div>
  <% end %>

  <%# Actions: Show + Clear on same row %>
  <div style="display:flex;gap:6px;align-items:center;">
    <button type="submit" class="show-btn" style="flex:1;">
      <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <circle cx="11" cy="11" r="7"/>
        <path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
      </svg>
      <%= t("biodata.filter_show") %>
    </button>
    <% if has_filters %>
      <%= link_to t("biodata.filter_clear"), biodatas_path, class: "clear-link", style: "flex-shrink:0;padding:8px 12px;margin-top:0;" %>
    <% end %>
  </div>
<% end %>

<%# Biodata Grid %>
<%= turbo_frame_tag "biodata_grid" do %>
  <% if @total_count > 0 %>
    <p class="text-xs text-gray-400 font-medium mb-3">
      <%= t("biodata.results_count", count: @total_count) %>
    </p>
  <% end %>

  <% if @biodatas.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-5 animate-fade-up">
      <% @biodatas.each do |biodata| %>
        <%= link_to biodata_path(biodata), class: "group card-premium rounded-2xl border border-gray-200/40 block overflow-hidden", data: { turbo_frame: "_top" } do %>
          <%# Photo — square on mobile %>
          <div class="aspect-square sm:aspect-[4/5] bg-gradient-to-br from-orange-100/90 via-amber-50 to-rose-100/80 relative overflow-hidden">
            <% if biodata.photo.attached? %>
              <%= optimized_image_tag biodata.photo, variant: :card, class: "img-zoom w-full h-full object-cover", loading: "lazy",
                  onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
            <% end %>
            <div class="w-full h-full flex items-center justify-center" style="<%= biodata.photo.attached? ? 'display:none' : '' %>">
              <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-full gradient-brand flex items-center justify-center shadow-lg">
                <span class="text-white font-black text-xl sm:text-2xl"><%= biodata.avatar_initial %></span>
              </div>
            </div>
            <%# Gender badge %>
            <span class="absolute top-2 left-2 text-[10px] font-bold px-2 py-0.5 rounded-full <%= biodata.female? ? 'bg-pink-100 text-pink-700' : 'bg-blue-100 text-blue-700' %>">
              <%= t("biodata.gender_#{biodata.gender}") %>
            </span>
          </div>

          <div class="p-2.5 sm:p-3">
            <h3 class="font-bold tracking-tight text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-1 text-sm leading-snug">
              <%= biodata.display_name %>
            </h3>
            <div class="flex items-center justify-between text-[11px] text-gray-400 mt-1">
              <span class="font-semibold text-gray-500"><%= biodata.age %> yrs</span>
              <span class="truncate ml-1.5 text-right"><%= biodata.city.presence || biodata.state %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Pagination %>
    <% total_pages = (@total_count.to_f / @per_page).ceil %>
    <% if total_pages > 1 %>
      <div class="mt-10 flex items-center justify-between">
        <p class="text-sm text-gray-500"><%= t("feed.page_info", current: @page, total: total_pages) %></p>
        <div class="flex gap-2">
          <% if @page > 1 %>
            <%= link_to t("feed.previous"), biodatas_path(request.query_parameters.merge(page: @page - 1)), class: "btn-ghost !py-2 !px-4 !text-sm" %>
          <% end %>
          <% if @page < total_pages %>
            <%= link_to t("feed.next"), biodatas_path(request.query_parameters.merge(page: @page + 1)), class: "btn-primary !py-2 !px-4 !text-sm" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="surface-elevated rounded-3xl border border-gray-200/40 px-8 py-20 sm:py-24 text-center shadow-xl animate-fade-in">
      <div class="w-20 h-20 rounded-3xl bg-gradient-to-br from-orange-100 to-rose-100 flex items-center justify-center mx-auto mb-6 border border-orange-200/40 shadow-inner">
        <svg class="w-10 h-10 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      </div>
      <p class="text-gray-500 font-medium mb-4"><%= t("biodata.no_biodatas") %></p>
      <% if logged_in? && current_user.biodata.nil? %>
        <%= link_to t("biodata.create_my_biodata"), new_my_biodata_path, class: "btn-primary !inline-flex" %>
      <% end %>
    </div>
  <% end %>
<% end %>
