<% content_for(:title, @biodata.display_name) %>

<div class="max-w-4xl mx-auto animate-fade-in">
  <%# Back link %>
  <div class="mb-6">
    <%= link_to biodatas_path, class: "btn-ghost !py-2 !px-3 !text-sm text-gray-600 hover:text-orange-600" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
      <%= t("biodata.back_to_biodatas") %>
    <% end %>
  </div>

  <div class="surface-elevated rounded-3xl border border-gray-200/40 overflow-hidden shadow-2xl shadow-gray-900/5">
    <div class="lg:flex">
      <%# Left column — photo %>
      <div class="lg:w-72 xl:w-80 shrink-0">
        <div class="aspect-square sm:aspect-[4/5] lg:aspect-auto lg:h-full bg-gradient-to-br from-orange-100/90 via-amber-50 to-rose-100/80 relative overflow-hidden">
          <% if @biodata.photo.attached? %>
            <%= optimized_image_tag @biodata.photo, variant: :profile, class: "w-full h-full object-cover", loading: "lazy",
                onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
          <% end %>
          <div class="w-full h-full flex items-center justify-center min-h-64" style="<%= @biodata.photo.attached? ? 'display:none' : '' %>">
            <div class="w-28 h-28 rounded-full gradient-brand flex items-center justify-center shadow-2xl">
              <span class="text-white font-black text-5xl"><%= @biodata.avatar_initial %></span>
            </div>
          </div>
          <%# Gender badge overlay %>
          <span class="absolute top-4 left-4 badge <%= @biodata.female? ? 'bg-pink-100 text-pink-700 border border-pink-200/60' : @biodata.male? ? 'bg-blue-100 text-blue-700 border border-blue-200/60' : 'bg-gray-100 text-gray-600 border border-gray-200/60' %>">
            <%= t("biodata.gender_#{@biodata.gender}") %>
          </span>
        </div>
      </div>

      <%# Right column — details %>
      <div class="flex-1 p-6 sm:p-8 lg:p-10">
        <h1 class="text-2xl sm:text-3xl font-black tracking-tight text-gray-900 mb-1"><%= @biodata.full_name.presence || @biodata.display_name %></h1>
        <% if @biodata.full_name_hi.present? && @biodata.full_name_hi != @biodata.full_name %>
          <p class="text-base text-gray-500 mb-4"><%= @biodata.full_name_hi %></p>
        <% else %>
          <div class="mb-4"></div>
        <% end %>

        <%# Key stats %>
        <div class="flex flex-wrap items-center gap-3 mb-6 pb-6 border-b border-gray-100">
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-gray-700">
            <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <%= @biodata.age %> <%= t("biodata.years") %>
          </span>
          <span class="w-1 h-1 rounded-full bg-gray-300"></span>
          <span class="inline-flex items-center gap-1.5 text-sm text-gray-600">
            <svg class="w-4 h-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            <%= [@biodata.city, @biodata.city_hi].select(&:present?).join(" / ") %><%= @biodata.state.present? ? ", #{@biodata.state}" : "" %><%= @biodata.country.present? && @biodata.country != "India" ? ", #{@biodata.country}" : "" %>
          </span>
          <% if @biodata.height_display.present? %>
            <span class="w-1 h-1 rounded-full bg-gray-300"></span>
            <span class="text-sm text-gray-600"><%= @biodata.height_display %></span>
          <% end %>
        </div>

        <%# Details Grid %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 mb-8">
          <% if @biodata.education.present? %>
            <div>
              <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-1"><%= t("biodata.education") %></p>
              <p class="text-sm text-gray-800 font-medium"><%= @biodata.education %></p>
            </div>
          <% end %>
          <% if @biodata.occupation.present? %>
            <div>
              <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-1"><%= t("biodata.occupation") %></p>
              <p class="text-sm text-gray-800 font-medium"><%= @biodata.occupation %></p>
            </div>
          <% end %>
          <% if @biodata.job_location.present? %>
            <div>
              <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-1"><%= t("biodata.job_location") %></p>
              <p class="text-sm text-gray-800 font-medium"><%= @biodata.job_location %></p>
            </div>
          <% end %>
          <% if @biodata.caste.present? %>
            <div>
              <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-1"><%= t("biodata.caste") %></p>
              <p class="text-sm text-gray-800 font-medium"><%= @biodata.caste %></p>
            </div>
          <% end %>
          <% if @biodata.mother_tongue.present? %>
            <div>
              <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-1"><%= t("biodata.mother_tongue") %></p>
              <p class="text-sm text-gray-800 font-medium"><%= @biodata.mother_tongue %></p>
            </div>
          <% end %>
          <% if @biodata.annual_income.present? %>
            <div>
              <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-1"><%= t("biodata.annual_income") %></p>
              <p class="text-sm text-gray-800 font-medium"><%= @biodata.annual_income %></p>
            </div>
          <% end %>
          <% if @biodata.complexion.present? %>
            <div>
              <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-1"><%= t("biodata.complexion") %></p>
              <p class="text-sm text-gray-800 font-medium"><%= @biodata.complexion %></p>
            </div>
          <% end %>
        </div>

        <%# Family Details %>
        <% if @biodata.father_name.present? || @biodata.father_occupation.present? || @biodata.mother_name.present? || @biodata.mother_occupation.present? || @biodata.siblings_count.to_i > 0 %>
          <div class="card-premium rounded-2xl p-5 mb-6 bg-gradient-to-br from-white via-orange-50/20 to-amber-50/10">
            <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-3"><%= t("biodata.family_details") %></p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <% if @biodata.father_name.present? %>
                <div>
                  <p class="text-xs text-gray-500 mb-0.5"><%= t("biodata.father_name") %></p>
                  <p class="text-sm font-semibold text-gray-800"><%= @biodata.father_name %></p>
                </div>
              <% end %>
              <% if @biodata.father_occupation.present? %>
                <div>
                  <p class="text-xs text-gray-500 mb-0.5"><%= t("biodata.father_occupation") %></p>
                  <p class="text-sm font-semibold text-gray-800"><%= @biodata.father_occupation %></p>
                </div>
              <% end %>
              <% if @biodata.mother_name.present? %>
                <div>
                  <p class="text-xs text-gray-500 mb-0.5"><%= t("biodata.mother_name") %></p>
                  <p class="text-sm font-semibold text-gray-800"><%= @biodata.mother_name %></p>
                </div>
              <% end %>
              <% if @biodata.mother_occupation.present? %>
                <div>
                  <p class="text-xs text-gray-500 mb-0.5"><%= t("biodata.mother_occupation") %></p>
                  <p class="text-sm font-semibold text-gray-800"><%= @biodata.mother_occupation %></p>
                </div>
              <% end %>
              <% if @biodata.siblings_count.to_i > 0 %>
                <div>
                  <p class="text-xs text-gray-500 mb-0.5"><%= t("biodata.siblings") %></p>
                  <p class="text-sm font-semibold text-gray-800"><%= @biodata.siblings_count %></p>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# About %>
        <% if @biodata.display_about.present? %>
          <div class="rounded-2xl border border-gray-200/40 bg-white/80 p-5 sm:p-6 mb-6 shadow-inner">
            <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-3"><%= t("biodata.about") %></p>
            <div class="prose prose-sm max-w-none text-gray-700">
              <%= simple_format(@biodata.display_about) %>
            </div>
          </div>
        <% end %>

        <%# Contact — gated behind login %>
        <% if (@biodata.contact_phone.present? || @biodata.contact_email.present?) %>
          <div class="rounded-2xl border border-orange-200/60 bg-gradient-to-br from-orange-50/80 to-amber-50/60 p-5 sm:p-6">
            <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-3"><%= t("biodata.contact") %></p>
            <% if logged_in? %>
              <div class="space-y-2">
                <% if @biodata.contact_phone.present? %>
                  <div class="flex items-center gap-2.5">
                    <svg class="w-4 h-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    <a href="tel:<%= @biodata.contact_phone %>" class="text-sm font-bold text-gray-800 hover:text-orange-600 transition-colors"><%= @biodata.contact_phone %></a>
                  </div>
                <% end %>
                <% if @biodata.contact_email.present? %>
                  <div class="flex items-center gap-2.5">
                    <svg class="w-4 h-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <a href="mailto:<%= @biodata.contact_email %>" class="text-sm font-bold text-gray-800 hover:text-orange-600 transition-colors"><%= @biodata.contact_email %></a>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                <p class="text-sm text-gray-600"><%= t("biodata.contact_login_required") %></p>
                <%= link_to t("nav.sign_in"), login_path, class: "ml-auto btn-primary !py-1.5 !px-4 !text-xs !rounded-lg shrink-0" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
