<%# ═══════════════════════════════════════════════════════════════
    MATRIMONIAL BIODATA TEMPLATE — premium redesign
    ═══════════════════════════════════════════════════════════════ %>

<div style="max-width:700px;margin:0 auto;background:white;font-family:'Inter','Noto Sans Devanagari',system-ui,sans-serif;border-radius:20px;overflow:hidden;box-shadow:0 8px 48px rgba(0,0,0,0.12);">

  <%# ── Hero header ── %>
  <div style="background:linear-gradient(135deg,#c2410c 0%,#ea580c 45%,#f97316 100%);padding:28px 32px 24px;position:relative;overflow:hidden;">
    <%# Decorative circles %>
    <div style="position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,0.06);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-60px;left:-20px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,0.04);pointer-events:none;"></div>

    <div style="position:relative;display:flex;align-items:flex-start;gap:20px;">

      <%# Photo in header %>
      <div style="flex-shrink:0;">
        <div style="width:100px;height:120px;border-radius:14px;overflow:hidden;background:rgba(255,255,255,0.15);border:2.5px solid rgba(255,255,255,0.4);box-shadow:0 4px 20px rgba(0,0,0,0.2);">
          <% if @biodata.photo.attached? %>
            <%= optimized_image_tag @biodata.photo, variant: :profile,
                style: "width:100%;height:100%;object-fit:cover;display:block;",
                loading: "eager",
                onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
          <% end %>
          <div style="width:100%;height:100%;display:<%= @biodata.photo.attached? ? 'none' : 'flex' %>;align-items:center;justify-content:center;">
            <span style="font-size:36px;font-weight:900;color:white;"><%= @biodata.avatar_initial %></span>
          </div>
        </div>
      </div>

      <%# Name + meta %>
      <div style="flex:1;min-width:0;padding-top:4px;">
        <p style="font-size:10px;color:rgba(255,255,255,0.65);font-weight:700;letter-spacing:0.16em;text-transform:uppercase;margin:0 0 8px;"><%= t("brand.name") %> &nbsp;·&nbsp; <%= t("biodata.template_title") %></p>
        <h1 style="font-size:28px;font-weight:900;color:white;margin:0 0 2px;letter-spacing:-0.02em;line-height:1.1;">
          <%= @biodata.full_name %>
        </h1>
        <% if @biodata.full_name_hi.present? %>
          <p style="font-size:16px;color:rgba(255,255,255,0.8);margin:0 0 12px;font-weight:500;font-family:'Noto Sans Devanagari',sans-serif;"><%= @biodata.full_name_hi %></p>
        <% else %>
          <div style="margin-bottom:12px;"></div>
        <% end %>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);">
            <%= t("biodata.gender_#{@biodata.gender}") %>
          </span>
          <% if @biodata.age.present? %>
            <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);">
              <%= @biodata.age %> <%= t("biodata.years") %>
            </span>
          <% end %>
          <% if @biodata.city.present? %>
            <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);">
              📍 <%= [@biodata.city, @biodata.state].select(&:present?).join(", ") %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Body ── %>
  <div style="padding:24px 32px;">

    <%# ── Personal Info ── %>
    <% personal = [
      [t("biodata.date_of_birth"), @biodata.date_of_birth&.strftime("%d %B %Y")],
      [t("biodata.height"),        @biodata.height_display],
      [t("biodata.complexion"),    @biodata.complexion],
      [t("biodata.caste"),         @biodata.caste],
      [t("biodata.mother_tongue"), @biodata.mother_tongue],
    ].reject { |_, v| v.blank? } %>
    <% if personal.any? %>
      <div style="margin-bottom:24px;">
        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          <% personal.each do |label, value| %>
            <div style="flex:1;min-width:140px;background:#fafafa;border:1px solid #f3f4f6;border-radius:10px;padding:10px 14px;">
              <p style="font-size:9px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 3px;"><%= label %></p>
              <p style="font-size:13px;font-weight:600;color:#111827;margin:0;"><%= value %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Education & Career ── %>
    <% edu_rows = [
      [t("biodata.education"),     @biodata.education],
      [t("biodata.occupation"),    @biodata.occupation],
      [t("biodata.job_location"),  @biodata.job_location],
      [t("biodata.annual_income"), @biodata.annual_income],
    ].reject { |_, v| v.blank? } %>
    <% if edu_rows.any? %>
      <div style="margin-bottom:24px;">
        <p style="font-size:10px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #fff7ed;"><%= t("biodata.education_career") %></p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <% edu_rows.each do |label, value| %>
            <div style="background:#fafafa;border:1px solid #f3f4f6;border-radius:10px;padding:10px 14px;">
              <p style="font-size:9px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 3px;"><%= label %></p>
              <p style="font-size:13px;font-weight:600;color:#111827;margin:0;"><%= value %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Family ── %>
    <% family_rows = [
      [t("biodata.father_name"),       @biodata.father_name],
      [t("biodata.father_occupation"), @biodata.father_occupation],
      [t("biodata.mother_name"),       @biodata.mother_name],
      [t("biodata.mother_occupation"), @biodata.mother_occupation],
      [t("biodata.siblings"),          @biodata.siblings_count.to_i > 0 ? @biodata.siblings_count.to_s : nil],
    ].reject { |_, v| v.blank? } %>
    <% if family_rows.any? %>
      <div style="margin-bottom:24px;">
        <p style="font-size:10px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #fff7ed;"><%= t("biodata.family_details") %></p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <% family_rows.each do |label, value| %>
            <div style="background:#fafafa;border:1px solid #f3f4f6;border-radius:10px;padding:10px 14px;">
              <p style="font-size:9px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 3px;"><%= label %></p>
              <p style="font-size:13px;font-weight:600;color:#111827;margin:0;"><%= value %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── About ── %>
    <% if @biodata.display_about.present? %>
      <div style="margin-bottom:24px;">
        <p style="font-size:10px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 10px;padding-bottom:6px;border-bottom:2px solid #fff7ed;"><%= t("biodata.about") %></p>
        <p style="font-size:13px;color:#374151;line-height:1.75;margin:0;"><%= @biodata.display_about %></p>
      </div>
    <% end %>

    <%# ── Contact ── %>
    <% if @biodata.contact_phone.present? || @biodata.contact_email.present? %>
      <div style="background:linear-gradient(135deg,#fff7ed,#fef3c7);border-radius:12px;padding:16px 20px;display:flex;gap:24px;flex-wrap:wrap;border:1px solid #fed7aa;">
        <% if @biodata.contact_phone.present? %>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:36px;height:36px;border-radius:50%;background:white;box-shadow:0 1px 4px rgba(0,0,0,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="font-size:16px;">📞</span>
            </div>
            <div>
              <p style="font-size:9px;font-weight:800;color:#9a3412;text-transform:uppercase;letter-spacing:0.1em;margin:0;"><%= t("biodata.contact_phone") %></p>
              <p style="font-size:15px;font-weight:700;color:#1c1917;margin:0;letter-spacing:0.02em;"><%= @biodata.contact_phone %></p>
            </div>
          </div>
        <% end %>
        <% if @biodata.contact_email.present? %>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:36px;height:36px;border-radius:50%;background:white;box-shadow:0 1px 4px rgba(0,0,0,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="font-size:16px;">✉️</span>
            </div>
            <div>
              <p style="font-size:9px;font-weight:800;color:#9a3412;text-transform:uppercase;letter-spacing:0.1em;margin:0;"><%= t("biodata.contact_email") %></p>
              <p style="font-size:14px;font-weight:700;color:#1c1917;margin:0;"><%= @biodata.contact_email %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ── Footer ── %>
  <div style="background:#f9fafb;border-top:1px solid #f3f4f6;padding:10px 32px;display:flex;align-items:center;justify-content:space-between;">
    <p style="font-size:10px;color:#9ca3af;margin:0;font-weight:500;"><%= t("brand.name") %> &nbsp;·&nbsp; <%= t("biodata.template_title") %></p>
    <p style="font-size:10px;color:#d1d5db;margin:0;">ID #<%= @biodata.id %><%= @biodata.published_at.present? ? " · #{@biodata.published_at.strftime('%d %b %Y')}" : "" %></p>
  </div>

</div>
