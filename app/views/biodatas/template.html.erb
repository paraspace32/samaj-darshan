<%# ═══════════════════════════════════════════════════════════════
    MATRIMONIAL BIODATA TEMPLATE
    ═══════════════════════════════════════════════════════════════ %>

<div style="max-width:640px;margin:0 auto;font-family:'Inter','Noto Sans Devanagari',system-ui,sans-serif;">
<div style="background:white;border-radius:16px;overflow:hidden;box-shadow:0 2px 24px rgba(0,0,0,0.09);border:1px solid #e5e7eb;">

  <%# ── Header ── %>
  <div style="background:linear-gradient(135deg,#b45309 0%,#ea580c 50%,#f97316 100%);padding:24px 24px 20px;position:relative;overflow:hidden;">
    <div style="position:absolute;top:-32px;right:-32px;width:140px;height:140px;border-radius:50%;background:rgba(255,255,255,0.07);"></div>
    <div style="position:absolute;bottom:-48px;left:40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,0.05);"></div>

    <div style="position:relative;display:flex;align-items:flex-start;gap:18px;">
      <%# Photo %>
      <div style="flex-shrink:0;width:90px;height:108px;border-radius:10px;overflow:hidden;border:2px solid rgba(255,255,255,0.5);box-shadow:0 4px 16px rgba(0,0,0,0.2);">
        <% if @biodata.photo.attached? %>
          <%= optimized_image_tag @biodata.photo, variant: :profile,
              style: "width:100%;height:100%;object-fit:cover;display:block;",
              loading: "eager",
              onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
        <% end %>
        <div style="width:100%;height:100%;display:<%= @biodata.photo.attached? ? 'none' : 'flex' %>;align-items:center;justify-content:center;background:rgba(255,255,255,0.15);">
          <span style="font-size:34px;font-weight:900;color:white;"><%= @biodata.avatar_initial %></span>
        </div>
      </div>

      <%# Name area %>
      <div style="flex:1;min-width:0;padding-top:2px;">
        <p style="font-size:9px;color:rgba(255,255,255,0.6);font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin:0 0 6px;"><%= t("brand.name") %> &nbsp;·&nbsp; <%= t("biodata.template_title") %></p>
        <h1 style="font-size:24px;font-weight:900;color:white;margin:0 0 2px;letter-spacing:-0.02em;line-height:1.15;"><%= @biodata.full_name.presence || @biodata.display_name %></h1>
        <% if @biodata.full_name_hi.present? %>
          <p style="font-size:14px;color:rgba(255,255,255,0.75);margin:0 0 12px;font-weight:500;"><%= @biodata.full_name_hi %></p>
        <% else %>
          <div style="margin-bottom:12px;"></div>
        <% end %>
        <div style="display:flex;flex-wrap:wrap;gap:5px;">
          <span style="padding:3px 10px;border-radius:99px;font-size:10px;font-weight:700;background:rgba(255,255,255,0.2);color:white;border:1px solid rgba(255,255,255,0.3);">
            <%= t("biodata.gender_#{@biodata.gender}") %>
          </span>
          <% if @biodata.age.present? %>
            <span style="padding:3px 10px;border-radius:99px;font-size:10px;font-weight:700;background:rgba(255,255,255,0.2);color:white;border:1px solid rgba(255,255,255,0.3);">
              <%= @biodata.age %> <%= t("biodata.years") %>
            </span>
          <% end %>
          <% if @biodata.city.present? || @biodata.state.present? %>
            <span style="padding:3px 10px;border-radius:99px;font-size:10px;font-weight:700;background:rgba(255,255,255,0.2);color:white;border:1px solid rgba(255,255,255,0.3);">
              📍 <%= [@biodata.city, @biodata.state].select(&:present?).join(", ") %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Body ── %>
  <div style="padding:20px 24px 22px;">

    <% def self.section_header(label)
    # rendered inline below
    end %>

    <%# Helper: renders a titled section with a 2-col tile grid %>
    <%# ── Personal Info ── %>
    <% personal = [
      [t("biodata.date_of_birth"), @biodata.date_of_birth&.strftime("%d %B %Y")],
      [t("biodata.height"),        @biodata.height_display],
      [t("biodata.complexion"),    @biodata.complexion],
      [t("biodata.caste"),         @biodata.caste],
      [t("biodata.mother_tongue"), @biodata.mother_tongue],
    ].reject { |_, v| v.blank? } %>
    <% if personal.any? %>
      <%# Section label %>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
        <div style="width:3px;height:14px;border-radius:2px;background:linear-gradient(180deg,#ea580c,#f97316);flex-shrink:0;"></div>
        <span style="font-size:10px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.12em;"><%= t("biodata.personal_details") %></span>
        <div style="flex:1;height:1px;background:#f3f4f6;"></div>
      </div>
      <%# 2-col tile grid %>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;">
        <% personal.each do |label, value| %>
          <div style="flex:1 1 calc(50% - 4px);min-width:120px;background:#fafaf9;border:1px solid #f0eeec;border-radius:8px;padding:8px 12px;">
            <p style="font-size:9px;font-weight:700;color:#b45309;text-transform:uppercase;letter-spacing:0.09em;margin:0 0 2px;"><%= label %></p>
            <p style="font-size:13px;font-weight:600;color:#1c1917;margin:0;line-height:1.4;"><%= value %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Education & Career ── %>
    <% edu_rows = [
      [t("biodata.education"),     @biodata.education],
      [t("biodata.occupation"),    @biodata.occupation],
      [t("biodata.job_location"),  @biodata.job_location],
      [t("biodata.annual_income"), @biodata.annual_income],
    ].reject { |_, v| v.blank? } %>
    <% if edu_rows.any? %>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
        <div style="width:3px;height:14px;border-radius:2px;background:linear-gradient(180deg,#ea580c,#f97316);flex-shrink:0;"></div>
        <span style="font-size:10px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.12em;"><%= t("biodata.education_career") %></span>
        <div style="flex:1;height:1px;background:#f3f4f6;"></div>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;">
        <% edu_rows.each do |label, value| %>
          <div style="flex:1 1 calc(50% - 4px);min-width:120px;background:#fafaf9;border:1px solid #f0eeec;border-radius:8px;padding:8px 12px;">
            <p style="font-size:9px;font-weight:700;color:#b45309;text-transform:uppercase;letter-spacing:0.09em;margin:0 0 2px;"><%= label %></p>
            <p style="font-size:13px;font-weight:600;color:#1c1917;margin:0;line-height:1.4;"><%= value %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Family ── %>
    <% family_rows = [
      [t("biodata.father_name"),       @biodata.father_name],
      [t("biodata.father_occupation"), @biodata.father_occupation],
      [t("biodata.mother_name"),       @biodata.mother_name],
      [t("biodata.mother_occupation"), @biodata.mother_occupation],
      [t("biodata.siblings"),          @biodata.siblings_count.to_i > 0 ? @biodata.siblings_count.to_s : nil],
    ].reject { |_, v| v.blank? } %>
    <% if family_rows.any? %>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
        <div style="width:3px;height:14px;border-radius:2px;background:linear-gradient(180deg,#ea580c,#f97316);flex-shrink:0;"></div>
        <span style="font-size:10px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.12em;"><%= t("biodata.family_details") %></span>
        <div style="flex:1;height:1px;background:#f3f4f6;"></div>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;">
        <% family_rows.each do |label, value| %>
          <div style="flex:1 1 calc(50% - 4px);min-width:120px;background:#fafaf9;border:1px solid #f0eeec;border-radius:8px;padding:8px 12px;">
            <p style="font-size:9px;font-weight:700;color:#b45309;text-transform:uppercase;letter-spacing:0.09em;margin:0 0 2px;"><%= label %></p>
            <p style="font-size:13px;font-weight:600;color:#1c1917;margin:0;line-height:1.4;"><%= value %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── About ── %>
    <% if @biodata.display_about.present? %>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
        <div style="width:3px;height:14px;border-radius:2px;background:linear-gradient(180deg,#ea580c,#f97316);flex-shrink:0;"></div>
        <span style="font-size:10px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.12em;"><%= t("biodata.about") %></span>
        <div style="flex:1;height:1px;background:#f3f4f6;"></div>
      </div>
      <p style="font-size:13px;color:#44403c;line-height:1.75;margin:0 0 18px;"><%= @biodata.display_about %></p>
    <% end %>

    <%# ── Contact ── %>
    <% if @biodata.contact_phone.present? || @biodata.contact_email.present? %>
      <div style="background:#fff7ed;border-radius:10px;padding:10px 14px;border:1px solid #fed7aa;display:flex;flex-wrap:wrap;gap:16px;align-items:center;">
        <% if @biodata.contact_phone.present? %>
          <div style="display:flex;align-items:center;gap:7px;">
            <span style="font-size:13px;">📞</span>
            <span style="font-size:9px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:0.08em;"><%= t("biodata.contact_phone") %>:</span>
            <span style="font-size:13px;font-weight:700;color:#1c1917;"><%= @biodata.contact_phone %></span>
          </div>
        <% end %>
        <% if @biodata.contact_email.present? %>
          <div style="display:flex;align-items:center;gap:7px;">
            <span style="font-size:13px;">✉️</span>
            <span style="font-size:9px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:0.08em;"><%= t("biodata.contact_email") %>:</span>
            <span style="font-size:13px;font-weight:700;color:#1c1917;"><%= @biodata.contact_email %></span>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ── Footer ── %>
  <div style="border-top:1px solid #f3f4f6;padding:8px 24px;display:flex;align-items:center;justify-content:space-between;background:#fafaf9;">
    <p style="font-size:9px;color:#a8a29e;margin:0;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;"><%= t("brand.name") %></p>
    <p style="font-size:9px;color:#d6d3d1;margin:0;">ID #<%= @biodata.id %><%= @biodata.published_at.present? ? " · #{@biodata.published_at.strftime('%d %b %Y')}" : "" %></p>
  </div>

</div>
</div>
