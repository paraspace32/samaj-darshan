<%# ═══════════════════════════════════════════════════════════════
    MATRIMONIAL BIODATA TEMPLATE — modern clean design
    ═══════════════════════════════════════════════════════════════ %>

<div style="max-width:680px;margin:0 auto;background:white;font-family:'Inter','Noto Sans Devanagari',system-ui,sans-serif;border-radius:16px;overflow:hidden;box-shadow:0 4px 32px rgba(0,0,0,0.10);">

  <%# ── Header bar ── %>
  <div style="background:linear-gradient(135deg,#ea580c 0%,#f97316 50%,#fb923c 100%);padding:20px 28px 16px;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(circle at 80% 50%,rgba(255,255,255,0.12),transparent 60%);pointer-events:none;"></div>
    <p style="font-size:11px;color:rgba(255,255,255,0.75);font-weight:600;letter-spacing:0.14em;text-transform:uppercase;margin:0 0 6px;">
      <%= t("brand.name") %> &nbsp;·&nbsp; <%= t("biodata.template_title") %>
    </p>
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap;">
      <div>
        <h1 style="font-size:26px;font-weight:900;color:white;margin:0;letter-spacing:-0.02em;line-height:1.15;">
          <%= @biodata.display_name %>
        </h1>
        <% if @biodata.full_name_hi.present? && @biodata.full_name_hi != @biodata.full_name %>
          <p style="font-size:15px;color:rgba(255,255,255,0.85);margin:2px 0 0;font-weight:500;"><%= @biodata.full_name_hi %></p>
        <% end %>
      </div>
      <span style="display:inline-block;padding:4px 14px;border-radius:99px;font-size:12px;font-weight:700;letter-spacing:0.04em;
        background:<%= @biodata.female? ? 'rgba(255,192,203,0.25)' : 'rgba(173,216,230,0.25)' %>;
        color:white;border:1.5px solid rgba(255,255,255,0.4);white-space:nowrap;">
        <%= t("biodata.gender_#{@biodata.gender}") %>
      </span>
    </div>
  </div>

  <%# ── Body ── %>
  <div style="padding:24px 28px;">

    <%# ── Photo + Personal details ── %>
    <div style="display:flex;gap:20px;margin-bottom:24px;">

      <%# Photo %>
      <div style="flex-shrink:0;">
        <div style="width:130px;height:160px;border-radius:12px;overflow:hidden;background:linear-gradient(135deg,#fff7ed,#fed7aa);border:2px solid #fed7aa;">
          <% if @biodata.photo.attached? %>
            <%= optimized_image_tag @biodata.photo, variant: :profile, style: "width:100%;height:100%;object-fit:cover;display:block;", loading: "eager" %>
          <% else %>
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
              <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#ea580c,#f97316);display:flex;align-items:center;justify-content:center;">
                <span style="color:white;font-weight:900;font-size:22px;"><%= @biodata.full_name[0].upcase %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Personal info grid %>
      <div style="flex:1;min-width:0;">
        <% personal = [
          [t("biodata.date_of_birth"), @biodata.date_of_birth&.strftime("%d %B %Y")],
          [t("biodata.age"),           @biodata.age.present? ? "#{@biodata.age} #{t('biodata.years')}" : nil],
          [t("biodata.height"),        @biodata.height_display],
          [t("biodata.complexion"),    @biodata.complexion],
          [t("biodata.caste"),         @biodata.caste],
          [t("biodata.mother_tongue"), @biodata.mother_tongue],
          [t("biodata.city"),          [@biodata.city, @biodata.city_hi, @biodata.state].select(&:present?).join(", ")],
        ].reject { |_, v| v.blank? } %>

        <div style="display:grid;grid-template-columns:auto 1fr;gap:0;">
          <% personal.each_with_index do |(label, value), i| %>
            <div style="padding:5px 10px 5px 0;font-size:11px;font-weight:700;color:#9a3412;white-space:nowrap;border-bottom:1px solid #fff7ed;"><%= label %></div>
            <div style="padding:5px 0;font-size:12px;color:#1c1917;font-weight:500;border-bottom:1px solid #fff7ed;"><%= value %></div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Education & Career ── %>
    <% edu_rows = [
      [t("biodata.education"),     @biodata.education],
      [t("biodata.occupation"),    @biodata.occupation],
      [t("biodata.job_location"),  @biodata.job_location],
      [t("biodata.annual_income"), @biodata.annual_income],
    ].reject { |_, v| v.blank? } %>
    <% if edu_rows.any? %>
      <div style="margin-bottom:20px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
          <div style="width:3px;height:16px;background:#ea580c;border-radius:2px;flex-shrink:0;"></div>
          <p style="font-size:11px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.1em;margin:0;"><%= t("biodata.education_career") %></p>
        </div>
        <div style="display:grid;grid-template-columns:auto 1fr;gap:0;border:1px solid #fff7ed;border-radius:8px;overflow:hidden;">
          <% edu_rows.each_with_index do |(label, value), i| %>
            <div style="padding:6px 12px;font-size:11px;font-weight:700;color:#9a3412;background:<%= i.even? ? '#fff7ed' : 'white' %>;border-bottom:<%= i < edu_rows.size - 1 ? '1px solid #fff7ed' : 'none' %>;white-space:nowrap;"><%= label %></div>
            <div style="padding:6px 12px 6px 8px;font-size:12px;color:#1c1917;font-weight:500;background:<%= i.even? ? '#fff7ed' : 'white' %>;border-bottom:<%= i < edu_rows.size - 1 ? '1px solid #fff7ed' : 'none' %>;"><%= value %></div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Family ── %>
    <% family_rows = [
      [t("biodata.father_name"),       @biodata.father_name],
      [t("biodata.father_occupation"), @biodata.father_occupation],
      [t("biodata.mother_name"),       @biodata.mother_name],
      [t("biodata.mother_occupation"), @biodata.mother_occupation],
      [t("biodata.siblings"),          @biodata.siblings_count.to_i > 0 ? @biodata.siblings_count.to_s : nil],
    ].reject { |_, v| v.blank? } %>
    <% if family_rows.any? %>
      <div style="margin-bottom:20px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
          <div style="width:3px;height:16px;background:#ea580c;border-radius:2px;flex-shrink:0;"></div>
          <p style="font-size:11px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.1em;margin:0;"><%= t("biodata.family_details") %></p>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <% family_rows.each do |label, value| %>
            <div style="background:#fff7ed;border-radius:8px;padding:8px 12px;">
              <p style="font-size:10px;font-weight:700;color:#9a3412;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 2px;"><%= label %></p>
              <p style="font-size:13px;font-weight:600;color:#1c1917;margin:0;"><%= value %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── About ── %>
    <% if @biodata.display_about.present? %>
      <div style="margin-bottom:20px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
          <div style="width:3px;height:16px;background:#ea580c;border-radius:2px;flex-shrink:0;"></div>
          <p style="font-size:11px;font-weight:800;color:#ea580c;text-transform:uppercase;letter-spacing:0.1em;margin:0;"><%= t("biodata.about") %></p>
        </div>
        <div style="background:#fff7ed;border-radius:8px;padding:12px 14px;">
          <p style="font-size:13px;color:#374151;line-height:1.7;margin:0;"><%= @biodata.display_about %></p>
        </div>
      </div>
    <% end %>

    <%# ── Contact ── %>
    <% if @biodata.contact_phone.present? || @biodata.contact_email.present? %>
      <div style="border-top:1px solid #f3f4f6;padding-top:16px;display:flex;gap:24px;flex-wrap:wrap;">
        <% if @biodata.contact_phone.present? %>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:32px;height:32px;border-radius:50%;background:#fff7ed;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="font-size:14px;">📞</span>
            </div>
            <div>
              <p style="font-size:10px;font-weight:700;color:#9a3412;text-transform:uppercase;letter-spacing:0.06em;margin:0;"><%= t("biodata.contact_phone") %></p>
              <p style="font-size:14px;font-weight:700;color:#1c1917;margin:0;"><%= @biodata.contact_phone %></p>
            </div>
          </div>
        <% end %>
        <% if @biodata.contact_email.present? %>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:32px;height:32px;border-radius:50%;background:#fff7ed;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="font-size:14px;">✉️</span>
            </div>
            <div>
              <p style="font-size:10px;font-weight:700;color:#9a3412;text-transform:uppercase;letter-spacing:0.06em;margin:0;"><%= t("biodata.contact_email") %></p>
              <p style="font-size:14px;font-weight:700;color:#1c1917;margin:0;"><%= @biodata.contact_email %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ── Footer ── %>
  <div style="background:#f9fafb;border-top:1px solid #f3f4f6;padding:10px 28px;display:flex;align-items:center;justify-content:space-between;">
    <p style="font-size:10px;color:#9ca3af;margin:0;"><%= t("brand.name") %> · <%= t("biodata.template_title") %></p>
    <p style="font-size:10px;color:#d1d5db;margin:0;">ID #<%= @biodata.id %><%= @biodata.published_at.present? ? " · #{@biodata.published_at.strftime('%d %b %Y')}" : "" %></p>
  </div>

</div>
