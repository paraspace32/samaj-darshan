<%# ═══════════════════════════════════════════════════════════════
    MATRIMONIAL BIODATA — Premium Template
    ═══════════════════════════════════════════════════════════════ %>
<% lspacing = I18n.locale == :hi ? "0" : "0.16em" %>
<% lbl_lspacing = I18n.locale == :hi ? "0" : "0.1em" %>

<div style="max-width:680px;margin:0 auto;padding:2px;">
<div style="background:#fdf7f0;border-radius:20px;overflow:hidden;box-shadow:0 8px 48px rgba(180,83,9,0.14),0 2px 8px rgba(0,0,0,0.06);border:1.5px solid #f5c897;position:relative;">

  <%# ── Decorative top strip ── %>
  <div style="height:6px;background:linear-gradient(90deg,#7c2d12,#c2410c,#ea580c,#f97316,#ea580c,#c2410c,#7c2d12);"></div>

  <%# ── Hero Header ── %>
  <div style="background:linear-gradient(150deg,#6b2009 0%,#b83a0a 35%,#ea580c 65%,#fb923c 100%);padding:28px 28px 26px;position:relative;overflow:hidden;">

    <%# Decorative background circles %>
    <div style="position:absolute;top:-50px;right:-50px;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,0.06);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-70px;right:60px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,0.04);pointer-events:none;"></div>
    <div style="position:absolute;top:20px;left:-40px;width:140px;height:140px;border-radius:50%;background:rgba(255,255,255,0.03);pointer-events:none;"></div>

    <div style="position:relative;display:flex;align-items:center;gap:22px;">

      <%# Circular photo with glowing ring %>
      <div style="flex-shrink:0;">
        <div style="width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,rgba(255,255,255,0.9) 0%,rgba(255,200,120,0.6) 100%);padding:3px;box-shadow:0 0 0 2px rgba(255,255,255,0.25),0 6px 24px rgba(0,0,0,0.3);">
          <div style="width:100%;height:100%;border-radius:50%;overflow:hidden;background:rgba(255,255,255,0.15);">
            <% if @biodata.photo.attached? %>
              <%= optimized_image_tag @biodata.photo, variant: :profile,
                  style: "width:100%;height:100%;object-fit:cover;display:block;",
                  loading: "eager",
                  onerror: "this.style.display='none';this.nextElementSibling.style.display='flex'" %>
            <% end %>
            <div style="width:100%;height:100%;display:<%= @biodata.photo.attached? ? 'none' : 'flex' %>;align-items:center;justify-content:center;">
              <span style="font-size:38px;font-weight:900;color:white;"><%= @biodata.avatar_initial %></span>
            </div>
          </div>
        </div>
      </div>

      <%# Name & Info %>
      <div style="flex:1;min-width:0;">
        <p style="font-size:8.5px;color:rgba(255,255,255,0.55);font-weight:700;letter-spacing:0.22em;text-transform:uppercase;margin:0 0 7px;">
          <%= t("brand.name") %> &nbsp;✦&nbsp; <%= t("biodata.template_title") %>
        </p>
        <h1 style="font-size:25px;font-weight:900;color:white;margin:0 0 2px;letter-spacing:-0.02em;line-height:1.1;text-shadow:0 1px 4px rgba(0,0,0,0.2);">
          <%= @biodata.full_name.presence || @biodata.display_name %>
        </h1>
        <% if @biodata.full_name_hi.present? && @biodata.full_name_hi != @biodata.full_name %>
          <p style="font-size:14px;color:rgba(255,255,255,0.78);margin:0 0 12px;font-weight:500;"><%= @biodata.full_name_hi %></p>
        <% else %>
          <div style="margin-bottom:12px;"></div>
        <% end %>
        <div style="display:flex;flex-wrap:wrap;gap:5px;">
          <span style="display:inline-flex;align-items:center;padding:3px 11px;border-radius:99px;font-size:10px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);backdrop-filter:blur(4px);">
            <%= t("biodata.gender_#{@biodata.gender}") %>
          </span>
          <% if @biodata.age.present? %>
            <span style="display:inline-flex;align-items:center;padding:3px 11px;border-radius:99px;font-size:10px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);">
              <%= @biodata.age %> <%= t("biodata.years") %>
            </span>
          <% end %>
          <% if @biodata.city.present? || @biodata.state.present? %>
            <span style="display:inline-flex;align-items:center;padding:3px 11px;border-radius:99px;font-size:10px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);">
              📍 <%= [@biodata.city, @biodata.state].select(&:present?).join(", ") %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Body ── %>
  <div style="padding:22px 24px 24px;background:#fdf7f0;">

    <%# Reusable section header partial – rendered inline below %>

    <%# ── Personal Info ── %>
    <% personal = [
      [t("biodata.date_of_birth"), @biodata.date_of_birth&.strftime("%d %B %Y")],
      [t("biodata.height"),        @biodata.height_display],
      [t("biodata.complexion"),    @biodata.complexion],
      [t("biodata.caste"),         @biodata.caste],
      [t("biodata.mother_tongue"), @biodata.mother_tongue],
    ].reject { |_, v| v.blank? } %>
    <% if personal.any? %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#f5c897);"></div>
        <span style="font-size:9.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;white-space:nowrap;">✦ <%= t("biodata.personal_details") %> ✦</span>
        <div style="flex:1;height:1px;background:linear-gradient(90deg,#f5c897,transparent);"></div>
      </div>
      <div style="background:white;border:1px solid #fde8cb;border-radius:10px;overflow:hidden;margin-bottom:18px;box-shadow:0 1px 4px rgba(180,83,9,0.06);">
        <% personal.each_with_index do |(label, value), i| %>
          <div style="display:flex;align-items:baseline;padding:8px 14px;<%= i < personal.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>">
            <span style="font-size:11px;font-weight:600;color:#b45309;min-width:120px;flex-shrink:0;"><%= label %></span>
            <span style="font-size:13px;font-weight:700;color:#1c1917;"><%= value %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Education & Career ── %>
    <% edu_rows = [
      [t("biodata.education"),     @biodata.education],
      [t("biodata.occupation"),    @biodata.occupation],
      [t("biodata.job_location"),  @biodata.job_location],
      [t("biodata.annual_income"), @biodata.annual_income],
    ].reject { |_, v| v.blank? } %>
    <% if edu_rows.any? %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#f5c897);"></div>
        <span style="font-size:9.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;white-space:nowrap;">✦ <%= t("biodata.education_career") %> ✦</span>
        <div style="flex:1;height:1px;background:linear-gradient(90deg,#f5c897,transparent);"></div>
      </div>
      <div style="background:white;border:1px solid #fde8cb;border-radius:10px;overflow:hidden;margin-bottom:18px;box-shadow:0 1px 4px rgba(180,83,9,0.06);">
        <% edu_rows.each_with_index do |(label, value), i| %>
          <div style="display:flex;align-items:baseline;padding:8px 14px;<%= i < edu_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>">
            <span style="font-size:11px;font-weight:600;color:#b45309;min-width:120px;flex-shrink:0;"><%= label %></span>
            <span style="font-size:13px;font-weight:700;color:#1c1917;"><%= value %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Family ── %>
    <% family_rows = [
      [t("biodata.father_name"),       @biodata.father_name],
      [t("biodata.father_occupation"), @biodata.father_occupation],
      [t("biodata.mother_name"),       @biodata.mother_name],
      [t("biodata.mother_occupation"), @biodata.mother_occupation],
      [t("biodata.siblings"),          @biodata.siblings_count.to_i > 0 ? @biodata.siblings_count.to_s : nil],
    ].reject { |_, v| v.blank? } %>
    <% if family_rows.any? %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#f5c897);"></div>
        <span style="font-size:9.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;white-space:nowrap;">✦ <%= t("biodata.family_details") %> ✦</span>
        <div style="flex:1;height:1px;background:linear-gradient(90deg,#f5c897,transparent);"></div>
      </div>
      <div style="background:white;border:1px solid #fde8cb;border-radius:10px;overflow:hidden;margin-bottom:18px;box-shadow:0 1px 4px rgba(180,83,9,0.06);">
        <% family_rows.each_with_index do |(label, value), i| %>
          <div style="display:flex;align-items:baseline;padding:8px 14px;<%= i < family_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>">
            <span style="font-size:11px;font-weight:600;color:#b45309;min-width:120px;flex-shrink:0;"><%= label %></span>
            <span style="font-size:13px;font-weight:700;color:#1c1917;"><%= value %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── About ── %>
    <% if @biodata.display_about.present? %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#f5c897);"></div>
        <span style="font-size:9.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;white-space:nowrap;">✦ <%= t("biodata.about") %> ✦</span>
        <div style="flex:1;height:1px;background:linear-gradient(90deg,#f5c897,transparent);"></div>
      </div>
      <div style="background:white;border:1px solid #fde8cb;border-radius:10px;padding:10px 14px;margin-bottom:18px;box-shadow:0 1px 4px rgba(180,83,9,0.06);">
        <p style="font-size:12.5px;color:#44403c;line-height:1.7;margin:0;"><%= @biodata.display_about %></p>
      </div>
    <% end %>

    <%# ── Contact ── %>
    <% if @biodata.contact_phone.present? || @biodata.contact_email.present? %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#f5c897);"></div>
        <span style="font-size:9.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;white-space:nowrap;">✦ <%= t("biodata.contact") %> ✦</span>
        <div style="flex:1;height:1px;background:linear-gradient(90deg,#f5c897,transparent);"></div>
      </div>
      <div style="background:white;border:1px solid #fde8cb;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(180,83,9,0.06);">
        <% contact_rows = [] %>
        <% contact_rows << ["📞 #{t('biodata.contact_phone')}", @biodata.contact_phone] if @biodata.contact_phone.present? %>
        <% contact_rows << ["✉️ #{t('biodata.contact_email')}", @biodata.contact_email] if @biodata.contact_email.present? %>
        <% contact_rows.each_with_index do |(label, value), i| %>
          <div style="display:flex;align-items:baseline;padding:8px 14px;<%= i < contact_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>">
            <span style="font-size:11px;font-weight:600;color:#b45309;min-width:120px;flex-shrink:0;"><%= label %></span>
            <span style="font-size:13px;font-weight:700;color:#1c1917;word-break:break-all;"><%= value %></span>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ── Footer ── %>
  <div style="border-top:1px solid #fde8cb;background:white;padding:9px 24px;display:flex;align-items:center;justify-content:space-between;">
    <p style="font-size:9px;color:#c4a47a;margin:0;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;"><%= t("brand.name") %></p>
    <p style="font-size:9px;color:#d6cfc6;margin:0;">ID #<%= @biodata.id %><%= @biodata.published_at.present? ? " · #{@biodata.published_at.strftime('%d %b %Y')}" : "" %></p>
  </div>

  <%# ── Bottom accent strip ── %>
  <div style="height:6px;background:linear-gradient(90deg,#7c2d12,#c2410c,#ea580c,#f97316,#ea580c,#c2410c,#7c2d12);"></div>

</div>
</div>
