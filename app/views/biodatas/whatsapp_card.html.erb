<%# ═══════════════════════════════════════════════════════════════
    WhatsApp Share Card — 540x720px compact biodata card
    Mirrors the app's biodata template design at a smaller scale.
    Rendered by WhatsappCardGenerator (photo passed as data URI).
    Uses only position/table layout (no flexbox — wkhtmltopdf compat).
    ═══════════════════════════════════════════════════════════════ %>

<%
  # Collect all sections
  personal = [
    ["Date of Birth", @biodata.date_of_birth&.strftime("%d %B %Y")],
    ["Height",        @biodata.height_display.presence],
    ["Complexion",    @biodata.complexion],
    ["Caste",         @biodata.caste],
  ].reject { |_, v| v.blank? }

  edu_rows = [
    ["Education",  @biodata.education],
    ["Occupation", @biodata.occupation],
    ["Income",     @biodata.annual_income],
  ].reject { |_, v| v.blank? }

  family_rows = [
    ["Father",       @biodata.father_name],
    ["Father's Work", @biodata.father_occupation],
    ["Mother",       @biodata.mother_name],
  ].reject { |_, v| v.blank? }

  contact_rows = []
  contact_rows << ["Phone", @biodata.contact_phone] if @biodata.contact_phone.present?
  contact_rows << ["Email", @biodata.contact_email] if @biodata.contact_email.present?

  location = [@biodata.city, @biodata.state].select(&:present?).join(", ")
%>

<div style="width:540px;height:720px;background:#fdf7f0;position:relative;overflow:hidden;border:1.5px solid #f5c897;">

  <%# ── Top gradient strip ── %>
  <div style="height:4px;background:linear-gradient(90deg,#7c2d12,#c2410c,#ea580c,#f97316,#ea580c,#c2410c,#7c2d12);"></div>

  <%# ── Hero Header (matches app template) ── %>
  <div style="background:linear-gradient(150deg,#6b2009 0%,#b83a0a 35%,#ea580c 65%,#fb923c 100%);padding:18px 20px 16px;position:relative;overflow:hidden;">
    <%# Decorative circles %>
    <div style="position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,0.06);"></div>
    <div style="position:absolute;bottom:-50px;right:40px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,0.04);"></div>

    <%# Photo + Name row using table layout %>
    <table style="width:100%;border-collapse:collapse;position:relative;z-index:1;">
      <tr>
        <%# Circular photo %>
        <td style="width:80px;vertical-align:middle;padding-right:16px;">
          <div style="width:76px;height:76px;border-radius:50%;background:linear-gradient(135deg,rgba(255,255,255,0.9),rgba(255,200,120,0.6));padding:2.5px;box-shadow:0 0 0 2px rgba(255,255,255,0.25),0 6px 20px rgba(0,0,0,0.3);">
            <div style="width:71px;height:71px;border-radius:50%;overflow:hidden;background:rgba(255,255,255,0.15);">
              <% if @photo_data_uri.present? %>
                <img src="<%= @photo_data_uri %>" style="width:71px;height:71px;object-fit:cover;display:block;border-radius:50%;" />
              <% else %>
                <div style="width:71px;height:71px;text-align:center;line-height:71px;background:linear-gradient(135deg,#f97316,#ea580c);border-radius:50%;">
                  <span style="font-size:30px;font-weight:900;color:white;"><%= @biodata.avatar_initial %></span>
                </div>
              <% end %>
            </div>
          </div>
        </td>

        <%# Name & badges %>
        <td style="vertical-align:middle;">
          <div style="font-size:7px;color:rgba(255,255,255,0.55);font-weight:700;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:5px;">
            Samaj Darshan &nbsp;✦&nbsp; Biodata
          </div>
          <div style="font-size:20px;font-weight:900;color:white;letter-spacing:-0.02em;line-height:1.1;text-shadow:0 1px 4px rgba(0,0,0,0.2);margin-bottom:2px;">
            <%= @biodata.full_name.presence || @biodata.display_name %>
          </div>
          <% if @biodata.full_name_hi.present? && @biodata.full_name_hi != @biodata.full_name %>
            <div style="font-size:12px;color:rgba(255,255,255,0.78);font-weight:500;margin-bottom:8px;"><%= @biodata.full_name_hi %></div>
          <% else %>
            <div style="margin-bottom:8px;"></div>
          <% end %>
          <%# Badges %>
          <div>
            <span style="display:inline-block;padding:2px 8px;border-radius:99px;font-size:8.5px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);margin-right:4px;">
              <%= @biodata.gender&.capitalize %>
            </span>
            <% if @biodata.age.present? %>
              <span style="display:inline-block;padding:2px 8px;border-radius:99px;font-size:8.5px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);margin-right:4px;">
                <%= @biodata.age %> yrs
              </span>
            <% end %>
            <% if location.present? %>
              <span style="display:inline-block;padding:2px 8px;border-radius:99px;font-size:8.5px;font-weight:700;background:rgba(255,255,255,0.18);color:white;border:1px solid rgba(255,255,255,0.35);">
                <%= location.truncate(30) %>
              </span>
            <% end %>
          </div>
        </td>
      </tr>
    </table>
  </div>

  <%# ── Body ── %>
  <div style="padding:10px 16px 0;">

    <%# ── Personal Info ── %>
    <% if personal.any? %>
      <div style="text-align:center;margin-bottom:6px;">
        <span style="font-size:7.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.16em;">✦ Personal Details ✦</span>
      </div>
      <table style="width:100%;background:white;border:1px solid #fde8cb;border-radius:8px;border-collapse:collapse;margin-bottom:10px;">
        <% personal.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:9.5px;font-weight:700;color:#b45309;padding:5px 10px;width:90px;vertical-align:middle;<%= i < personal.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:9.5px;font-weight:400;color:#1c1917;padding:5px 10px;vertical-align:middle;<%= i < personal.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(35) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

    <%# ── Education & Career ── %>
    <% if edu_rows.any? %>
      <div style="text-align:center;margin-bottom:6px;">
        <span style="font-size:7.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.16em;">✦ Education & Career ✦</span>
      </div>
      <table style="width:100%;background:white;border:1px solid #fde8cb;border-radius:8px;border-collapse:collapse;margin-bottom:10px;">
        <% edu_rows.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:9.5px;font-weight:700;color:#b45309;padding:5px 10px;width:90px;vertical-align:middle;<%= i < edu_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:9.5px;font-weight:400;color:#1c1917;padding:5px 10px;vertical-align:middle;<%= i < edu_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(35) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

    <%# ── Family ── %>
    <% if family_rows.any? %>
      <div style="text-align:center;margin-bottom:6px;">
        <span style="font-size:7.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.16em;">✦ Family ✦</span>
      </div>
      <table style="width:100%;background:white;border:1px solid #fde8cb;border-radius:8px;border-collapse:collapse;margin-bottom:10px;">
        <% family_rows.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:9.5px;font-weight:700;color:#b45309;padding:5px 10px;width:90px;vertical-align:middle;<%= i < family_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:9.5px;font-weight:400;color:#1c1917;padding:5px 10px;vertical-align:middle;<%= i < family_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(35) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

    <%# ── Contact ── %>
    <% if contact_rows.any? %>
      <div style="text-align:center;margin-bottom:6px;">
        <span style="font-size:7.5px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:0.16em;">✦ Contact ✦</span>
      </div>
      <table style="width:100%;background:white;border:1px solid #fde8cb;border-radius:8px;border-collapse:collapse;margin-bottom:10px;">
        <% contact_rows.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:9.5px;font-weight:700;color:#b45309;padding:5px 10px;width:90px;vertical-align:middle;<%= i < contact_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:9.5px;font-weight:400;color:#1c1917;padding:5px 10px;vertical-align:middle;<%= i < contact_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(35) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

  </div>

  <%# ── Footer ── %>
  <div style="position:absolute;bottom:0;left:0;right:0;height:40px;background:linear-gradient(150deg,#7c2d12,#c2410c,#ea580c);text-align:center;line-height:40px;">
    <span style="font-size:10px;font-weight:700;color:rgba(255,255,255,0.85);letter-spacing:0.04em;">
      See full profile at
    </span>
    <span style="font-size:11px;font-weight:900;color:white;letter-spacing:0.02em;">
      www.samaj-darshan.com
    </span>
  </div>

  <%# ── Bottom gradient strip ── %>
  <div style="position:absolute;bottom:40px;left:0;right:0;height:4px;background:linear-gradient(90deg,#7c2d12,#c2410c,#ea580c,#f97316,#ea580c,#c2410c,#7c2d12);"></div>
</div>
