<%# ═══════════════════════════════════════════════════════════════
    WhatsApp Share Card — 1080×1440px
    Clean design matching the app's elegant biodata template
    ═══════════════════════════════════════════════════════════════ %>
<%
  personal = [
    [t("biodata.date_of_birth"), @biodata.date_of_birth&.strftime("%d %B %Y")],
    [t("biodata.height"),        @biodata.height_display.presence],
    [t("biodata.complexion"),    @biodata.complexion],
    [t("biodata.caste"),         @biodata.caste],
    [t("biodata.mother_tongue"), @biodata.mother_tongue],
  ].reject { |_, v| v.blank? }

  edu_rows = [
    [t("biodata.education"),     @biodata.education],
    [t("biodata.occupation"),    @biodata.occupation],
    [t("biodata.job_location"),  @biodata.job_location],
    [t("biodata.annual_income"), @biodata.annual_income],
  ].reject { |_, v| v.blank? }

  family_rows = [
    [t("biodata.father_name"),       @biodata.father_name],
    [t("biodata.father_occupation"), @biodata.father_occupation],
    [t("biodata.mother_name"),       @biodata.mother_name],
    [t("biodata.mother_occupation"), @biodata.mother_occupation],
  ].reject { |_, v| v.blank? }

  contact_rows = []
  contact_rows << [t("biodata.contact_phone"), @biodata.contact_phone] if @biodata.contact_phone.present?
  contact_rows << [t("biodata.contact_email"), @biodata.contact_email] if @biodata.contact_email.present?

  location = [@biodata.city, @biodata.state].select(&:present?).join(", ")
  lspacing = I18n.locale == :hi ? "0" : "0.16em"
%>

<div style="width:1080px;height:1440px;position:relative;overflow:hidden;">
<div style="background-color:#fdf7f0;border-radius:30px;overflow:hidden;border:2px solid #f5c897;height:100%;position:relative;">

  <%# ── Top accent ── %>
  <div style="height:8px;background-color:#d97706;"></div>

  <%# ── Hero Header — large, impactful ── %>
  <div style="background-color:#b83a0a;padding:40px 44px 36px;position:relative;overflow:hidden;">

    <table style="width:100%;border-collapse:collapse;position:relative;z-index:1;">
      <tr>
        <%# Large circular photo with elegant ring ── %>
        <td style="width:200px;vertical-align:middle;padding-right:30px;">
          <div style="width:180px;height:180px;border-radius:50%;border:4px solid rgba(255,255,255,0.35);padding:5px;">
            <div style="width:166px;height:166px;border-radius:50%;overflow:hidden;background-color:#ea580c;">
              <% if @photo_data_uri.present? %>
                <img src="<%= @photo_data_uri %>" style="width:166px;height:166px;object-fit:cover;display:block;border-radius:50%;" />
              <% else %>
                <div style="width:166px;height:166px;text-align:center;line-height:166px;background-color:#ea580c;border-radius:50%;">
                  <span style="font-size:68px;font-weight:900;color:white;"><%= @biodata.avatar_initial %></span>
                </div>
              <% end %>
            </div>
          </div>
        </td>
        <%# Name & badges %>
        <td style="vertical-align:middle;">
          <div style="font-size:13px;color:rgba(255,255,255,0.5);font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:8px;">
            <%= t("brand.name") %> &bull; <%= t("biodata.template_title") %>
          </div>
          <div style="font-size:42px;font-weight:900;color:white;letter-spacing:-0.01em;line-height:1.1;margin-bottom:4px;">
            <%= @biodata.full_name.presence || @biodata.display_name %>
          </div>
          <% if @biodata.full_name_hi.present? && @biodata.full_name_hi != @biodata.full_name %>
            <div style="font-size:24px;color:rgba(255,255,255,0.75);font-weight:500;margin-bottom:16px;"><%= @biodata.full_name_hi %></div>
          <% else %>
            <div style="margin-bottom:16px;"></div>
          <% end %>
          <%# Badges %>
          <span style="display:inline-block;padding:6px 18px;border-radius:99px;font-size:16px;font-weight:700;background-color:rgba(255,255,255,0.15);color:white;border:2px solid rgba(255,255,255,0.3);margin-right:8px;">
            <%= t("biodata.gender_#{@biodata.gender}") %>
          </span>
          <% if @biodata.age.present? %>
            <span style="display:inline-block;padding:6px 18px;border-radius:99px;font-size:16px;font-weight:700;background-color:rgba(255,255,255,0.15);color:white;border:2px solid rgba(255,255,255,0.3);margin-right:8px;">
              <%= @biodata.age %> <%= t("biodata.years") %>
            </span>
          <% end %>
          <% if location.present? %>
            <span style="display:inline-block;padding:6px 18px;border-radius:99px;font-size:16px;font-weight:700;background-color:rgba(255,255,255,0.15);color:white;border:2px solid rgba(255,255,255,0.3);">
              <%= location.truncate(28) %>
            </span>
          <% end %>
        </td>
      </tr>
    </table>
  </div>

  <%# ── Body ── %>
  <div style="padding:20px 36px 0;">

    <%# ── Personal Info ── %>
    <% if personal.any? %>
      <table style="width:100%;border-collapse:collapse;margin-bottom:12px;">
        <tr>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
          <td style="text-align:center;white-space:nowrap;padding:0 12px;">
            <span style="font-size:15px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;">&#10022; <%= t("biodata.personal_details") %> &#10022;</span>
          </td>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
        </tr>
      </table>
      <table style="width:100%;background-color:white;border:1px solid #fde8cb;border-radius:14px;border-collapse:collapse;margin-bottom:20px;">
        <% personal.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:18px;font-weight:700;color:#b45309;padding:12px 24px;width:200px;vertical-align:middle;<%= i < personal.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:18px;font-weight:400;color:#292524;padding:12px 24px;vertical-align:middle;<%= i < personal.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(40) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

    <%# ── Education & Career ── %>
    <% if edu_rows.any? %>
      <table style="width:100%;border-collapse:collapse;margin-bottom:12px;">
        <tr>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
          <td style="text-align:center;white-space:nowrap;padding:0 12px;">
            <span style="font-size:15px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;">&#10022; <%= t("biodata.education_career") %> &#10022;</span>
          </td>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
        </tr>
      </table>
      <table style="width:100%;background-color:white;border:1px solid #fde8cb;border-radius:14px;border-collapse:collapse;margin-bottom:20px;">
        <% edu_rows.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:18px;font-weight:700;color:#b45309;padding:12px 24px;width:200px;vertical-align:middle;<%= i < edu_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:18px;font-weight:400;color:#292524;padding:12px 24px;vertical-align:middle;<%= i < edu_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(40) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

    <%# ── Family ── %>
    <% if family_rows.any? %>
      <table style="width:100%;border-collapse:collapse;margin-bottom:12px;">
        <tr>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
          <td style="text-align:center;white-space:nowrap;padding:0 12px;">
            <span style="font-size:15px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;">&#10022; <%= t("biodata.family_details") %> &#10022;</span>
          </td>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
        </tr>
      </table>
      <table style="width:100%;background-color:white;border:1px solid #fde8cb;border-radius:14px;border-collapse:collapse;margin-bottom:20px;">
        <% family_rows.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:18px;font-weight:700;color:#b45309;padding:12px 24px;width:200px;vertical-align:middle;<%= i < family_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:18px;font-weight:400;color:#292524;padding:12px 24px;vertical-align:middle;<%= i < family_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(40) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

    <%# ── Contact ── %>
    <% if contact_rows.any? %>
      <table style="width:100%;border-collapse:collapse;margin-bottom:12px;">
        <tr>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
          <td style="text-align:center;white-space:nowrap;padding:0 12px;">
            <span style="font-size:15px;font-weight:800;color:#92400e;text-transform:uppercase;letter-spacing:<%= lspacing %>;">&#10022; <%= t("biodata.contact") %> &#10022;</span>
          </td>
          <td style="width:35%;border-bottom:1px solid #f5c897;"></td>
        </tr>
      </table>
      <table style="width:100%;background-color:white;border:1px solid #fde8cb;border-radius:14px;border-collapse:collapse;margin-bottom:20px;">
        <% contact_rows.each_with_index do |(label, value), i| %>
          <tr>
            <td style="font-size:18px;font-weight:700;color:#b45309;padding:12px 24px;width:200px;vertical-align:middle;<%= i < contact_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= label %></td>
            <td style="font-size:18px;font-weight:400;color:#292524;padding:12px 24px;vertical-align:middle;<%= i < contact_rows.size - 1 ? 'border-bottom:1px solid #fef3e2;' : '' %>"><%= value&.truncate(40) %></td>
          </tr>
        <% end %>
      </table>
    <% end %>

  </div>

  <%# ── Footer ── %>
  <div style="position:absolute;bottom:0;left:0;right:0;">
    <div style="height:8px;background-color:#d97706;"></div>
    <div style="height:60px;background-color:#7c2d12;text-align:center;line-height:60px;">
      <span style="font-size:18px;font-weight:600;color:rgba(255,255,255,0.8);">
        <%= t("biodata.card_see_profile") %>
      </span>
      <span style="font-size:20px;font-weight:900;color:white;margin-left:8px;">
        www.samaj-darshan.com
      </span>
    </div>
  </div>

</div>
</div>
