<% content_for(:title, @education_post.display_title) %>

<div class="max-w-3xl mx-auto animate-fade-in">
  <div class="surface-elevated rounded-3xl border border-gray-200/40 p-6 sm:p-8 lg:p-10 shadow-2xl shadow-gray-900/5">
    <%# Back link %>
    <div class="mb-8">
      <%= link_to education_index_path, class: "btn-ghost !py-2 !px-3 !text-sm text-gray-600 hover:text-orange-600" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
        <%= t("education.back") %>
      <% end %>
    </div>

    <%# Category badge %>
    <div class="flex flex-wrap items-center gap-2.5 mb-6">
      <span class="badge badge-category bg-indigo-100 text-indigo-700 border border-indigo-200/50"><%= @education_post.category_label %></span>
    </div>

    <%# Title %>
    <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-gray-900 mb-6 leading-[1.15]"><%= @education_post.display_title %></h1>

    <%# Meta row %>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-200/40">
      <% if @education_post.organization_name.present? %>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <span class="font-bold text-gray-700"><%= @education_post.organization_name %></span>
        </div>
      <% end %>
      <% if @education_post.exam_date.present? %>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <span><%= t("education.exam_date") %>: <%= @education_post.exam_date.strftime("%d %b %Y") %></span>
        </div>
      <% end %>
      <% if @education_post.registration_deadline.present? %>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><%= t("education.deadline") %>: <%= @education_post.registration_deadline.strftime("%d %b %Y") %></span>
        </div>
      <% end %>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span><%= @education_post.published_at&.strftime("%d %b %Y") %></span>
      </div>
    </div>

    <%# Cover image %>
    <% if @education_post.cover_image.attached? %>
      <div class="mb-10 rounded-3xl overflow-hidden border border-gray-200/40 shadow-xl group">
        <%= optimized_image_tag @education_post.cover_image, variant: :hero, class: "img-zoom w-full object-cover", loading: "lazy" %>
      </div>
    <% end %>

    <%# Official URL link %>
    <% if @education_post.official_url.present? %>
      <div class="text-center mb-10">
        <%= link_to sanitize_url(@education_post.official_url), target: "_blank", rel: "noopener noreferrer",
            class: "btn-primary !inline-flex !items-center !gap-3 !px-8 !py-3.5 !text-base !rounded-2xl !shadow-lg" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          <%= t("education.visit_official") %>
        <% end %>
      </div>
    <% end %>

    <%# Content %>
    <div class="rounded-3xl border border-gray-200/40 bg-white/80 p-6 sm:p-8 shadow-inner">
      <div class="prose prose-sm max-w-none text-gray-700 prose-headings:tracking-tight">
        <%= simple_format(@education_post.display_content) %>
      </div>
    </div>
  </div>
</div>
