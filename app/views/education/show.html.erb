<% content_for(:title, "#{@education_post.display_title} — #{t('brand.name')}") %>
<% content_for(:og_title, @education_post.display_title) %>
<% content_for(:og_type, "article") %>
<% content_for(:description, truncate(strip_tags(@education_post.display_content), length: 200)) %>
<% if @education_post.cover_image.attached? %>
  <% content_for(:og_image, rails_storage_proxy_url(@education_post.cover_image)) %>
<% end %>

<div class="flex flex-col lg:flex-row gap-12 lg:gap-16 xl:gap-20">
  <%# Main content %>
  <article class="flex-1 min-w-0 animate-fade-in">
    <%# Breadcrumb %>
    <nav class="flex items-center gap-2 text-sm text-stone-500 mb-8 animate-fade-up">
      <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors font-medium" %>
      <svg class="w-3.5 h-3.5 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <%= link_to t("nav.education"), education_index_path, class: "hover:text-orange-600 transition-colors font-medium" %>
      <svg class="w-3.5 h-3.5 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-stone-600 truncate font-medium"><%= truncate(@education_post.display_title, length: 40) %></span>
    </nav>

    <%# Title %>
    <h1 class="text-xl sm:text-2xl lg:text-3xl font-black tracking-tight text-gradient leading-snug mb-4"><%= @education_post.display_title %></h1>

    <% other_title = I18n.locale == :hi ? @education_post.title_en : @education_post.title_hi %>

    <%# Author line %>
    <div class="flex items-center gap-2.5 mb-3">
      <div class="w-8 h-8 rounded-full gradient-brand flex items-center justify-center shadow-sm">
        <span class="text-white font-bold text-xs"><%= @education_post.author.name[0] %></span>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-stone-800"><%= @education_post.author.name %></p>
        <p class="text-xs text-stone-400"><%= t("feed.ago", time: time_ago_in_words(@education_post.published_at)) %></p>
      </div>
    </div>

    <%# Category & meta %>
    <div class="flex flex-wrap items-center gap-3 mb-6 animate-fade-up">
      <span class="badge badge-category bg-indigo-100 text-indigo-700 border border-indigo-200/50 shadow-md">
        <%= @education_post.category_label %>
      </span>
      <span class="text-xs text-stone-500 tracking-wide font-medium tabular-nums"><%= @education_post.published_at&.strftime("%d %b %Y") %></span>
    </div>

    <%# Meta info row (exam date, deadline, organization) %>
    <% if @education_post.organization_name.present? || @education_post.exam_date.present? || @education_post.registration_deadline.present? %>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-stone-500 mb-6 pb-6 border-b border-stone-100/90">
        <% if @education_post.organization_name.present? %>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <span class="font-bold text-stone-700"><%= @education_post.organization_name %></span>
          </div>
        <% end %>
        <% if @education_post.exam_date.present? %>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <span><%= t("education.exam_date") %>: <%= @education_post.exam_date.strftime("%d %b %Y") %></span>
          </div>
        <% end %>
        <% if @education_post.registration_deadline.present? %>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= t("education.deadline") %>: <%= @education_post.registration_deadline.strftime("%d %b %Y") %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="section-divider mb-10"></div>

    <%= render "shared/billboard_article_top" %>

    <%# Cover image %>
    <% if @education_post.cover_image.attached? %>
      <div class="mb-10 -mx-4 sm:mx-0 group overflow-hidden rounded-3xl border border-gray-200/40 shadow-2xl shadow-stone-900/10">
        <%= optimized_image_tag @education_post.cover_image, variant: :hero, class: "w-full h-64 sm:h-80 lg:h-[520px] object-cover img-zoom" %>
      </div>
    <% end %>

    <%# Official URL link %>
    <% if @education_post.official_url.present? %>
      <div class="text-center mb-10">
        <%= link_to sanitize_url(@education_post.official_url), target: "_blank", rel: "noopener noreferrer",
            class: "btn-primary !inline-flex !items-center !gap-3 !px-8 !py-3.5 !text-base !rounded-2xl !shadow-lg" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          <%= t("education.visit_official") %>
        <% end %>
      </div>
    <% end %>

    <%# Content body %>
    <div class="prose prose-stone prose-lg max-w-none mb-12 animate-fade-up
                prose-headings:font-black prose-headings:tracking-tight prose-headings:text-stone-900
                prose-p:text-stone-600 prose-p:leading-relaxed prose-p:text-[1.05rem]
                prose-a:text-orange-600 prose-a:font-semibold prose-a:no-underline hover:prose-a:underline prose-a:decoration-orange-300/80
                prose-blockquote:border-orange-500 prose-blockquote:border-l-4 prose-blockquote:bg-orange-50/60 prose-blockquote:rounded-r-2xl prose-blockquote:py-3 prose-blockquote:px-2 prose-blockquote:text-stone-700">
      <%= simple_format(@education_post.display_content) %>
    </div>

    <%= render "shared/billboard_article_mid" %>

    <%# Like & Share actions %>
    <div id="like-section" class="surface-elevated rounded-3xl border border-gray-200/40 p-6 sm:p-8 mb-10 shadow-xl shadow-stone-900/[0.06]">
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <% if current_user %>
          <%= button_to toggle_education_like_path(@education_post), method: :post, class: "inline-flex items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-semibold transition-all cursor-pointer shadow-md #{@liked ? 'bg-red-50 border border-red-200/80 text-red-600 hover:bg-red-100' : 'bg-white border border-gray-200/40 text-stone-600 hover:bg-red-50/90 hover:border-red-200/60 hover:text-red-500'}" do %>
            <svg class="w-5 h-5 <%= 'fill-red-500' if @liked %>" fill="<%= @liked ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <span><%= @liked ? t("likes.liked") : t("likes.like") %></span>
            <span class="text-xs opacity-70">(<%= @education_post.likes_count %>)</span>
          <% end %>
        <% else %>
          <%= link_to login_path, class: "btn-ghost inline-flex items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-semibold text-stone-500 hover:text-red-600" do %>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <span><%= t("likes.like") %></span>
            <span class="text-xs opacity-70">(<%= @education_post.likes_count %>)</span>
          <% end %>
        <% end %>

        <span class="text-stone-300 font-light select-none">|</span>

        <a href="#comments" class="btn-ghost inline-flex items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-semibold text-stone-600 hover:text-blue-700 hover:border-blue-200/80 hover:bg-blue-50/80">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          <span><%= t("comments.title") %></span>
          <span class="text-xs opacity-70">(<%= @education_post.comments_count %>)</span>
        </a>
      </div>

      <p class="text-sm font-bold text-stone-900 tracking-tight mb-4"><%= t("article.share_whatsapp").gsub("WhatsApp", "") %></p>
      <div class="flex flex-wrap items-center gap-3">
        <% share_text = "#{@education_post.display_title}\n#{request.original_url}" %>
        <a href="https://wa.me/?text=<%= ERB::Util.url_encode(share_text) %>"
           target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 rounded-2xl bg-emerald-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-emerald-700 shadow-lg shadow-emerald-900/15 hover:shadow-xl transition-all">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <button data-controller="copy-link" data-copy-link-url-value="<%= request.original_url %>" data-action="copy-link#copy"
                class="btn-ghost inline-flex items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-semibold">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
          Copy Link
        </button>
      </div>
    </div>

    <%# Comments section %>
    <div id="comments" class="surface-elevated rounded-3xl border border-gray-200/40 overflow-hidden mb-10 shadow-xl shadow-stone-900/[0.06]">
      <div class="px-6 sm:px-8 py-5 border-b border-stone-100/90 flex items-center gap-3 bg-gradient-to-r from-stone-50/80 via-white to-orange-50/30">
        <span class="flex h-9 w-9 items-center justify-center rounded-2xl gradient-brand shadow-md shadow-orange-500/25">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        </span>
        <h3 class="text-base font-black text-stone-900 tracking-tight"><%= t("comments.title") %> (<%= @education_post.comments_count %>)</h3>
      </div>

      <div class="px-6 sm:px-8">
        <% if current_user %>
          <%= form_with model: Comment.new, url: education_comments_path(@education_post), class: "py-6 border-b border-stone-100/90" do |f| %>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-2xl gradient-brand flex items-center justify-center shrink-0 shadow-lg shadow-orange-500/25 ring-2 ring-white/70">
                <span class="text-white font-bold text-sm"><%= current_user.name[0].upcase %></span>
              </div>
              <div class="flex-1 min-w-0">
                <%= f.text_area :body, placeholder: t("comments.write_placeholder"), rows: 2,
                      class: "input-premium w-full rounded-2xl border border-gray-200/60 bg-stone-50/80 px-4 py-3.5 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-100/80 focus:outline-none resize-none transition-all shadow-inner shadow-stone-900/5" %>
                <div class="flex justify-end mt-3">
                  <%= f.submit t("comments.submit"), class: "btn-primary cursor-pointer" %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="py-8 text-center">
            <%= link_to login_path, class: "btn-ghost inline-flex items-center gap-2 text-sm font-semibold" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
              <%= t("comments.login_to_comment") %>
            <% end %>
          </div>
        <% end %>

        <% if @comments.any? %>
          <div class="divide-y divide-stone-100/90">
            <%= render partial: "comments/comment", collection: @comments %>
          </div>
        <% else %>
          <div class="py-12 text-center">
            <p class="text-sm text-stone-500"><%= t("comments.no_comments") %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# Bilingual toggle (only if other language has content) %>
    <% other_content = I18n.locale == :hi ? @education_post.content_en : @education_post.content_hi %>
    <% if other_title.present? || other_content.present? %>
      <details class="surface-raised rounded-3xl border border-gray-200/40 overflow-hidden mb-10 shadow-lg shadow-stone-900/[0.05] open:shadow-xl open:ring-1 open:ring-orange-200/40 transition-shadow">
        <summary class="px-6 sm:px-8 py-5 text-sm font-bold text-stone-800 cursor-pointer hover:bg-stone-50/80 transition-colors flex items-center gap-3 list-none [&::-webkit-details-marker]:hidden">
          <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-stone-100 text-stone-500 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
          </span>
          <%= t("article.read_other_lang") %>
        </summary>
        <div class="px-6 sm:px-8 pb-8 pt-2 prose prose-sm prose-stone max-w-none border-t border-stone-100/90" dir="auto">
          <% if other_title.present? %><h3 class="text-lg font-black tracking-tight text-stone-900"><%= other_title %></h3><% end %>
          <% if other_content.present? %><%= simple_format(other_content.gsub(/\n{3,}/, "\n\n").strip) %><% end %>
        </div>
      </details>
    <% end %>

    <%# Back link %>
    <div class="mt-10 mb-2 animate-fade-up">
      <%= link_to education_index_path, class: "btn-ghost inline-flex items-center gap-2 text-sm font-bold text-stone-700 hover:text-orange-700" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        <%= t("education.back") %>
      <% end %>
    </div>
  </article>

  <%# Sidebar — related education posts %>
  <aside class="lg:w-80 shrink-0 animate-fade-in">
    <div class="lg:sticky lg:top-28">
      <div class="card-premium !rounded-3xl border border-gray-200/40 shadow-2xl shadow-stone-900/10">
        <div class="px-6 py-5 border-b border-stone-100/90 bg-gradient-to-br from-white via-stone-50/50 to-orange-50/20">
          <h3 class="text-sm font-black text-stone-900 tracking-tight flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-xl gradient-brand shadow-md shadow-orange-500/20">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            </span>
            <%= t("education.more_in_category") %>
          </h3>
        </div>
        <% if @related.any? %>
          <div class="divide-y divide-stone-100/80">
            <% @related.each do |rel| %>
              <%= link_to education_path(rel), class: "block px-5 py-5 hover:bg-gradient-to-r hover:from-orange-50/60 hover:to-amber-50/40 transition-colors group border-b-0 last:border-0" do %>
                <div class="flex gap-4">
                  <% if rel.cover_image.attached? %>
                    <div class="shrink-0 overflow-hidden rounded-2xl border border-gray-200/40 shadow-md">
                      <%= optimized_image_tag rel.cover_image, variant: :thumb, class: "w-[5.25rem] h-14 object-cover img-zoom", loading: "lazy" %>
                    </div>
                  <% else %>
                    <div class="w-[5.25rem] h-14 rounded-2xl gradient-brand-soft border border-orange-100/60 flex items-center justify-center shrink-0 shadow-inner">
                      <span class="text-orange-300 font-black text-xs"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                  <div class="min-w-0">
                    <p class="text-sm font-bold text-stone-900 line-clamp-2 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-orange-600 group-hover:to-red-600 transition-all leading-snug tracking-tight"><%= rel.display_title %></p>
                    <div class="flex items-center gap-2 mt-2">
                      <span class="badge badge-category bg-indigo-100 text-indigo-700 border border-indigo-200/50 !py-0.5 !text-[0.65rem]">
                        <%= rel.category_label %>
                      </span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-10 text-center">
            <p class="text-sm text-stone-500"><%= t("education.no_related") %></p>
          </div>
        <% end %>
      </div>
    </div>
  </aside>
</div>
