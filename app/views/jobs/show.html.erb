<% content_for(:title, @job_post.display_title) %>

<div class="max-w-3xl mx-auto animate-fade-in">
  <div class="surface-elevated rounded-3xl border border-gray-200/40 p-6 sm:p-8 lg:p-10 shadow-2xl shadow-gray-900/5">
    <%# Back link %>
    <div class="mb-8">
      <%= link_to jobs_path, class: "btn-ghost !py-2 !px-3 !text-sm text-gray-600 hover:text-orange-600" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
        <%= t("jobs.back") %>
      <% end %>
    </div>

    <%# Category & status badges %>
    <div class="flex flex-wrap items-center gap-2.5 mb-6">
      <span class="badge badge-category bg-blue-100 text-blue-700 border border-blue-200/50"><%= @job_post.category_label %></span>
      <% if @job_post.deadline_passed? %>
        <span class="badge bg-red-100 text-red-700 border border-red-200/50"><%= t("jobs.closed") %></span>
      <% end %>
    </div>

    <%# Title %>
    <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-gray-900 mb-6 leading-[1.15]"><%= @job_post.display_title %></h1>

    <%# Meta row %>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-200/40">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        <span class="font-bold text-gray-700"><%= @job_post.company_name %></span>
      </div>
      <% if @job_post.location.present? %>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span><%= @job_post.location %></span>
        </div>
      <% end %>
      <% if @job_post.deadline.present? %>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><%= t("jobs.deadline") %>: <%= @job_post.deadline.strftime("%d %b %Y") %></span>
        </div>
      <% end %>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span><%= @job_post.published_at&.strftime("%d %b %Y") %></span>
      </div>
    </div>

    <%# Cover image %>
    <% if @job_post.cover_image.attached? %>
      <div class="mb-10 rounded-3xl overflow-hidden border border-gray-200/40 shadow-xl group">
        <%= optimized_image_tag @job_post.cover_image, variant: :hero, class: "img-zoom w-full object-cover", loading: "lazy" %>
      </div>
    <% end %>

    <%# Apply button %>
    <% if @job_post.application_url.present? && !@job_post.deadline_passed? %>
      <div class="text-center mb-10">
        <%= link_to sanitize_url(@job_post.application_url), target: "_blank", rel: "noopener noreferrer",
            class: "btn-primary !inline-flex !items-center !gap-3 !px-10 !py-4 !text-lg !rounded-2xl !shadow-xl" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          <%= t("jobs.apply_now") %>
        <% end %>
      </div>
    <% elsif @job_post.deadline_passed? %>
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2.5 rounded-2xl surface-raised border border-gray-200/40 px-8 py-4 text-gray-500 font-semibold shadow-inner">
          <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= t("jobs.deadline_passed") %>
        </div>
      </div>
    <% end %>

    <%# Description %>
    <div class="rounded-3xl border border-gray-200/40 bg-white/80 p-6 sm:p-8 shadow-inner">
      <div class="prose prose-sm max-w-none text-gray-700 prose-headings:tracking-tight break-words">
        <%= simple_format(@job_post.display_description) %>
      </div>
    </div>
  </div>
</div>
