<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("brand.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : t('brand.tagline') %>">
    <meta name="theme-color" content="#ea580c">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="<%= t('brand.name') %>">
    <meta name="application-name" content="<%= t('brand.name') %>">
    <meta name="mobile-web-app-capable" content="yes">

    <%# Open Graph / WhatsApp / Social sharing %>
    <meta property="og:site_name" content="<%= t('brand.name') %>">
    <meta property="og:locale" content="<%= I18n.locale == :hi ? 'hi_IN' : 'en_IN' %>">
    <meta property="og:type" content="<%= content_for?(:og_type) ? yield(:og_type) : 'website' %>">
    <meta property="og:title" content="<%= content_for?(:og_title) ? yield(:og_title) : (content_for?(:title) ? yield(:title) : t('brand.name')) %>">
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : t('brand.tagline') %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "#{request.base_url}/icon-login.png" %>">
    <meta property="og:image:width" content="<%= content_for?(:og_image) ? "1200" : "500" %>">
    <meta property="og:image:height" content="<%= content_for?(:og_image) ? "630" : "500" %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:og_title) ? yield(:og_title) : (content_for?(:title) ? yield(:title) : t('brand.name')) %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? yield(:description) : t('brand.tagline') %>">
    <meta name="twitter:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "#{request.base_url}/icon-login.png" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Leaflet — loaded in head so it's always available for the visitor map %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <%= yield :head %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Devanagari:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Devanagari:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"></noscript>
    <style>
      body { font-family: 'Inter', 'Noto Sans Devanagari', system-ui, sans-serif; }
      @keyframes live-glow {
        0%, 100% { box-shadow: 0 0 0 3px rgba(255,80,80,0.35), 0 6px 28px rgba(220,38,38,0.8); }
        50%       { box-shadow: 0 0 0 6px rgba(255,80,80,0.15), 0 8px 36px rgba(220,38,38,0.5); }
      }
      .live-badge-wrap > div { animation: live-glow 0.9s ease-in-out infinite; }
    </style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script>
      window.__pwaPrompt = null;
      window.addEventListener('beforeinstallprompt', function(e) {
        e.preventDefault();
        window.__pwaPrompt = e;
      });
    </script>
    <%= javascript_importmap_tags %>

    <% if Rails.env.production? && (ga_id = ENV["GA_MEASUREMENT_ID"]).present? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ga_id %>"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());

        // ── User properties ────────────────────────────────────────
        var _isPWA = window.matchMedia('(display-mode: standalone)').matches || navigator.standalone === true;
        var _pushOn = localStorage.getItem('fcm_subscribed') === 'true';
        var _os = /Android/i.test(navigator.userAgent) ? 'android' : /iPhone|iPad|iPod/i.test(navigator.userAgent) ? 'ios' : 'desktop';
        var _visits = parseInt(localStorage.getItem('sd_visit_count') || '0') + 1;
        localStorage.setItem('sd_visit_count', _visits);
        var _freq = _visits <= 1 ? 'new' : _visits <= 5 ? 'returning' : 'regular';

        gtag('config', '<%= ga_id %>', {
          send_page_view: false,
          user_properties: {
            user_type:          '<%= logged_in? ? "logged_in" : "anonymous" %>',
            preferred_language: '<%= I18n.locale %>',
            pwa_user:           _isPWA ? 'yes' : 'no',
            push_enabled:       _pushOn ? 'yes' : 'no',
            device_os:          _os,
            visit_frequency:    _freq
          }
        });

        // ── Page views (Turbo-aware) ──────────────────────────────────
        document.addEventListener('turbo:load', function() {
          gtag('event', 'page_view', {
            page_path:     window.location.pathname + window.location.search,
            page_title:    document.title,
            page_location: window.location.href
          });
        });

        // ── Article read (75% scroll depth) ───────────────────────────
        (function() {
          var fired = {};
          document.addEventListener('turbo:load', function() {
            var key = location.pathname;
            if (fired[key]) return;
            // Only track on article pages
            if (!/^\/(news|education|jobs)\/\d+/.test(key)) return;
            function onScroll() {
              var h = document.documentElement.scrollHeight - window.innerHeight;
              if (h > 0 && (window.scrollY / h) >= 0.75) {
                fired[key] = true;
                gtag('event', 'article_read', {
                  event_category: 'Engagement',
                  page_path: key,
                  page_title: document.title
                });
                window.removeEventListener('scroll', onScroll);
              }
            }
            window.addEventListener('scroll', onScroll, { passive: true });
            document.addEventListener('turbo:before-visit', function() {
              window.removeEventListener('scroll', onScroll);
            }, { once: true });
          });
        })();

        // ── Share click tracking ──────────────────────────────────────
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a[href*="wa.me"], a[href*="whatsapp"], [data-controller="copy-link"]');
          if (!link) return;
          var method = link.href && link.href.indexOf('wa.me') > -1 ? 'whatsapp' : 'copy_link';
          gtag('event', 'share_click', {
            event_category: 'Engagement',
            method: method,
            page_path: location.pathname
          });
        });

        // ── Language switch tracking ──────────────────────────────────
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a[href*="locale"]');
          if (!link) return;
          gtag('event', 'language_switch', {
            event_category: 'Engagement',
            from_language: '<%= I18n.locale %>',
            to_language: '<%= I18n.locale == :hi ? "en" : "hi" %>'
          });
        });

        // ── Push notification subscribe/dismiss ──────────────────────
        document.addEventListener('push:subscribed', function() {
          gtag('event', 'notification_subscribe', {
            event_category: 'Growth',
            page_path: location.pathname
          });
        });

        // ── Outbound link clicks ─────────────────────────────────────
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a[href^="http"]');
          if (!link) return;
          if (link.hostname === location.hostname) return;
          gtag('event', 'outbound_click', {
            event_category: 'Engagement',
            url: link.href,
            page_path: location.pathname
          });
        });

        // ── PWA install tracking ─────────────────────────────────────
        window.addEventListener('appinstalled', function() {
          gtag('event', 'pwa_installed', {
            event_category: 'PWA',
            event_label: _os
          });
        });

        if (_isPWA) {
          gtag('event', 'pwa_session', {
            event_category: 'PWA',
            event_label: _os
          });
        }
      </script>
    <% end %>
  </head>

  <body class="min-h-screen bg-white" data-managed-prompts
        data-controller="prompt-queue"
        data-prompt-queue-logged-in-value="<%= logged_in? %>"
        data-prompt-queue-pwa-installed-value="false"
        data-prompt-queue-push-subscribed-value="false">
    <%# Navigation %>
    <nav class="glass border-b border-white/10 sticky top-0 z-50" data-controller="mobile-nav">
      <div class="max-w-6xl lg:max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-10">
        <div class="flex items-center justify-between h-14">
          <div class="shrink-0 flex items-center gap-1.5">
            <%= link_to root_path, class: "flex items-center gap-2" do %>
              <span class="text-lg sm:text-xl font-black tracking-tight text-gradient leading-none"><%= t("brand.short_name") %></span>
            <% end %>
            <div class="relative" data-controller="region-picker">
              <button data-action="region-picker#toggle" class="inline-flex items-center gap-0.5 text-[10px] sm:text-[11px] text-white/70 hover:text-white font-semibold transition-colors cursor-pointer">
                <svg class="w-2.5 h-2.5 sm:w-3 sm:h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <%= visitor_location_name.presence || t("nav.select_region") %>
                <svg class="w-2.5 h-2.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div data-region-picker-target="dropdown" class="hidden absolute top-full left-0 mt-1.5 w-44 bg-gray-900 border border-white/10 rounded-xl shadow-xl z-50 py-1 overflow-hidden">
                <% Region.active.ordered.each do |r| %>
                  <%= link_to set_region_path(slug: r.slug), data: { turbo: false }, class: "block px-3 py-2 text-[11px] sm:text-xs font-medium #{cookies[:region] == r.slug ? 'text-orange-400 bg-white/10' : 'text-white/70 hover:text-white hover:bg-white/10'} transition-colors" do %>
                    <%= I18n.locale == :hi ? (r.name_hi.presence || r.name_en) : r.name_en %>
                    <% if cookies[:region] == r.slug %>
                      <span class="text-orange-400 ml-1">✓</span>
                    <% end %>
                  <% end %>
                <% end %>
                <div class="border-t border-white/10 mt-1 pt-1">
                  <%= link_to set_region_path(slug: "auto"), data: { turbo: false }, class: "block px-3 py-2 text-[11px] sm:text-xs font-medium #{cookies[:region].blank? ? 'text-orange-400 bg-white/10' : 'text-white/50 hover:text-white hover:bg-white/10'} transition-colors" do %>
                    🔄 <%= I18n.locale == :hi ? "स्वतः पहचान" : "Auto-detect" %>
                    <% if cookies[:region].blank? %>
                      <span class="text-orange-400 ml-1">✓</span>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <%# Desktop nav %>
          <div class="hidden sm:flex items-center gap-1">

            <%# ── Nav links ── %>
            <%= link_to t("nav.webinars"), webinars_path, class: "inline-flex items-center text-[13px] font-semibold #{controller_name == 'webinars' ? 'text-orange-600 bg-orange-50/80' : 'text-white/60 hover:text-white hover:bg-white/10'} rounded-lg px-3 py-2 transition-all" %>
            <%= link_to t("nav.marriage"), biodatas_path, class: "inline-flex items-center text-[13px] font-semibold #{controller_name == 'biodatas' ? 'text-orange-600 bg-orange-50/80' : 'text-white/60 hover:text-white hover:bg-white/10'} rounded-lg px-3 py-2 transition-all" %>
            <%= link_to t("nav.education"), education_index_path, class: "inline-flex items-center text-[13px] font-semibold #{controller_name == 'education' ? 'text-orange-600 bg-orange-50/80' : 'text-white/60 hover:text-white hover:bg-white/10'} rounded-lg px-3 py-2 transition-all" %>
            <%= link_to t("nav.jobs"), jobs_path, class: "inline-flex items-center text-[13px] font-semibold #{controller_name == 'jobs' ? 'text-orange-600 bg-orange-50/80' : 'text-white/60 hover:text-white hover:bg-white/10'} rounded-lg px-3 py-2 transition-all" %>

            <div class="w-px h-5 bg-white/20 mx-1.5"></div>

            <%# ── Language + Push Bell + Shortlist ── %>
            <%= link_to t("nav.language_switch"), switch_locale_path, "data-turbo": "false", class: "text-[13px] font-semibold text-white/60 hover:text-white hover:bg-white/10 rounded-lg px-3 py-2 transition-all" %>
            <% if firebase_configured? %>
              <button id="nav-push-bell"
                      data-controller="push-notification"
                      data-push-notification-vapid-key-value="<%= firebase_vapid_key %>"
                      data-push-notification-config-value="<%= firebase_js_config_json %>"
                      data-push-notification-save-url-value="<%= push_subscription_path %>"
                      data-action="click->push-notification#subscribe"
                      class="hidden relative inline-flex items-center justify-center w-8 h-8 rounded-lg text-white/50 hover:text-orange-400 hover:bg-white/10 transition-all"
                      title="<%= I18n.locale == :hi ? 'सूचनाएं चालू करें' : 'Enable notifications' %>">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                <span class="absolute -top-0.5 -right-0.5 flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
                </span>
              </button>
            <% end %>
            <% if logged_in? %>
              <%= link_to shortlists_path, title: t("shortlists.title"),
                    class: "inline-flex items-center justify-center w-8 h-8 rounded-lg #{controller_name == 'shortlists' ? 'text-orange-500 bg-orange-50' : 'text-white/50 hover:text-orange-400 hover:bg-white/10'} transition-all" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              <% end %>
            <% end %>

            <div class="w-px h-5 bg-white/20 mx-1.5"></div>

            <%# ── User / Auth ── %>
            <% if logged_in? %>
              <% if current_user.admin_panel_access? %>
                <%= link_to admin_root_path, class: "btn-primary !py-1.5 !px-3 !text-[13px] !rounded-lg !gap-1.5 mr-1" do %>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  Dashboard
                <% end %>
              <% end %>
              <div class="flex items-center gap-1.5 pl-1">
                <div class="w-7 h-7 rounded-full gradient-brand flex items-center justify-center ring-2 ring-white shadow-sm shrink-0">
                  <span class="text-white font-bold text-[10px]"><%= current_user.name[0] %></span>
                </div>
                <span class="text-[13px] text-white font-semibold"><%= current_user.name %></span>
                <span class="text-white/30">·</span>
                <%= link_to t("nav.edit_profile"), edit_profile_path, class: "text-[12px] text-white/50 hover:text-orange-400 transition-colors" %>
                <span class="text-white/30">·</span>
                <%= link_to t("nav.logout"), logout_path, data: { turbo_method: :delete }, class: "text-[12px] text-white/50 hover:text-red-400 transition-colors" %>
              </div>
            <% else %>
              <%= link_to t("nav.sign_in"), login_path, class: "btn-primary !py-1.5 !px-4 !text-[13px] !rounded-lg" %>
            <% end %>

            <div class="w-px h-5 bg-white/20 mx-1.5 lg:hidden"></div>

            <%# ── Download App (far right, mobile/tablet only) ── %>
            <button data-pwa-install-btn onclick="pwaInstallFromNav()"
                    class="pwa-nav-btn lg:hidden inline-flex items-center gap-1.5 text-[13px] font-bold text-white gradient-brand rounded-lg px-3 py-1.5 shadow-sm cursor-pointer hover:shadow-md transition-shadow">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              <%= t("pwa.download_app") %>
            </button>
          </div>

          <%# Mobile: Download App + hamburger %>
          <div class="sm:hidden flex items-center gap-1.5">
            <button data-pwa-install-btn onclick="pwaInstallFromNav()"
                    class="pwa-nav-btn inline-flex items-center gap-1 text-[10px] font-bold text-white gradient-brand rounded-lg px-2 py-1 shadow-sm cursor-pointer">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              <%= t("pwa.download_app") %>
            </button>
            <%= link_to switch_locale_path, "data-turbo": "false", class: "text-[10px] font-bold text-white/60 hover:text-white border border-white/20 rounded-md px-1.5 py-0.5 transition-colors" do %>
              <%= I18n.locale == :hi ? "ENG" : "हिंदी" %>
            <% end %>
            <% if firebase_configured? %>
              <button id="nav-push-bell-mobile"
                      data-controller="push-notification"
                      data-push-notification-vapid-key-value="<%= firebase_vapid_key %>"
                      data-push-notification-config-value="<%= firebase_js_config_json %>"
                      data-push-notification-save-url-value="<%= push_subscription_path %>"
                      data-action="click->push-notification#subscribe"
                      class="hidden relative p-1.5 text-white/60 hover:text-orange-400 transition-colors"
                      title="<%= I18n.locale == :hi ? 'सूचनाएं चालू करें' : 'Enable notifications' %>">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                <span class="absolute top-0.5 right-0.5 flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-orange-500"></span>
                </span>
              </button>
            <% end %>
            <button class="p-2 -mr-1.5 text-white/60 hover:text-white hover:bg-white/10 rounded-lg transition-colors" data-action="mobile-nav#toggle" aria-label="Menu">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
          </div>
        </div>
      </div>

      <%# Mobile dropdown %>
      <div class="hidden sm:hidden border-t border-gray-100 bg-white px-4 py-3 shadow-xl shadow-black/5 animate-fade-in" data-mobile-nav-target="menu">
        <%# 2-column grid for nav links %>
        <div class="grid grid-cols-2 gap-1 mb-2">
          <%= link_to webinars_path, class: "flex items-center gap-2 px-3 py-2 text-sm font-medium #{controller_name == 'webinars' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <%= t("nav.webinars") %>
          <% end %>
          <%= link_to biodatas_path, class: "flex items-center gap-2 px-3 py-2 text-sm font-medium #{controller_name == 'biodatas' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <%= t("nav.marriage") %>
          <% end %>
          <%= link_to education_index_path, class: "flex items-center gap-2 px-3 py-2 text-sm font-medium #{controller_name == 'education' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
            <%= t("nav.education") %>
          <% end %>
          <%= link_to jobs_path, class: "flex items-center gap-2 px-3 py-2 text-sm font-medium #{controller_name == 'jobs' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <%= t("nav.jobs") %>
          <% end %>
        </div>
        <% if logged_in? %>
          <div class="section-divider my-1.5"></div>
          <%= link_to shortlists_path, class: "flex items-center gap-2 px-3 py-2 text-sm font-medium #{controller_name == 'shortlists' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <%= t("shortlists.title") %>
          <% end %>
          <div class="section-divider my-1.5"></div>
          <div class="flex items-center gap-3 px-3 py-2">
            <div class="w-8 h-8 rounded-full gradient-brand flex items-center justify-center ring-2 ring-white shadow-sm shrink-0">
              <span class="text-white font-bold text-sm"><%= current_user.name[0] %></span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= current_user.name %></p>
            </div>
            <%= link_to t("nav.edit_profile"), edit_profile_path, class: "text-xs font-semibold text-orange-500 hover:text-orange-700 shrink-0" %>
            <% if current_user.admin_panel_access? %>
              <%= link_to "Dashboard", admin_root_path, class: "text-xs font-semibold text-orange-500 hover:text-orange-700 shrink-0" %>
            <% end %>
            <%= link_to t("nav.logout"), logout_path, data: { turbo_method: :delete }, class: "text-xs text-red-500 hover:text-red-700 font-medium shrink-0" %>
          </div>
        <% else %>
          <div class="section-divider my-1.5"></div>
          <div class="flex gap-2">
            <%= link_to t("nav.sign_in"), login_path, class: "flex-1 flex items-center justify-center px-3 py-2 text-sm font-semibold text-white gradient-brand rounded-xl shadow-sm" %>
          </div>
        <% end %>
      </div>
    </nav>

    <%# Flash messages %>
    <% if flash[:notice] %>
      <div class="max-w-6xl lg:max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-10 mt-4 animate-fade-in" data-controller="flash">
        <div class="rounded-xl bg-emerald-50 border border-emerald-200/60 text-emerald-800 px-5 py-3.5 text-sm flex items-center justify-between surface-raised">
          <div class="flex items-center gap-3">
            <div class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-medium"><%= flash[:notice] %></span>
          </div>
          <button data-action="flash#dismiss" class="text-emerald-400 hover:text-emerald-600 ml-3 cursor-pointer p-1">&times;</button>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-6xl lg:max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-10 mt-4 animate-fade-in" data-controller="flash">
        <div class="rounded-xl bg-red-50 border border-red-200/60 text-red-800 px-5 py-3.5 text-sm flex items-center justify-between surface-raised">
          <div class="flex items-center gap-3">
            <div class="w-7 h-7 rounded-full bg-red-100 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            </div>
            <span class="font-medium"><%= flash[:alert] %></span>
          </div>
          <button data-action="flash#dismiss" class="text-red-400 hover:text-red-600 ml-3 cursor-pointer p-1">&times;</button>
        </div>
      </div>
    <% end %>

    <%= render "shared/billboard_banner" %>

    <main class="max-w-6xl lg:max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-10 py-4 sm:py-8 lg:py-10 pb-20 sm:pb-8 lg:pb-10">
      <%= yield %>
    </main>

    <%# Mobile bottom navigation — app-wide %>
    <%= render "shared/mobile_bottom_bar",
          toggle_path: content_for?(:mobile_bar_toggle_path) ? yield(:mobile_bar_toggle_path) : nil,
          liked:       content_for?(:mobile_bar_liked) ? yield(:mobile_bar_liked) == "true" : false,
          likes_count: content_for?(:mobile_bar_likes_count) ? yield(:mobile_bar_likes_count).to_i : nil,
          share_text:  content_for?(:mobile_bar_share_text) ? yield(:mobile_bar_share_text) : nil %>

    <%# Footer %>
    <footer class="bg-gray-950 mt-8 sm:mt-12 no-print">
      <div class="max-w-6xl lg:max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-10 pt-10 pb-8">

        <%# Links — 2-col grid on mobile, 5-col on desktop %>
        <div class="mb-8">
          <p class="text-[10px] font-black text-gray-600 uppercase tracking-widest mb-3">Links</p>
          <div class="grid grid-cols-2 sm:grid-cols-5 gap-x-4 gap-y-3">
            <%= link_to t("nav.home"),      root_path,            class: "text-sm text-gray-400 hover:text-orange-400 transition-colors" %>
            <%= link_to t("nav.webinars"),  webinars_path,        class: "text-sm text-gray-400 hover:text-orange-400 transition-colors" %>
            <%= link_to t("nav.marriage"),  biodatas_path,        class: "text-sm text-gray-400 hover:text-orange-400 transition-colors" %>
            <%= link_to t("nav.education"), education_index_path, class: "text-sm text-gray-400 hover:text-orange-400 transition-colors" %>
            <%= link_to t("nav.jobs"),      jobs_path,            class: "text-sm text-gray-400 hover:text-orange-400 transition-colors" %>
          </div>
        </div>

        <%# Account — profile chip with inline actions %>
        <div class="mb-8">
          <p class="text-[10px] font-black text-gray-600 uppercase tracking-widest mb-3">Account</p>
          <% if logged_in? %>
            <div class="flex items-center gap-3 bg-white/5 rounded-2xl px-4 py-3">
              <div class="w-9 h-9 rounded-full gradient-brand flex items-center justify-center shrink-0">
                <span class="text-white font-bold text-sm"><%= current_user.name[0] %></span>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-white truncate"><%= current_user.name %></p>
                <p class="text-xs text-gray-500"><%= current_user.role.humanize %></p>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                <% if current_user.admin_panel_access? %>
                  <%= link_to "Dashboard", admin_root_path, class: "text-xs font-semibold text-orange-400 hover:text-orange-300 transition-colors" %>
                <% end %>
                <%= link_to t("nav.logout"), logout_path, data: { turbo_method: :delete }, class: "text-xs font-semibold text-red-500 hover:text-red-400 transition-colors" %>
              </div>
            </div>
          <% else %>
            <%= link_to t("nav.sign_in"), login_path, class: "text-sm font-semibold text-orange-400 hover:text-orange-300 transition-colors" %>
          <% end %>
        </div>

        <div class="border-t border-white/8"></div>

        <%# Bottom bar %>
        <div class="flex flex-col sm:flex-row items-center justify-between gap-2 pt-6">
          <p class="text-xs text-gray-600">&copy; <%= Date.current.year %> <%= t("brand.name") %>. All rights reserved.</p>
          <p class="text-xs text-gray-700">Powered by Ambe Software</p>
        </div>

      </div>
    </footer>

    <% unless logged_in? %>
      <%= render "shared/login_prompt_bar" %>
      <% if @login_gate %>
        <%= render "shared/login_gate" %>
      <% end %>
    <% end %>
    <%= render "shared/pwa_install_banner" %>
    <%= render "shared/push_notification_banner" if firebase_configured? %>
    <% if @consent_pending_biodata %>
      <%= render "shared/consent_popup" %>
    <% end %>
    <% if controller_name == "news" && action_name == "index" && params[:page].blank? && params[:slug].blank? %>
      <%= render "shared/billboard_splash" %>
    <% end %>
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          <% if firebase_configured? %>
          var currentVapidKey = '<%= firebase_vapid_key %>';
          var storedVapidKey  = localStorage.getItem('fcm_vapid_key');

          if (storedVapidKey && storedVapidKey !== currentVapidKey) {
            // VAPID key changed — unregister old SW and clear cached token so
            // the Stimulus controller fetches a fresh FCM token on next load.
            navigator.serviceWorker.getRegistrations().then(function(regs) {
              regs.forEach(function(r) { r.unregister(); });
              localStorage.removeItem('fcm_token');
              // Re-register SW and reload once so the new key takes effect
              navigator.serviceWorker.register('/firebase-messaging-sw.js', { scope: '/' }).then(function() {
                localStorage.setItem('fcm_vapid_key', currentVapidKey);
                window.location.reload();
              });
            });
            return;
          }
          localStorage.setItem('fcm_vapid_key', currentVapidKey);
          <% end %>

          // Single merged SW handles both PWA caching and FCM push notifications
          navigator.serviceWorker.register('/firebase-messaging-sw.js', { scope: '/' }).then(function(reg) {
            console.log('Service worker registered with scope:', reg.scope);
          }).catch(function(err) {
            console.warn('Service worker registration failed:', err);
          });
        });
      }

      function pwaInstallFromNav() {
        if (window.__pwaPrompt) {
          window.__pwaPrompt.prompt();
          window.__pwaPrompt.userChoice.then(function(choice) {
            if (choice.outcome === 'accepted') window.__pwaPrompt = null;
          });
        } else if (window.__pwaController) {
          window.__pwaController.install();
        }
      }

      if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone) {
        document.querySelectorAll('[data-pwa-install-btn]').forEach(function(btn) { btn.style.display = 'none'; });
      }

      // Page duration tracking
      (function() {
        var startTime = Date.now();
        var pagePath = window.location.pathname;
        var sent = false;
        function sendDuration() {
          if (sent) return;
          var seconds = Math.round((Date.now() - startTime) / 1000);
          if (seconds < 2) return;
          sent = true;
          var csrf = document.querySelector('meta[name="csrf-token"]');
          var data = new URLSearchParams({
            duration: seconds, path: pagePath, authenticity_token: csrf ? csrf.content : ''
          });
          try { navigator.sendBeacon('/visit_ping', data); } catch(e) {}
        }
        document.addEventListener('visibilitychange', function() {
          if (document.visibilityState === 'hidden') sendDuration();
        });
        document.addEventListener('turbo:before-visit', sendDuration);
        window.addEventListener('pagehide', sendDuration);
        window.addEventListener('beforeunload', sendDuration);
      })();
    </script>
  </body>
</html>
