<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("brand.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : t('brand.tagline') %>">
    <meta name="theme-color" content="#ea580c">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="<%= t('brand.name') %>">
    <meta name="application-name" content="<%= t('brand.name') %>">
    <meta name="mobile-web-app-capable" content="yes">

    <%# Open Graph / WhatsApp / Social sharing %>
    <meta property="og:site_name" content="<%= t('brand.name') %>">
    <meta property="og:locale" content="<%= I18n.locale == :hi ? 'hi_IN' : 'en_IN' %>">
    <meta property="og:type" content="<%= content_for?(:og_type) ? yield(:og_type) : 'website' %>">
    <meta property="og:title" content="<%= content_for?(:og_title) ? yield(:og_title) : (content_for?(:title) ? yield(:title) : t('brand.name')) %>">
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : t('brand.tagline') %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "#{request.base_url}/og-default.png" %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:og_title) ? yield(:og_title) : (content_for?(:title) ? yield(:title) : t('brand.name')) %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? yield(:description) : t('brand.tagline') %>">
    <meta name="twitter:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "#{request.base_url}/og-default.png" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Devanagari:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Devanagari:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"></noscript>
    <style>body { font-family: 'Inter', 'Noto Sans Devanagari', system-ui, sans-serif; }</style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script>
      window.__pwaPrompt = null;
      window.addEventListener('beforeinstallprompt', function(e) {
        e.preventDefault();
        window.__pwaPrompt = e;
      });
    </script>
    <%= javascript_importmap_tags %>

    <% if Rails.env.production? && (ga_id = ENV["GA_MEASUREMENT_ID"]).present? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ga_id %>"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '<%= ga_id %>');
      </script>
    <% end %>
  </head>

  <body class="min-h-screen bg-[#f8f7f4]">
    <%# Navigation %>
    <nav class="glass border-b border-gray-200/40 sticky top-0 z-50" data-controller="mobile-nav">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-[3.75rem]">
          <%= link_to root_path, class: "shrink-0 flex items-center gap-2" do %>
            <span class="text-base sm:text-lg font-black tracking-tight text-gradient leading-none"><%= t("brand.short_name") %></span>
          <% end %>

          <%# Desktop nav %>
          <div class="hidden sm:flex items-center gap-1">
            <%#= link_to t("nav.magazine"), magazines_path, class: "inline-flex items-center gap-1.5 text-[13px] font-semibold #{controller_name == 'magazines' ? 'text-orange-600 bg-orange-50/80' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100/60'} rounded-lg px-3 py-2 transition-all" %>
            <%= link_to t("nav.webinars"), webinars_path, class: "inline-flex items-center gap-1.5 text-[13px] font-semibold #{controller_name == 'webinars' ? 'text-orange-600 bg-orange-50/80' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100/60'} rounded-lg px-3 py-2 transition-all" %>
            <%= link_to t("nav.marriage"), biodatas_path, class: "inline-flex items-center gap-1.5 text-[13px] font-semibold #{controller_name == 'biodatas' ? 'text-orange-600 bg-orange-50/80' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100/60'} rounded-lg px-3 py-2 transition-all" %>
            <%= link_to t("nav.education"), education_index_path, class: "inline-flex items-center gap-1.5 text-[13px] font-semibold #{controller_name == 'education' ? 'text-orange-600 bg-orange-50/80' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100/60'} rounded-lg px-3 py-2 transition-all" %>
            <%= link_to t("nav.jobs"), jobs_path, class: "inline-flex items-center gap-1.5 text-[13px] font-semibold #{controller_name == 'jobs' ? 'text-orange-600 bg-orange-50/80' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100/60'} rounded-lg px-3 py-2 transition-all" %>
            <button data-pwa-install-btn onclick="pwaInstallFromNav()"
                    class="pwa-nav-btn inline-flex items-center gap-1.5 text-[13px] font-bold text-white gradient-brand rounded-lg px-3 py-1.5 shadow-sm cursor-pointer hover:shadow-md transition-shadow">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              <%= t("pwa.download_app") %>
            </button>
            <%= link_to t("nav.language_switch"), switch_locale_path, class: "text-[13px] font-semibold text-gray-500 hover:text-gray-900 hover:bg-gray-100/60 rounded-lg px-3 py-2 transition-all" %>

            <div class="w-px h-5 bg-gray-200/60 mx-1.5"></div>

            <% if logged_in? %>
              <% if current_user.admin_panel_access? %>
                <% if current_user.can_create_news? %>
                  <%= link_to new_admin_news_path, class: "inline-flex items-center gap-1.5 text-[13px] font-bold text-orange-600 hover:text-orange-700 bg-orange-50 hover:bg-orange-100 rounded-lg px-3 py-2 transition-all" do %>
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg>
                    <%= t("nav.new_article") %>
                  <% end %>
                <% end %>
                <%= link_to admin_root_path, class: "btn-primary !py-1.5 !px-3.5 !text-[13px] !rounded-lg !gap-1.5" do %>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  Dashboard
                <% end %>
              <% end %>

              <div class="w-px h-5 bg-gray-200/60 mx-1"></div>

              <div class="flex items-center gap-2 px-2">
                <div class="w-7 h-7 rounded-full gradient-brand flex items-center justify-center ring-2 ring-white shadow-sm">
                  <span class="text-white font-bold text-[10px]"><%= current_user.name[0] %></span>
                </div>
                <span class="text-[13px] text-gray-700 font-medium"><%= current_user.name %></span>
              </div>
              <%= link_to t("nav.logout"), logout_path, class: "text-[13px] text-gray-400 hover:text-red-500 transition-colors" %>
            <% else %>
              <%= link_to t("nav.sign_in"), login_path, class: "btn-primary !py-1.5 !px-4 !text-[13px] !rounded-lg" %>
              <%= link_to t("nav.sign_up"), signup_path, class: "text-[13px] font-semibold text-gray-500 hover:text-orange-600 transition-colors ml-1" %>
            <% end %>
          </div>

          <%# Mobile: Download App + hamburger %>
          <div class="sm:hidden flex items-center gap-1.5">
            <button data-pwa-install-btn onclick="pwaInstallFromNav()"
                    class="pwa-nav-btn inline-flex items-center gap-1.5 text-[11px] font-bold text-white gradient-brand rounded-lg px-2.5 py-1.5 shadow-sm cursor-pointer">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              <%= t("pwa.download_app") %>
            </button>
            <button class="p-2.5 -mr-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-xl transition-colors" data-action="mobile-nav#toggle" aria-label="Menu">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
          </div>
        </div>
      </div>

      <%# Mobile dropdown %>
      <div class="hidden sm:hidden border-t border-gray-100 bg-white px-4 py-4 space-y-1 shadow-xl shadow-black/5 animate-fade-in" data-mobile-nav-target="menu">
        <%# link_to magazines_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium #{controller_name == 'magazines' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
          <%# <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg> %>
          <%# t("nav.magazine") %>
        <%# end %>
        <%= link_to webinars_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium #{controller_name == 'webinars' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <%= t("nav.webinars") %>
        <% end %>
        <%= link_to biodatas_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium #{controller_name == 'biodatas' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <%= t("nav.marriage") %>
        <% end %>
        <%= link_to education_index_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium #{controller_name == 'education' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
          <%= t("nav.education") %>
        <% end %>
        <%= link_to jobs_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium #{controller_name == 'jobs' ? 'text-orange-600 bg-orange-50' : 'text-gray-600 hover:bg-gray-50'} rounded-xl" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <%= t("nav.jobs") %>
        <% end %>
        <%= link_to t("nav.language_switch"), switch_locale_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-gray-600 rounded-xl hover:bg-gray-50" %>
        <% if logged_in? %>
          <% if current_user.admin_panel_access? %>
            <div class="section-divider my-2"></div>
            <p class="px-3 pt-1 pb-1 text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= t("nav.admin") %></p>
            <% if current_user.can_create_news? %>
              <%= link_to new_admin_news_path, class: "flex items-center gap-3 px-3 py-2 text-sm font-semibold text-orange-600 rounded-xl hover:bg-orange-50" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg>
                <%= t("nav.new_article") %>
              <% end %>
            <% end %>
            <%= link_to admin_root_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-semibold text-white gradient-brand rounded-xl mt-1 shadow-sm" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4"/></svg>
              Dashboard
            <% end %>
          <% end %>
          <div class="section-divider my-2"></div>
          <div class="flex items-center gap-3 px-3 py-2.5">
            <div class="w-9 h-9 rounded-full gradient-brand flex items-center justify-center ring-2 ring-white shadow-sm">
              <span class="text-white font-bold text-sm"><%= current_user.name[0] %></span>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= current_user.name %></p>
              <p class="text-xs text-gray-400"><%= current_user.role.humanize %></p>
            </div>
          </div>
          <%= link_to t("nav.logout"), logout_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm text-red-600 rounded-xl hover:bg-red-50" %>
        <% else %>
          <div class="section-divider my-2"></div>
          <%= link_to t("nav.sign_in"), login_path, class: "flex items-center justify-center gap-2 px-3 py-2.5 text-sm font-semibold text-white gradient-brand rounded-xl shadow-sm" %>
          <%= link_to t("nav.sign_up", default: "Sign up"), signup_path, class: "flex items-center justify-center gap-2 px-3 py-2.5 text-sm font-medium text-gray-600 border border-gray-200 rounded-xl hover:bg-gray-50 mt-1" %>
        <% end %>
      </div>
    </nav>

    <%# Flash messages %>
    <% if flash[:notice] %>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-4 animate-fade-in" data-controller="flash">
        <div class="rounded-xl bg-emerald-50 border border-emerald-200/60 text-emerald-800 px-5 py-3.5 text-sm flex items-center justify-between surface-raised">
          <div class="flex items-center gap-3">
            <div class="w-7 h-7 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="font-medium"><%= flash[:notice] %></span>
          </div>
          <button data-action="flash#dismiss" class="text-emerald-400 hover:text-emerald-600 ml-3 cursor-pointer p-1">&times;</button>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-4 animate-fade-in" data-controller="flash">
        <div class="rounded-xl bg-red-50 border border-red-200/60 text-red-800 px-5 py-3.5 text-sm flex items-center justify-between surface-raised">
          <div class="flex items-center gap-3">
            <div class="w-7 h-7 rounded-full bg-red-100 flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            </div>
            <span class="font-medium"><%= flash[:alert] %></span>
          </div>
          <button data-action="flash#dismiss" class="text-red-400 hover:text-red-600 ml-3 cursor-pointer p-1">&times;</button>
        </div>
      </div>
    <% end %>

    <%= render "shared/billboard_banner" %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="bg-white border-t border-gray-200/40 mt-16 no-print">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12">
          <div>
            <div class="flex items-center gap-3 mb-3">
              <img src="/icon-navbar.png" alt="<%= t('brand.name') %>" class="h-7 w-auto rounded-md">
            </div>
            <p class="text-sm text-gray-400 leading-relaxed"><%= t("brand.tagline") %></p>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Links</p>
            <ul class="space-y-2">
              <li><%= link_to t("nav.home"), root_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li>
              <% if false %><li><%= link_to t("nav.magazine"), magazines_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li><% end %>
              <li><%= link_to t("nav.webinars"), webinars_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li>
              <li><%= link_to t("nav.marriage"), biodatas_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li>
              <li><%= link_to t("nav.education"), education_index_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li>
              <li><%= link_to t("nav.jobs"), jobs_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li>
            </ul>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Account</p>
            <ul class="space-y-2">
              <% if logged_in? %>
                <li><%= link_to "Dashboard", admin_root_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" if current_user.admin_panel_access? %></li>
                <li><%= link_to t("nav.logout"), logout_path, class: "text-sm text-gray-500 hover:text-red-500 transition-colors" %></li>
              <% else %>
                <li><%= link_to t("nav.sign_in"), login_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li>
                <li><%= link_to t("nav.sign_up"), signup_path, class: "text-sm text-gray-500 hover:text-orange-600 transition-colors" %></li>
              <% end %>
            </ul>
          </div>
        </div>
        <div class="section-divider mt-8 mb-6"></div>
        <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
          <p class="text-xs text-gray-400">&copy; <%= Date.current.year %> <%= t("brand.name") %></p>
          <p class="text-xs text-gray-300">Powered by Ambe Software</p>
        </div>
      </div>
    </footer>

    <%= render "shared/pwa_install_banner" %>
    <% if controller_name == "news" && action_name == "index" && params[:page].blank? && params[:slug].blank? %>
      <%= render "shared/billboard_splash" %>
    <% end %>
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          navigator.serviceWorker.register('<%= pwa_service_worker_path %>', { scope: '/' }).then(function(reg) {
            console.log('Service worker registered with scope:', reg.scope);
          }).catch(function(err) {
            console.warn('Service worker registration failed:', err);
          });
        });
      }

      function pwaInstallFromNav() {
        if (window.__pwaPrompt) {
          window.__pwaPrompt.prompt();
          window.__pwaPrompt.userChoice.then(function(choice) {
            if (choice.outcome === 'accepted') window.__pwaPrompt = null;
          });
        } else if (window.__pwaController) {
          window.__pwaController.install();
        }
      }

      if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone) {
        document.querySelectorAll('[data-pwa-install-btn]').forEach(function(btn) { btn.style.display = 'none'; });
      }
    </script>
