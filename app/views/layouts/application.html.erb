<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("brand.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= t('brand.tagline') %>">
    <meta name="theme-color" content="#ea580c">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="<%= t('brand.name') %>">
    <meta name="application-name" content="<%= t('brand.name') %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Devanagari:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', 'Noto Sans Devanagari', system-ui, sans-serif; }</style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50/80">
    <%# Top accent bar %>
    <div class="h-1 gradient-brand"></div>

    <%# Navigation %>
    <nav class="bg-white/90 glass border-b border-gray-200/60 sticky top-0 z-50" data-controller="mobile-nav">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16">
          <%= link_to root_path, class: "flex items-center gap-2.5 shrink-0 group" do %>
            <div class="gradient-brand rounded-xl flex items-center justify-center shadow-sm shadow-orange-200 group-hover:shadow-md group-hover:shadow-orange-200 transition-shadow px-2.5 py-1.5">
              <span class="text-white font-extrabold text-xs leading-none"><%= t("brand.logo_letter") %></span>
            </div>
            <div class="hidden xs:block">
              <span class="font-extrabold text-gray-900 text-lg tracking-tight"><%= t("brand.name") %></span>
            </div>
          <% end %>

          <%# Desktop nav %>
          <div class="hidden sm:flex items-center gap-2">
            <%= link_to t("nav.language_switch"), switch_locale_path, class: "text-sm font-medium text-gray-500 hover:text-orange-600 bg-gray-50 hover:bg-orange-50 rounded-full px-3.5 py-1.5 transition-all" %>
            <% if logged_in? %>
              <% if current_user.super_admin? %>
                <%= link_to new_admin_article_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-orange-600 hover:text-orange-700 bg-orange-50 hover:bg-orange-100 rounded-full px-3.5 py-1.5 transition-all" do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg>
                  <%= t("nav.new_article") %>
                <% end %>
                <%= link_to admin_articles_path, class: "text-sm font-medium text-gray-500 hover:text-orange-600 transition-colors" do %>
                  <%= t("nav.articles") %>
                <% end %>
                <%= link_to admin_regions_path, class: "text-sm font-medium text-gray-500 hover:text-orange-600 transition-colors" do %>
                  <%= t("nav.regions") %>
                <% end %>
                <%= link_to admin_categories_path, class: "text-sm font-medium text-gray-500 hover:text-orange-600 transition-colors" do %>
                  <%= t("nav.categories") %>
                <% end %>
                <%= link_to admin_users_path, class: "text-sm font-medium text-gray-500 hover:text-orange-600 transition-colors" do %>
                  <%= t("nav.users") %>
                <% end %>
                <%= link_to admin_root_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-white gradient-brand rounded-full px-4 py-1.5 shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-shadow" do %>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  Dashboard
                <% end %>
              <% elsif current_user.admin_or_above? %>
                <%= link_to t("nav.admin"), admin_root_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-white gradient-brand rounded-full px-4 py-1.5 shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-shadow" %>
              <% end %>
              <div class="w-px h-5 bg-gray-200 mx-1"></div>
              <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-full bg-orange-100 flex items-center justify-center">
                  <span class="text-orange-700 font-semibold text-xs"><%= current_user.name[0] %></span>
                </div>
                <span class="text-sm text-gray-600 font-medium"><%= current_user.name %></span>
              </div>
              <%= link_to t("nav.logout"), logout_path, class: "text-sm text-gray-400 hover:text-gray-600 ml-1" %>
            <% else %>
              <%= link_to t("nav.sign_in"), login_path, class: "text-sm font-semibold text-white gradient-brand rounded-full px-4 py-1.5 shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-shadow" %>
            <% end %>
          </div>

          <%# Mobile hamburger %>
          <button class="sm:hidden p-2.5 -mr-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-xl transition-colors" data-action="mobile-nav#toggle" aria-label="Menu">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>

      <%# Mobile dropdown %>
      <div class="hidden sm:hidden border-t border-gray-100 bg-white px-4 py-4 space-y-1 shadow-lg animate-fade-in" data-mobile-nav-target="menu">
        <%= link_to t("nav.language_switch"), switch_locale_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-gray-600 rounded-xl hover:bg-gray-50" %>
        <% if logged_in? %>
          <% if current_user.super_admin? %>
            <p class="px-3 pt-2 pb-1 text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= t("nav.admin") %></p>
            <%= link_to new_admin_article_path, class: "flex items-center gap-3 px-3 py-2 text-sm font-semibold text-orange-600 rounded-xl hover:bg-orange-50" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg>
              <%= t("nav.new_article") %>
            <% end %>
            <%= link_to admin_articles_path, class: "flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-700 rounded-xl hover:bg-gray-50" do %>
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              <%= t("nav.articles") %>
            <% end %>
            <%= link_to admin_regions_path, class: "flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-700 rounded-xl hover:bg-gray-50" do %>
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <%= t("nav.regions") %>
            <% end %>
            <%= link_to admin_categories_path, class: "flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-700 rounded-xl hover:bg-gray-50" do %>
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
              <%= t("nav.categories") %>
            <% end %>
            <%= link_to admin_users_path, class: "flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-700 rounded-xl hover:bg-gray-50" do %>
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197"/></svg>
              <%= t("nav.users") %>
            <% end %>
            <%= link_to admin_root_path, class: "flex items-center gap-3 px-3 py-2 text-sm font-semibold text-white gradient-brand rounded-xl mt-1" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4"/></svg>
              Dashboard
            <% end %>
            <div class="border-t border-gray-100 my-1"></div>
          <% elsif current_user.admin_or_above? %>
            <%= link_to t("nav.admin"), admin_root_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-semibold text-white gradient-brand rounded-xl" %>
          <% end %>
          <div class="flex items-center gap-3 px-3 py-2.5">
            <div class="w-8 h-8 rounded-full bg-orange-100 flex items-center justify-center">
              <span class="text-orange-700 font-semibold text-sm"><%= current_user.name[0] %></span>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900"><%= current_user.name %></p>
              <p class="text-xs text-gray-400"><%= current_user.role.humanize %></p>
            </div>
          </div>
          <%= link_to t("nav.logout"), logout_path, class: "flex items-center gap-3 px-3 py-2.5 text-sm text-red-600 rounded-xl hover:bg-red-50" %>
        <% else %>
          <%= link_to t("nav.sign_in"), login_path, class: "flex items-center justify-center gap-2 px-3 py-2.5 text-sm font-semibold text-white gradient-brand rounded-xl" %>
        <% end %>
      </div>
    </nav>

    <%# Flash messages %>
    <% if flash[:notice] %>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-4 animate-fade-in" data-controller="flash">
        <div class="rounded-xl bg-emerald-50 border border-emerald-200/60 text-emerald-800 px-5 py-3.5 text-sm flex items-center justify-between shadow-sm">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= flash[:notice] %></span>
          </div>
          <button data-action="flash#dismiss" class="text-emerald-400 hover:text-emerald-600 ml-3 cursor-pointer">&times;</button>
        </div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-4 animate-fade-in" data-controller="flash">
        <div class="rounded-xl bg-red-50 border border-red-200/60 text-red-800 px-5 py-3.5 text-sm flex items-center justify-between shadow-sm">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <span><%= flash[:alert] %></span>
          </div>
          <button data-action="flash#dismiss" class="text-red-400 hover:text-red-600 ml-3 cursor-pointer">&times;</button>
        </div>
      </div>
    <% end %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <%= yield %>
    </main>

    <%# Footer %>
    <footer class="bg-white border-t border-gray-200/60 mt-16 no-print">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="gradient-brand rounded-xl flex items-center justify-center px-2 py-1.5">
              <span class="text-white font-extrabold text-[10px] leading-none"><%= t("brand.logo_letter") %></span>
            </div>
            <div>
              <p class="font-bold text-gray-900 text-sm"><%= t("brand.name") %></p>
              <p class="text-xs text-gray-400"><%= t("brand.tagline") %></p>
            </div>
          </div>
          <p class="text-xs text-gray-400">&copy; <%= Date.current.year %> <%= t("brand.name") %></p>
        </div>
      </div>
    </footer>
  </body>
</html>
