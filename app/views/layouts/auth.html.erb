<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "#{t('login.submit')} — #{t('brand.name')}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#ea580c">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Devanagari:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', 'Noto Sans Devanagari', system-ui, sans-serif; }</style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50/80">
    <div class="min-h-screen flex">
      <%# Left panel — branding (hidden on mobile) %>
      <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-gradient-to-br from-gray-950 via-gray-900 to-red-950">
        <div class="absolute inset-0">
          <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-red-600/20 blur-3xl"></div>
          <div class="absolute bottom-1/4 right-1/4 w-72 h-72 rounded-full bg-amber-500/10 blur-3xl"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full border border-amber-500/5"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-amber-500/5"></div>
        </div>
        <div class="relative z-10 flex flex-col items-center justify-center w-full px-16">
          <img src="/icon-login.png" alt="अंतर्राष्ट्रीय असाटी समाज दर्शन" class="w-56 h-56 drop-shadow-2xl mb-8" style="filter: drop-shadow(0 0 40px rgba(220, 50, 50, 0.3)) drop-shadow(0 0 80px rgba(255, 180, 50, 0.15));">
          <% if I18n.locale == :hi %>
            <h1 class="text-2xl font-extrabold text-white/90 tracking-wide text-center">अंतर्राष्ट्रीय असाटी समाज दर्शन</h1>
          <% else %>
            <h1 class="text-2xl font-extrabold text-white/90 tracking-wide text-center">Antarrashtriya Asati Samaj Darshan</h1>
          <% end %>
          <div class="mt-3 w-20 h-0.5 bg-gradient-to-r from-transparent via-amber-500/60 to-transparent rounded-full"></div>
          <p class="text-sm text-gray-500 mt-4"><%= t("login.footer") %></p>
        </div>
      </div>

      <%# Right panel — form %>
      <div class="flex-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-12">
        <div class="w-full max-w-sm mx-auto">
          <% if flash[:notice] %>
            <div class="mb-6 rounded-xl bg-emerald-50 border border-emerald-200/60 text-emerald-800 px-5 py-3.5 text-sm flex items-center gap-3 animate-fade-in">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <%= flash[:notice] %>
            </div>
          <% end %>
          <% if flash[:alert] %>
            <div class="mb-6 rounded-xl bg-red-50 border border-red-200/60 text-red-800 px-5 py-3.5 text-sm flex items-center gap-3 animate-fade-in">
              <svg class="w-5 h-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
