<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "#{t('login.submit')} — #{t('brand.name')}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#ea580c">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Devanagari:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      body { font-family: 'Inter', 'Noto Sans Devanagari', system-ui, sans-serif; }

      .auth-bg {
        background: linear-gradient(135deg, #7c1010 0%, #b91c1c 20%, #c2410c 45%, #ea580c 65%, #d97706 85%, #92400e 100%);
      }

      /* Subtle pulsing orbs */
      @keyframes orb-pulse {
        0%, 100% { transform: scale(1); opacity: 0.5; }
        50% { transform: scale(1.08); opacity: 0.75; }
      }
      @keyframes orb-drift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(12px, -18px) scale(1.04); }
        66% { transform: translate(-8px, 10px) scale(0.97); }
      }
      @keyframes spin-slow {
        from { transform: translate(-50%, -50%) rotate(0deg); }
        to   { transform: translate(-50%, -50%) rotate(360deg); }
      }
      @keyframes spin-reverse {
        from { transform: translate(-50%, -50%) rotate(0deg); }
        to   { transform: translate(-50%, -50%) rotate(-360deg); }
      }
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes shimmer {
        0%   { background-position: -200% center; }
        100% { background-position: 200% center; }
      }

      .orb-1 { animation: orb-drift 9s ease-in-out infinite; }
      .orb-2 { animation: orb-drift 12s ease-in-out infinite reverse; }
      .orb-3 { animation: orb-pulse 6s ease-in-out infinite; }

      .ring-spin { animation: spin-slow 30s linear infinite; transform-origin: center; }
      .ring-spin-r { animation: spin-reverse 22s linear infinite; transform-origin: center; }

      .fade-up { animation: fade-up 0.7s ease both; }
      .fade-up-d1 { animation: fade-up 0.7s 0.1s ease both; }
      .fade-up-d2 { animation: fade-up 0.7s 0.2s ease both; }
      .fade-up-d3 { animation: fade-up 0.7s 0.35s ease both; }

      /* Glass card */
      .glass-card {
        background: rgba(255,255,255,0.07);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.18);
        box-shadow: 0 24px 64px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.15);
      }

      /* Shiny input */
      .input-auth {
        background: rgba(255,255,255,0.92);
        border: 1.5px solid rgba(255,255,255,0.3);
        border-radius: 14px;
        padding: 14px 14px 14px 44px;
        width: 100%;
        font-size: 0.9375rem;
        color: #1a1a1a;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        outline: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }
      .input-auth::placeholder { color: #9ca3af; }
      .input-auth:focus {
        background: #fff;
        border-color: #ea580c;
        box-shadow: 0 0 0 4px rgba(234,88,12,0.12), 0 2px 8px rgba(0,0,0,0.06);
      }

      /* Submit button */
      .btn-auth {
        background: linear-gradient(135deg, #ea580c 0%, #dc2626 50%, #b91c1c 100%);
        background-size: 200% auto;
        color: #fff;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 0.02em;
        border: none;
        border-radius: 16px;
        padding: 15px;
        width: 100%;
        cursor: pointer;
        transition: background-position 0.4s ease, box-shadow 0.2s, transform 0.15s;
        box-shadow: 0 8px 28px -4px rgba(185,28,28,0.55), 0 2px 8px rgba(0,0,0,0.1);
        position: relative;
        overflow: hidden;
      }
      .btn-auth:hover {
        background-position: right center;
        box-shadow: 0 12px 36px -4px rgba(185,28,28,0.65), 0 4px 12px rgba(0,0,0,0.15);
        transform: translateY(-1px);
      }
      .btn-auth:active { transform: translateY(0); }
      .btn-auth::after {
        content: '';
        position: absolute;
        top: -50%; left: -60%;
        width: 40%; height: 200%;
        background: rgba(255,255,255,0.18);
        transform: skewX(-20deg);
        transition: left 0.5s ease;
        pointer-events: none;
      }
      .btn-auth:hover::after { left: 120%; }

      /* Right panel on mobile: gradient instead of plain white */
      @media (max-width: 1023px) {
        .auth-right {
          background: linear-gradient(160deg, #fff7ed 0%, #fef3c7 40%, #fff 100%);
        }
      }
    </style>
  </head>

  <body class="min-h-screen">
    <div class="min-h-screen flex">

      <%# ── Left panel: branding ──────────────────────────────────────────── %>
      <div class="hidden lg:flex lg:w-[52%] relative overflow-hidden auth-bg flex-col items-center justify-center">

        <%# Background orbs %>
        <div class="orb-1 absolute top-[15%] left-[12%] w-72 h-72 rounded-full bg-white/5 blur-3xl"></div>
        <div class="orb-2 absolute bottom-[12%] right-[10%] w-80 h-80 rounded-full bg-yellow-300/10 blur-3xl"></div>
        <div class="orb-3 absolute top-[55%] left-[55%] w-48 h-48 rounded-full bg-red-300/10 blur-2xl"></div>

        <%# Spinning rings (decorative) %>
        <svg class="ring-spin absolute top-1/2 left-1/2 pointer-events-none opacity-[0.07]" width="700" height="700" viewBox="0 0 700 700" fill="none">
          <circle cx="350" cy="350" r="280" stroke="white" stroke-width="1" stroke-dasharray="8 18"/>
          <circle cx="350" cy="350" r="220" stroke="white" stroke-width="0.5" stroke-dasharray="4 12"/>
        </svg>
        <svg class="ring-spin-r absolute top-1/2 left-1/2 pointer-events-none opacity-[0.06]" width="560" height="560" viewBox="0 0 560 560" fill="none">
          <circle cx="280" cy="280" r="240" stroke="#fde68a" stroke-width="1" stroke-dasharray="12 24"/>
          <circle cx="280" cy="280" r="160" stroke="#fde68a" stroke-width="0.5" stroke-dasharray="6 14"/>
        </svg>

        <%# Mandala-like center diamond grid %>
        <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none opacity-[0.04]" width="500" height="500" viewBox="0 0 500 500" fill="none">
          <line x1="250" y1="0"   x2="250" y2="500" stroke="white" stroke-width="0.8"/>
          <line x1="0"   y1="250" x2="500" y2="250" stroke="white" stroke-width="0.8"/>
          <line x1="0"   y1="0"   x2="500" y2="500" stroke="white" stroke-width="0.6"/>
          <line x1="500" y1="0"   x2="0"   y2="500" stroke="white" stroke-width="0.6"/>
          <polygon points="250,80 420,250 250,420 80,250" stroke="white" stroke-width="0.8" fill="none"/>
          <polygon points="250,140 360,250 250,360 140,250" stroke="white" stroke-width="0.6" fill="none"/>
        </svg>

        <%# Content %>
        <div class="relative z-10 flex flex-col items-center text-center px-14">
          <%# Glowing logo %>
          <div class="relative mb-8">
            <div class="absolute inset-0 rounded-3xl bg-white/20 blur-2xl scale-110"></div>
            <div class="absolute inset-0 rounded-3xl bg-amber-400/20 blur-3xl scale-125"></div>
            <img src="/icon-login.png" alt="Samaj Darshan"
                 class="relative w-36 h-36 rounded-3xl shadow-[0_20px_60px_rgba(0,0,0,0.4)]"
                 style="filter: drop-shadow(0 0 30px rgba(255,200,80,0.4)) drop-shadow(0 0 60px rgba(255,100,30,0.25));">
          </div>

          <% if I18n.locale == :hi %>
            <h1 class="text-3xl font-black text-white leading-tight tracking-wide drop-shadow-lg">अंतर्राष्ट्रीय<br>असाटी समाज दर्शन</h1>
          <% else %>
            <h1 class="text-3xl font-black text-white leading-tight tracking-wide drop-shadow-lg">Antarrashtriya<br>Asati Samaj Darshan</h1>
          <% end %>

          <div class="mt-4 flex items-center gap-3">
            <div class="h-px w-14 bg-gradient-to-r from-transparent to-amber-300/60"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-amber-300/80"></div>
            <div class="h-px w-14 bg-gradient-to-l from-transparent to-amber-300/60"></div>
          </div>

          <p class="mt-5 text-base text-white/60 leading-relaxed max-w-xs"><%= t("login.footer") %></p>

          <%# Feature pills %>
          <div class="mt-10 flex flex-wrap justify-center gap-2">
            <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 text-white/80 text-xs font-semibold rounded-full px-4 py-1.5">
              <svg class="w-3.5 h-3.5 text-amber-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              समाचार
            </span>
            <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 text-white/80 text-xs font-semibold rounded-full px-4 py-1.5">
              <svg class="w-3.5 h-3.5 text-amber-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              शिक्षा
            </span>
            <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 text-white/80 text-xs font-semibold rounded-full px-4 py-1.5">
              <svg class="w-3.5 h-3.5 text-amber-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              विवाह
            </span>
            <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm border border-white/15 text-white/80 text-xs font-semibold rounded-full px-4 py-1.5">
              <svg class="w-3.5 h-3.5 text-amber-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              रोजगार
            </span>
          </div>
        </div>

        <%# Bottom corner flourish %>
        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-300/30 to-transparent"></div>
      </div>

      <%# ── Right panel: form ─────────────────────────────────────────────── %>
      <div class="auth-right flex-1 flex flex-col justify-center items-center px-6 sm:px-10 py-12 relative overflow-hidden min-h-screen lg:min-h-0">

        <%# Subtle background pattern on mobile %>
        <div class="lg:hidden absolute inset-0 pointer-events-none">
          <div class="absolute top-0 right-0 w-72 h-72 rounded-full bg-orange-200/30 blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-amber-200/20 blur-3xl translate-y-1/2 -translate-x-1/2"></div>
        </div>

        <div class="relative w-full max-w-[400px]">
          <% if flash[:notice] %>
            <div class="mb-5 rounded-2xl bg-emerald-50 border border-emerald-200/60 text-emerald-800 px-5 py-3.5 text-sm flex items-center gap-3 fade-up shadow-sm">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <%= flash[:notice] %>
            </div>
          <% end %>
          <% if flash[:alert] %>
            <div class="mb-5 rounded-2xl bg-red-50 border border-red-200/60 text-red-800 px-5 py-3.5 text-sm flex items-center gap-3 fade-up shadow-sm">
              <svg class="w-5 h-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </div>

    </div>
  </body>
</html>
