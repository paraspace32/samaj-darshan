<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "#{t('login.submit')} — #{t('brand.name')}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#ea580c">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Devanagari:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', 'Noto Sans Devanagari', system-ui, sans-serif; }</style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50/80">
    <div class="min-h-screen flex">
      <%# Left panel — branding (hidden on mobile) %>
      <div class="hidden lg:flex lg:w-1/2 gradient-hero relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute top-20 -left-10 w-72 h-72 rounded-full bg-orange-500 blur-3xl"></div>
          <div class="absolute bottom-20 right-10 w-96 h-96 rounded-full bg-purple-500 blur-3xl"></div>
        </div>
        <div class="relative z-10 flex flex-col justify-center px-16">
          <div class="gradient-brand rounded-2xl flex items-center justify-center shadow-lg shadow-orange-500/30 mb-8 px-4 py-3">
            <span class="text-white font-extrabold text-lg leading-none"><%= t("brand.logo_letter") %></span>
          </div>
          <h1 class="text-4xl font-extrabold text-white leading-tight mb-4"><%= t("brand.name") %></h1>
          <p class="text-lg text-gray-400 leading-relaxed max-w-md"><%= t("brand.tagline") %></p>
          <div class="mt-12 flex items-center gap-4">
            <div class="flex -space-x-3">
              <% %w[भ क स].each_with_index do |letter, i| %>
                <div class="w-10 h-10 rounded-full border-2 border-gray-800 bg-gradient-to-br from-orange-400 to-orange-600 flex items-center justify-center shadow-md" style="z-index: <%= 3 - i %>">
                  <span class="text-white font-bold text-xs"><%= letter %></span>
                </div>
              <% end %>
            </div>
            <p class="text-sm text-gray-500"><%= t("login.footer") %></p>
          </div>
        </div>
      </div>

      <%# Right panel — form %>
      <div class="flex-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-12">
        <div class="w-full max-w-sm mx-auto">
          <% if flash[:notice] %>
            <div class="mb-6 rounded-xl bg-emerald-50 border border-emerald-200/60 text-emerald-800 px-5 py-3.5 text-sm flex items-center gap-3 animate-fade-in">
              <svg class="w-5 h-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <%= flash[:notice] %>
            </div>
          <% end %>
          <% if flash[:alert] %>
            <div class="mb-6 rounded-xl bg-red-50 border border-red-200/60 text-red-800 px-5 py-3.5 text-sm flex items-center gap-3 animate-fade-in">
              <svg class="w-5 h-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
