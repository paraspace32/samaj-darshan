<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= @biodata.display_name %> — <%= t("biodata.template_title") %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+Devanagari:wght@400;500;600;700;800;900&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', 'Noto Sans Devanagari', sans-serif; background: #f1ece4; min-height: 100vh; }
    @media print {
      body { background: white; }
      .no-print { display: none !important; }
      .biodata-card { box-shadow: none !important; border: 2px solid #d97706 !important; }
      @page { margin: 0.5cm; size: A4; }
    }
  </style>
</head>
<body>
  <%# Toolbar — hidden on print %>
  <div class="no-print sticky top-0 z-50" style="background:linear-gradient(90deg,#7c2d12,#c2410c,#ea580c);box-shadow:0 2px 12px rgba(124,45,18,0.25);">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:0 16px;height:48px;">

      <%# Left: back + brand %>
      <div style="display:flex;align-items:center;gap:10px;">
        <%= link_to biodatas_path, style: "display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.15);color:white;transition:background 0.15s;" do %>
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
        <% end %>
        <%= link_to root_path, style: "font-size:14px;font-weight:900;color:white;letter-spacing:-0.02em;text-decoration:none;opacity:0.92;" do %>
          <%= t("brand.short_name") %>
        <% end %>
      </div>

      <%# Center: person name %>
      <div style="position:absolute;left:50%;transform:translateX(-50%);text-align:center;pointer-events:none;">
        <p style="font-size:13px;font-weight:700;color:white;margin:0;opacity:0.95;white-space:nowrap;max-width:180px;overflow:hidden;text-overflow:ellipsis;"><%= @biodata.display_name %></p>
      </div>

      <%# Right: shortlist + PDF + print %>
      <div style="display:flex;align-items:center;gap:6px;">
        <% if logged_in? %>
          <% is_shortlisted = current_user.shortlists.exists?(biodata: @biodata) %>
          <% if is_shortlisted %>
            <%= button_to unshortlist_biodata_path(@biodata), method: :delete, style: "display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.9);color:#ea580c;border:none;cursor:pointer;" do %>
              ♥
            <% end %>
          <% else %>
            <%= button_to shortlist_biodata_path(@biodata), method: :post, style: "display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.3);cursor:pointer;" do %>
              ♡
            <% end %>
          <% end %>
        <% end %>
        <% if @pdf_download_path.present? %>
          <%= link_to @pdf_download_path, style: "display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:8px;background:rgba(255,255,255,0.18);color:white;font-size:12px;font-weight:700;text-decoration:none;border:1px solid rgba(255,255,255,0.3);transition:background 0.15s;" do %>
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            PDF
          <% end %>
        <% end %>
        <button onclick="window.print()" style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,0.15);color:white;border:none;cursor:pointer;" title="<%= t('biodata.print_save') %>">
          <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
        </button>
      </div>

    </div>
  </div>

  <div class="py-8 px-4">
    <%= yield %>
  </div>
</body>
</html>
