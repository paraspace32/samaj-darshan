<% content_for(:title, t("magazine.title") + " — " + t("brand.name")) %>

<%# News / Magazine tab switcher %>
<div class="flex items-center gap-1 mb-6 bg-gray-100 rounded-xl p-1 max-w-xs">
  <%= link_to root_path, class: "flex-1 text-center py-2.5 rounded-lg text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" do %>
    <%= t("magazine.tab_news") %>
  <% end %>
  <span class="flex-1 text-center py-2.5 rounded-lg text-sm font-bold bg-white text-gray-900 shadow-sm">
    <%= t("magazine.tab_magazine") %>
  </span>
</div>

<%# Category filter chips %>
<div class="mb-6">
  <div class="flex items-center gap-2 overflow-x-auto pb-2 -mx-1 px-1 scrollbar-hide">
    <%= link_to magazine_path, class: "shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium transition-all #{@category.nil? ? 'gradient-brand text-white shadow-sm shadow-orange-200' : 'bg-white text-gray-600 border border-gray-200 hover:border-orange-200 hover:text-orange-600'}" do %>
      <%= t("magazine.all_categories") %>
    <% end %>
    <% @categories.each do |c| %>
      <%= link_to magazine_path(category: c.slug), class: "shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium transition-all #{@category&.id == c.id ? 'gradient-brand text-white shadow-sm shadow-orange-200' : 'bg-white text-gray-600 border border-gray-200 hover:border-orange-200 hover:text-orange-600'}" do %>
        <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= c.color %>"></span>
        <%= c.display_name %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @featured.present? %>
  <%# Story-First Hero Card — tall portrait with overlay %>
  <div class="mb-8 animate-fade-in">
    <%= link_to magazine_article_path(@featured), class: "group block relative rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow" do %>
      <div class="aspect-[3/4] sm:aspect-[16/9]">
        <% if @featured.cover_image.attached? %>
          <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover", loading: "eager" %>
        <% else %>
          <div class="w-full h-full gradient-hero flex items-center justify-center">
            <span class="text-5xl text-white/20 font-extrabold"><%= t("brand.logo_letter") %></span>
          </div>
        <% end %>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/10"></div>
      </div>
      <div class="absolute top-4 left-4">
        <span class="inline-block gradient-brand text-white text-[10px] font-extrabold uppercase tracking-wider px-3 py-1 rounded-md shadow-sm">
          <%= t("magazine.featured") %>
        </span>
      </div>
      <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-8">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-white/20 text-white backdrop-blur-sm">
            <span class="w-1.5 h-1.5 rounded-full" style="background-color: <%= @featured.category.color %>"></span>
            <%= @featured.category.display_name %>
          </span>
        </div>
        <h2 class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-white leading-tight group-hover:text-orange-200 transition-colors line-clamp-2">
          <%= @featured.display_title %>
        </h2>
        <p class="text-sm text-white/70 mt-2 line-clamp-2 hidden sm:block"><%= truncate(strip_tags(@featured.display_content), length: 160) %></p>
        <div class="flex items-center gap-3 mt-4">
          <div class="w-7 h-7 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
            <span class="text-white font-semibold text-xs"><%= @featured.author.name[0] %></span>
          </div>
          <span class="text-sm text-white/80"><%= @featured.author.name %></span>
          <span class="text-white/40">&middot;</span>
          <span class="text-sm text-white/60"><%= t("feed.ago", time: time_ago_in_words(@featured.published_at)) %></span>
        </div>
      </div>
    <% end %>
  </div>
<% elsif @articles.empty? %>
  <div class="bg-white rounded-2xl border border-gray-200/60 px-6 py-20 text-center">
    <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
    </div>
    <p class="text-gray-400"><%= t("magazine.no_articles") %></p>
  </div>
<% end %>

<% if @articles.any? %>
  <%# Section heading %>
  <% unless @category %>
    <h2 class="text-lg font-bold text-gray-900 mb-5"><%= t("magazine.latest") %></h2>
  <% end %>

  <%# Text-First List (Medium-style) — compact, scannable %>
  <div class="space-y-0">
    <% @articles.each_with_index do |article, idx| %>
      <div class="animate-fade-in" style="animation-delay: <%= idx * 40 %>ms">
        <%= link_to magazine_article_path(article), class: "group flex gap-4 py-5 #{'border-t border-gray-100' if idx > 0}" do %>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-[10px] font-bold text-orange-600 uppercase tracking-wider"><%= article.category.display_name %></span>
            </div>
            <h3 class="text-[15px] font-extrabold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug">
              <%= article.display_title %>
            </h3>
            <p class="text-sm text-gray-500 line-clamp-2 mt-1 leading-relaxed hidden sm:block"><%= truncate(strip_tags(article.display_content), length: 120) %></p>
            <div class="flex items-center gap-2 mt-2">
              <div class="w-5 h-5 rounded-full bg-orange-100 flex items-center justify-center">
                <span class="text-orange-700 font-semibold text-[9px]"><%= article.author.name[0] %></span>
              </div>
              <span class="text-[11px] text-gray-400"><%= article.author.name %></span>
              <span class="text-gray-300">&middot;</span>
              <span class="text-[11px] text-gray-400"><%= t("feed.ago", time: time_ago_in_words(article.published_at)) %></span>
            </div>
          </div>
          <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-xl shrink-0 overflow-hidden">
            <% if article.cover_image.attached? %>
              <%= optimized_image_tag article.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-orange-50 via-orange-100 to-amber-50 flex items-center justify-center">
                <span class="text-xl text-orange-200 font-extrabold"><%= t("brand.logo_letter") %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Pagination %>
  <% total_pages = (@total_count.to_f / @per_page).ceil %>
  <% if total_pages > 1 %>
    <div class="flex items-center justify-center gap-3 mt-10">
      <% if @page > 1 %>
        <% prev_params = { page: @page - 1 } %>
        <% prev_params[:category] = @category.slug if @category %>
        <%= link_to magazine_path(prev_params), class: "inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium rounded-xl border border-gray-200 bg-white text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
          <%= t("feed.previous") %>
        <% end %>
      <% end %>
      <span class="px-4 py-2.5 text-sm text-gray-400 font-medium"><%= t("feed.page_info", current: @page, total: total_pages) %></span>
      <% if @page < total_pages %>
        <% next_params = { page: @page + 1 } %>
        <% next_params[:category] = @category.slug if @category %>
        <%= link_to magazine_path(next_params), class: "inline-flex items-center gap-1.5 px-5 py-2.5 text-sm font-medium rounded-xl gradient-brand text-white shadow-sm shadow-orange-200 hover:shadow-md hover:shadow-orange-200 transition-shadow" do %>
          <%= t("feed.next") %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
