<% content_for(:title, "#{@article.display_title} — #{t('magazine.title')} — #{t('brand.name')}") %>
<% content_for(:og_title, @article.display_title) %>
<% content_for(:og_type, "article") %>
<% content_for(:description, truncate(strip_tags(@article.display_content), length: 200)) %>
<% if @article.cover_image.attached? %>
  <% content_for(:og_image, rails_storage_proxy_url(@article.cover_image)) %>
<% end %>

<% content_for(:head) do %>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
<% end %>

<article class="max-w-2xl mx-auto animate-fade-in">
  <%# Breadcrumb %>
  <nav class="flex items-center gap-2 text-sm text-gray-400 mb-6">
    <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors" %>
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <%= link_to t("magazine.title"), magazine_path, class: "hover:text-orange-600 transition-colors" %>
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <span class="text-gray-500 truncate"><%= truncate(@article.display_title, length: 30) %></span>
  </nav>

  <%# Category & read time %>
  <div class="flex items-center gap-2 mb-3">
    <span class="text-[10px] font-extrabold text-orange-600 uppercase tracking-wider">
      <%= @article.category.display_name %>
    </span>
    <span class="text-gray-300">&middot;</span>
    <span class="text-[11px] text-gray-400"><%= @article.region.display_name %></span>
  </div>

  <%# Title — serif editorial style %>
  <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 leading-tight mb-4" style="font-family: 'Playfair Display', 'Noto Sans Devanagari', serif;">
    <%= @article.display_title %>
  </h1>

  <%# Author inline %>
  <div class="flex items-center gap-3 mb-6">
    <div class="w-9 h-9 rounded-full gradient-brand flex items-center justify-center shadow-sm shadow-orange-200">
      <span class="text-white font-bold text-sm"><%= @article.author.name[0] %></span>
    </div>
    <div>
      <p class="text-sm font-semibold text-gray-900"><%= @article.author.name %></p>
      <p class="text-xs text-gray-400"><%= @article.published_at.strftime("%d %b %Y") %> &middot; <%= t("feed.ago", time: time_ago_in_words(@article.published_at)) %></p>
    </div>
  </div>

  <%# Cover image below title (Clean Editorial pattern) %>
  <% gallery_images = [@article.cover_image.attached? ? @article.cover_image : nil, *(@article.images.attached? ? @article.images : [])].compact %>
  <% if gallery_images.size == 1 %>
    <div class="mb-8 -mx-4 sm:mx-0">
      <%= optimized_image_tag gallery_images.first, variant: :hero, class: "w-full max-h-[500px] object-cover sm:rounded-2xl shadow-lg" %>
    </div>
  <% elsif gallery_images.size > 1 %>
    <div class="mb-8 -mx-4 sm:mx-0 relative rounded-none sm:rounded-2xl overflow-hidden shadow-lg group"
         data-controller="carousel" data-carousel-autoplay-value="true">
      <div class="relative">
        <div class="overflow-hidden">
          <div class="flex transition-transform duration-500 ease-out" data-carousel-target="track">
            <% gallery_images.each do |img| %>
              <div class="w-full shrink-0" data-carousel-target="slide">
                <%= optimized_image_tag img, variant: :carousel, class: "w-full h-64 sm:h-96 object-cover", loading: "lazy" %>
              </div>
            <% end %>
          </div>
        </div>
        <button data-action="carousel#prev"
                class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/30 backdrop-blur-sm text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/50 cursor-pointer">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button data-action="carousel#next"
                class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/30 backdrop-blur-sm text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/50 cursor-pointer">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-1.5">
          <% gallery_images.each_with_index do |_, i| %>
            <button data-carousel-target="dot" data-action="carousel#goToSlide" data-index="<%= i %>"
                    class="h-2 rounded-full transition-all duration-300 cursor-pointer <%= i == 0 ? 'bg-white w-6' : 'bg-white/40 w-2' %>"></button>
          <% end %>
        </div>
        <div class="absolute top-4 right-4 bg-black/30 backdrop-blur-sm text-white text-xs font-semibold px-2.5 py-1 rounded-full"
             data-carousel-target="counter">
          1 / <%= gallery_images.size %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Article body — editorial prose %>
  <div class="magazine-prose prose prose-gray prose-lg max-w-none mb-10
              prose-headings:font-extrabold prose-headings:text-gray-900
              prose-p:text-gray-600 prose-p:leading-[1.85]
              prose-a:text-orange-600 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
              prose-blockquote:border-orange-400 prose-blockquote:bg-orange-50/50 prose-blockquote:rounded-r-xl prose-blockquote:py-3 prose-blockquote:px-5 prose-blockquote:not-italic prose-blockquote:font-bold prose-blockquote:text-gray-800">
    <%= simple_format(@article.display_content) %>
  </div>

  <%# Like & Share actions %>
  <div id="like-section" class="bg-gray-50 rounded-2xl border border-gray-200/60 p-5 sm:p-6 mb-8">
    <div class="flex flex-wrap items-center gap-3 mb-5">
      <% if current_user %>
        <%= button_to toggle_article_like_path(@article), method: :post, class: "inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold transition-all cursor-pointer shadow-sm #{@liked ? 'bg-red-50 border border-red-200 text-red-600 hover:bg-red-100' : 'bg-white border border-gray-200 text-gray-600 hover:bg-red-50 hover:border-red-200 hover:text-red-500'}" do %>
          <svg class="w-5 h-5 <%= 'fill-red-500' if @liked %>" fill="<%= @liked ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <span><%= @liked ? t("likes.liked") : t("likes.like") %></span>
          <span class="text-xs opacity-70">(<%= @article.likes_count %>)</span>
        <% end %>
      <% else %>
        <%= link_to login_path, class: "inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-medium bg-white border border-gray-200 text-gray-500 hover:bg-red-50 hover:border-red-200 hover:text-red-500 transition-all shadow-sm" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <span><%= t("likes.like") %></span>
          <span class="text-xs opacity-70">(<%= @article.likes_count %>)</span>
        <% end %>
      <% end %>

      <span class="text-gray-300">|</span>

      <a href="#comments" class="inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-medium bg-white border border-gray-200 text-gray-600 hover:bg-blue-50 hover:border-blue-200 hover:text-blue-600 transition-all shadow-sm">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        <span><%= t("comments.title") %></span>
        <span class="text-xs opacity-70">(<%= @article.comments_count %>)</span>
      </a>
    </div>

    <p class="text-sm font-semibold text-gray-900 mb-4"><%= t("article.share_whatsapp").gsub("WhatsApp", "") %></p>
    <div class="flex flex-wrap items-center gap-3">
      <% share_text = "#{@article.display_title}\n#{request.original_url}" %>
      <a href="https://wa.me/?text=<%= ERB::Util.url_encode(share_text) %>"
         target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-green-700 shadow-sm hover:shadow-md transition-all">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
      <button data-controller="copy-link" data-copy-link-url-value="<%= request.original_url %>" data-action="copy-link#copy"
              class="inline-flex items-center gap-2 rounded-xl bg-white border border-gray-200 px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 shadow-sm transition-all cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
        Copy Link
      </button>
    </div>
  </div>

  <%# Comments section %>
  <div id="comments" class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden mb-8 shadow-sm">
    <div class="px-5 sm:px-6 py-4 border-b border-gray-100 flex items-center gap-2">
      <svg class="w-4.5 h-4.5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      <h3 class="text-sm font-bold text-gray-900"><%= t("comments.title") %> (<%= @article.comments_count %>)</h3>
    </div>

    <div class="px-5 sm:px-6">
      <% if current_user %>
        <%= form_with model: Comment.new, url: article_comments_path(@article), class: "py-4 border-b border-gray-100" do |f| %>
          <div class="flex gap-3">
            <div class="w-9 h-9 rounded-full gradient-brand flex items-center justify-center shrink-0 shadow-sm">
              <span class="text-white font-bold text-xs"><%= current_user.name[0].upcase %></span>
            </div>
            <div class="flex-1">
              <%= f.text_area :body, placeholder: t("comments.write_placeholder"), rows: 2,
                    class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-700 placeholder-gray-400 focus:bg-white focus:border-orange-300 focus:ring-2 focus:ring-orange-100 focus:outline-none resize-none transition-all" %>
              <div class="flex justify-end mt-2">
                <%= f.submit t("comments.submit"), class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-xl gradient-brand text-white text-sm font-semibold shadow-sm shadow-orange-200 hover:shadow-md cursor-pointer transition-all" %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="py-5 text-center">
          <%= link_to login_path, class: "inline-flex items-center gap-2 text-sm font-medium text-orange-600 hover:text-orange-700 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
            <%= t("comments.login_to_comment") %>
          <% end %>
        </div>
      <% end %>

      <% if @comments.any? %>
        <div class="divide-y divide-gray-100">
          <%= render partial: "comments/comment", collection: @comments %>
        </div>
      <% else %>
        <div class="py-8 text-center">
          <p class="text-sm text-gray-400"><%= t("comments.no_comments") %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Bilingual toggle %>
  <% other_title = I18n.locale == :hi ? @article.title_en : @article.title_hi %>
  <% other_content = I18n.locale == :hi ? @article.content_en : @article.content_hi %>
  <% if other_title.present? || other_content.present? %>
    <details class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden mb-8 shadow-sm">
      <summary class="px-5 sm:px-6 py-4 text-sm font-semibold text-gray-700 cursor-pointer hover:bg-gray-50 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
        <%= t("article.read_other_lang") %>
      </summary>
      <div class="px-5 sm:px-6 pb-6 pt-2 prose prose-sm prose-gray max-w-none border-t border-gray-100" dir="auto">
        <% if other_title.present? %><h3 class="text-lg font-bold"><%= other_title %></h3><% end %>
        <% if other_content.present? %><%= simple_format(other_content) %><% end %>
      </div>
    </details>
  <% end %>

  <%# Related articles %>
  <% if @related.any? %>
    <div class="mb-8">
      <h3 class="text-lg font-bold text-gray-900 mb-5"><%= t("magazine.related") %></h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% @related.each do |rel| %>
          <%= link_to magazine_article_path(rel), class: "group flex gap-3 bg-white rounded-xl border border-gray-200/60 p-3 card-hover" do %>
            <div class="w-20 h-20 rounded-lg shrink-0 overflow-hidden">
              <% if rel.cover_image.attached? %>
                <%= optimized_image_tag rel.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full bg-gradient-to-br from-orange-50 to-amber-50 flex items-center justify-center">
                  <span class="text-orange-200 font-bold text-[10px]"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-between">
              <div>
                <span class="text-[9px] font-bold text-orange-600 uppercase tracking-wider"><%= rel.category.display_name %></span>
                <h4 class="text-sm font-extrabold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug mt-0.5"><%= rel.display_title %></h4>
              </div>
              <span class="text-[10px] text-gray-400"><%= rel.author.name %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Back link %>
  <div class="mt-8">
    <%= link_to magazine_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-orange-600 hover:text-orange-700 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      <%= t("magazine.back_to_magazine") %>
    <% end %>
  </div>
</article>
