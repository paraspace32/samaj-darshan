<% content_for(:title, "#{@magazine.display_title} — #{t('magazine.title')} — #{t('brand.name')}") %>

<% content_for(:head) do %>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
<% end %>

<div class="max-w-3xl mx-auto animate-fade-in">
  <%# Breadcrumb %>
  <nav class="flex items-center flex-wrap gap-x-2 gap-y-1 text-sm text-stone-400 mb-10">
    <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors font-medium" %>
    <svg class="w-3.5 h-3.5 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <%= link_to t("magazine.title"), magazines_path, class: "hover:text-orange-600 transition-colors font-medium" %>
    <svg class="w-3.5 h-3.5 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <span class="text-stone-500 truncate font-medium"><%= @magazine.display_issue %></span>
  </nav>

  <%# Cover image %>
  <% if @magazine.cover_image.attached? %>
    <div class="mb-12 sm:mb-14 -mx-4 sm:mx-0 rounded-none sm:rounded-3xl overflow-hidden surface-elevated ring-1 ring-black/[0.06] shadow-2xl shadow-stone-900/10">
      <div class="relative group">
        <%= optimized_image_tag @magazine.cover_image, variant: :hero, class: "w-full max-h-[min(520px,70vh)] object-cover img-zoom" %>
        <div class="absolute inset-0 bg-gradient-to-t from-stone-950/80 via-stone-900/20 to-orange-950/30 pointer-events-none"></div>
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.12] via-transparent to-orange-900/25 pointer-events-none"></div>
        <div class="absolute inset-0 gradient-shine opacity-50 pointer-events-none"></div>
        <div class="absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-black/55 to-transparent pointer-events-none"></div>
      </div>
    </div>
  <% end %>

  <%# Issue header %>
  <header class="mb-12 sm:mb-14 text-center sm:text-left relative">
    <div class="flex items-center justify-center sm:justify-start gap-4 mb-6">
      <span class="h-px w-8 sm:w-12 bg-gradient-to-r from-transparent to-orange-300/80 hidden sm:block" aria-hidden="true"></span>
      <span class="badge gradient-brand text-white shadow-lg shadow-orange-900/15 uppercase tracking-[0.15em] ring-1 ring-white/25">
        <%= @magazine.display_issue %>
      </span>
      <span class="h-px w-8 sm:w-12 bg-gradient-to-l from-transparent to-orange-300/80 hidden sm:block" aria-hidden="true"></span>
    </div>
    <h1 class="text-3xl sm:text-[2.125rem] font-black tracking-tight text-stone-900 leading-[1.15]" style="font-family: 'Playfair Display', 'Noto Sans Devanagari', serif;">
      <%= @magazine.display_title %>
    </h1>
    <% if @magazine.display_description.present? %>
      <div class="mt-6 text-stone-600 text-base sm:text-lg leading-[1.75] max-w-2xl mx-auto sm:mx-0">
        <%= simple_format(@magazine.display_description) %>
      </div>
    <% end %>
    <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mt-8"><%= @magazine.published_at&.strftime("%d %b %Y") %></p>
    <div class="section-divider mt-10"></div>
  </header>

  <%# Articles table of contents %>
  <% if @articles.any? %>
    <div class="mb-12 sm:mb-16 animate-fade-up">
      <h2 class="text-xl sm:text-2xl font-black tracking-tight text-stone-900 mb-8 flex flex-col sm:flex-row sm:items-end gap-3">
        <span class="flex items-center gap-3">
          <span class="inline-flex h-10 w-1 rounded-full gradient-brand shadow-sm shadow-orange-200/80" aria-hidden="true"></span>
          <span class="text-gradient"><%= t("magazine.in_this_issue") %></span>
        </span>
      </h2>

      <nav class="surface-elevated rounded-3xl p-2 sm:p-3 ring-1 ring-black/[0.04]" aria-label="<%= t('magazine.in_this_issue') %>">
        <ol class="list-none space-y-0">
          <% @articles.each_with_index do |article, idx| %>
            <li class="animate-fade-in" style="animation-delay: <%= idx * 40 %>ms">
              <a href="#article-<%= article.id %>" class="group flex gap-4 sm:gap-5 items-center rounded-2xl px-4 py-5 sm:px-5 sm:py-6 transition-colors hover:bg-stone-50/90 <%= 'border-t border-stone-100/90' if idx > 0 %>">
                <span class="flex h-11 w-11 sm:h-12 sm:w-12 shrink-0 items-center justify-center rounded-2xl gradient-brand text-white text-sm font-black shadow-md shadow-orange-900/20 ring-1 ring-white/20">
                  <%= idx + 1 %>
                </span>
                <div class="flex-1 min-w-0 py-0.5">
                  <h3 class="text-[15px] sm:text-base font-black tracking-tight text-stone-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug">
                    <%= article.display_title %>
                  </h3>
                  <p class="text-xs font-medium text-stone-400 mt-2"><%= article.author.name %></p>
                </div>
                <% if article.cover_image.attached? %>
                  <div class="w-[4.5rem] h-[4.5rem] sm:w-20 sm:h-20 rounded-2xl shrink-0 overflow-hidden ring-1 ring-black/[0.06] shadow-md group-hover:ring-orange-200/60 transition-all">
                    <%= optimized_image_tag article.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom" %>
                  </div>
                <% end %>
              </a>
            </li>
          <% end %>
        </ol>
      </nav>
    </div>

    <div class="section-divider mb-12 sm:mb-16"></div>

    <%# Full articles %>
    <% @articles.each_with_index do |article, idx| %>
      <article id="article-<%= article.id %>" class="mb-16 sm:mb-20 last:mb-8 scroll-mt-24 animate-fade-in">
        <div class="surface-elevated rounded-3xl p-6 sm:p-10 lg:p-12 ring-1 ring-black/[0.05] shadow-xl shadow-stone-900/[0.06]">
          <div class="flex flex-wrap items-center gap-3 mb-8 pb-8 border-b border-stone-100">
            <span class="inline-flex items-center justify-center min-w-[2.25rem] h-9 px-2 rounded-full gradient-brand text-white text-xs font-black shadow-sm ring-1 ring-white/20"><%= idx + 1 %></span>
            <span class="text-xs font-semibold uppercase tracking-widest text-stone-400"><%= article.author.name %></span>
          </div>

          <h2 class="text-2xl sm:text-3xl font-black tracking-tight text-stone-900 leading-[1.2] mb-8 sm:mb-10" style="font-family: 'Playfair Display', 'Noto Sans Devanagari', serif;">
            <%= article.display_title %>
          </h2>

          <% if article.cover_image.attached? %>
            <div class="mb-10 sm:mb-12 -mx-2 sm:mx-0">
              <div class="rounded-2xl sm:rounded-3xl overflow-hidden surface-raised ring-1 ring-black/[0.05] shadow-lg">
                <div class="relative group">
                  <%= optimized_image_tag article.cover_image, variant: :card, class: "w-full max-h-[min(420px,55vh)] object-cover img-zoom" %>
                  <div class="absolute inset-0 bg-gradient-to-t from-stone-900/10 to-transparent pointer-events-none opacity-0 sm:opacity-100"></div>
                </div>
              </div>
            </div>
          <% end %>

          <div class="magazine-prose prose prose-stone prose-lg max-w-none
                      prose-headings:font-black prose-headings:tracking-tight prose-headings:text-stone-900
                      prose-p:text-stone-600 prose-p:leading-[1.9] prose-p:text-[1.0625rem]
                      prose-a:text-orange-600 prose-a:font-semibold prose-a:no-underline hover:prose-a:underline
                      prose-blockquote:border-orange-400 prose-blockquote:bg-orange-50/60 prose-blockquote:rounded-2xl prose-blockquote:border-l-4 prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:font-bold prose-blockquote:text-stone-800">
            <%= simple_format(article.display_content) %>
          </div>

          <%# Bilingual toggle %>
          <% other_title = I18n.locale == :hi ? article.title_en : article.title_hi %>
          <% other_content = I18n.locale == :hi ? article.content_en : article.content_hi %>
          <% if other_title.present? || other_content.present? %>
            <details class="surface-raised rounded-2xl border border-stone-200/80 overflow-hidden mt-10 ring-1 ring-black/[0.03]">
              <summary class="px-5 sm:px-6 py-4 text-sm font-bold text-stone-700 cursor-pointer hover:bg-stone-50 transition-colors flex items-center gap-2 list-none [&::-webkit-details-marker]:hidden">
                <svg class="w-4 h-4 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
                <%= t("article.read_other_lang") %>
              </summary>
              <div class="px-5 sm:px-6 pb-6 pt-0 prose prose-sm prose-stone max-w-none border-t border-stone-100" dir="auto">
                <% if other_title.present? %><h3 class="text-lg font-black tracking-tight mt-4"><%= other_title %></h3><% end %>
                <% if other_content.present? %><%= simple_format(other_content) %><% end %>
              </div>
            </details>
          <% end %>
        </div>

        <% if idx < @articles.size - 1 %>
          <div class="section-divider mt-14 sm:mt-16"></div>
        <% end %>
      </article>
    <% end %>
  <% else %>
    <div class="surface-elevated rounded-3xl px-8 py-20 text-center ring-1 ring-black/[0.04]">
      <p class="text-stone-500 font-medium"><%= t("magazine.no_articles") %></p>
    </div>
  <% end %>

  <%# Back link %>
  <div class="mt-12 mb-6 flex justify-center sm:justify-start">
    <%= link_to magazines_path, class: "btn-ghost" do %>
      <svg class="w-4 h-4 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      <%= t("magazine.back_to_magazine") %>
    <% end %>
  </div>
</div>
