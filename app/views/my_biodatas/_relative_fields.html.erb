<div class="flex items-center gap-2 relative-row">
  <%= rf.select :relative_type,
    Relative::TYPES.map { |t| [t, t] },
    { include_blank: t("biodata.relatives_type_placeholder") },
    class: "input-premium w-36 shrink-0" %>
  <%= rf.text_field :name, placeholder: t("biodata.relatives_name_placeholder"), class: "input-premium flex-1 block w-full" %>
  <%= rf.hidden_field :id %>
  <%= rf.hidden_field :_destroy, class: "destroy-flag" %>
  <button type="button" data-action="relatives#remove"
          class="shrink-0 w-7 h-7 flex items-center justify-center rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>
