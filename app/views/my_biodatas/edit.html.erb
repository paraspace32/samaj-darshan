<% content_for(:title, t("biodata.edit_my_biodata")) %>

<div class="max-w-3xl mx-auto animate-fade-in">
  <div class="mb-8">
    <h1 class="text-3xl font-black tracking-tight text-gray-900">
      <span class="text-gradient"><%= t("biodata.edit_my_biodata") %></span>
    </h1>
    <p class="text-sm text-gray-500 mt-2"><%= t("biodata.edit_subtitle") %></p>
    <% if @biodata.published? || @biodata.rejected? %>
      <div class="mt-4 flex items-center gap-2.5 rounded-xl bg-amber-50 border border-amber-200/60 px-4 py-3">
        <svg class="w-4 h-4 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <p class="text-sm text-amber-700"><%= t("biodata.edit_resubmit_notice") %></p>
      </div>
    <% end %>
  </div>

  <% url = my_biodata_path(@biodata) %>
  <% submit_label = t("biodata.update_biodata") %>
  <%= render "form", biodata: @biodata, url: url, submit_label: submit_label, cancel_path: my_biodata_path(@biodata) %>
</div>
