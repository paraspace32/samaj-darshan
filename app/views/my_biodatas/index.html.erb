<% content_for(:title, t("biodata.my_biodatas_title")) %>

<div class="max-w-3xl mx-auto animate-fade-in">
  <%# Header %>
  <div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-2xl sm:text-3xl font-black tracking-tight text-gray-900">
        <span class="text-gradient"><%= t("biodata.my_biodatas_title") %></span>
      </h1>
      <p class="text-sm text-gray-500 mt-1"><%= t("biodata.my_biodatas_subtitle") %></p>
    </div>
    <%= link_to new_my_biodata_path, class: "btn-primary !py-2 !px-4 !text-sm" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg>
      <%= t("biodata.create_my_biodata") %>
    <% end %>
  </div>

  <% if @biodatas.any? %>
    <ul class="space-y-3">
      <% @biodatas.each do |bio| %>
        <%= link_to my_biodata_path(bio), class: "block rounded-2xl border border-gray-200/60 bg-white hover:border-orange-300 hover:shadow-sm transition px-4 py-3" do %>
          <div class="flex items-center gap-3">
            <%# Thumbnail %>
            <div class="w-12 h-14 rounded-lg overflow-hidden bg-gradient-to-br from-orange-100 to-rose-100 flex items-center justify-center shrink-0 border border-gray-200/40">
              <% if bio.photo.attached? %>
                <%= optimized_image_tag bio.photo, variant: :thumb, class: "w-full h-full object-cover" %>
              <% else %>
                <span class="text-orange-500 font-black"><%= bio.avatar_initial %></span>
              <% end %>
            </div>
            <%# Meta %>
            <div class="flex-1 min-w-0">
              <p class="font-bold text-gray-900 truncate"><%= bio.display_name %></p>
              <p class="text-xs text-gray-500 mt-0.5 truncate">
                <%= bio.age %> <%= t("biodata.years") %>
                <% if bio.city.present? %> &middot; <%= bio.city %><% end %>
              </p>
            </div>
            <%# Status %>
            <% badge_class, badge_label = case bio.status
              when "published"      then [ "bg-emerald-100 text-emerald-700 border-emerald-200/60", t("biodata.status_published") ]
              when "pending_review" then [ "bg-amber-100 text-amber-700 border-amber-200/60",       t("biodata.status_pending") ]
              when "rejected"       then [ "bg-red-100 text-red-700 border-red-200/60",             t("biodata.status_rejected") ]
              else                       [ "bg-gray-100 text-gray-600 border-gray-200/60",          t("biodata.status_draft") ]
              end %>
            <span class="shrink-0 text-[10px] font-bold uppercase tracking-wider border px-2 py-1 rounded-md <%= badge_class %>">
              <%= badge_label %>
            </span>
          </div>
        <% end %>
      <% end %>
    </ul>
  <% else %>
    <div class="surface-elevated rounded-3xl border border-gray-200/40 px-8 py-16 text-center shadow-sm">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-orange-100 to-rose-100 flex items-center justify-center mx-auto mb-5 border border-orange-200/40">
        <svg class="w-8 h-8 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg>
      </div>
      <p class="text-gray-600 font-medium mb-5"><%= t("biodata.my_biodatas_empty") %></p>
      <%= link_to t("biodata.create_my_biodata"), new_my_biodata_path, class: "btn-primary !inline-flex" %>
    </div>
  <% end %>
</div>
