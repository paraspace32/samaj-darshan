<%# ═══════════════════════════════════════════════════════════════════
    CATEGORY SECTIONS — alternating slider/grid per category
    Requires: @category_sections
    ═══════════════════════════════════════════════════════════════════ %>
<% if @category_sections.present? %>
  <% section_accents = %w[#3b82f6 #10b981 #8b5cf6 #14b8a6 #d97706 #e11d48] %>
  <% @category_sections.each_with_index do |section, sec_idx| %>
    <%# Ad between sections %>
    <% if sec_idx > 0 %>
      <%= render "shared/billboard_feed" %>
    <% end %>

    <% accent = section_accents[sec_idx % section_accents.size] %>
    <div class="py-4 sm:py-6 lg:py-8 <%= sec_idx > 0 ? 'mt-2 border-t border-gray-100' : '' %>">
      <div class="flex items-center gap-3 mb-3 lg:mb-5">
        <div class="w-1 h-6 rounded-full shrink-0" style="background: <%= accent %>"></div>
        <h2 class="text-base sm:text-xl lg:text-2xl font-black text-gray-900 tracking-tight"><%= section[:category].display_name %></h2>
        <div class="flex-1 h-px bg-gray-100"></div>
        <%= link_to category_feed_path(slug: section[:category].slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold hover:opacity-80 px-2.5 py-1 rounded-full transition-all", style: "color: #{accent}; background: #{accent}12" do %>
          <%= I18n.locale == :hi ? "और देखें" : "View All" %>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>

      <%# Mobile: ALTERNATING layouts for variety %>
      <div class="sm:hidden">
        <% if sec_idx.odd? && section[:items].size > 1 %>
          <%# ODD sections: horizontal scroll cards — breaks the monotony %>
          <div class="category-scroll -mx-4 px-4">
            <% section[:items].each_with_index do |item, idx| %>
              <%= link_to news_path(item), class: "group category-scroll-card" do %>
                <div class="relative h-44">
                  <% if item.cover_image.attached? %>
                    <%= optimized_image_tag item.cover_image, variant: :card, class: "w-full h-full object-cover", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-full gradient-brand-soft"></div>
                  <% end %>
                  <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, transparent 100%)"></div>
                  <div class="absolute top-2.5 left-2.5">
                    <span class="text-[9px] font-black px-2 py-0.5 rounded-md text-white/90 uppercase tracking-wider" style="background: <%= accent %>cc"><%= section[:category].display_name %></span>
                  </div>
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <h3 class="text-[13px] font-bold text-white line-clamp-2 leading-snug tracking-tight group-hover:text-orange-200 transition-colors"><%= item.display_title %></h3>
                    <div class="flex items-center gap-1.5 mt-1.5">
                      <span class="text-[10px] text-white/40"><%= item.region.display_name %></span>
                      <span class="text-white/20">&middot;</span>
                      <span class="text-[10px] text-white/30"><%= item.published_at&.strftime("%d %b") %></span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <%# EVEN sections: featured card + compact numbered list %>
          <% mobile_lead = section[:items].first %>
          <% if mobile_lead %>
            <%= link_to news_path(mobile_lead), class: "group block relative overflow-hidden rounded-xl mb-2" do %>
              <div class="relative h-44">
                <% if mobile_lead.cover_image.attached? %>
                  <%= optimized_image_tag mobile_lead.cover_image, variant: :card, class: "w-full h-full object-cover", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft"></div>
                <% end %>
                <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.15) 55%, transparent 100%)"></div>
                <div class="absolute top-2.5 left-2.5">
                  <span class="text-[9px] font-black px-2 py-0.5 rounded-md text-white/90 uppercase tracking-wider" style="background: <%= accent %>cc"><%= section[:category].display_name %></span>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-3">
                  <h3 class="text-[15px] font-black text-white line-clamp-2 leading-snug tracking-tight group-hover:text-orange-200 transition-colors"><%= mobile_lead.display_title %></h3>
                  <div class="flex items-center gap-1.5 mt-1.5">
                    <span class="text-[10px] text-white/40"><%= mobile_lead.region.display_name %></span>
                    <span class="text-white/20">&middot;</span>
                    <span class="text-[10px] text-white/30"><%= mobile_lead.published_at&.strftime("%d %b") %></span>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
          <% if section[:items].size > 1 %>
            <div class="space-y-1">
              <% section[:items].drop(1).each_with_index do |item, idx| %>
                <%= link_to news_path(item), class: "group flex items-center gap-2.5 p-2 rounded-lg hover:bg-gray-50 transition-colors" do %>
                  <span class="text-[13px] font-black w-4 text-center shrink-0" style="color: <%= accent %>88"><%= idx + 2 %></span>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-[13px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                  </div>
                  <div class="w-12 h-10 rounded-md overflow-hidden shrink-0">
                    <% if item.cover_image.attached? %>
                      <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                    <% else %>
                      <div class="w-full h-full gradient-brand-soft"></div>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# Desktop: lead image + list layout %>
      <% lead = section[:items].first %>
      <% rest = section[:items].drop(1) %>
      <div class="hidden sm:block">
        <% if lead %>
          <div class="<%= rest.any? ? 'flex gap-5' : '' %>">
            <div class="<%= rest.any? ? 'w-1/2 shrink-0' : 'w-full' %>">
              <%= link_to news_path(lead), class: "group block rounded-xl overflow-hidden card-lift" do %>
                <div class="relative aspect-[16/10] overflow-hidden">
                  <% if lead.cover_image.attached? %>
                    <%= optimized_image_tag lead.cover_image, variant: :card, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-full gradient-brand-soft"></div>
                  <% end %>
                  <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.25) 45%, transparent 100%)"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-4 lg:p-5">
                    <h3 class="text-base lg:text-lg font-black text-white group-hover:text-orange-200 transition-colors line-clamp-3 leading-snug tracking-tight drop-shadow-md"><%= lead.display_title %></h3>
                    <p class="text-[12px] text-white/50 line-clamp-1 leading-relaxed mt-1"><%= lead.region.display_name %> &middot; <%= lead.published_at&.strftime("%d %b") %></p>
                  </div>
                </div>
              <% end %>
            </div>
            <% if rest.any? %>
              <div class="flex-1 min-w-0 flex flex-col gap-1">
                <% rest.each do |item| %>
                  <%= link_to news_path(item), class: "group flex gap-3 p-2.5 rounded-lg hover:bg-orange-50/60 transition-colors" do %>
                    <div class="w-20 h-14 rounded-lg overflow-hidden shrink-0">
                      <% if item.cover_image.attached? %>
                        <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                      <% else %>
                        <div class="w-full h-full gradient-brand-soft"></div>
                      <% end %>
                    </div>
                    <div class="flex-1 min-w-0 flex flex-col justify-center">
                      <h3 class="text-[13px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                      <span class="text-[11px] text-gray-400 mt-0.5"><%= item.region.display_name %> &middot; <%= item.published_at&.strftime("%d %b") %></span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
