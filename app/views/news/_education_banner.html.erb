<%# ═══════════════════════════════════════════════════════════════════
    EDUCATION BANNER — CTA card linking to education section
    Requires: @education_news (shown only when present)
    ═══════════════════════════════════════════════════════════════════ %>
<% if @education_news.present? %>
  <%= link_to education_index_path, class: "block group my-3 -mx-4 px-4 sm:mx-0 sm:px-0" do %>
    <div class="rounded-xl relative overflow-hidden text-white px-4 py-3 flex items-center gap-3"
         style="background: linear-gradient(150deg, #312e81 0%, #4338ca 35%, #6366f1 65%, #818cf8 100%); box-shadow: 0 6px 28px -6px rgba(79,70,229,0.55); border: 1.5px solid rgba(199,210,254,0.25)">
      <div class="absolute top-0 left-0 right-0 h-[3px] pointer-events-none" style="background: linear-gradient(90deg,#312e81,#4338ca,#6366f1,#818cf8,#6366f1,#4338ca,#312e81)"></div>
      <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
        <div class="absolute -top-8 -left-8 w-40 h-40 rounded-full" style="border: 16px solid rgba(255,255,255,0.08)"></div>
        <div class="absolute -bottom-12 left-20 w-32 h-32 rounded-full" style="border: 12px solid rgba(255,255,255,0.06)"></div>
        <div class="absolute top-1/2 -translate-y-1/2 -right-8 w-28 h-28 rounded-full" style="border: 10px solid rgba(255,255,255,0.07)"></div>
      </div>
      <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 relative z-10"
           style="background: rgba(255,255,255,0.15); box-shadow: 0 0 18px rgba(255,255,255,0.1)">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/>
          <path stroke-linecap="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0 relative z-10">
        <h3 class="font-black text-[13px] leading-tight mb-0.5"><%= I18n.locale == :hi ? "शिक्षा समाचार" : "Education News" %></h3>
        <p class="text-[11px] leading-snug" style="color: rgba(255,255,255,0.65)"><%= I18n.locale == :hi ? "डिग्री, परीक्षा और प्रवेश अपडेट" : "Degree, exam & admission updates" %></p>
      </div>
      <svg class="w-4 h-4 shrink-0 relative z-10 group-hover:translate-x-0.5 transition-transform" style="color:rgba(255,255,255,0.45)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" d="M9 5l7 7-7 7"/>
      </svg>
    </div>
  <% end %>
<% end %>
