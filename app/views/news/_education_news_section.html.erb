<%# ═══════════════════════════════════════════════════════════════════
    EDUCATION NEWS SECTION — degree/exam/admission news list
    Requires: @education_news
    ═══════════════════════════════════════════════════════════════════ %>
<% if @education_news.present? %>
  <%= render "shared/billboard_feed" %>
  <div class="py-3 sm:py-5 lg:py-8 border-t border-gray-100" data-reveal>
    <div class="flex items-center gap-3 mb-3 lg:mb-5">
      <div class="w-1 h-6 rounded-full shrink-0" style="background: linear-gradient(180deg, #6366f1, #4338ca)"></div>
      <h2 class="text-lg sm:text-xl lg:text-2xl font-black text-gray-900 tracking-tight"><%= I18n.locale == :hi ? "शिक्षा समाचार" : "Education News" %></h2>
      <div class="flex-1 h-px bg-gray-100"></div>
      <%= link_to education_index_path(category: :degree_news), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 px-2.5 py-1 rounded-full transition-all" do %>
        <%= I18n.locale == :hi ? "और देखें" : "View All" %>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="space-y-2 sm:hidden">
      <% @education_news.each do |post| %>
        <%= link_to education_path(post), class: "group news-list-row" do %>
          <div class="self-stretch overflow-hidden shrink-0" style="width:10rem; margin-left:-0.5rem; margin-top:-0.75rem; margin-bottom:-0.75rem;">
            <% if post.cover_image.attached? %>
              <%= optimized_image_tag post.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-indigo-50 to-violet-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/></svg>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0 flex flex-col justify-center">
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= post.display_title %></h3>
          </div>
        <% end %>
      <% end %>
    </div>
    <div class="hidden sm:grid sm:grid-cols-2 gap-3 lg:gap-5">
      <% @education_news.each do |post| %>
        <%= link_to education_path(post), class: "group flex gap-3 p-3 rounded-xl bg-white border border-gray-100 hover:border-indigo-200 hover:shadow-md hover:shadow-indigo-50 transition-all" do %>
          <div class="w-20 h-16 rounded-lg overflow-hidden shrink-0">
            <% if post.cover_image.attached? %>
              <%= optimized_image_tag post.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-indigo-50 to-violet-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/></svg>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0 flex flex-col justify-center">
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= post.display_title %></h3>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
