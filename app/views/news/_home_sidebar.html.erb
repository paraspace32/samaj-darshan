<%# Sticky right sidebar — desktop home page only %>
<aside class="hidden lg:block lg:w-80 shrink-0" style="border-left: 1px solid rgba(229,231,235,0.8)">
  <div class="sticky top-4 space-y-5 max-h-[calc(100vh-2rem)] overflow-y-auto scrollbar-hide pl-6">

    <%# ── Marriage ad (desktop sidebar) ─────────────── %>
    <%= render "shared/billboard_marriage" %>

    <%# ── Sidebar ad slot #1 ──────────────────────────── %>
    <%= render "shared/billboard_sidebar" %>

    <%# ── Latest News ────────────────────────────────── %>
    <% if @latest_news_tab.present? %>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <div class="flex items-center gap-2.5 mb-3">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h3 class="text-[13px] font-black text-gray-900">
            <%= I18n.locale == :hi ? "ताज़ा ख़बरें" : "Latest News" %>
          </h3>
        </div>
        <div class="space-y-0.5">
          <% @latest_news_tab.each do |item| %>
            <%= link_to news_path(item), class: "group flex items-start gap-2.5 px-1.5 py-2 rounded-lg hover:bg-orange-50/60 transition-colors" do %>
              <div class="w-16 h-12 rounded-lg overflow-hidden shrink-0 mt-0.5">
                <% if item.cover_image.attached? %>
                  <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft"></div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="text-[12px] font-semibold text-gray-700 group-hover:text-orange-700 line-clamp-2 leading-snug"><%= item.display_title %></h4>
                <span class="text-[10px] text-gray-400 mt-0.5 block"><%= item.published_at&.strftime("%d %b, %I:%M %p") %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Most Read Today ─────────────────────────────── %>
    <% if @trending.present? %>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <div class="flex items-center gap-2.5 mb-3">
          <div class="w-1 h-5 rounded-full bg-red-500 shrink-0"></div>
          <h3 class="text-[13px] font-black text-gray-900">
            <%= I18n.locale == :hi ? "सर्वाधिक पढ़ा गया" : "Most Read" %>
          </h3>
        </div>
        <div class="space-y-0.5">
          <% @trending.each_with_index do |item, idx| %>
            <%= link_to news_path(item), class: "group flex items-start gap-3 px-2 py-2.5 rounded-xl hover:bg-orange-50 transition-colors" do %>
              <span class="text-2xl font-black leading-none w-7 shrink-0 mt-0.5 select-none" style="color: rgba(249,115,22,<%= idx < 3 ? '0.5' : '0.2' %>)"><%= "%02d" % (idx + 1) %></span>
              <div class="flex-1 min-w-0">
                <h4 class="text-[12px] font-semibold text-gray-700 group-hover:text-orange-700 line-clamp-2 leading-snug"><%= item.display_title %></h4>
                <% if idx < 3 %>
                  <div class="mt-1 h-0.5 w-8 rounded-full bg-orange-400/30"></div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Sidebar ad slot #2 ──────────────────────────── %>
    <%= render "shared/billboard_feed" %>

    <%# ── Upcoming Webinar ─────────────────────────────── %>
    <% if @upcoming_webinar.present? %>
      <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
        <div class="px-4 pt-3 pb-2">
          <div class="flex items-center gap-2.5">
            <div class="w-1 h-5 rounded-full bg-violet-500 shrink-0"></div>
            <h3 class="text-[13px] font-black text-gray-900">
              <%= I18n.locale == :hi ? "आगामी वेबिनार" : "Upcoming Webinar" %>
            </h3>
          </div>
        </div>
        <%= link_to webinar_path(@upcoming_webinar), class: "group block px-4 pb-3" do %>
          <% if @upcoming_webinar.cover_image.attached? %>
            <div class="w-full aspect-video rounded-lg overflow-hidden mb-2">
              <%= optimized_image_tag @upcoming_webinar.cover_image, variant: :card, class: "w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300", loading: "lazy" %>
            </div>
          <% end %>
          <h4 class="text-[13px] font-bold text-gray-800 group-hover:text-orange-600 line-clamp-2 leading-snug"><%= @upcoming_webinar.title %></h4>
          <p class="text-[11px] text-gray-400 mt-1"><%= @upcoming_webinar.scheduled_at&.strftime("%d %b %Y, %I:%M %p") %></p>
        <% end %>
      </div>
    <% end %>

    <%# ── Explore categories ───────────────────────────── %>
    <% if @categories.present? %>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <div class="flex items-center gap-2.5 mb-3">
          <div class="w-1 h-5 rounded-full bg-orange-500 shrink-0"></div>
          <h3 class="text-[13px] font-black text-gray-900"><%= t("feed.explore_categories") %></h3>
        </div>
        <div class="flex flex-wrap gap-1.5">
          <% @categories.each do |c| %>
            <%= link_to category_feed_path(slug: c.slug), class: "text-[11px] font-semibold px-2.5 py-1 rounded-full bg-gray-100 text-gray-600 hover:bg-orange-100 hover:text-orange-700 transition-colors" do %>
              <%= c.display_name %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Quick Links ──────────────────────────────────── %>
    <div class="bg-white rounded-2xl border border-gray-100 p-4">
      <div class="flex items-center gap-2.5 mb-3">
        <div class="w-1 h-5 rounded-full bg-gray-400 shrink-0"></div>
        <h3 class="text-[13px] font-black text-gray-900">
          <%= I18n.locale == :hi ? "त्वरित लिंक" : "Quick Links" %>
        </h3>
      </div>
      <div class="grid grid-cols-2 gap-1.5">
        <%= link_to biodatas_path, class: "text-[11px] font-semibold px-3 py-2 rounded-lg bg-orange-50 text-orange-700 hover:bg-orange-100 transition-colors text-center" do %>
          <%= t("nav.marriage") %>
        <% end %>
        <%= link_to tributes_path, class: "text-[11px] font-semibold px-3 py-2 rounded-lg bg-pink-50 text-pink-700 hover:bg-pink-100 transition-colors text-center" do %>
          <%= t("nav.tributes") %>
        <% end %>
        <%= link_to education_index_path, class: "text-[11px] font-semibold px-3 py-2 rounded-lg bg-indigo-50 text-indigo-700 hover:bg-indigo-100 transition-colors text-center" do %>
          <%= I18n.locale == :hi ? "शिक्षा" : "Education" %>
        <% end %>
        <%= link_to jobs_path, class: "text-[11px] font-semibold px-3 py-2 rounded-lg bg-sky-50 text-sky-700 hover:bg-sky-100 transition-colors text-center" do %>
          <%= I18n.locale == :hi ? "रोजगार" : "Jobs" %>
        <% end %>
      </div>
    </div>

    <%# ── Sidebar ad slot #3 ──────────────────────────── %>
    <%= render "shared/billboard_feed" %>

  </div>
</aside>
