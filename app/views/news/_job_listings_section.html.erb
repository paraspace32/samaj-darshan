<%# ═══════════════════════════════════════════════════════════════════
    JOB LISTINGS SECTION — job postings (mobile list + desktop slider)
    Requires: @job_listings
    ═══════════════════════════════════════════════════════════════════ %>
<% if @job_listings.present? %>
  <%= render "shared/billboard_feed" %>
  <div class="py-3 sm:py-5 lg:py-8 border-t border-gray-100" data-reveal>
    <div class="flex items-center gap-3 mb-3 lg:mb-5">
      <div class="w-1 h-6 rounded-full shrink-0" style="background: linear-gradient(180deg, #0ea5e9, #0284c7)"></div>
      <h2 class="text-lg sm:text-xl lg:text-2xl font-black text-gray-900 tracking-tight"><%= t("feed.job_news") %></h2>
      <div class="flex-1 h-px bg-gray-100"></div>
      <%= link_to jobs_path, class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-sky-600 bg-sky-50 hover:bg-sky-100 px-2.5 py-1 rounded-full transition-all" do %>
        <%= I18n.locale == :hi ? "और देखें" : "View All" %>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>

    <%# Mobile: compact list rows %>
    <div class="sm:hidden space-y-2">
      <% @job_listings.each do |post| %>
        <%= link_to job_path(post), class: "group news-list-row" do %>
          <div class="self-stretch overflow-hidden shrink-0" style="width:7.5rem; margin-left:-0.5rem; margin-top:-0.75rem; margin-bottom:-0.75rem;">
            <% if post.cover_image.attached? %>
              <%= optimized_image_tag post.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-sky-50 to-cyan-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0 flex flex-col justify-center">
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= post.display_title %></h3>
            <div class="flex items-center gap-1.5">
              <% if post.deadline_passed? %>
                <span class="text-[11px] font-bold text-red-500"><%= t("jobs.closed") %></span>
              <% end %>
              <span class="text-[11px] text-gray-400 truncate"><%= post.company_name %><% if post.location.present? %> · <%= post.location %><% end %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Desktop: horizontal slider %>
    <div class="hidden sm:block"><div class="horizontal-slider">
      <% @job_listings.each do |post| %>
        <%= link_to job_path(post), class: "group slider-card" do %>
          <% if post.cover_image.attached? %>
            <div class="slider-img-wrap">
              <%= optimized_image_tag post.cover_image, variant: :card, class: "w-full h-36 sm:h-40 object-cover img-zoom", loading: "lazy" %>
            </div>
          <% else %>
            <div class="slider-img-wrap">
              <div class="w-full h-36 sm:h-40 bg-gradient-to-br from-sky-50 to-cyan-50 flex items-center justify-center">
                <svg class="w-10 h-10 text-sky-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
            </div>
          <% end %>
          <div class="p-3">
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-1.5"><%= post.display_title %></h3>
            <div class="flex flex-wrap items-center gap-1.5">
              <% if post.deadline_passed? %>
                <span class="text-[10px] font-bold px-2 py-0.5 rounded-md text-red-600 bg-red-50 border border-red-100"><%= t("jobs.closed") %></span>
              <% end %>
            </div>
            <div class="flex items-center gap-2 mt-1.5">
              <span class="text-[11px] text-gray-400 truncate"><%= post.company_name %></span>
              <% if post.location.present? %>
                <span class="text-[11px] text-gray-300">&middot;</span>
                <span class="text-[11px] text-gray-400 truncate"><%= post.location %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div></div>
  </div>
<% end %>
