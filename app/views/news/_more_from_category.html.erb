<%# ═══════════════════════════════════════════════════════════════════
    MORE FROM CATEGORY — grid of articles from the same category
    Requires: @category_articles, @news_item (for category name/slug)
    ═══════════════════════════════════════════════════════════════════ %>
<% if @category_articles.present? %>
  <%= render "shared/billboard_feed" %>
  <div class="mt-10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#f97316,#ea580c)"></div>
      <h2 class="text-base font-black text-gray-900 tracking-tight whitespace-nowrap"><%= @news_item.category.display_name %></h2>
      <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fed7aa,transparent)"></div>
      <%= link_to category_feed_path(slug: @news_item.category.slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-700 bg-orange-100 hover:bg-orange-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
        <%= I18n.locale == :hi ? "और देखें" : "View All" %>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% @category_articles.first(4).each do |art| %>
        <%= link_to news_path(art),
              class: "group flex gap-3 p-3 rounded-2xl border border-gray-200/40 bg-white hover:bg-orange-50/30
                      hover:border-orange-200/50 hover:shadow-md hover:shadow-orange-100/30 transition-all duration-200 no-underline" do %>
          <% if art.cover_image.attached? %>
            <div class="shrink-0 overflow-hidden rounded-xl border border-gray-200/30">
              <%= optimized_image_tag art.cover_image, variant: :thumb, class: "w-16 h-12 object-cover img-zoom", loading: "lazy" %>
            </div>
          <% else %>
            <div class="w-16 h-12 rounded-xl gradient-brand-soft border border-orange-100/60 flex items-center justify-center shrink-0">
              <span class="text-orange-300 font-black text-[10px]"><%= t("brand.logo_letter") %></span>
            </div>
          <% end %>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-bold text-stone-800 line-clamp-2 leading-snug group-hover:text-orange-700 transition-colors mb-1"><%= art.display_title %></p>
            <span class="text-[10px] text-stone-400 font-medium"><%= art.region.display_name %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
