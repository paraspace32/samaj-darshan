<% idx ||= 0 %>
<% cache [ news_item, I18n.locale, "list3", ENV.fetch("CACHE_VERSION", "v1") ] do %>
  <div class="animate-fade-in" style="animation-delay: <%= idx * 40 %>ms">
    <%= link_to news_path(news_item), class: "group news-list-row" do %>
      <%# Image flush to edges — no padding, self-stretches to full row height %>
      <div class="self-stretch overflow-hidden shrink-0" style="width:7.5rem; margin-left:-0.5rem; margin-top:-0.75rem; margin-bottom:-0.75rem;">
        <% if news_item.cover_image.attached? %>
          <%= optimized_image_tag news_item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
        <% else %>
          <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
            <span class="text-lg text-orange-300/70 font-black"><%= t("brand.logo_letter") %></span>
          </div>
        <% end %>
      </div>
      <div class="flex-1 min-w-0 flex flex-col justify-between py-1 pl-1">
        <h2 class="text-[15px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-2"><%= news_item.display_title %></h2>
        <div class="flex items-center gap-2 text-[11px] text-gray-400 flex-wrap">
          <span class="font-bold text-orange-600 truncate max-w-[90px]"><%= news_item.category.display_name %></span>
          <% if news_item.region&.display_name.present? %>
            <span class="text-gray-300">&middot;</span>
            <span class="truncate max-w-[80px]"><%= news_item.region.display_name %></span>
          <% end %>
          <span class="text-gray-300 ml-auto">&middot;</span>
          <span class="inline-flex items-center gap-0.5">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            <%= news_item.likes_count %>
          </span>
          <span class="inline-flex items-center gap-0.5">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            <%= news_item.comments_count %>
          </span>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
