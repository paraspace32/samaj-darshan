<%# ═══════════════════════════════════════════════════════════════════
    NEWS SIDEBAR — regions + categories navigation for filtered views
    Requires: @regions, @categories, @region, @category
    ═══════════════════════════════════════════════════════════════════ %>
<aside class="lg:w-72 shrink-0 space-y-6">
  <div class="surface-raised rounded-2xl p-5">
    <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <%= t("feed.regions") %>
    </h3>
    <ul class="space-y-0.5">
      <li>
        <%= link_to root_path, class: "flex items-center gap-2 px-3 py-2 text-sm rounded-lg transition-all #{@region.nil? && @category.nil? ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
          <%= t("feed.all_regions") %>
        <% end %>
      </li>
      <% @regions.each do |r| %>
        <li>
          <%= link_to r.display_name, region_feed_path(slug: r.slug), class: "block px-3 py-2 text-sm rounded-lg transition-all #{@region&.id == r.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" %>
        </li>
      <% end %>
    </ul>
  </div>
  <div class="hidden lg:block surface-raised rounded-2xl p-5">
    <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
      <%= t("feed.categories") %>
    </h3>
    <ul class="space-y-0.5">
      <% @categories.each do |c| %>
        <li>
          <%= link_to category_feed_path(slug: c.slug), class: "flex items-center gap-2.5 px-3 py-2 text-sm rounded-lg transition-all #{@category&.id == c.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
            <span class="w-2.5 h-2.5 rounded-full shrink-0 ring-2 ring-white shadow-sm" style="background-color:#f97316"></span>
            <%= c.display_name %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</aside>
