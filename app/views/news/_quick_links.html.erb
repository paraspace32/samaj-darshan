<%# ═══════════════════════════════════════════════════════════════════
    QUICK LINKS — Webinars/Education/Jobs/Marriage CTA + visitor map
    Desktop: cards left, map right. Mobile: cards then map stacked.
    Requires: @active_users, @visitor_stats (for visitor_map)
    ═══════════════════════════════════════════════════════════════════ %>
<div class="border-t border-gray-100 mt-3 pt-3 sm:mt-5 sm:pt-5 lg:mt-8 lg:pt-8" data-reveal>
  <div class="flex flex-col lg:flex-row lg:gap-8 lg:items-start">

    <%# ── Cards: after map on mobile, right on desktop ── %>
    <div class="order-2 mt-4 lg:mt-0 lg:flex-1 lg:min-w-0 lg:order-2">
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4" data-reveal-stagger>

        <%# ── Webinars ── %>
        <%= link_to webinars_path, class: "group block rounded-2xl p-3 sm:p-4 relative overflow-hidden transition-all active:scale-[0.97]", style: "background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); box-shadow: 0 4px 20px rgba(15,23,42,0.35)" do %>
          <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full opacity-10" style="background: radial-gradient(circle, #f97316, transparent)"></div>
          <div class="flex items-center gap-2.5 mb-1.5">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: linear-gradient(135deg, rgba(249,115,22,0.3), rgba(249,115,22,0.15)); border: 1px solid rgba(249,115,22,0.25)">
              <svg class="w-4 h-4 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="font-black text-[13px] text-white leading-tight"><%= t("feed.view_all_webinars") %></h3>
          </div>
          <p class="text-[11px] text-white/45 line-clamp-1 leading-relaxed mb-1.5"><%= t("webinar.subtitle") %></p>
          <div class="flex items-center gap-1 text-orange-400/70 text-[11px] font-bold">
            <%= I18n.locale == :hi ? "देखें" : "Explore" %>
            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>

        <%# ── Education ── %>
        <%= link_to education_index_path, class: "group block rounded-2xl p-3 sm:p-4 relative overflow-hidden transition-all active:scale-[0.97]", style: "background: linear-gradient(135deg, #3730a3 0%, #6366f1 100%); box-shadow: 0 4px 20px rgba(99,102,241,0.35)" do %>
          <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full opacity-10" style="background: radial-gradient(circle, white, transparent)"></div>
          <div class="flex items-center gap-2.5 mb-1.5">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.2)">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
            </div>
            <h3 class="font-black text-[13px] text-white leading-tight"><%= t("feed.view_all_education") %></h3>
          </div>
          <p class="text-[11px] text-white/45 line-clamp-1 leading-relaxed mb-1.5"><%= t("feed.education_news_subtitle") %></p>
          <div class="flex items-center gap-1 text-indigo-200/70 text-[11px] font-bold">
            <%= I18n.locale == :hi ? "देखें" : "Explore" %>
            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>

        <%# ── Jobs ── %>
        <%= link_to jobs_path, class: "group block rounded-2xl p-3 sm:p-4 relative overflow-hidden transition-all active:scale-[0.97]", style: "background: linear-gradient(135deg, #0369a1 0%, #0ea5e9 100%); box-shadow: 0 4px 20px rgba(14,165,233,0.35)" do %>
          <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full opacity-10" style="background: radial-gradient(circle, white, transparent)"></div>
          <div class="flex items-center gap-2.5 mb-1.5">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.2)">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="font-black text-[13px] text-white leading-tight"><%= t("feed.view_all_jobs") %></h3>
          </div>
          <p class="text-[11px] text-white/45 line-clamp-1 leading-relaxed mb-1.5"><%= t("feed.job_news_subtitle") %></p>
          <div class="flex items-center gap-1 text-sky-200/70 text-[11px] font-bold">
            <%= I18n.locale == :hi ? "देखें" : "Explore" %>
            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>

        <%# ── Marriage ── %>
        <%= link_to biodatas_path, class: "group block rounded-2xl p-3 sm:p-4 relative overflow-hidden transition-all active:scale-[0.97]", style: "background: linear-gradient(135deg, #7c2d12 0%, #c2410c 50%, #ea580c 100%); box-shadow: 0 4px 20px rgba(194,65,12,0.4)" do %>
          <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full opacity-10" style="background: radial-gradient(circle, #fbbf24, transparent)"></div>
          <div class="flex items-center gap-2.5 mb-1.5">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.2)">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
            </div>
            <h3 class="font-black text-[13px] text-white leading-tight"><%= t("nav.marriage") %></h3>
          </div>
          <p class="text-[11px] text-white/45 line-clamp-1 leading-relaxed mb-1.5"><%= t("feed.marriage_ads_subtitle") %></p>
          <div class="flex items-center gap-1 text-orange-200/70 text-[11px] font-bold">
            <%= I18n.locale == :hi ? "देखें" : "Explore" %>
            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>

        <%# ── Tributes ── %>
        <%= link_to tributes_path, class: "group block rounded-2xl p-3 sm:p-4 relative overflow-hidden transition-all active:scale-[0.97]", style: "background: linear-gradient(135deg, #831843 0%, #be185d 50%, #ec4899 100%); box-shadow: 0 4px 20px rgba(190,24,93,0.4)" do %>
          <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full opacity-10" style="background: radial-gradient(circle, #fce7f3, transparent)"></div>
          <div class="flex items-center gap-2.5 mb-1.5">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.2)">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </div>
            <h3 class="font-black text-[13px] text-white leading-tight"><%= t("nav.tributes") %></h3>
          </div>
          <p class="text-[11px] text-white/45 line-clamp-1 leading-relaxed mb-1.5"><%= t("tributes.subtitle") %></p>
          <div class="flex items-center gap-1 text-pink-200/70 text-[11px] font-bold">
            <%= I18n.locale == :hi ? "देखें" : "Explore" %>
            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>

        <%# ── Magazines ── %>
        <%= link_to magazines_path, class: "group block rounded-2xl p-3 sm:p-4 relative overflow-hidden transition-all active:scale-[0.97]", style: "background: linear-gradient(135deg, #064e3b 0%, #059669 50%, #10b981 100%); box-shadow: 0 4px 20px rgba(5,150,105,0.4)" do %>
          <div class="absolute -top-6 -right-6 w-24 h-24 rounded-full opacity-10" style="background: radial-gradient(circle, #d1fae5, transparent)"></div>
          <div class="flex items-center gap-2.5 mb-1.5">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0 shadow-lg" style="background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.2)">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <h3 class="font-black text-[13px] text-white leading-tight"><%= I18n.locale == :hi ? "पत्रिकाएँ" : "Magazines" %></h3>
          </div>
          <p class="text-[11px] text-white/45 line-clamp-1 leading-relaxed mb-1.5"><%= I18n.locale == :hi ? "समाज की मासिक पत्रिका" : "Community monthly magazine" %></p>
          <div class="flex items-center gap-1 text-emerald-200/70 text-[11px] font-bold">
            <%= I18n.locale == :hi ? "देखें" : "Explore" %>
            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>

      </div>
    </div>

    <%# ── Map: first on mobile, left on desktop ── %>
    <div class="order-1 lg:mt-0 lg:w-[480px] lg:shrink-0 lg:order-1">
      <%# Load visitor map via lazy Turbo Frame — never blocks main page render %>
      <%= turbo_frame_tag "visitor_map", src: visitor_map_path, loading: :lazy do %>
        <div class="rounded-2xl bg-gray-50 animate-pulse" style="height:320px;"></div>
      <% end %>
    </div>

  </div>
</div>
