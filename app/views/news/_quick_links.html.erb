<%# ═══════════════════════════════════════════════════════════════════
    QUICK LINKS — visitor map + Webinars/Education/Jobs/Marriage CTA grid
    Requires: @active_users, @visitor_stats (for visitor_map)
    ═══════════════════════════════════════════════════════════════════ %>
<%= render "shared/visitor_map", realtime: @active_users, reporting: @visitor_stats %>

<div class="border-t border-gray-100 mt-3 pt-3 sm:mt-5 sm:pt-5" data-reveal>
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-2.5 sm:gap-4" data-reveal-stagger>
    <%= link_to webinars_path, class: "group block rounded-2xl p-3.5 sm:p-5 relative overflow-hidden transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-gray-200", style: "background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%)" do %>
      <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg sm:rounded-xl flex items-center justify-center mb-2 sm:mb-3" style="background: rgba(249,115,22,0.15)">
        <svg class="w-4.5 h-4.5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="font-bold text-[13px] text-white leading-tight mb-0.5"><%= t("feed.view_all_webinars") %></h3>
      <p class="text-[11px] text-white/35 line-clamp-1"><%= t("webinar.subtitle") %></p>
      <svg class="absolute top-4 right-4 w-4 h-4 text-white/15 group-hover:text-white/30 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <% end %>

    <%= link_to education_index_path, class: "group block rounded-2xl p-3.5 sm:p-5 relative overflow-hidden transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-100", style: "background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%)" do %>
      <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg sm:rounded-xl flex items-center justify-center mb-2 sm:mb-3" style="background: rgba(255,255,255,0.15)">
        <svg class="w-4.5 h-4.5 text-indigo-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
      </div>
      <h3 class="font-bold text-[13px] text-white leading-tight mb-0.5"><%= t("feed.view_all_education") %></h3>
      <p class="text-[11px] text-white/35 line-clamp-1"><%= t("feed.education_news_subtitle") %></p>
      <svg class="absolute top-4 right-4 w-4 h-4 text-white/15 group-hover:text-white/30 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <% end %>

    <%= link_to jobs_path, class: "group block rounded-2xl p-3.5 sm:p-5 relative overflow-hidden transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-sky-100", style: "background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%)" do %>
      <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg sm:rounded-xl flex items-center justify-center mb-2 sm:mb-3" style="background: rgba(255,255,255,0.15)">
        <svg class="w-4.5 h-4.5 text-sky-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="font-bold text-[13px] text-white leading-tight mb-0.5"><%= t("feed.view_all_jobs") %></h3>
      <p class="text-[11px] text-white/35 line-clamp-1"><%= t("feed.job_news_subtitle") %></p>
      <svg class="absolute top-4 right-4 w-4 h-4 text-white/15 group-hover:text-white/30 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <% end %>

    <%= link_to biodatas_path, class: "group block rounded-2xl p-3.5 sm:p-5 relative overflow-hidden transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-orange-100", style: "background: linear-gradient(135deg, #9a3412 0%, #ea580c 100%)" do %>
      <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg sm:rounded-xl flex items-center justify-center mb-2 sm:mb-3" style="background: rgba(255,255,255,0.15)">
        <svg class="w-4.5 h-4.5 text-orange-200" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
        </svg>
      </div>
      <h3 class="font-bold text-[13px] text-white leading-tight mb-0.5"><%= t("nav.marriage") %></h3>
      <p class="text-[11px] text-white/35 line-clamp-1"><%= t("feed.marriage_ads_subtitle") %></p>
      <svg class="absolute top-4 right-4 w-4 h-4 text-white/15 group-hover:text-white/30 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <% end %>

    <%= link_to tributes_path, class: "group block rounded-2xl p-3.5 sm:p-5 relative overflow-hidden transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-pink-100", style: "background: linear-gradient(135deg, #9d174d 0%, #ec4899 100%)" do %>
      <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg sm:rounded-xl flex items-center justify-center mb-2 sm:mb-3" style="background: rgba(255,255,255,0.15)">
        <span class="text-lg">🌸</span>
      </div>
      <h3 class="font-bold text-[13px] text-white leading-tight mb-0.5"><%= t("nav.tributes") %></h3>
      <p class="text-[11px] text-white/35 line-clamp-1"><%= t("tributes.subtitle") %></p>
      <svg class="absolute top-4 right-4 w-4 h-4 text-white/15 group-hover:text-white/30 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    <% end %>
  </div>
</div>
