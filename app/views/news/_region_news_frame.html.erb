<%# ═══════════════════════════════════════════════════════════════════
    REGION NEWS FRAME — turbo-frame with region or latest news feed
    Requires: @news_items, @auto_region, @is_home
    ═══════════════════════════════════════════════════════════════════ %>
<% active_region_on_home = @auto_region %>
<turbo-frame id="region-news" target="_top">

<% if active_region_on_home.present? %>
  <%# ── Region news section ── %>
  <% region_extra = @news_items.to_a %>
  <% if region_extra.any? %>
    <div class="py-3 sm:py-5 lg:py-8">
      <div class="flex items-center gap-3 mb-3 lg:mb-5">
        <div class="w-1 h-6 rounded-full shrink-0" style="background: linear-gradient(180deg, #f97316, #ea580c)"></div>
        <h2 class="text-base sm:text-xl lg:text-2xl font-black text-gray-900 tracking-tight"><%= active_region_on_home.display_name %> <%= I18n.locale == :hi ? "समाचार" : "News" %></h2>
        <div class="flex-1 h-px bg-gray-100"></div>
        <%= link_to region_feed_path(slug: active_region_on_home.slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-600 hover:text-orange-700 px-2.5 py-1 rounded-full bg-orange-50 hover:bg-orange-100 transition-all" do %>
          <%= I18n.locale == :hi ? "और देखें" : "View All" %>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
      <div class="space-y-2 sm:hidden">
        <% region_extra.each_with_index do |item, idx| %>
          <%= link_to news_path(item), class: "group news-list-row" do %>
            <div class="w-28 self-stretch rounded-l-xl overflow-hidden shrink-0 -ml-[0.5rem] -my-[0.75rem]" style="min-width:7rem;">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-lg text-orange-300/70 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-between py-1 pl-1">
              <h3 class="text-[15px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-3 leading-snug tracking-tight mb-1"><%= item.display_title %></h3>
              <div class="flex items-center gap-1.5 text-[11.5px] text-gray-400">
                <span class="w-1.5 h-1.5 rounded-full shrink-0 bg-orange-400"></span>
                <span><%= item.region&.display_name %></span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      <div class="hidden sm:grid sm:grid-cols-2 gap-3 lg:gap-5">
        <% region_extra.each do |item| %>
          <%= link_to news_path(item), class: "group flex gap-3 p-3 rounded-xl bg-white border border-gray-100 hover:border-orange-200 hover:shadow-md hover:shadow-orange-50 transition-all card-lift" do %>
            <div class="w-28 h-24 rounded-lg overflow-hidden shrink-0">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
              <span class="text-[11px] text-gray-400 mt-0.5"><%= item.region&.display_name %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% elsif @is_home %>
  <%# ── Latest news (सभी active) ── %>
  <% latest_all = @news_items.to_a %>
  <% if latest_all.any? %>
    <div class="py-3 sm:py-5 lg:py-8">
      <div class="flex items-center gap-3 mb-3 lg:mb-5">
        <div class="w-1 h-6 rounded-full shrink-0" style="background: linear-gradient(180deg, #f97316, #ea580c)"></div>
        <h2 class="text-base sm:text-xl lg:text-2xl font-black text-gray-900 tracking-tight"><%= I18n.locale == :hi ? "ताज़ा समाचार" : "Latest News" %></h2>
        <div class="flex-1 h-px bg-gray-100"></div>
      </div>
      <div class="space-y-1.5 sm:hidden">
        <% latest_all.each_with_index do |item, idx| %>
          <%= link_to news_path(item), class: "group flex items-center gap-2.5 p-2 rounded-lg bg-white border border-gray-50 hover:border-orange-200 hover:shadow-sm transition-all" do %>
            <div class="w-16 h-14 rounded-lg overflow-hidden shrink-0">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <h3 class="text-[13px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
              <span class="text-[10px] text-gray-400 mt-0.5"><%= item.region&.display_name %></span>
            </div>
          <% end %>
        <% end %>
      </div>
      <div class="hidden sm:grid sm:grid-cols-2 gap-3 lg:gap-5">
        <% latest_all.each do |item| %>
          <%= link_to news_path(item), class: "group flex gap-3 p-3 rounded-xl bg-white border border-gray-100 hover:border-orange-200 hover:shadow-md hover:shadow-orange-50 transition-all card-lift" do %>
            <div class="w-28 h-24 rounded-lg overflow-hidden shrink-0">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
              <span class="text-[11px] text-gray-400 mt-0.5"><%= item.region&.display_name %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
</turbo-frame>
