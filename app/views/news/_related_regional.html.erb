<%# ═══════════════════════════════════════════════════════════════════
    RELATED REGIONAL — news from the same region (mobile only, article page)
    Requires: @related, @news_item (for region name/slug)
    ═══════════════════════════════════════════════════════════════════ %>
<% if @related.present? %>
  <div class="mt-10 lg:hidden">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#d97706,#b45309)"></div>
      <h2 class="text-base font-black text-gray-900 tracking-tight whitespace-nowrap"><%= @news_item.region&.display_name %> <%= I18n.locale == :hi ? "से और" : "News" %></h2>
      <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fde68a,transparent)"></div>
      <%= link_to region_feed_path(slug: @news_item.region&.slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-amber-700 bg-amber-100 hover:bg-amber-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
        <%= I18n.locale == :hi ? "और देखें" : "View All" %>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="space-y-2.5">
      <% @related.each do |rel| %>
        <%= link_to news_path(rel), class: "group news-list-row" do %>
          <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
            <% if rel.cover_image.attached? %>
              <%= optimized_image_tag rel.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0 flex flex-col justify-center">
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= rel.display_title %></h3>
            <span class="text-[11px] text-gray-400"><%= rel.category.display_name %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
