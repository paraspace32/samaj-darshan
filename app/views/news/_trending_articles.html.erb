<%# ═══════════════════════════════════════════════════════════════════
    TRENDING ARTICLES — ranked list by views/engagement
    Requires: @trending_articles
    ═══════════════════════════════════════════════════════════════════ %>
<% if @trending_articles.present? %>
  <%= render "shared/billboard_feed" %>
  <div class="mt-10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#f97316,#ea580c)"></div>
      <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse shrink-0"></span>
      <h2 class="text-base font-black text-gray-900 tracking-tight whitespace-nowrap"><%= I18n.locale == :hi ? "ट्रेंडिंग खबरें" : "Trending Now" %></h2>
      <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fed7aa,transparent)"></div>
    </div>
    <div class="divide-y divide-stone-100/80 rounded-2xl border border-gray-200/40 overflow-hidden">
      <% @trending_articles.each_with_index do |art, i| %>
        <%= link_to news_path(art),
              class: "group flex items-center gap-3 px-4 py-3.5 bg-white hover:bg-orange-50/40 transition-colors no-underline" do %>
          <span class="trending-rank text-xl shrink-0 leading-none w-7 text-center"><%= "%02d" % (i + 1) %></span>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-bold text-stone-800 line-clamp-2 leading-snug group-hover:text-orange-700 transition-colors tracking-tight mb-1"><%= art.display_title %></p>
            <div class="flex items-center gap-1.5">
              <span class="text-[10px] font-semibold text-stone-400"><%= art.region&.display_name %></span>
              <span class="text-stone-200 text-[10px]">·</span>
              <span class="text-[10px] font-semibold text-stone-400 flex items-center gap-0.5">
                <svg class="w-2.5 h-2.5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <%= number_with_delimiter(art.views_count) %>
              </span>
            </div>
          </div>
          <div class="w-16 h-[4.25rem] rounded-xl overflow-hidden shrink-0 border border-gray-200/40">
            <% if art.cover_image.attached? %>
              <%= optimized_image_tag art.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                <span class="text-orange-300 font-black text-xs"><%= t("brand.logo_letter") %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
