<%# ═══════════════════════════════════════════════════════════════════
    TRENDING SECTION — dark editorial ranked card list
    Requires: @trending
    ═══════════════════════════════════════════════════════════════════ %>
<% if @trending.present? %>
  <div class="-mx-4 lg:mx-0 lg:rounded-2xl overflow-hidden my-5 lg:my-10" data-reveal style="background: linear-gradient(160deg, #0f172a 0%, #1e293b 65%, #1a1731 100%); box-shadow: 0 8px 32px -8px rgba(15,23,42,0.45)">
    <div class="flex items-center gap-3 px-4 lg:px-5 py-3.5" style="border-bottom: 1px solid rgba(255,255,255,0.06)">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
      </span>
      <span class="text-[11px] font-black text-white/90 uppercase tracking-[0.15em]"><%= t("feed.trending") %></span>
      <div class="flex-1 h-px" style="background: linear-gradient(90deg, rgba(255,255,255,0.08), transparent)"></div>
      <span class="text-[10px] text-white/20 font-medium"><%= I18n.locale == :hi ? "सर्वाधिक पढ़े गए" : "Most Read" %></span>
    </div>

    <%# First trending item — featured hero card (mobile only) %>
    <% trend_hero = @trending.first %>
    <div class="sm:hidden">
      <%= link_to news_path(trend_hero), class: "group block relative overflow-hidden" do %>
        <div class="relative h-48">
          <% if trend_hero.cover_image.attached? %>
            <%= optimized_image_tag trend_hero.cover_image, variant: :card, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
          <% else %>
            <div class="w-full h-full" style="background: linear-gradient(135deg, rgba(249,115,22,0.2), rgba(234,88,12,0.08))"></div>
          <% end %>
          <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(15,23,42,0.95) 0%, rgba(15,23,42,0.4) 50%, rgba(15,23,42,0.2) 100%)"></div>
          <div class="absolute top-3 left-3 flex items-center gap-2">
            <span class="trending-rank text-3xl">01</span>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-md text-orange-300/90" style="background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.2)"><%= trend_hero.region&.display_name %></span>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-4">
            <h3 class="text-[15px] font-black text-white line-clamp-2 leading-snug tracking-tight group-hover:text-orange-200 transition-colors"><%= trend_hero.display_title %></h3>
            <div class="flex items-center gap-3 mt-2">
              <span class="flex items-center gap-1 text-[11px] text-white/40">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                <%= trend_hero.likes_count %>
              </span>
              <span class="flex items-center gap-1 text-[11px] text-white/40">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                <%= trend_hero.comments_count %>
              </span>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="sm:grid sm:grid-cols-2">
      <% @trending.each_with_index do |item, idx| %>
        <% trend_classes = "group flex items-center gap-3 sm:gap-4 px-4 lg:px-5 py-3.5 hover:bg-white/[0.03] transition-colors" %>
        <% trend_classes += " hidden sm:flex" if idx == 0 %>
        <%= link_to news_path(item), class: trend_classes, style: "border-bottom: 1px solid rgba(255,255,255,0.04)" do %>
          <span class="trending-rank text-xl sm:text-2xl"><%= "%02d" % (idx + 1) %></span>
          <div class="flex-1 min-w-0">
            <h3 class="text-[13px] sm:text-[15px] lg:text-base font-bold line-clamp-2 leading-snug tracking-tight mb-1 text-gray-100 group-hover:text-orange-300 transition-colors"><%= item.display_title %></h3>
            <div class="flex items-center gap-2.5 flex-wrap">
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-md text-orange-300/90" style="background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.2)"><%= item.region&.display_name %></span>
              <span class="flex items-center gap-1 text-[11px] text-gray-500">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                <%= item.likes_count %>
              </span>
              <span class="flex items-center gap-1 text-[11px] text-gray-500">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                <%= item.comments_count %>
              </span>
            </div>
          </div>
          <div class="w-20 h-20 sm:w-24 sm:h-24 lg:w-28 lg:h-28 rounded-xl overflow-hidden shrink-0 ring-1 ring-white/[0.06]">
            <% if item.cover_image.attached? %>
              <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(249,115,22,0.15), rgba(234,88,12,0.08))">
                <svg class="w-5 h-5 text-orange-500/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
