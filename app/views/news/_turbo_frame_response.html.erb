<%# ═══════════════════════════════════════════════════════════════════
    TURBO FRAME RESPONSE — region tab click response (non-home)
    Only rendered when Turbo-Frame header is present on non-home requests
    Requires: @region, @news_items
    ═══════════════════════════════════════════════════════════════════ %>
<% if request.headers["Turbo-Frame"].present? %>
  <turbo-frame id="region-news" target="_top">
    <% if @region.present? %>
      <div class="flex items-center gap-3 mb-3 pt-4">
        <div class="w-1 h-6 rounded-full shrink-0" style="background: linear-gradient(180deg, #f97316, #ea580c)"></div>
        <h2 class="text-lg font-black text-gray-900 tracking-tight"><%= @region.display_name %> <%= I18n.locale == :hi ? "समाचार" : "News" %></h2>
        <div class="flex-1 h-px bg-gray-100"></div>
      </div>
    <% end %>
    <div class="space-y-2 mb-4">
      <% @news_items.first(8).each do |item| %>
        <%= link_to news_path(item), class: "group news-list-row" do %>
          <div class="self-stretch overflow-hidden shrink-0" style="min-width:7.5rem; margin-left:-0.5rem; margin-top:-0.75rem; margin-bottom:-0.75rem;">
            <% if item.cover_image.attached? %>
              <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0 flex flex-col justify-center">
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= item.display_title %></h3>
            <span class="text-[11px] text-gray-400"><%= item.region&.display_name %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </turbo-frame>
<% end %>
