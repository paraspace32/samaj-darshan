                      <span class="text-[9px] font-black px-2 py-0.5 rounded-md text-white/90 uppercase tracking-wider" style="background: <%= accent %>cc"><%= section[:category].display_name %></span>
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 p-3">
                      <h3 class="text-[13px] font-bold text-white line-clamp-2 leading-snug tracking-tight group-hover:text-orange-200 transition-colors"><%= item.display_title %></h3>
                      <div class="flex items-center gap-1.5 mt-1.5">
                        <span class="text-[10px] text-white/40"><%= item.region.display_name %></span>
                        <span class="text-white/20">&middot;</span>
                        <span class="text-[10px] text-white/30"><%= item.published_at&.strftime("%d %b") %></span>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <%# EVEN sections: featured card + compact numbered list %>
            <% mobile_lead = section[:items].first %>
            <% if mobile_lead %>
              <%= link_to news_path(mobile_lead), class: "group block relative overflow-hidden rounded-xl mb-2" do %>
                <div class="relative h-44">
                  <% if mobile_lead.cover_image.attached? %>
                    <%= optimized_image_tag mobile_lead.cover_image, variant: :card, class: "w-full h-full object-cover", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-full gradient-brand-soft"></div>
                  <% end %>
                  <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.15) 55%, transparent 100%)"></div>
                  <div class="absolute top-2.5 left-2.5">
                    <span class="text-[9px] font-black px-2 py-0.5 rounded-md text-white/90 uppercase tracking-wider" style="background: <%= accent %>cc"><%= section[:category].display_name %></span>
                  </div>
                  <div class="absolute bottom-0 left-0 right-0 p-3">
                    <h3 class="text-[15px] font-black text-white line-clamp-2 leading-snug tracking-tight group-hover:text-orange-200 transition-colors"><%= mobile_lead.display_title %></h3>
                    <div class="flex items-center gap-1.5 mt-1.5">
                      <span class="text-[10px] text-white/40"><%= mobile_lead.region.display_name %></span>
                      <span class="text-white/20">&middot;</span>
                      <span class="text-[10px] text-white/30"><%= mobile_lead.published_at&.strftime("%d %b") %></span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
            <% if section[:items].size > 1 %>
