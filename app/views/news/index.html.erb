      <div class="-mx-4 sm:-mx-6">
        <div class="px-4 sm:px-6 py-2.5 flex items-center gap-3" style="background:<%= st[:hc] %>">
          <h2 class="text-sm sm:text-base font-black text-white tracking-tight whitespace-nowrap"><%= section[:category].display_name %></h2>
          <div class="flex-1 h-px bg-white/25"></div>
          <%= link_to category_feed_path(slug: section[:category].slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-white/90 hover:text-white whitespace-nowrap" do %>
            <%= I18n.locale == :hi ? "और देखें" : "View All" %>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
        <div class="px-4 sm:px-6 pt-3 pb-1" style="background-color:<%= st[:bg] %>; background-image:<%= st[:pattern] %>; border-bottom:1px solid #e5e7eb">

        <%# Mobile: compact news-list-row (no big image cards) %>
        <div class="sm:hidden space-y-2.5">
          <% section[:items].each do |item| %>
            <%= link_to news_path(item), class: "group news-list-row" do %>
              <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
                <% if item.cover_image.attached? %>
                  <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                    <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0 flex flex-col justify-center">
                <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= item.display_title %></h3>
                <span class="text-[11px] text-gray-400"><%= item.region.display_name %></span>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# Desktop: 4-column card grid for even sections, 2-col for odd %>
        <% if sec_idx.even? %>
          <div class="hidden sm:grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <% section[:items].each do |item| %>
              <%= link_to news_path(item), class: "group card-premium" do %>
                <div class="relative overflow-hidden">
                  <% if item.cover_image.attached? %>
                    <%= optimized_image_tag item.cover_image, variant: :card, class: "w-full h-36 object-cover img-zoom", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-36 gradient-brand-soft flex items-center justify-center">
                      <span class="text-2xl text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                </div>
                <div class="p-4">
                  <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-1"><%= item.display_title %></h3>
                  <span class="text-[11px] text-gray-400"><%= item.region.display_name %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="hidden sm:grid sm:grid-cols-2 gap-4">
            <% section[:items].each do |item| %>
              <%= link_to news_path(item), class: "group news-list-row surface-raised rounded-xl p-3" do %>
                <div class="w-24 h-20 rounded-lg overflow-hidden shrink-0">
                  <% if item.cover_image.attached? %>
                    <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                      <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0 flex flex-col justify-center">
                  <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= item.display_title %></h3>
                  <span class="text-[11px] text-gray-400"><%= item.region.display_name %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
        </div><%# close px wrapper %>
      </div><%# close full-bleed wrapper %>
    <% end %>
  <% end %>

  <%# ── TRENDING — dark slate themed card ─────────────────────────── %>
  <% if @trending.present? %>
    <div class="rounded-2xl overflow-hidden mb-4" style="background: linear-gradient(160deg, #0f172a 0%, #1e293b 65%, #1a1731 100%); box-shadow: 0 8px 32px -8px rgba(15,23,42,0.45)">
      <div class="flex items-center gap-3 px-4 py-3" style="border-bottom: 1px solid rgba(255,255,255,0.07)">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse shrink-0"></span>
        <span class="text-sm font-black text-white uppercase tracking-widest"><%= t("feed.trending") %></span>
        <div class="flex-1 h-px" style="background: linear-gradient(90deg, rgba(249,115,22,0.5), transparent)"></div>
      </div>
      <div class="divide-y divide-white/5">
        <% @trending.each_with_index do |item, idx| %>
          <%= link_to news_path(item), class: "group flex items-center gap-3 sm:gap-4 px-3 sm:px-4 py-3 transition-colors", style: "color: white" do %>
            <span class="trending-rank text-xl sm:text-2xl"><%= "%02d" % (idx + 1) %></span>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm sm:text-[15px] font-bold line-clamp-2 leading-snug tracking-tight mb-1.5 group-hover:text-orange-300 transition-colors" style="color: #f1f5f9"><%= item.display_title %></h3>
              <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
                <span class="text-[10px] font-bold px-2 py-0.5 rounded-md" style="background:rgba(249,115,22,0.22); color:#fdba74; border: 1px solid rgba(249,115,22,0.3)"><%= item.category.display_name %></span>
                <span class="flex items-center gap-1 text-[11px]" style="color: #94a3b8">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                  <%= item.likes_count %>
                </span>
                <span class="flex items-center gap-1 text-[11px]" style="color: #94a3b8">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                  <%= item.comments_count %>
                </span>
              </div>
            </div>
            <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl overflow-hidden shrink-0" style="box-shadow: 0 0 0 1px rgba(255,255,255,0.08)">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(249,115,22,0.15), rgba(234,88,12,0.08))">
                  <svg class="w-6 h-6" style="color:rgba(249,115,22,0.4)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

