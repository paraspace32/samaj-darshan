<% if @is_home %>
  <%# ── Marriage ad — first thing below the header ─────────────────── %>
  <%= render "shared/billboard_marriage" %>

  <%# ═══════════════════════════════════════════════════════════════════
      TRENDING TICKER — Aaj Tak-style horizontal scrolling topics
      ═══════════════════════════════════════════════════════════════════ %>
  <% if @trending.present? %>
    <div class="ticker-strip -mx-4 sm:-mx-6 px-4 sm:px-6 py-2 mb-3 mt-3">
      <div class="flex items-center gap-3">
        <span class="shrink-0 flex items-center gap-1.5 text-[11px] font-black uppercase tracking-wider text-orange-700">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
          <%= t("feed.trending") %>
        </span>
        <div class="w-px h-4 bg-gray-300 shrink-0"></div>
        <div class="overflow-hidden flex-1">
          <div class="ticker-scroll flex items-center gap-4">
            <% @trending.each do |item| %>
              <%= link_to item.display_title, news_path(item), class: "text-sm font-semibold text-gray-900 shrink-0 whitespace-nowrap" %>
              <span class="text-orange-300 shrink-0">&bull;</span>
            <% end %>
            <% @trending.each do |item| %>
              <%= link_to item.display_title, news_path(item), class: "text-sm font-semibold text-gray-900 shrink-0 whitespace-nowrap" %>
              <span class="text-orange-300 shrink-0">&bull;</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════
    Category pills — top of page on filtered/paged views only
    ═══════════════════════════════════════════════════════════════════ %>
<% unless @is_home %>
<div class="mb-3">
  <div class="flex items-center gap-2 overflow-x-auto pb-1 -mx-1 px-1 scrollbar-hide">
    <%= link_to root_path, class: "shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold transition-all #{ @region.nil? && @category.nil? ? 'gradient-brand text-white shadow-md shadow-orange-400/35' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
      <%= t("feed.all_regions") %>
    <% end %>
    <% @categories.each do |c| %>
      <%= link_to category_feed_path(slug: c.slug), class: "shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold transition-all #{ @category&.id == c.id ? 'gradient-brand text-white shadow-md shadow-orange-400/35' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
        <span class="w-1.5 h-1.5 rounded-full shrink-0 ring-1 ring-white/50" style="background-color:#f97316"></span>
        <%= c.display_name %>
      <% end %>
    <% end %>
  </div>
</div>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════
    Filtered view header (region / category)
    ═══════════════════════════════════════════════════════════════════ %>
<% if @region || @category %>
  <div class="mb-6 animate-fade-in">
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-2">
      <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-600 font-medium"><%= (@region || @category).display_name %></span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-black text-gray-900 tracking-tight"><%= (@region || @category).display_name %></h1>
    <p class="text-gray-500 mt-1">
      <% if @region %>
        <%= t("feed.news_from", name: @region.display_name) %>
      <% else %>
        <%= t("feed.news_in", name: @category.display_name) %>
      <% end %>
    </p>
  </div>
<% end %>

<% if @is_home %>
  <%# ═════════════════════════════════════════════════════════════════
      HOME PAGE — advanced multi-section layout
      ═════════════════════════════════════════════════════════════════ %>

  <%# ── HERO (full-bleed on mobile) + Top stories side stack ─────── %>
  <% if @featured.present? %>
    <%
      featured_path = case @featured_type
                      when :education then education_path(@featured)
                      when :job then job_path(@featured)
                      else news_path(@featured)
                      end
      featured_content = case @featured_type
                         when :job then @featured.display_description
                         else @featured.display_content
                         end
      featured_badge_label = case @featured_type
                             when :education then @featured.category_label
                             when :job then @featured.category_label
                             else @featured.category.display_name
                             end
      featured_badge_color = "#f97316"
      featured_sub_label = case @featured_type
                           when :education then t("education.title")
                           when :job then @featured.company_name
                           else @featured.region.display_name
                           end
    %>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 lg:gap-5 mb-4">
      <div class="lg:col-span-3 -mx-4 sm:mx-0 animate-fade-up">
        <%= link_to featured_path, class: "group block overflow-hidden sm:rounded-2xl glow-hero h-full" do %>

          <%# MOBILE: full cinematic overlay — title ON the image %>
          <div class="sm:hidden">
            <div class="relative w-full overflow-hidden" style="height:200px">
              <% if @featured.cover_image.attached? %>
                <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover img-zoom", loading: "eager" %>
              <% else %>
                <div class="w-full h-full gradient-hero"></div>
              <% end %>
              <%# Strong gradient so title is always readable %>
              <div class="absolute inset-0" style="background:linear-gradient(0deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.45) 45%, rgba(0,0,0,0.08) 100%)"></div>
              <%# LIVE dot — mobile %>
              <div class="absolute top-3 left-3 z-10">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-5 w-5 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-red-500 opacity-60"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                </span>
              </div>
              <%# Title overlaid on image — no category/region label %>
              <div class="absolute bottom-0 left-0 right-0 px-4 pb-4 pt-8">
                <h2 class="text-[1.05rem] font-black text-white group-hover:text-orange-200 transition-colors line-clamp-2 leading-snug tracking-tight drop-shadow-md">
                  <%= @featured.display_title %>
                </h2>
              </div>
            </div>
          </div>

          <%# TABLET/DESKTOP: full-bleed cinematic overlay %>
          <div class="hidden sm:block relative min-h-[380px]">
            <div class="absolute inset-0">
              <% if @featured.cover_image.attached? %>
                <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover img-zoom", loading: "eager" %>
              <% else %>
                <div class="w-full h-full gradient-hero"></div>
              <% end %>
              <div class="absolute inset-0 gradient-dark-strong"></div>
            </div>
            <%# LIVE dot — desktop %>
            <div class="absolute top-5 left-5 z-10">
              <span class="relative flex h-3.5 w-3.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-red-500"></span>
              </span>
            </div>
            <div class="relative h-full flex flex-col justify-end p-8">
              <h2 class="text-2xl lg:text-3xl font-black text-white leading-tight group-hover:text-orange-200 transition-colors line-clamp-2 tracking-tight">
                <%= @featured.display_title %>
              </h2>
              <p class="text-[13px] text-white/50 mt-2 line-clamp-2 max-w-2xl"><%= truncate(strip_tags(featured_content), length: 180) %></p>
              <div class="flex items-center gap-2.5 mt-4">
                <div class="w-8 h-8 rounded-full bg-white/15 backdrop-blur-md flex items-center justify-center ring-1 ring-white/20">
                  <span class="text-white font-bold text-xs"><%= (@featured.author&.name.presence || "?")[0] %></span>
                </div>
                <span class="text-sm text-white/80 font-semibold"><%= @featured.author&.name.presence || "Unknown" %></span>
                <span class="text-white/30">&middot;</span>
              </div>
            </div>
          </div>

        <% end %>
      </div>

      <%# 4 globally-latest news items — desktop right column, mobile below hero %>
      <div class="lg:col-span-2 flex flex-col gap-2.5">
        <% @home_side_items.each_with_index do |item, idx| %>
          <%= link_to news_path(item), class: "group news-list-row animate-fade-in stagger-#{idx + 1}" do %>
            <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= item.display_title %></h3>
              <span class="text-[11px] text-gray-400"><%= item.category.display_name %> · <%= item.region.display_name %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── MARRIAGE BANNER — above regions ──────────────────────────── %>
  <% if @is_home %>
    <%= link_to biodatas_path, class: "block group mb-4" do %>
      <div class="rounded-2xl relative overflow-hidden text-white px-5 py-4 sm:px-6 sm:py-5 flex items-center gap-4 sm:gap-5"
           style="background: linear-gradient(150deg,#6b2009 0%,#b83a0a 35%,#ea580c 65%,#fb923c 100%); box-shadow: 0 6px 28px -6px rgba(180,83,9,0.55); border: 1.5px solid rgba(245,200,151,0.25)">
        <%# top accent line %>
        <div class="absolute top-0 left-0 right-0 h-[3px] pointer-events-none" style="background: linear-gradient(90deg,#7c2d12,#c2410c,#ea580c,#f97316,#ea580c,#c2410c,#7c2d12)"></div>
        <%# decorative circles %>
        <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
          <div class="absolute -top-8 -left-8 w-40 h-40 rounded-full" style="border: 16px solid rgba(255,255,255,0.08)"></div>
          <div class="absolute -bottom-12 left-20 w-32 h-32 rounded-full" style="border: 12px solid rgba(255,255,255,0.06)"></div>
          <div class="absolute top-1/2 -translate-y-1/2 -right-8 w-28 h-28 rounded-full" style="border: 10px solid rgba(255,255,255,0.07)"></div>
          <div class="absolute -bottom-6 -left-4 w-20 h-20 rounded-full" style="background: rgba(255,255,255,0.04)"></div>
          <div class="absolute top-2 left-32 w-10 h-10 rounded-full" style="border: 6px solid rgba(255,255,255,0.08)"></div>
        </div>
        <%# icon %>
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl flex items-center justify-center shrink-0 relative z-10"
             style="background: rgba(255,255,255,0.15); box-shadow: 0 0 18px rgba(255,255,255,0.1)">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
          </svg>
        </div>
        <%# text %>
        <div class="flex-1 min-w-0 relative z-10">
          <div class="flex flex-wrap items-center gap-2 mb-0.5">
            <h3 class="font-black text-[13px] sm:text-base leading-tight"><%= t("nav.marriage") %></h3>
            <% if @biodata_count&.positive? %>
              <span class="text-[11px] font-bold px-2 py-0.5 rounded-full whitespace-nowrap" style="background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.25)">
                <%= @biodata_count %>+ <%= I18n.locale == :hi ? "प्रोफाइल" : "Profiles" %>
              </span>
            <% end %>
          </div>
          <p class="text-[11px] sm:text-sm leading-snug" style="color: rgba(255,255,255,0.65)"><%= t("feed.marriage_ads_subtitle") %></p>
        </div>
        <%# CTA — desktop %>
        <div class="shrink-0 relative z-10 hidden sm:flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-[12px] font-bold whitespace-nowrap transition-colors group-hover:bg-white/20"
             style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25)">
          <%= I18n.locale == :hi ? "प्रोफाइल देखें" : "Browse Profiles" %>
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        </div>
        <%# arrow — mobile %>
        <svg class="w-4 h-4 shrink-0 sm:hidden relative z-10 group-hover:translate-x-0.5 transition-transform" style="color:rgba(255,255,255,0.45)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    <% end %>
  <% end %>

  <%# ── REGIONS — horizontal scroll tabs ──────────────────────────── %>
  <div class="mb-4" data-controller="region-tabs">
    <%# Determine which tab is active: explicit region > auto-detected > all %>
    <% active_region = @region || @auto_region %>
    <div class="relative">
    <div class="flex items-center gap-2 overflow-x-auto scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0 pb-2">
      <%= link_to root_path(all: 1),
            class: "region-tab shrink-0 #{active_region.nil? ? 'region-tab-active' : ''}",
            data: { region_tabs_target: "tab", action: "region-tabs#select", turbo_frame: "region-news" } do %>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M4 6h16M4 10h16M4 14h8"/></svg>
        <%= I18n.locale == :hi ? "सभी" : "All" %>
      <% end %>
      <% @regions.each do |r| %>
        <% is_active = active_region&.id == r.id %>
        <%= link_to region_feed_path(slug: r.slug),
              class: "region-tab shrink-0 #{is_active ? 'region-tab-active' : ''}",
              data: { region_tabs_target: "tab", action: "region-tabs#select", turbo_frame: "region-news" } do %>
          <%= r.display_name %>
          <% if @auto_region&.id == r.id %>
            <span class="w-1.5 h-1.5 rounded-full bg-orange-300 inline-block ml-0.5 align-middle" title="Auto-detected from your location"></span>
          <% end %>
        <% end %>
      <% end %>
    </div>
    <%# Fade hint — only on mobile, hidden on sm+ where all pills fit %>
    <div class="absolute right-0 top-0 bottom-2 w-10 pointer-events-none sm:hidden rounded-r-lg" style="background: linear-gradient(90deg, transparent, white 90%)"></div>
    </div>
  </div>

  <%# ── AD after regions ───────────────────────────────────────────── %>
  <%= render "shared/billboard_feed" %>

  <div class="page-section-break mb-4"></div>

  <% active_region_on_home = @auto_region %>
  <turbo-frame id="region-news">

  <% if active_region_on_home.present? %>
    <%# ── Region news — all @news_items (side-stack now uses @home_side_items) ── %>
    <% region_extra = @news_items.to_a.first(5) %>
    <% if region_extra.any? %>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#f97316,#ea580c)"></div>
        <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight whitespace-nowrap"><%= active_region_on_home.display_name %> <%= I18n.locale == :hi ? "समाचार" : "News" %></h2>
        <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fed7aa,transparent)"></div>
        <%= link_to region_feed_path(slug: active_region_on_home.slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-700 bg-orange-100 hover:bg-orange-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
          <%= I18n.locale == :hi ? "और देखें" : "View All" %>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
      <div class="space-y-2.5 mb-4">
        <% region_extra.each do |item| %>
          <%= link_to news_path(item), class: "group news-list-row" do %>
            <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= item.display_title %></h3>
              <span class="text-[11px] text-gray-400"><%= item.region.display_name %> · <%= item.category.display_name %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% elsif @is_home %>
    <%# ── 5 latest news (सभी active) — @news_items excludes hero + side-stack ── %>
    <% latest_five = @news_items.to_a.first(5) %>
    <% if latest_five.any? %>
      <div class="flex items-center gap-3 mb-3">
        <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#f97316,#ea580c)"></div>
        <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight whitespace-nowrap"><%= I18n.locale == :hi ? "ताज़ा समाचार" : "Latest News" %></h2>
        <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fed7aa,transparent)"></div>
        <%= link_to root_path(all: 1), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-700 bg-orange-100 hover:bg-orange-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
          <%= I18n.locale == :hi ? "और देखें" : "View All" %>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
      <div class="space-y-2.5 mb-4">
        <% latest_five.each do |item| %>
          <%= link_to news_path(item), class: "group news-list-row" do %>
            <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= item.display_title %></h3>
              <span class="text-[11px] text-gray-400"><%= item.region.display_name %> · <%= item.category.display_name %></span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
  </turbo-frame>

  <%# ── CATEGORY SECTIONS ──────────────────────────────────────────── %>
  <% if @category_sections.present? %>
    <% @category_sections.each_with_index do |section, sec_idx| %>
      <%# Ad between sections %>
      <% if sec_idx > 0 %>
        <%= render "shared/billboard_feed" %>
      <% end %>

      <%# Alternating white / warm-stone full-bleed strips %>
      <div class="<%= sec_idx.odd? ? '-mx-4 sm:-mx-6 px-4 sm:px-6 py-4' : 'py-2' %> mb-2"
           <%= sec_idx.odd? ? 'style="background: linear-gradient(135deg, #fafaf9 0%, #f5f4f2 100%)"' : '' %>>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#f97316,#ea580c)"></div>
          <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight whitespace-nowrap"><%= section[:category].display_name %></h2>
          <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fed7aa,transparent)"></div>
          <%= link_to category_feed_path(slug: section[:category].slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-700 bg-orange-100 hover:bg-orange-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
            <%= I18n.locale == :hi ? "और देखें" : "View All" %>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>

        <%# Mobile: compact news-list-row (no big image cards) %>
        <div class="sm:hidden space-y-2.5">
          <% section[:items].each do |item| %>
            <%= link_to news_path(item), class: "group news-list-row" do %>
              <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
                <% if item.cover_image.attached? %>
                  <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                    <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0 flex flex-col justify-center">
