                    </div>
                    <div class="w-12 h-10 rounded-md overflow-hidden shrink-0">
                      <% if item.cover_image.attached? %>
                        <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                      <% else %>
                        <div class="w-full h-full gradient-brand-soft"></div>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# Desktop: lead + grid layout for even, 2-col list for odd %>
        <% if sec_idx.even? && section[:items].size > 1 %>
