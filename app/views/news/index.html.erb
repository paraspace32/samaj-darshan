<% if @is_home %>
  <%# ═══════════════════════════════════════════════════════════════════
      TRENDING TICKER — horizontal scrolling breaking news
      ═══════════════════════════════════════════════════════════════════ %>
  <% if @trending.present? %>
    <div class="-mx-4 sm:-mx-6 -mt-4 sm:-mt-8 px-4 sm:px-6 py-2.5 mb-2 border-b border-gray-100" style="background: linear-gradient(90deg, #fff7ed 0%, white 50%, #fff7ed 100%)">
      <div class="flex items-center gap-3">
        <span class="shrink-0 flex items-center gap-1.5 text-[10px] font-black uppercase tracking-[0.15em] text-red-600">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
          </span>
          <%= t("feed.trending") %>
        </span>
        <div class="w-px h-4 bg-gray-200 shrink-0"></div>
        <div class="overflow-hidden flex-1">
          <div class="ticker-scroll flex items-center gap-5">
            <% @trending.each do |item| %>
              <%= link_to item.display_title, news_path(item), class: "text-[13px] font-semibold text-gray-700 hover:text-orange-600 shrink-0 whitespace-nowrap transition-colors" %>
              <span class="text-gray-300 shrink-0">|</span>
            <% end %>
            <% @trending.each do |item| %>
              <%= link_to item.display_title, news_path(item), class: "text-[13px] font-semibold text-gray-700 hover:text-orange-600 shrink-0 whitespace-nowrap transition-colors" %>
              <span class="text-gray-300 shrink-0">|</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# ── Marriage ad — below the ticker ─────────────────── %>
  <%= render "shared/billboard_marriage" %>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════
    Category pills — top of page on filtered/paged views only
    ═══════════════════════════════════════════════════════════════════ %>
<% unless @is_home %>
<div class="mb-3">
  <div class="flex items-center gap-2 overflow-x-auto pb-1 -mx-1 px-1 scrollbar-hide">
    <%= link_to root_path, class: "shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold transition-all #{ @region.nil? && @category.nil? ? 'gradient-brand text-white shadow-md shadow-orange-400/35' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
      <%= t("feed.all_regions") %>
    <% end %>
    <% @categories.each do |c| %>
      <%= link_to category_feed_path(slug: c.slug), class: "shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold transition-all #{ @category&.id == c.id ? 'gradient-brand text-white shadow-md shadow-orange-400/35' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
        <span class="w-1.5 h-1.5 rounded-full shrink-0 ring-1 ring-white/50" style="background-color:#f97316"></span>
        <%= c.display_name %>
      <% end %>
    <% end %>
  </div>
</div>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════
    Filtered view header (region / category)
    ═══════════════════════════════════════════════════════════════════ %>
<% if @region || @category %>
  <div class="mb-6 animate-fade-in">
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-2">
      <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-600 font-medium"><%= (@region || @category).display_name %></span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-black text-gray-900 tracking-tight"><%= (@region || @category).display_name %></h1>
    <p class="text-gray-500 mt-1">
      <% if @region %>
        <%= t("feed.news_from", name: @region.display_name) %>
      <% else %>
        <%= t("feed.news_in", name: @category.display_name) %>
      <% end %>
    </p>
  </div>
<% end %>

<% if @is_home %>
  <%# ═════════════════════════════════════════════════════════════════
      HOME PAGE — editorial magazine-style layout
      ═════════════════════════════════════════════════════════════════ %>

  <%# ── HERO BENTO — lead story + 4 side stories ──────────────────── %>
  <% if @featured.present? %>
    <%
      featured_path = case @featured_type
                      when :education then education_path(@featured)
                      when :job then job_path(@featured)
                      else news_path(@featured)
                      end
      featured_content = case @featured_type
                         when :job then @featured.display_description
                         else @featured.display_content
                         end
      featured_badge_label = case @featured_type
                             when :education then t("education.title")
                             when :job then t("feed.job_news")
                             else @featured.region.display_name
                             end
      featured_badge_color = "#f97316"
      featured_sub_label = case @featured_type
                           when :education then t("education.title")
                           when :job then @featured.company_name
                           else @featured.region.display_name
                           end
    %>

    <%# ── Mobile Hero: title-first card layout ── %>
    <div class="sm:hidden -mx-4 mb-2 animate-fade-up">
      <%= link_to featured_path, class: "group block bg-white" do %>
        <%# 1. Heading at top %>
        <div class="px-4 pt-1.5 pb-1.5">
          <h2 class="text-[1rem] font-black text-gray-900 leading-[1.3] line-clamp-3 tracking-tight group-hover:text-orange-600 transition-colors">
            <%= @featured.display_title %>
          </h2>
        </div>
        <%# 2. Image with pulse dot %>
        <div class="w-full aspect-[2/1] overflow-hidden relative">
          <% if @featured.cover_image.attached? %>
            <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500", loading: "eager" %>
          <% else %>
            <div class="w-full h-full gradient-hero"></div>
          <% end %>
          <div class="absolute top-2.5 left-3 flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-black/40 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
            </span>
            <span class="text-[10px] font-bold text-white/90 uppercase tracking-wider"><%= t("feed.trending") %></span>
          </div>
        </div>
        <%# 3. Content excerpt (2 lines) %>
        <div class="px-4 pt-2 pb-2.5">
          <p class="text-[13px] text-gray-600 leading-relaxed line-clamp-2"><%= truncate(strip_tags(featured_content), length: 160) %></p>
        </div>
      <% end %>

      <%# Mobile side items — 2-per-row story grid %>
      <div class="story-stack mt-2">
        <% @home_side_items.each_with_index do |item, idx| %>
          <%= link_to news_path(item), class: "group story-card bg-white overflow-hidden" do %>
            <%# Image on top %>
            <div class="w-full aspect-[4/3] overflow-hidden">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :card, class: "w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft"></div>
              <% end %>
            </div>
            <%# Title + excerpt below %>
            <div class="p-2.5">
              <h3 class="text-[13px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
              <p class="text-[11px] text-gray-400 mt-1 line-clamp-2 leading-relaxed"><%= truncate(strip_tags(item.display_content), length: 80) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# ── Desktop Hero: title-first bento grid ── %>
    <div class="hidden sm:grid sm:grid-cols-12 gap-4 mb-6 animate-fade-up">
      <%# Main hero — spans 8 cols %>
      <div class="col-span-8">
        <%= link_to featured_path, class: "group block rounded-2xl overflow-hidden bg-white border border-gray-100 hover:border-orange-200 hover:shadow-lg hover:shadow-orange-50/50 transition-all h-full" do %>
          <%# 1. Title at top %>
          <div class="p-5 lg:p-6 pb-3">
            <h2 class="text-xl lg:text-2xl font-black text-gray-900 leading-tight line-clamp-3 tracking-tight group-hover:text-orange-600 transition-colors">
              <%= @featured.display_title %>
            </h2>
          </div>
          <%# 2. Image with pulse dot %>
          <div class="w-full aspect-[2/1] overflow-hidden relative">
            <% if @featured.cover_image.attached? %>
              <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500", loading: "eager" %>
            <% else %>
              <div class="w-full h-full gradient-hero"></div>
            <% end %>
            <div class="absolute top-3 left-4 flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-black/40 backdrop-blur-sm">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
              </span>
              <span class="text-[11px] font-bold text-white/90 uppercase tracking-wider"><%= t("feed.trending") %></span>
            </div>
          </div>
          <%# 3. Content excerpt %>
          <div class="p-5 lg:p-6 pt-3">
            <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed"><%= truncate(strip_tags(featured_content), length: 200) %></p>
          </div>
        <% end %>
      </div>

      <%# Side stack — items in 4 cols, title-first cards %>
      <div class="col-span-4 grid grid-rows-2 gap-4">
        <% @home_side_items.first(2).each_with_index do |item, idx| %>
          <%= link_to news_path(item), class: "group block rounded-2xl overflow-hidden bg-white border border-gray-100 hover:border-orange-200 hover:shadow-md hover:shadow-orange-50/50 transition-all" do %>
            <div class="w-full aspect-[16/10] overflow-hidden">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :card, class: "w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500", loading: idx == 0 ? "eager" : "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft"></div>
              <% end %>
            </div>
            <div class="p-3">
              <h3 class="text-[14px] font-bold text-gray-900 leading-snug line-clamp-2 tracking-tight group-hover:text-orange-600 transition-colors"><%= item.display_title %></h3>
              <p class="text-[11px] text-gray-400 mt-1 line-clamp-1 leading-relaxed"><%= truncate(strip_tags(item.display_content), length: 80) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Desktop: remaining side items as text rows below hero %>
    <% if @home_side_items.size > 2 %>
      <div class="hidden sm:grid sm:grid-cols-2 gap-3 mb-6">
        <% @home_side_items.drop(2).each_with_index do |item, idx| %>
          <%= link_to news_path(item), class: "group flex gap-3 p-3 rounded-xl bg-white border border-gray-100 hover:border-orange-200 hover:shadow-md hover:shadow-orange-50 transition-all" do %>
            <div class="w-20 h-16 rounded-lg overflow-hidden shrink-0">
              <% if item.cover_image.attached? %>
                <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300", loading: "lazy" %>
              <% else %>
                <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                  <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
              <p class="text-[11px] text-gray-400 mt-0.5 line-clamp-1"><%= truncate(strip_tags(item.display_content), length: 80) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ── MARRIAGE BANNER — browse profiles CTA ────────────────────── %>
  <% if @is_home %>
    <%= link_to biodatas_path, class: "block group mb-4" do %>
      <div class="rounded-xl sm:rounded-2xl relative overflow-hidden text-white px-4 py-3 sm:px-6 sm:py-5 flex items-center gap-3 sm:gap-5"
           style="background: linear-gradient(150deg,#6b2009 0%,#b83a0a 35%,#ea580c 65%,#fb923c 100%); box-shadow: 0 6px 28px -6px rgba(180,83,9,0.55); border: 1.5px solid rgba(245,200,151,0.25)">
        <%# top accent line %>
        <div class="absolute top-0 left-0 right-0 h-[3px] pointer-events-none" style="background: linear-gradient(90deg,#7c2d12,#c2410c,#ea580c,#f97316,#ea580c,#c2410c,#7c2d12)"></div>
        <%# decorative circles %>
        <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
          <div class="absolute -top-8 -left-8 w-40 h-40 rounded-full" style="border: 16px solid rgba(255,255,255,0.08)"></div>
          <div class="absolute -bottom-12 left-20 w-32 h-32 rounded-full" style="border: 12px solid rgba(255,255,255,0.06)"></div>
          <div class="absolute top-1/2 -translate-y-1/2 -right-8 w-28 h-28 rounded-full" style="border: 10px solid rgba(255,255,255,0.07)"></div>
        </div>
        <%# icon %>
        <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl flex items-center justify-center shrink-0 relative z-10"
             style="background: rgba(255,255,255,0.15); box-shadow: 0 0 18px rgba(255,255,255,0.1)">
          <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
          </svg>
        </div>
        <%# text %>
        <div class="flex-1 min-w-0 relative z-10">
          <div class="flex flex-wrap items-center gap-2 mb-0.5">
            <h3 class="font-black text-[13px] sm:text-base leading-tight"><%= t("nav.marriage") %></h3>
            <% if @biodata_count&.positive? %>
              <span class="text-[11px] font-bold px-2 py-0.5 rounded-full whitespace-nowrap" style="background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.25)">
                <%= @biodata_count %>+ <%= I18n.locale == :hi ? "प्रोफाइल" : "Profiles" %>
              </span>
            <% end %>
          </div>
          <p class="text-[11px] sm:text-sm leading-snug" style="color: rgba(255,255,255,0.65)"><%= t("feed.marriage_ads_subtitle") %></p>
        </div>
        <%# CTA — desktop %>
        <div class="shrink-0 relative z-10 hidden sm:flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-[12px] font-bold whitespace-nowrap transition-colors group-hover:bg-white/20"
             style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25)">
          <%= I18n.locale == :hi ? "प्रोफाइल देखें" : "Browse Profiles" %>
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        </div>
        <%# arrow — mobile %>
        <svg class="w-4 h-4 shrink-0 sm:hidden relative z-10 group-hover:translate-x-0.5 transition-transform" style="color:rgba(255,255,255,0.45)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    <% end %>
  <% end %>

  <%# ── REGIONS — horizontal scroll tabs ──────────────────────────── %>
  <div class="-mx-4 sm:-mx-6 px-4 sm:px-6 pt-3 pb-1 bg-white border-b border-gray-100" data-controller="region-tabs">
    <%# Determine which tab is active: explicit region > auto-detected > all %>
    <% active_region = @region || @auto_region %>
    <div class="relative">
    <div class="flex items-center gap-2 overflow-x-auto scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0 pb-2">
      <%= link_to root_path(all: 1),
            class: "region-tab shrink-0 #{active_region.nil? ? 'region-tab-active' : ''}",
            data: { region_tabs_target: "tab", action: "region-tabs#select", turbo_frame: "region-news" } do %>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M4 6h16M4 10h16M4 14h8"/></svg>
        <%= I18n.locale == :hi ? "सभी" : "All" %>
      <% end %>
      <%# Active region first, then the rest in original order %>
      <% sorted_regions = active_region ? ([ @regions.find { |r| r.id == active_region.id } ] + @regions.reject { |r| r.id == active_region.id }).compact : @regions %>
      <% sorted_regions.each do |r| %>
        <% is_active = active_region&.id == r.id %>
        <%= link_to region_feed_path(slug: r.slug),
              class: "region-tab shrink-0 #{is_active ? 'region-tab-active' : ''}",
              data: { region_tabs_target: "tab", action: "region-tabs#select", turbo_frame: "region-news" } do %>
          <%= r.display_name %>
          <% if @auto_region&.id == r.id %>
            <span class="w-1.5 h-1.5 rounded-full bg-orange-300 inline-block ml-0.5 align-middle" title="Auto-detected from your location"></span>
          <% end %>
        <% end %>
      <% end %>
    </div>
    <%# Fade hint — only on mobile %>
    <div class="absolute right-0 top-0 bottom-2 w-10 pointer-events-none sm:hidden rounded-r-lg" style="background: linear-gradient(90deg, transparent, white 90%)"></div>
    </div>
  </div>

  <%# ── AD after regions ───────────────────────────────────────────── %>
  <%= render "shared/billboard_feed" %>

  <% active_region_on_home = @auto_region %>
  <turbo-frame id="region-news">

  <% if active_region_on_home.present? %>
    <%# ── Region news section ── %>
    <% region_extra = @news_items.to_a.first(5) %>
    <% if region_extra.any? %>
      <div class="py-3 sm:py-5" data-reveal>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-1 h-6 rounded-full shrink-0" style="background: linear-gradient(180deg, #f97316, #ea580c)"></div>
          <h2 class="text-base sm:text-xl font-black text-gray-900 tracking-tight"><%= active_region_on_home.display_name %> <%= I18n.locale == :hi ? "समाचार" : "News" %></h2>
          <div class="flex-1 h-px bg-gray-100"></div>
          <%= link_to region_feed_path(slug: active_region_on_home.slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-600 hover:text-orange-700 px-2.5 py-1 rounded-full bg-orange-50 hover:bg-orange-100 transition-all" do %>
            <%= I18n.locale == :hi ? "और देखें" : "View All" %>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
        <div class="space-y-1.5" data-reveal-stagger>
          <% region_extra.each_with_index do |item, idx| %>
            <%= link_to news_path(item), class: "group flex items-center gap-2.5 p-2 sm:p-3 rounded-lg bg-white border border-gray-50 hover:border-orange-200 hover:shadow-sm transition-all" do %>
              <span class="text-[15px] font-black text-orange-400/70 w-5 text-center shrink-0 sm:hidden"><%= idx + 1 %></span>
              <div class="w-16 h-14 sm:w-20 sm:h-[4.25rem] rounded-lg overflow-hidden shrink-0">
                <% if item.cover_image.attached? %>
                  <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                    <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0 flex flex-col justify-center">
                <h3 class="text-[13px] sm:text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                <span class="text-[10px] sm:text-[11px] text-gray-400 mt-0.5"><%= item.region.display_name %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% elsif @is_home %>
    <%# ── Latest news (सभी active) ── %>
    <% latest_five = @news_items.to_a.first(5) %>
    <% if latest_five.any? %>
      <div class="py-3 sm:py-5" data-reveal>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-1 h-6 rounded-full shrink-0" style="background: linear-gradient(180deg, #f97316, #ea580c)"></div>
          <h2 class="text-base sm:text-xl font-black text-gray-900 tracking-tight"><%= I18n.locale == :hi ? "ताज़ा समाचार" : "Latest News" %></h2>
          <div class="flex-1 h-px bg-gray-100"></div>
          <%= link_to root_path(all: 1), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-600 hover:text-orange-700 px-2.5 py-1 rounded-full bg-orange-50 hover:bg-orange-100 transition-all" do %>
            <%= I18n.locale == :hi ? "और देखें" : "View All" %>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
        <div class="space-y-1.5" data-reveal-stagger>
          <% latest_five.each_with_index do |item, idx| %>
            <%= link_to news_path(item), class: "group flex items-center gap-2.5 p-2 sm:p-3 rounded-lg bg-white border border-gray-50 hover:border-orange-200 hover:shadow-sm transition-all" do %>
              <span class="text-[15px] font-black text-orange-400/70 w-5 text-center shrink-0 sm:hidden"><%= idx + 1 %></span>
