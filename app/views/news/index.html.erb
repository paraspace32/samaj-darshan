                <div class="relative h-48 overflow-hidden">
                  <% if lead.cover_image.attached? %>
                    <%= optimized_image_tag lead.cover_image, variant: :card, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                      <span class="text-2xl text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                  <div class="absolute bottom-0 inset-x-0 h-16" style="background: linear-gradient(to top, rgba(0,0,0,0.06), transparent)"></div>
                </div>
                <div class="p-4">
                  <h3 class="text-base font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-1.5"><%= lead.display_title %></h3>
                  <span class="text-[11px] text-gray-400"><%= lead.region.display_name %></span>
                </div>
              <% end %>
            </div>
            <%# Remaining items — stacked list %>
            <div class="col-span-6 flex flex-col gap-2.5">
              <% section[:items].drop(1).each do |item| %>
                <%= link_to news_path(item), class: "group flex gap-3 p-3 rounded-xl bg-white border border-gray-100 hover:border-orange-200 hover:shadow-md hover:shadow-orange-50 transition-all" do %>
                  <div class="w-20 h-16 rounded-lg overflow-hidden shrink-0">
                    <% if item.cover_image.attached? %>
                      <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                    <% else %>
                      <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                        <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="flex-1 min-w-0 flex flex-col justify-center">
                    <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                    <span class="text-[11px] text-gray-400 mt-0.5"><%= item.region.display_name %></span>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="hidden sm:grid sm:grid-cols-3 gap-4">
            <% section[:items].each do |item| %>
              <%= link_to news_path(item), class: "group block rounded-2xl overflow-hidden bg-white border border-gray-100 hover:border-gray-200 hover:shadow-lg hover:shadow-gray-100 transition-all" do %>
                <div class="relative h-36 overflow-hidden">
                  <% if item.cover_image.attached? %>
