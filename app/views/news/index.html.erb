<%# ═══════════════════════════════════════════════════════════════════
    NEWS INDEX — orchestrator
    All presentational logic lives in the partials below.
    ═══════════════════════════════════════════════════════════════════ %>

<% if @is_home %>
  <%# ── Trending ticker + marriage billboard ─────────────────────── %>
  <%= render "news/trending_ticker" %>
<% end %>

<%# ── Category pills (filtered/paged views only) ───────────────── %>
<% unless @is_home %>
  <%= render "news/category_pills" %>
<% end %>

<%# ── Breadcrumb header for region/category filter ─────────────── %>
<% if @region || @category %>
  <%= render "news/filter_header" %>
<% end %>

<% if @is_home %>
  <%# ── Hero: featured story + marriage ad (full width) ──────────── %>
  <%= render "news/home_hero" %>

  <%# ── Desktop: 2-column newspaper layout with sidebar ──────────── %>
  <div class="lg:flex lg:gap-0">
    <div class="lg:flex-1 lg:min-w-0 lg:pr-8">
      <%# ── Regions tabs + billboard ─────────────────────────────── %>
      <%= render "news/regions_tabs" %>

      <%# ── Region / latest news turbo-frame ─────────────────────── %>
      <div class="section-band-gray">
        <%= render "news/region_news_frame" %>
      </div>

      <%# ── Education CTA banner ─────────────────────────────────── %>
      <%= render "news/education_banner" %>

      <%# ── Trending dark section ────────────────────────────────── %>
      <%= render "news/trending_section" %>

      <%# ── Category sections (alternating layouts) ──────────────── %>
      <%= render "news/category_sections" %>

      <%# ── Education news list ──────────────────────────────────── %>
      <div class="section-band-gray">
        <%= render "news/education_news_section" %>
      </div>

      <%# ── Job news list ────────────────────────────────────────── %>
      <%= render "news/job_news_section" %>

      <%# ── Job listings slider ──────────────────────────────────── %>
      <div class="section-band-gray">
        <%= render "news/job_listings_section" %>
      </div>
    </div>

    <%# ── Sidebar: trending + latest + quick links (desktop only) ── %>
    <%= render "news/home_sidebar" %>
  </div>

<% else %>
  <%# ── Turbo Frame response for region tab clicks (non-home) ────── %>
  <%= render "news/turbo_frame_response" %>
<% end %>

<%# ── News grid + sidebar (filtered views) ─────────────────────── %>
<%= render "news/news_grid" %>

<%# ── Quick links + visitor map (home only) ────────────────────── %>
<% if @is_home %>
  <%= render "news/quick_links" %>
<% end %>

<%# ── Scroll-reveal observer ───────────────────────────────────── %>
<script>
(function() {
  function initReveal() {
    var els = document.querySelectorAll("[data-reveal]:not(.revealed),[data-reveal-stagger]:not(.revealed)");
    if (!els.length) return;
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add("revealed"); io.unobserve(e.target); }
      });
    }, { threshold: 0.08, rootMargin: "0px 0px -40px 0px" });
    els.forEach(function(el) { io.observe(el); });
  }
  document.addEventListener("turbo:load", initReveal);
  document.addEventListener("turbo:frame-load", initReveal);
})();
</script>
