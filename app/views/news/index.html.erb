<% if @is_home %>
  <%# ═══════════════════════════════════════════════════════════════════
      TRENDING TICKER — Aaj Tak-style horizontal scrolling topics
      ═══════════════════════════════════════════════════════════════════ %>
  <% if @trending.present? %>
    <div class="ticker-strip -mx-4 sm:-mx-6 px-4 sm:px-6 py-2 mb-3">
      <div class="flex items-center gap-3">
        <span class="shrink-0 flex items-center gap-1.5 text-[11px] font-black uppercase tracking-wider text-orange-400">
          <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
          <%= t("feed.trending") %>
        </span>
        <div class="w-px h-4 bg-white/20 shrink-0"></div>
        <div class="overflow-hidden flex-1">
          <div class="ticker-scroll flex items-center gap-4">
            <% @trending.each do |item| %>
              <%= link_to item.display_title, news_path(item), class: "text-xs font-medium text-white/80 shrink-0 whitespace-nowrap" %>
              <span class="text-white/20 shrink-0">&bull;</span>
            <% end %>
            <% @trending.each do |item| %>
              <%= link_to item.display_title, news_path(item), class: "text-xs font-medium text-white/80 shrink-0 whitespace-nowrap" %>
              <span class="text-white/20 shrink-0">&bull;</span>
            <% end %>
          </div>
        </div>
        <%# Active users widget — right side of ticker %>
        <% if @active_users %>
          <div class="shrink-0 hidden sm:block">
            <%= render "shared/active_users", data: @active_users %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════
    Category pills — horizontal scroll on mobile
    ═══════════════════════════════════════════════════════════════════ %>
<div class="mb-3">
  <div class="flex items-center gap-2 overflow-x-auto pb-1 -mx-1 px-1 scrollbar-hide">
    <%= link_to root_path, class: "shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold transition-all #{ @region.nil? && @category.nil? ? 'gradient-brand text-white shadow-sm shadow-orange-200/60' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
      <%= t("feed.all_regions") %>
    <% end %>
    <% @categories.each do |c| %>
      <%= link_to category_feed_path(slug: c.slug), class: "shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold transition-all #{ @category&.id == c.id ? 'gradient-brand text-white shadow-sm shadow-orange-200/60' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
        <span class="w-1.5 h-1.5 rounded-full shrink-0 ring-1 ring-white/50" style="background-color: <%= c.color %>"></span>
        <%= c.display_name %>
      <% end %>
    <% end %>
  </div>
</div>

<%# ═══════════════════════════════════════════════════════════════════
    Filtered view header (region / category)
    ═══════════════════════════════════════════════════════════════════ %>
<% if @region || @category %>
  <div class="mb-6 animate-fade-in">
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-2">
      <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-600 font-medium"><%= (@region || @category).display_name %></span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-black text-gray-900 tracking-tight"><%= (@region || @category).display_name %></h1>
    <p class="text-gray-500 mt-1">
      <% if @region %>
        <%= t("feed.news_from", name: @region.display_name) %>
      <% else %>
        <%= t("feed.news_in", name: @category.display_name) %>
      <% end %>
    </p>
  </div>
<% end %>

<% if @is_home %>
  <%# ═════════════════════════════════════════════════════════════════
      HOME PAGE — advanced multi-section layout
      ═════════════════════════════════════════════════════════════════ %>

  <%# ── HERO (full-bleed on mobile) + Top stories side stack ─────── %>
  <% if @featured.present? %>
    <%
      featured_path = case @featured_type
                      when :education then education_path(@featured)
                      when :job then job_path(@featured)
                      else news_path(@featured)
                      end
      featured_content = case @featured_type
                         when :job then @featured.display_description
                         else @featured.display_content
                         end
      featured_badge_label = case @featured_type
                             when :education then @featured.category_label
                             when :job then @featured.category_label
                             else @featured.category.display_name
                             end
      featured_badge_color = case @featured_type
                             when :education then "#6366f1"
                             when :job then "#0ea5e9"
                             else @featured.category.color
                             end
      featured_sub_label = case @featured_type
                           when :education then t("education.title")
                           when :job then @featured.company_name
                           else @featured.region.display_name
                           end
    %>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-5 lg:gap-6 mb-10">
      <div class="lg:col-span-3 -mx-4 sm:mx-0 animate-fade-up">
        <%= link_to featured_path, class: "group block overflow-hidden sm:rounded-2xl shadow-xl shadow-gray-300/30 h-full" do %>

          <%# MOBILE: image + title only — clean, no meta clutter %>
          <div class="sm:hidden">
            <div class="relative w-full h-52 overflow-hidden">
              <% if @featured.cover_image.attached? %>
                <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover img-zoom", loading: "eager" %>
              <% else %>
                <div class="w-full h-full gradient-hero"></div>
              <% end %>
              <%# LIVE badge — always shown on the latest featured article %>
              <div class="absolute top-3 left-3 z-10 flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-black text-white tracking-widest uppercase"
                   style="background:linear-gradient(135deg,#dc2626,#b91c1c); box-shadow:0 2px 12px rgba(220,38,38,0.55)">
                <span class="w-1.5 h-1.5 rounded-full bg-white animate-ping absolute"></span>
                <span class="w-1.5 h-1.5 rounded-full bg-white relative"></span>
                <%= t("feed.live") %>
              </div>
            </div>
            <div class="bg-white px-4 py-3.5">
              <h2 class="text-base font-black text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight">
                <%= @featured.display_title %>
              </h2>
            </div>
          </div>

          <%# TABLET/DESKTOP: full-bleed cinematic overlay %>
          <div class="hidden sm:block relative min-h-[400px] lg:min-h-[460px] h-full">
            <div class="absolute inset-0">
              <% if @featured.cover_image.attached? %>
                <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover img-zoom", loading: "eager" %>
              <% else %>
                <div class="w-full h-full gradient-hero"></div>
              <% end %>
              <div class="absolute inset-0 gradient-dark-strong"></div>
            </div>
            <%# LIVE badge — always shown on the latest featured article %>
            <div class="absolute top-5 left-5 z-10 flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-black text-white tracking-widest uppercase"
                 style="background:linear-gradient(135deg,#dc2626,#b91c1c); box-shadow:0 4px 16px rgba(220,38,38,0.6)">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
              </span>
              <%= t("feed.live") %>
            </div>
            <div class="relative h-full flex flex-col justify-end p-8">
              <div class="flex items-center gap-2 mb-3">
                <span class="badge badge-category !bg-white/20 !text-white !backdrop-blur-md !text-[11px]">
                  <span class="w-1.5 h-1.5 rounded-full" style="background-color: <%= featured_badge_color %>"></span>
                  <%= featured_badge_label %>
                </span>
                <span class="text-xs text-white/60 font-medium"><%= featured_sub_label %></span>
              </div>
              <h2 class="text-2xl lg:text-3xl font-black text-white leading-tight group-hover:text-orange-200 transition-colors line-clamp-2 tracking-tight">
                <%= @featured.display_title %>
              </h2>
              <p class="text-[13px] text-white/50 mt-2 line-clamp-2 max-w-2xl"><%= truncate(strip_tags(featured_content), length: 180) %></p>
              <div class="flex items-center gap-2.5 mt-4">
                <div class="w-8 h-8 rounded-full bg-white/15 backdrop-blur-md flex items-center justify-center ring-1 ring-white/20">
                  <span class="text-white font-bold text-xs"><%= @featured.author.name[0] %></span>
                </div>
                <span class="text-sm text-white/80 font-semibold"><%= @featured.author.name %></span>
                <span class="text-white/30">&middot;</span>
                <span class="text-sm text-white/40"><%= t("feed.ago", time: time_ago_in_words(@featured.published_at)) %></span>
              </div>
            </div>
          </div>

        <% end %>
      </div>

      <%# Side stack — next 3 stories %>
      <div class="lg:col-span-2 flex flex-col gap-3">
        <% @news_items.first(3).each_with_index do |item, idx| %>
          <div class="animate-fade-in stagger-<%= idx + 1 %>">
            <%= link_to news_path(item), class: "group news-list-row" do %>
              <div class="w-20 h-[4.5rem] sm:w-28 sm:h-[5.5rem] rounded-lg overflow-hidden shrink-0">
                <% if item.cover_image.attached? %>
                  <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                    <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0 flex flex-col justify-center">
                <div class="flex items-center gap-1.5 mb-1">
                  <span class="text-[10px] sm:text-[11px] font-bold text-orange-600"><%= item.category.display_name %></span>
                  <span class="text-[10px] text-gray-300">&middot;</span>
                  <span class="text-[10px] sm:text-[11px] text-gray-400"><%= t("feed.ago", time: time_ago_in_words(item.published_at)) %></span>
                </div>
                <h3 class="text-[13px] sm:text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                <span class="text-[11px] text-gray-400 mt-1"><%= item.region.display_name %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── TRENDING + SIDEBAR ────────────────────────────────────────── %>
  <% if @trending.present? %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 mb-10 lg:mb-14">
      <div class="lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <div class="section-heading">
            <div>
              <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight"><%= t("feed.trending") %></h2>
              <p class="text-[11px] text-gray-400 mt-0.5 hidden sm:block"><%= t("feed.trending_subtitle") %></p>
            </div>
          </div>
        </div>

        <%# Mobile: compact list | Desktop: with thumbnails %>
        <div class="space-y-0.5">
          <% @trending.each_with_index do |item, idx| %>
            <%= link_to news_path(item), class: "group flex items-center gap-3 sm:gap-4 px-3 sm:px-4 py-3 rounded-xl hover:bg-white hover:shadow-sm transition-all" do %>
              <span class="trending-rank text-xl sm:text-2xl"><%= "%02d" % (idx + 1) %></span>
              <div class="flex-1 min-w-0">
                <h3 class="text-[13px] sm:text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                <div class="flex items-center gap-2 sm:gap-3 mt-1">
                  <span class="text-[10px] sm:text-[11px] font-semibold text-orange-600"><%= item.category.display_name %></span>
                  <span class="flex items-center gap-0.5 text-[10px] sm:text-[11px] text-gray-400">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    <%= item.likes_count %>
                  </span>
                  <span class="flex items-center gap-0.5 text-[10px] sm:text-[11px] text-gray-400">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    <%= item.comments_count %>
                  </span>
                </div>
              </div>
              <% if item.cover_image.attached? %>
                <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-lg overflow-hidden shrink-0">
                  <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Sidebar — Webinar + Magazine promos %>
      <aside class="space-y-4 sm:space-y-5">
        <%# On mobile: horizontal scroll for promos, on desktop: stacked %>
        <div class="flex lg:flex-col gap-4 overflow-x-auto lg:overflow-visible scrollbar-hide -mx-4 px-4 lg:mx-0 lg:px-0">
          <% if @upcoming_webinar %>
            <div class="promo-card gradient-hero text-white p-5 sm:p-6 min-w-[280px] lg:min-w-0 shrink-0 lg:shrink">
              <div class="flex items-center gap-2 mb-3">
                <span class="badge badge-upcoming !text-[10px]"><%= t("webinar.upcoming_badge") %></span>
              </div>
              <h3 class="font-bold text-[13px] sm:text-base leading-snug line-clamp-2 mb-2"><%= @upcoming_webinar.display_title %></h3>
              <p class="text-[12px] sm:text-sm text-white/60 mb-1"><%= @upcoming_webinar.speaker_name %></p>
              <p class="text-[11px] text-white/40 mb-3">
                <svg class="w-3.5 h-3.5 inline -mt-0.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <%= I18n.l(@upcoming_webinar.starts_at, format: :long) rescue @upcoming_webinar.starts_at.strftime("%b %d, %Y · %I:%M %p") %>
              </p>
              <%= link_to webinar_path(@upcoming_webinar), class: "inline-flex items-center gap-2 text-[12px] sm:text-sm font-bold text-white/90 hover:text-white transition-colors group" do %>
                <%= t("feed.read_more") %>
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              <% end %>
            </div>
          <% end %>

          <%# Magazine promo — hidden for now %>
          <% if false # @latest_magazine %>
            <div class="promo-card surface-elevated p-0 min-w-[240px] lg:min-w-0 shrink-0 lg:shrink">
              <% if @latest_magazine.cover_image.attached? %>
                <div class="h-32 sm:h-40 overflow-hidden">
                  <%= optimized_image_tag @latest_magazine.cover_image, variant: :card, class: "w-full h-full object-cover", loading: "lazy" %>
                </div>
              <% else %>
                <div class="h-32 sm:h-40 gradient-brand-soft flex items-center justify-center">
                  <span class="text-4xl text-orange-200/40 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
              <div class="p-4 sm:p-5">
                <span class="badge gradient-brand text-white !text-[10px] mb-2"><%= @latest_magazine.display_issue %></span>
                <h3 class="font-bold text-gray-900 text-[13px] sm:text-sm leading-snug line-clamp-2 mb-2"><%= @latest_magazine.display_title %></h3>
                <%= link_to magazine_path(@latest_magazine), class: "inline-flex items-center gap-2 text-[12px] sm:text-sm font-bold text-orange-600 hover:text-orange-700 transition-colors group" do %>
                  <%= t("feed.read_more") %>
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <%# Explore categories — hidden on mobile (pills already visible) %>
        <div class="hidden lg:block surface-raised rounded-2xl p-5">
          <h3 class="text-[13px] font-bold text-gray-900 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
            <%= t("feed.explore_categories") %>
          </h3>
          <div class="flex flex-wrap gap-2">
            <% @categories.each do |c| %>
              <%= link_to category_feed_path(slug: c.slug), class: "category-chip" do %>
                <span class="w-2 h-2 rounded-full" style="background-color: <%= c.color %>"></span>
                <%= c.display_name %>
              <% end %>
            <% end %>
          </div>
        </div>
      </aside>
    </div>
  <% end %>

  <%# ── REGIONS — horizontal scroll tabs (Aaj Tak state-bar style) ── %>
  <div class="mb-6">
    <div class="flex items-center gap-2.5 overflow-x-auto scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0 pb-2">
      <svg class="w-4 h-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <% @regions.each do |r| %>
        <%= link_to r.display_name, region_feed_path(slug: r.slug), class: "region-tab" %>
      <% end %>
    </div>
  </div>

  <%# ── VISITOR MAP ───────────────────────────────────────────────── %>
  <%= render "shared/visitor_map", realtime: @active_users, reporting: @visitor_stats %>

  <%# ── CATEGORY SECTIONS — alternating slider / grid layouts ────── %>
  <% if @category_sections.present? %>
    <% @category_sections.each_with_index do |section, sec_idx| %>
      <div class="mb-10">
        <div class="flex items-center justify-between mb-4">
          <div class="section-heading">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background-color: <%= section[:category].color %>"></span>
              <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight"><%= section[:category].display_name %></h2>
            </div>
          </div>
          <%= link_to category_feed_path(slug: section[:category].slug), class: "text-xs sm:text-sm font-bold text-orange-600 hover:text-orange-700 transition-colors shrink-0" do %>
            <%= t("feed.view_all") %> →
          <% end %>
        </div>

        <% if sec_idx.even? %>
          <%# ── SLIDER layout — horizontal scroll ──────────────────── %>
          <div class="horizontal-slider">
            <% section[:items].each do |item| %>
              <%= link_to news_path(item), class: "group slider-card" do %>
                <div class="relative overflow-hidden rounded-t-2xl">
                  <% if item.cover_image.attached? %>
                    <%= optimized_image_tag item.cover_image, variant: :card, class: "w-full h-40 sm:h-44 object-cover img-zoom", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-40 sm:h-44 gradient-brand-soft flex items-center justify-center">
                      <span class="text-2xl text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                </div>
                <div class="p-4">
                  <div class="mb-1">
                    <span class="badge badge-category !text-[10px]">
                      <span class="w-1.5 h-1.5 rounded-full" style="background-color: <%= item.category.color %>"></span>
                      <%= item.region.display_name %>
                    </span>
                  </div>
                  <span class="text-[10px] text-gray-400"><%= t("feed.ago", time: time_ago_in_words(item.published_at)) %></span>
                  <h3 class="text-[13px] sm:text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mt-1"><%= item.display_title %></h3>
                </div>
              <% end %>
            <% end %>
          </div>

        <% else %>
          <%# ── GRID / LIST layout ─────────────────────────────────── %>
          <div class="sm:hidden space-y-2.5">
            <% section[:items].each do |item| %>
              <%= link_to news_path(item), class: "group news-list-row" do %>
                <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
                  <% if item.cover_image.attached? %>
                    <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                      <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0 flex flex-col justify-center">
                  <span class="text-[10px] text-gray-400 mb-0.5"><%= item.region.display_name %> · <%= t("feed.ago", time: time_ago_in_words(item.published_at)) %></span>
                  <h3 class="text-[13px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                </div>
              <% end %>
            <% end %>
          </div>

          <div class="hidden sm:grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <% section[:items].each do |item| %>
              <%= link_to news_path(item), class: "group card-premium" do %>
                <div class="relative overflow-hidden">
                  <% if item.cover_image.attached? %>
                    <%= optimized_image_tag item.cover_image, variant: :card, class: "w-full h-36 object-cover img-zoom", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-36 gradient-brand-soft flex items-center justify-center">
                      <span class="text-2xl text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                </div>
                <div class="p-4">
                  <div class="flex items-center gap-1.5 mb-1.5">
                    <span class="text-[11px] font-bold text-orange-600"><%= item.region.display_name %></span>
                    <span class="text-[11px] text-gray-300">&middot;</span>
                    <span class="text-[11px] text-gray-400"><%= t("feed.ago", time: time_ago_in_words(item.published_at)) %></span>
                  </div>
                  <h3 class="text-[13px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= item.display_title %></h3>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ── EDUCATION NEWS SECTION ─────────────────────────────────────── %>
  <% if @education_posts.present? %>
    <div class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <div class="section-heading">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full shrink-0 bg-indigo-500"></span>
            <div>
              <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight"><%= t("feed.education_news") %></h2>
              <p class="text-[11px] text-gray-400 mt-0.5 hidden sm:block"><%= t("feed.education_news_subtitle") %></p>
            </div>
          </div>
        </div>
        <%= link_to education_index_path, class: "text-xs sm:text-sm font-bold text-orange-600 hover:text-orange-700 transition-colors shrink-0" do %>
          <%= t("feed.view_all") %> →
        <% end %>
      </div>

      <div class="horizontal-slider">
        <% @education_posts.each do |post| %>
          <%= link_to education_path(post), class: "group slider-card" do %>
            <div class="relative overflow-hidden rounded-t-2xl">
              <% if post.cover_image.attached? %>
                <%= optimized_image_tag post.cover_image, variant: :card, class: "w-full h-40 sm:h-44 object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-40 sm:h-44 bg-gradient-to-br from-indigo-100/90 via-blue-50 to-violet-100/80 flex items-center justify-center">
                  <svg class="w-10 h-10 text-indigo-300/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
                </div>
              <% end %>
            </div>
            <div class="p-4">
              <div class="mb-1">
                <span class="badge badge-category bg-indigo-600/90 text-white border-0 shadow-lg !text-[10px]"><%= post.category_label %></span>
              </div>
              <span class="text-[10px] text-gray-400"><%= t("feed.ago", time: time_ago_in_words(post.published_at)) %></span>
              <h3 class="text-[13px] sm:text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mt-1"><%= post.display_title %></h3>
              <% if post.organization_name.present? %>
                <span class="text-[11px] text-gray-400 mt-1 block truncate"><%= post.organization_name %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── JOB NEWS SECTION ───────────────────────────────────────────── %>
  <% if @job_posts.present? %>
    <div class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <div class="section-heading">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full shrink-0 bg-sky-500"></span>
            <div>
              <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight"><%= t("feed.job_news") %></h2>
              <p class="text-[11px] text-gray-400 mt-0.5 hidden sm:block"><%= t("feed.job_news_subtitle") %></p>
            </div>
          </div>
        </div>
        <%= link_to jobs_path, class: "text-xs sm:text-sm font-bold text-orange-600 hover:text-orange-700 transition-colors shrink-0" do %>
          <%= t("feed.view_all") %> →
        <% end %>
      </div>

      <div class="horizontal-slider">
        <% @job_posts.each do |post| %>
          <%= link_to job_path(post), class: "group slider-card" do %>
            <div class="relative overflow-hidden rounded-t-2xl">
              <% if post.cover_image.attached? %>
                <%= optimized_image_tag post.cover_image, variant: :card, class: "w-full h-40 sm:h-44 object-cover img-zoom", loading: "lazy" %>
              <% else %>
                <div class="w-full h-40 sm:h-44 bg-gradient-to-br from-blue-100/90 via-sky-50 to-cyan-100/80 flex items-center justify-center">
                  <svg class="w-10 h-10 text-blue-300/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
              <% end %>
            </div>
            <div class="p-4">
              <div class="flex flex-wrap items-center gap-1.5 mb-1">
                <span class="badge badge-category bg-blue-600/90 text-white border-0 shadow-lg !text-[10px]"><%= post.category_label %></span>
                <% if post.deadline_passed? %>
                  <span class="badge bg-red-600/90 text-white border-0 shadow-lg !text-[10px]"><%= t("jobs.closed") %></span>
                <% end %>
              </div>
              <span class="text-[10px] text-gray-400"><%= t("feed.ago", time: time_ago_in_words(post.published_at)) %></span>
              <h3 class="text-[13px] sm:text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mt-1"><%= post.display_title %></h3>
              <div class="flex items-center gap-2 mt-1">
                <span class="text-[11px] text-gray-400 truncate"><%= post.company_name %></span>
                <% if post.location.present? %>
                  <span class="text-[10px] text-gray-300">&middot;</span>
                  <span class="text-[11px] text-gray-400 truncate"><%= post.location %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── LATEST NEWS heading ───────────────────────────────────────── %>
  <% if @news_items.any? %>
    <div class="flex items-center justify-between mb-5">
      <div class="section-heading">
        <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight"><%= t("feed.latest_news") %></h2>
      </div>
      <div class="flex-1 section-divider mx-4 hidden sm:block"></div>
    </div>
  <% end %>

<% else %>
  <%# ═════════════════════════════════════════════════════════════════
      FILTERED / PAGED view
      ═════════════════════════════════════════════════════════════════ %>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════
    NEWS GRID + SIDEBAR
    ═══════════════════════════════════════════════════════════════════ %>
<% if @news_items.any? || (@featured.present? && !@is_home) %>
  <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
    <div class="flex-1 min-w-0">
      <% if @featured.present? && !@is_home %>
        <div class="mb-8 -mx-4 sm:mx-0 animate-fade-up">
          <%= link_to news_path(@featured), class: "group block relative overflow-hidden sm:rounded-2xl shadow-xl shadow-gray-300/30" do %>
            <div class="aspect-[16/9] sm:aspect-[2/1]">
              <% if @featured.cover_image.attached? %>
                <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover img-zoom", loading: "eager" %>
              <% else %>
                <div class="w-full h-full gradient-hero flex items-center justify-center">
                  <span class="text-6xl text-white/10 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
              <div class="absolute inset-0 gradient-dark-strong"></div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-8">
              <h2 class="text-lg sm:text-2xl font-black text-white leading-snug group-hover:text-orange-200 transition-colors line-clamp-2 tracking-tight"><%= @featured.display_title %></h2>
              <p class="text-sm text-white/60 mt-2 line-clamp-2 hidden sm:block"><%= truncate(strip_tags(@featured.display_content), length: 180) %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @news_items.empty? && @featured.blank? %>
        <div class="surface-elevated rounded-2xl px-6 py-16 sm:py-20 text-center">
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          </div>
          <p class="text-gray-400 font-medium text-sm"><%= t("feed.no_articles") %></p>
        </div>
      <% end %>

      <% if @news_items.any? %>
        <%# Mobile: list rows | Desktop: 2-column grid %>
        <% start_idx = @is_home ? 3 : 0 %>

        <%# MOBILE — compact list view (visible < sm) %>
        <div class="sm:hidden space-y-3">
          <% @news_items.drop(start_idx).each_with_index do |news_item, idx| %>
            <% if idx == 4 %>
              <%= render "shared/billboard_feed" %>
            <% end %>
            <% cache [ news_item, I18n.locale, "list", ENV.fetch("CACHE_VERSION", "v1") ] do %>
              <div class="animate-fade-in" style="animation-delay: <%= idx * 40 %>ms">
                <%= link_to news_path(news_item), class: "group news-list-row" do %>
                  <div class="w-24 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
                    <% if news_item.cover_image.attached? %>
                      <%= optimized_image_tag news_item.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
                    <% else %>
                      <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                        <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="flex-1 min-w-0 flex flex-col justify-center">
                    <div class="flex items-center gap-1.5 mb-1">
                      <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background-color: <%= news_item.category.color %>"></span>
                      <span class="text-[10px] font-bold text-orange-600 truncate"><%= news_item.category.display_name %></span>
                      <span class="text-[10px] text-gray-300">&middot;</span>
                      <span class="text-[10px] text-gray-400 shrink-0"><%= t("feed.ago", time: time_ago_in_words(news_item.published_at)) %></span>
                    </div>
                    <h2 class="text-[13px] font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight"><%= news_item.display_title %></h2>
                    <div class="flex items-center gap-2 mt-1.5 text-[10px] text-gray-400">
                      <span><%= news_item.region.display_name %></span>
                      <span class="inline-flex items-center gap-0.5">
                        <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                        <%= news_item.likes_count %>
                      </span>
                      <span class="inline-flex items-center gap-0.5">
                        <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        <%= news_item.comments_count %>
                      </span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# DESKTOP — 2-column card grid (visible >= sm) %>
        <div class="hidden sm:grid sm:grid-cols-2 gap-6">
          <% @news_items.drop(start_idx).each_with_index do |news_item, idx| %>
            <% if idx == 4 %>
              <%= render "shared/billboard_feed" %>
            <% end %>
            <% cache [ news_item, I18n.locale, "card", ENV.fetch("CACHE_VERSION", "v1") ] do %>
              <div class="animate-fade-in" style="animation-delay: <%= idx * 60 %>ms">
                <%= link_to news_path(news_item), class: "group block card-premium" do %>
                  <div class="relative overflow-hidden">
                    <% if news_item.cover_image.attached? %>
                      <%= optimized_image_tag news_item.cover_image, variant: :card, class: "w-full h-44 object-cover img-zoom", loading: "lazy" %>
                    <% else %>
                      <div class="w-full h-44 gradient-brand-soft flex items-center justify-center">
                        <span class="text-3xl text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="p-5">
                    <div class="mb-2">
                      <span class="badge badge-category">
                        <span class="w-2 h-2 rounded-full" style="background-color: <%= news_item.category.color %>"></span>
                        <%= news_item.category.display_name %>
                      </span>
                    </div>
                    <div class="flex items-center gap-2 mb-2.5">
                      <span class="text-xs font-bold text-orange-600"><%= news_item.region.display_name %></span>
                      <span class="text-xs text-gray-300">&middot;</span>
                      <span class="text-xs text-gray-400"><%= t("feed.ago", time: time_ago_in_words(news_item.published_at)) %></span>
                    </div>
                    <h2 class="font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 mb-2 text-[15px] leading-snug tracking-tight"><%= news_item.display_title %></h2>
                    <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed"><%= truncate(strip_tags(news_item.display_content), length: 120) %></p>
                    <div class="flex items-center justify-between mt-4 pt-3.5 border-t border-gray-100/80">
                      <div class="flex items-center gap-2.5">
                        <div class="w-6 h-6 rounded-full gradient-brand flex items-center justify-center">
                          <span class="text-white font-bold text-[9px]"><%= news_item.author.name[0] %></span>
                        </div>
                        <span class="text-xs text-gray-500 font-medium"><%= news_item.author.name %></span>
                      </div>
                      <div class="flex items-center gap-3 text-xs text-gray-400">
                        <span class="inline-flex items-center gap-1">
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                          <%= news_item.likes_count %>
                        </span>
                        <span class="inline-flex items-center gap-1">
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                          <%= news_item.comments_count %>
                        </span>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# Pagination %>
        <% total_pages = (@total_count.to_f / @per_page).ceil %>
        <% if total_pages > 1 %>
          <div class="flex items-center justify-center gap-2 sm:gap-3 mt-10 sm:mt-12">
            <% if @page > 1 %>
              <%= link_to url_for(request.query_parameters.merge(page: @page - 1)), class: "btn-ghost !text-[13px] !px-3 sm:!px-5" do %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
                <%= t("feed.previous") %>
              <% end %>
            <% end %>
            <span class="px-3 sm:px-4 py-2.5 text-[13px] sm:text-sm text-gray-400 font-semibold"><%= t("feed.page_info", current: @page, total: total_pages) %></span>
            <% if @page < total_pages %>
              <%= link_to url_for(request.query_parameters.merge(page: @page + 1)), class: "btn-primary !text-[13px] !px-3 sm:!px-5" do %>
                <%= t("feed.next") %>
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <% unless @is_home %>
      <aside class="lg:w-72 shrink-0 space-y-6">
        <div class="surface-raised rounded-2xl p-5">
          <h3 class="text-[13px] font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <%= t("feed.regions") %>
          </h3>
          <ul class="space-y-0.5">
            <li>
              <%= link_to root_path, class: "flex items-center gap-2 px-3 py-2 text-sm rounded-lg transition-all #{@region.nil? && @category.nil? ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                <%= t("feed.all_regions") %>
              <% end %>
            </li>
            <% @regions.each do |r| %>
              <li>
                <%= link_to r.display_name, region_feed_path(slug: r.slug), class: "block px-3 py-2 text-sm rounded-lg transition-all #{@region&.id == r.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" %>
              </li>
            <% end %>
          </ul>
        </div>
        <div class="hidden lg:block surface-raised rounded-2xl p-5">
          <h3 class="text-[13px] font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
            <%= t("feed.categories") %>
          </h3>
          <ul class="space-y-0.5">
            <% @categories.each do |c| %>
              <li>
                <%= link_to category_feed_path(slug: c.slug), class: "flex items-center gap-2.5 px-3 py-2 text-sm rounded-lg transition-all #{@category&.id == c.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
                  <span class="w-2.5 h-2.5 rounded-full shrink-0 ring-2 ring-white shadow-sm" style="background-color: <%= c.color %>"></span>
                  <%= c.display_name %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </aside>
    <% end %>
  </div>
<% elsif @news_items.empty? && @featured.blank? && !@is_home %>
  <div class="surface-elevated rounded-2xl px-6 py-16 sm:py-20 text-center">
    <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
      <svg class="w-6 h-6 sm:w-7 sm:h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
    </div>
    <p class="text-gray-400 font-medium text-sm"><%= t("feed.no_articles") %></p>
  </div>
<% end %>

<%# ═══════════════════════════════════════════════════════════════════
    HOME: Quick links — Webinars & Magazine
    ═══════════════════════════════════════════════════════════════════ %>
<% if @is_home %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mt-10 sm:mt-14 mb-4">
