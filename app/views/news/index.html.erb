<%# Category pills — horizontal scroll on mobile %>
<div class="mb-8">
  <div class="flex items-center gap-2 overflow-x-auto pb-2 -mx-1 px-1 scrollbar-hide">
    <%= link_to root_path, class: "shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-[13px] font-semibold transition-all #{ @region.nil? && @category.nil? ? 'gradient-brand text-white shadow-sm shadow-orange-200/60' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
      <%= t("feed.all_regions") %>
    <% end %>
    <% @categories.each do |c| %>
      <%= link_to category_feed_path(slug: c.slug), class: "shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-[13px] font-semibold transition-all #{ @category&.id == c.id ? 'gradient-brand text-white shadow-sm shadow-orange-200/60' : 'bg-white text-gray-600 border border-gray-200/60 hover:border-orange-200 hover:text-orange-600 shadow-sm shadow-gray-100' }" do %>
        <span class="w-2 h-2 rounded-full shrink-0 ring-1 ring-white/50" style="background-color: <%= c.color %>"></span>
        <%= c.display_name %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Page header for filtered views %>
<% if @region || @category %>
  <div class="mb-8 animate-fade-in">
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-2">
      <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-600 font-medium"><%= (@region || @category).display_name %></span>
    </nav>
    <h1 class="text-2xl sm:text-3xl font-black text-gray-900 tracking-tight"><%= (@region || @category).display_name %></h1>
    <p class="text-gray-500 mt-1">
      <% if @region %>
        <%= t("feed.news_from", name: @region.display_name) %>
      <% else %>
        <%= t("feed.news_in", name: @category.display_name) %>
      <% end %>
    </p>
  </div>
<% end %>

<div class="flex flex-col lg:flex-row gap-8">
  <%# Main content %>
  <div class="flex-1 min-w-0">
    <% if @featured.present? && @region.nil? && @category.nil? %>
      <%# Hero featured news item %>
      <div class="mb-10 animate-fade-up">
        <%= link_to news_path(@featured), class: "group block relative rounded-2xl overflow-hidden shadow-xl shadow-gray-300/30" do %>
          <div class="aspect-[16/8] sm:aspect-[2/1]">
            <% if @featured.cover_image.attached? %>
              <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover img-zoom", loading: "eager" %>
            <% else %>
              <div class="w-full h-full gradient-hero flex items-center justify-center">
                <span class="text-6xl text-white/10 font-black"><%= t("brand.logo_letter") %></span>
              </div>
            <% end %>
            <div class="absolute inset-0 gradient-dark-strong"></div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8 lg:p-10">
            <div class="flex items-center gap-2.5 mb-3">
              <span class="badge badge-category !bg-white/20 !text-white !backdrop-blur-md">
                <span class="w-1.5 h-1.5 rounded-full" style="background-color: <%= @featured.category.color %>"></span>
                <%= @featured.category.display_name %>
              </span>
              <span class="text-xs text-white/60 font-medium"><%= @featured.region.display_name %></span>
            </div>
            <h2 class="text-xl sm:text-2xl lg:text-3xl font-black text-white leading-tight group-hover:text-orange-200 transition-colors line-clamp-2 tracking-tight">
              <%= @featured.display_title %>
            </h2>
            <p class="text-sm text-white/60 mt-3 line-clamp-2 hidden sm:block max-w-2xl"><%= truncate(strip_tags(@featured.display_content), length: 180) %></p>
            <div class="flex items-center gap-3 mt-4">
              <div class="w-8 h-8 rounded-full bg-white/15 backdrop-blur-md flex items-center justify-center ring-1 ring-white/20">
                <span class="text-white font-bold text-xs"><%= @featured.author.name[0] %></span>
              </div>
              <div>
                <span class="text-sm text-white/90 font-semibold"><%= @featured.author.name %></span>
                <span class="text-white/30 mx-1.5">&middot;</span>
                <span class="text-sm text-white/50"><%= t("feed.ago", time: time_ago_in_words(@featured.published_at)) %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% unless @region || @category %>
        <div class="flex items-center gap-3 mb-6">
          <h2 class="text-lg font-bold text-gray-900"><%= t("feed.title") %></h2>
          <div class="flex-1 section-divider"></div>
        </div>
      <% end %>
    <% elsif @news_items.empty? && @featured.blank? %>
      <div class="surface-elevated rounded-2xl px-6 py-20 text-center">
        <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        </div>
        <p class="text-gray-400 font-medium"><%= t("feed.no_articles") %></p>
      </div>
    <% end %>

    <% if @news_items.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <% @news_items.each_with_index do |news_item, idx| %>
          <% if idx == 4 %>
            <%= render "shared/billboard_feed" %>
          <% end %>
          <% cache [ news_item, I18n.locale ] do %>
            <div class="animate-fade-in" style="animation-delay: <%= idx * 60 %>ms">
              <%= link_to news_path(news_item), class: "group block card-premium" do %>
                <div class="relative overflow-hidden">
                  <% if news_item.cover_image.attached? %>
                    <%= optimized_image_tag news_item.cover_image, variant: :card, class: "w-full h-48 sm:h-44 object-cover img-zoom", loading: "lazy" %>
                  <% else %>
                    <div class="w-full h-48 sm:h-44 gradient-brand-soft flex items-center justify-center">
                      <span class="text-3xl text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                  <div class="absolute top-3 left-3">
                    <span class="badge badge-category">
                      <span class="w-2 h-2 rounded-full" style="background-color: <%= news_item.category.color %>"></span>
                      <%= news_item.category.display_name %>
                    </span>
                  </div>
                </div>

                <div class="p-5">
                  <div class="flex items-center gap-2 mb-2.5">
                    <span class="text-xs font-bold text-orange-600"><%= news_item.region.display_name %></span>
                    <span class="text-xs text-gray-300">&middot;</span>
                    <span class="text-xs text-gray-400"><%= t("feed.ago", time: time_ago_in_words(news_item.published_at)) %></span>
                  </div>

                  <h2 class="font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 mb-2 text-[15px] leading-snug tracking-tight">
                    <%= news_item.display_title %>
                  </h2>

                  <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed"><%= truncate(strip_tags(news_item.display_content), length: 120) %></p>

                  <div class="flex items-center justify-between mt-4 pt-3.5 border-t border-gray-100/80">
                    <div class="flex items-center gap-2.5">
                      <div class="w-6 h-6 rounded-full gradient-brand flex items-center justify-center">
                        <span class="text-white font-bold text-[9px]"><%= news_item.author.name[0] %></span>
                      </div>
                      <span class="text-xs text-gray-500 font-medium"><%= news_item.author.name %></span>
                    </div>
                    <div class="flex items-center gap-3 text-xs text-gray-400">
                      <span class="inline-flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                        <%= news_item.likes_count %>
                      </span>
                      <span class="inline-flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        <%= news_item.comments_count %>
                      </span>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# Pagination %>
      <% total_pages = (@total_count.to_f / @per_page).ceil %>
      <% if total_pages > 1 %>
        <div class="flex items-center justify-center gap-3 mt-12">
          <% if @page > 1 %>
            <%= link_to url_for(request.query_parameters.merge(page: @page - 1)), class: "btn-ghost" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
              <%= t("feed.previous") %>
            <% end %>
          <% end %>
          <span class="px-4 py-2.5 text-sm text-gray-400 font-semibold"><%= t("feed.page_info", current: @page, total: total_pages) %></span>
          <% if @page < total_pages %>
            <%= link_to url_for(request.query_parameters.merge(page: @page + 1)), class: "btn-primary" do %>
              <%= t("feed.next") %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Sidebar %>
  <aside class="lg:w-72 shrink-0 space-y-6">
    <%# Regions %>
    <div class="surface-raised rounded-2xl p-5">
      <h3 class="text-[13px] font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <%= t("feed.regions") %>
      </h3>
      <ul class="space-y-0.5">
        <li>
          <%= link_to root_path, class: "flex items-center gap-2 px-3 py-2 text-sm rounded-lg transition-all #{@region.nil? && @category.nil? ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
            <%= t("feed.all_regions") %>
          <% end %>
        </li>
        <% @regions.each do |r| %>
          <li>
            <%= link_to r.display_name, region_feed_path(slug: r.slug), class: "block px-3 py-2 text-sm rounded-lg transition-all #{@region&.id == r.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" %>
          </li>
        <% end %>
      </ul>
    </div>

    <%# Categories — visible on desktop only (pills are mobile-friendly) %>
    <div class="hidden lg:block surface-raised rounded-2xl p-5">
      <h3 class="text-[13px] font-bold text-gray-900 mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
        <%= t("feed.categories") %>
      </h3>
      <ul class="space-y-0.5">
        <% @categories.each do |c| %>
          <li>
            <%= link_to category_feed_path(slug: c.slug), class: "flex items-center gap-2.5 px-3 py-2 text-sm rounded-lg transition-all #{@category&.id == c.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
              <span class="w-2.5 h-2.5 rounded-full shrink-0 ring-2 ring-white shadow-sm" style="background-color: <%= c.color %>"></span>
              <%= c.display_name %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </aside>
</div>
