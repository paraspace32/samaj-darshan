<%# ═══════════════════════════════════════════════════════════════════
    NEWS GRID + SIDEBAR
    ═══════════════════════════════════════════════════════════════════ %>
<% if !@is_home && (@news_items.any? || @featured.present?) %>
  <div class="flex flex-col lg:flex-row gap-5 lg:gap-6">
    <div class="flex-1 min-w-0">
      <% if @featured.present? && !@is_home %>
        <div class="mb-8 -mx-4 sm:mx-0 animate-fade-up">
          <%= link_to news_path(@featured), class: "group block relative overflow-hidden sm:rounded-2xl shadow-xl shadow-gray-300/30" do %>
            <div class="aspect-[16/9] sm:aspect-[2/1]">
              <% if @featured.cover_image.attached? %>
                <%= optimized_image_tag @featured.cover_image, variant: :hero, class: "w-full h-full object-cover img-zoom", loading: "eager" %>
              <% else %>
                <div class="w-full h-full gradient-hero flex items-center justify-center">
                  <span class="text-6xl text-white/10 font-black"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
              <div class="absolute inset-0 gradient-dark-strong"></div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-8">
              <h2 class="text-lg sm:text-2xl font-black text-white leading-snug group-hover:text-orange-200 transition-colors line-clamp-2 tracking-tight"><%= @featured.display_title %></h2>
              <p class="text-sm text-white/60 mt-2 line-clamp-2 hidden sm:block"><%= truncate(strip_tags(@featured.display_content), length: 180) %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @news_items.empty? && @featured.blank? %>
        <div class="surface-elevated rounded-2xl px-6 py-16 sm:py-20 text-center">
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          </div>
          <p class="text-gray-400 font-medium text-sm"><%= t("feed.no_articles") %></p>
        </div>
      <% end %>

      <% if @news_items.any? %>
        <%# Mobile: list rows | Desktop: 2-column grid — wrapped in infinite scroll controller %>
        <% start_idx   = 0 %>
        <% total_pages = (@total_count.to_f / @per_page).ceil %>
        <% has_more    = @page < total_pages %>
        <% next_url    = has_more ? url_for(request.query_parameters.merge(page: @page + 1)) : nil %>

        <div>
          <%# MOBILE — compact list view (visible < sm) %>
          <div id="news-grid-mobile" class="sm:hidden space-y-2">
            <% @news_items.drop(start_idx).each_with_index do |news_item, idx| %>
              <% if idx == 4 || idx == 9 %>
                <%# In-feed ad — after every ~4 articles %>
                <%= render "shared/billboard_feed" %>
              <% end %>
              <%= render "news/news_mobile_item", news_item: news_item, idx: idx %>
            <% end %>
          </div>

          <%# DESKTOP — 2-column card grid (visible >= sm) %>
          <div id="news-grid-desktop" class="hidden sm:grid sm:grid-cols-2 gap-6">
            <% @news_items.drop(start_idx).each_with_index do |news_item, idx| %>
              <% if idx == 4 || idx == 9 %>
                <%# In-feed ad — spans both columns %>
                <div class="col-span-2">
                  <%= render "shared/billboard_feed" %>
                </div>
              <% end %>
              <%= render "news/news_desktop_item", news_item: news_item, idx: idx %>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>

    <% if @is_home %>
      <%= render "news/home_sidebar" %>
    <% else %>
      <aside class="lg:w-72 shrink-0 space-y-6">
        <div class="surface-raised rounded-2xl p-5">
          <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <%= t("feed.regions") %>
          </h3>
          <ul class="space-y-0.5">
            <li>
              <%= link_to root_path, class: "flex items-center gap-2 px-3 py-2 text-sm rounded-lg transition-all #{@region.nil? && @category.nil? ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                <%= t("feed.all_regions") %>
              <% end %>
            </li>
            <% @regions.each do |r| %>
              <li>
                <%= link_to r.display_name, region_feed_path(slug: r.slug), class: "block px-3 py-2 text-sm rounded-lg transition-all #{@region&.id == r.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" %>
              </li>
            <% end %>
          </ul>
        </div>
        <div class="hidden lg:block surface-raised rounded-2xl p-5">
          <h3 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
            <%= t("feed.categories") %>
          </h3>
          <ul class="space-y-0.5">
            <% @categories.each do |c| %>
              <li>
                <%= link_to category_feed_path(slug: c.slug), class: "flex items-center gap-2.5 px-3 py-2 text-sm rounded-lg transition-all #{@category&.id == c.id ? 'bg-orange-50 text-orange-700 font-semibold' : 'text-gray-600 hover:bg-gray-50'}" do %>
                  <span class="w-2.5 h-2.5 rounded-full shrink-0 ring-2 ring-white shadow-sm" style="background-color:#f97316"></span>
                  <%= c.display_name %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </aside>
    <% end %>
  </div>
<% elsif @news_items.empty? && @featured.blank? && !@is_home %>
  <div class="surface-elevated rounded-2xl px-6 py-16 sm:py-20 text-center">
    <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
      <svg class="w-6 h-6 sm:w-7 sm:h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
    </div>
    <p class="text-gray-400 font-medium text-sm"><%= t("feed.no_articles") %></p>
  </div>
<% end %>

