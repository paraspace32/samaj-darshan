        <div>
          <span class="stat-number"><%= total_articles %>+</span>
        </div>
        <div>
          <span class="text-[12px] font-bold text-amber-900/80"><%= I18n.locale == :hi ? "आज की खबरें" : "Stories Today" %></span>
          <span class="text-[10px] text-amber-700/50 block"><%= I18n.locale == :hi ? "सभी श्रेणियों से" : "Across all categories" %></span>
        </div>
        <svg class="w-5 h-5 text-amber-400/40 ml-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
    </div>
  <% end %>

  <%# ── CATEGORY SECTIONS — clean white cards with accent headers ── %>
  <% if @category_sections.present? %>
