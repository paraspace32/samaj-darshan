<%
  # ─── Locale-aware OG / sharing variables ───────────────────────────────────
  og_title_text    = I18n.locale == :en ? (@news_item.title_en.presence || @news_item.title_hi) : @news_item.display_title
  og_desc_text     = I18n.locale == :en ? (@news_item.content_en.presence || @news_item.content_hi) : @news_item.display_content
  share_locale_url = I18n.locale == :en ? news_url(@news_item, locale: :en) : news_url(@news_item)
  share_text       = "#{og_title_text}\n\n#{share_locale_url}"

  # Reading time (200 wpm average)
  word_count   = @news_item.display_content.to_s.split.size
  reading_mins = [[( word_count / 200.0).ceil, 1].max, 60].min

  smart_date = @news_item.published_at.strftime("%d %b %Y")

  # Other-language helpers for bilingual toggle
  other_lang_label = I18n.locale == :hi ? "Read in English" : "हिंदी में पढ़ें"
  other_title      = I18n.locale == :hi ? @news_item.title_en : @news_item.title_hi
  other_content    = I18n.locale == :hi ? @news_item.content_en : @news_item.content_hi
%>

<%# ── Meta tags ──────────────────────────────────────────────────────────────── %>
<% content_for(:title, "#{og_title_text} — #{t('brand.name')}") %>
<% content_for(:og_title, og_title_text) %>
<% content_for(:og_type, "article") %>
<% content_for(:description, truncate(strip_tags(og_desc_text), length: 200)) %>
<% if @news_item.cover_image.attached? %>
  <% content_for(:og_image, og_image_url(@news_item.cover_image)) %>
<% end %>

<%# ── Canonical URL — prevents ?locale=en duplicate content penalty ──────────── %>
<% content_for :head do %>
  <link rel="canonical" href="<%= news_url(@news_item) %>">
<% end %>

<%# ── Schema.org Article JSON-LD — Google News / Discover / rich snippets ──────── %>
<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": <%= og_title_text.to_json %>,
    "description": <%= truncate(strip_tags(og_desc_text), length: 200).to_json %>,
    "url": <%= news_url(@news_item).to_json %>,
    "datePublished": <%= @news_item.published_at.iso8601.to_json %>,
    "dateModified": <%= @news_item.updated_at.iso8601.to_json %>,
    "inLanguage": <%= (I18n.locale == :hi ? "hi-IN" : "en-IN").to_json %>,
    "author": {
      "@type": "Person",
      "name": <%= @news_item.author.name.to_json %>
    },
    "publisher": {
      "@type": "Organization",
      "name": <%= t("brand.name").to_json %>,
      "logo": {
        "@type": "ImageObject",
        "url": "<%= request.base_url %>/icon-192.png",
        "width": 192,
        "height": 192
      }
    }<%= @news_item.cover_image.attached? ? ",\n    \"image\": [#{og_image_url(@news_item.cover_image).to_json}]" : "" %>
  }
  </script>
<% end %>

<%# ── Reading progress bar (fixed, above everything) ─────────────────────────── %>
<div data-controller="reading-progress" class="fixed top-0 left-0 right-0 z-[100] h-[3px] pointer-events-none">
  <div data-reading-progress-target="bar" class="h-full w-0 rounded-r-full"
       style="background:linear-gradient(90deg,#f97316,#dc2626); box-shadow:0 0 10px rgba(249,115,22,0.7); transition:none"></div>
</div>

<%# ── Sticky mobile bottom bar ────────────────────────────────────────────────── %>
<%= render "shared/mobile_bottom_bar",
      toggle_path: toggle_news_like_path(@news_item),
      liked: @liked,
      likes_count: @news_item.likes_count,
      share_text: share_text %>

<%# ── Main layout ─────────────────────────────────────────────────────────────── %>
<div class="flex flex-col lg:flex-row gap-12 lg:gap-16 xl:gap-20 pb-20 sm:pb-0">

  <%# ════ Main article ════════════════════════════════════════════════════════ %>
  <article class="flex-1 min-w-0 animate-fade-in">

    <%# Breadcrumb %>
    <nav class="flex items-center gap-2 text-sm text-stone-500 mb-5 animate-fade-up flex-wrap">
      <%= link_to t("nav.home"), root_path, class: "hover:text-orange-600 transition-colors font-medium shrink-0" %>
      <svg class="w-3.5 h-3.5 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <%= link_to @news_item.region.display_name, region_feed_path(slug: @news_item.region.slug), class: "hover:text-orange-600 transition-colors font-medium shrink-0" %>
      <svg class="w-3.5 h-3.5 text-stone-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-stone-600 truncate font-medium"><%= truncate(@news_item.display_title, length: 40) %></span>
    </nav>

    <%# Category pill + reading time ── new row above title %>
    <div class="flex items-center gap-2.5 mb-3 flex-wrap">
      <%= link_to category_feed_path(slug: @news_item.category.slug),
            class: "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-black text-white shrink-0 transition-opacity hover:opacity-90",
            style: "background:linear-gradient(135deg,#f97316,#dc2626); box-shadow:0 2px 10px -2px rgba(249,115,22,0.5)" do %>
        <span class="w-1.5 h-1.5 rounded-full bg-white/70 shrink-0"></span>
        <%= @news_item.category.display_name %>
      <% end %>
      <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-stone-400 bg-stone-50 border border-stone-100 rounded-full px-3 py-1">
        <svg class="w-3 h-3 shrink-0 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= reading_mins %> <%= I18n.locale == :hi ? "मिनट पढ़ें" : "min read" %>
      </span>
    </div>

    <%# Title %>
    <h1 class="text-lg sm:text-xl lg:text-2xl font-black tracking-tight text-stone-900 leading-snug mb-4">
      <%= @news_item.display_title %>
    </h1>

    <%# Cover image — right below headline %>
    <% gallery_images = [@news_item.cover_image.attached? ? @news_item.cover_image : nil, *(@news_item.images.attached? ? @news_item.images : [])].compact %>
    <% if gallery_images.size == 1 %>
      <div class="mb-0 -mx-4 sm:mx-0 group overflow-hidden rounded-none sm:rounded-3xl border border-gray-200/40 shadow-2xl shadow-stone-900/10">
        <%= optimized_image_tag gallery_images.first, variant: :hero, class: "w-full h-64 sm:h-80 lg:h-[520px] object-cover img-zoom" %>
      </div>
    <% elsif gallery_images.size > 1 %>
      <div class="mb-0 -mx-4 sm:mx-0 relative rounded-none sm:rounded-3xl overflow-hidden border border-gray-200/40 shadow-2xl shadow-stone-900/10 group"
           data-controller="carousel" data-carousel-autoplay-value="true">
        <div class="relative">
          <div class="overflow-hidden">
            <div class="flex transition-transform duration-500 ease-out" data-carousel-target="track">
              <% gallery_images.each do |img| %>
                <div class="w-full shrink-0 group" data-carousel-target="slide">
                  <%= optimized_image_tag img, variant: :carousel, class: "w-full h-64 sm:h-96 object-cover img-zoom", loading: "lazy" %>
                </div>
              <% end %>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-28 sm:h-32 gradient-dark-strong opacity-90"></div>
          <button data-action="carousel#prev"
                  class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-2xl bg-black/35 backdrop-blur-md text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-black/55 cursor-pointer shadow-lg border border-white/10">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button data-action="carousel#next"
                  class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-2xl bg-black/35 backdrop-blur-md text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-black/55 cursor-pointer shadow-lg border border-white/10">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </button>
          <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 flex items-center gap-2">
            <% gallery_images.each_with_index do |_, i| %>
              <button data-carousel-target="dot" data-action="carousel#goToSlide" data-index="<%= i %>"
                      class="h-2 rounded-full transition-all duration-300 cursor-pointer <%= i == 0 ? 'bg-white w-7 shadow-md' : 'bg-white/45 w-2 hover:bg-white/70' %>"></button>
            <% end %>
          </div>
          <div class="absolute top-5 right-5 z-10 rounded-2xl bg-black/45 backdrop-blur-md text-white text-xs font-bold px-3 py-1.5 border border-white/15 shadow-lg"
               data-carousel-target="counter">
            1 / <%= gallery_images.size %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Author card — single compact line %>
    <div class="flex items-center gap-2.5 animate-fade-up" style="margin-top:0.25rem; margin-bottom:0.25rem">
      <div class="w-5 h-5 rounded-full gradient-brand flex items-center justify-center shadow-sm ring-1 ring-white shrink-0">
        <span class="text-white font-black text-[9px]"><%= @news_item.author.name[0] %></span>
      </div>
      <div class="min-w-0 flex-1 flex items-center gap-1.5 flex-wrap">
        <span class="text-[12px] font-normal text-stone-600"><%= @news_item.author.name %></span>
        <span class="text-stone-300 text-[11px]">·</span>
        <span class="text-[11px] text-stone-400 font-medium"><%= @news_item.region.display_name %></span>
        <span class="text-stone-300 text-[11px]">·</span>
        <span class="text-[11px] text-stone-400 font-medium"><%= smart_date %></span>
      </div>
      <%# Live readers %>
      <% live_count  = @active_readers.to_i > 0 ? @active_readers : nil %>
      <% live_count ||= @site_active_users.to_i > 0 ? @site_active_users : nil %>
      <% if live_count %>
        <div class="shrink-0 flex items-center gap-1.5">
          <span class="relative flex h-1.5 w-1.5 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
          </span>
          <span class="text-[11px] font-black text-green-600"><%= live_count %> <%= I18n.locale == :hi ? "पढ़ रहे हैं" : "reading" %></span>
        </div>
      <% else %>
        <div class="shrink-0 flex items-center gap-1 text-[11px] text-stone-400 font-semibold">
          <svg class="w-3 h-3 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          <%= number_with_delimiter(@news_item.views_count) %>
        </div>
      <% end %>
    </div>

    <div class="section-divider mb-0"></div>

    <%= render "shared/billboard_article_top" %>

    <%# News body %>
    <div class="prose prose-stone prose-lg max-w-none mb-12 animate-fade-up
                prose-headings:font-black prose-headings:tracking-tight prose-headings:text-stone-900
                prose-p:text-stone-600 prose-p:leading-relaxed prose-p:text-[1.05rem]
                prose-a:text-orange-600 prose-a:font-semibold prose-a:no-underline hover:prose-a:underline prose-a:decoration-orange-300/80
                prose-blockquote:border-orange-500 prose-blockquote:border-l-4 prose-blockquote:bg-orange-50/60 prose-blockquote:rounded-r-2xl prose-blockquote:py-3 prose-blockquote:px-2 prose-blockquote:text-stone-700">
      <%= format_with_links(@news_item.display_content) %>
    </div>

    <%= render "shared/billboard_article_mid" %>

    <%# Engagement card — pass locale-aware share_url to fix copy link %>
    <%= render "shared/engagement_card",
          item: @news_item,
          liked: @liked,
          toggle_path: toggle_news_like_path(@news_item),
          comments_path: news_comments_path(@news_item),
          comments: @comments,
          share_text: share_text,
          share_url: share_locale_url %>

    <%# Bilingual toggle — specific language label %>
    <% if other_title.present? || other_content.present? %>
      <details class="surface-raised rounded-3xl border border-gray-200/40 overflow-hidden mb-10 shadow-lg shadow-stone-900/[0.05] open:shadow-xl open:ring-1 open:ring-orange-200/40 transition-shadow">
        <summary class="px-6 sm:px-8 py-5 text-sm font-bold text-stone-800 cursor-pointer hover:bg-stone-50/80 transition-colors flex items-center gap-3 list-none [&::-webkit-details-marker]:hidden">
          <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-stone-100 text-stone-500 transition-colors shrink-0">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
          </span>
          <%= other_lang_label %>
        </summary>
        <div class="px-6 sm:px-8 pb-8 pt-2 prose prose-sm prose-stone max-w-none border-t border-stone-100/90" dir="auto">
          <% if other_title.present? %><h3 class="text-lg font-black tracking-tight text-stone-900"><%= other_title %></h3><% end %>
          <% if other_content.present? %><%= format_with_links(other_content) %><% end %>
        </div>
      </details>
    <% end %>

    <%# Continue reading — first related article, or back link if none %>
    <% if @related.any? %>
      <% next_article = @related.first %>
      <div class="mt-8 mb-2">
        <p class="text-[10px] font-black uppercase tracking-[0.15em] text-orange-500 mb-3 pl-1">
          <%= I18n.locale == :hi ? "आगे पढ़ें" : "Continue Reading" %>
        </p>
        <%= link_to news_path(next_article),
              class: "group flex gap-4 p-4 sm:p-5 rounded-3xl border border-gray-200/40 shadow-lg shadow-stone-900/[0.06]
                      hover:shadow-xl hover:shadow-orange-100/40 transition-all duration-200 bg-white
                      hover:bg-gradient-to-r hover:from-orange-50/30 hover:to-amber-50/20 no-underline" do %>
          <% if next_article.cover_image.attached? %>
            <div class="shrink-0 overflow-hidden rounded-2xl border border-gray-200/30 shadow-md">
              <%= optimized_image_tag next_article.cover_image, variant: :thumb, class: "w-24 h-16 sm:w-28 sm:h-18 object-cover img-zoom", loading: "lazy" %>
            </div>
          <% else %>
            <div class="w-24 h-16 rounded-2xl gradient-brand-soft border border-orange-100/60 flex items-center justify-center shrink-0 shadow-inner">
              <span class="text-orange-300 font-black text-xs"><%= t("brand.logo_letter") %></span>
            </div>
          <% end %>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-black text-stone-900 line-clamp-2 group-hover:text-transparent group-hover:bg-clip-text
                       group-hover:bg-gradient-to-r group-hover:from-orange-600 group-hover:to-red-600 transition-all leading-snug tracking-tight mb-1.5">
              <%= next_article.display_title %>
            </p>
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-bold text-stone-400"><%= next_article.region.display_name %></span>
              <span class="text-stone-200 text-[10px]">·</span>
            </div>
          </div>
          <div class="shrink-0 flex items-center self-center text-stone-300 group-hover:text-orange-400 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-10 mb-2 animate-fade-up">
        <%= link_to root_path, class: "btn-ghost inline-flex items-center gap-2 text-sm font-bold text-stone-700 hover:text-orange-700" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          <%= t("article.back_to_news") %>
        <% end %>
      </div>
    <% end %>

    <%# ══ 1. Trending now — first, highest engagement ══════════════════════════ %>
    <%= render "shared/billboard_feed" %>
    <% if @trending_articles.any? %>
      <div class="mt-10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#f97316,#ea580c)"></div>
          <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse shrink-0"></span>
          <h2 class="text-base font-black text-gray-900 tracking-tight whitespace-nowrap"><%= I18n.locale == :hi ? "ट्रेंडिंग खबरें" : "Trending Now" %></h2>
          <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fed7aa,transparent)"></div>
        </div>
        <div class="divide-y divide-stone-100/80 rounded-2xl border border-gray-200/40 overflow-hidden">
          <% @trending_articles.each_with_index do |art, i| %>
            <%= link_to news_path(art),
                  class: "group flex items-center gap-3 px-4 py-3.5 bg-white hover:bg-orange-50/40 transition-colors no-underline" do %>
              <span class="trending-rank text-xl shrink-0 leading-none w-7 text-center"><%= "%02d" % (i + 1) %></span>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-bold text-stone-800 line-clamp-2 leading-snug group-hover:text-orange-700 transition-colors tracking-tight mb-1"><%= art.display_title %></p>
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-semibold text-stone-400"><%= art.region.display_name %></span>
                  <span class="text-stone-200 text-[10px]">·</span>
                  <span class="text-[10px] font-semibold text-stone-400 flex items-center gap-0.5">
                    <svg class="w-2.5 h-2.5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    <%= number_with_delimiter(art.views_count) %>
                  </span>
                </div>
              </div>
              <div class="w-16 h-[4.25rem] rounded-xl overflow-hidden shrink-0 border border-gray-200/40">
                <% if art.cover_image.attached? %>
                  <%= optimized_image_tag art.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                    <span class="text-orange-300 font-black text-xs"><%= t("brand.logo_letter") %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ══ 2. More from this category ══════════════════════════════════════════════ %>
    <%= render "shared/billboard_feed" %>
    <% if @category_articles.any? %>
      <div class="mt-10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#f97316,#ea580c)"></div>
          <h2 class="text-base font-black text-gray-900 tracking-tight whitespace-nowrap"><%= @news_item.category.display_name %></h2>
          <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fed7aa,transparent)"></div>
          <%= link_to category_feed_path(slug: @news_item.category.slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-orange-700 bg-orange-100 hover:bg-orange-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
            <%= I18n.locale == :hi ? "और देखें" : "View All" %>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% @category_articles.first(4).each do |art| %>
            <%= link_to news_path(art),
                  class: "group flex gap-3 p-3 rounded-2xl border border-gray-200/40 bg-white hover:bg-orange-50/30
                          hover:border-orange-200/50 hover:shadow-md hover:shadow-orange-100/30 transition-all duration-200 no-underline" do %>
              <% if art.cover_image.attached? %>
                <div class="shrink-0 overflow-hidden rounded-xl border border-gray-200/30">
                  <%= optimized_image_tag art.cover_image, variant: :thumb, class: "w-16 h-12 object-cover img-zoom", loading: "lazy" %>
                </div>
              <% else %>
                <div class="w-16 h-12 rounded-xl gradient-brand-soft border border-orange-100/60 flex items-center justify-center shrink-0">
                  <span class="text-orange-300 font-black text-[10px]"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
              <div class="min-w-0 flex-1">
                <p class="text-xs font-bold text-stone-800 line-clamp-2 leading-snug group-hover:text-orange-700 transition-colors mb-1"><%= art.display_title %></p>
                <span class="text-[10px] text-stone-400 font-medium"><%= art.region.display_name %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ══ 3. Regional news — mobile only (desktop uses sidebar) ════════════════ %>
    <% if @related.any? %>
      <div class="mt-10 lg:hidden">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#d97706,#b45309)"></div>
          <h2 class="text-base font-black text-gray-900 tracking-tight whitespace-nowrap"><%= @news_item.region.display_name %> <%= I18n.locale == :hi ? "से और" : "News" %></h2>
          <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#fde68a,transparent)"></div>
          <%= link_to region_feed_path(slug: @news_item.region.slug), class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-amber-700 bg-amber-100 hover:bg-amber-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
            <%= I18n.locale == :hi ? "और देखें" : "View All" %>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
        <div class="space-y-2.5">
          <% @related.each do |rel| %>
            <%= link_to news_path(rel), class: "group news-list-row" do %>
              <div class="w-20 h-[4.25rem] rounded-lg overflow-hidden shrink-0">
                <% if rel.cover_image.attached? %>
                  <%= optimized_image_tag rel.cover_image, variant: :thumb, class: "w-full h-full object-cover img-zoom", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full gradient-brand-soft flex items-center justify-center">
                    <span class="text-base text-orange-200/60 font-black"><%= t("brand.logo_letter") %></span>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0 flex flex-col justify-center">
                <h3 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-snug tracking-tight mb-0.5"><%= rel.display_title %></h3>
                <span class="text-[11px] text-gray-400"><%= rel.category.display_name %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ══ Share CTA ═════════════════════════════════════════════════════════════ %>
    <div class="mt-12 mb-4 rounded-3xl overflow-hidden relative"
         style="background:linear-gradient(135deg,#fff7ed,#fef3c7,#fff7ed); border:1px solid rgba(249,115,22,0.15); box-shadow:0 8px 32px -8px rgba(249,115,22,0.2)">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image:radial-gradient(#f97316 1px,transparent 1px); background-size:20px 20px"></div>
      <div class="relative px-6 py-8 text-center">
        <div class="w-12 h-12 rounded-2xl mx-auto mb-4 flex items-center justify-center shadow-lg"
             style="background:linear-gradient(135deg,#f97316,#dc2626); box-shadow:0 8px 20px -4px rgba(249,115,22,0.45)">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <h3 class="text-base font-black text-stone-800 mb-1">
          <%= I18n.locale == :hi ? "खबर अच्छी लगी? शेयर करें!" : "Liked this story? Share it!" %>
        </h3>
        <p class="text-xs text-stone-500 mb-5">
          <%= I18n.locale == :hi ? "अपने परिवार और दोस्तों तक पहुँचाएं" : "Spread the word to your community" %>
        </p>
        <a href="https://wa.me/?text=<%= ERB::Util.url_encode(share_text) %>"
           target="_blank" rel="noopener"
           class="inline-flex items-center gap-2.5 px-6 py-3 rounded-2xl font-black text-sm text-white shadow-lg transition-all hover:scale-[1.03] hover:shadow-xl active:scale-95"
           style="background:linear-gradient(135deg,#22c55e,#16a34a); box-shadow:0 8px 20px -4px rgba(34,197,94,0.45)">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <%= I18n.locale == :hi ? "WhatsApp पर शेयर करें" : "Share on WhatsApp" %>
        </a>
      </div>
    </div>

    <%# ══ Bottom ad ══════════════════════════════════════════════════════════════ %>
    <%= render "shared/billboard_feed" %>

    <%# ══ ताज़ी नौकरियां — cross-content block ════════════════════════════════ %>
    <% if @sidebar_jobs.any? %>
      <div class="mt-8 mb-4">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-1.5 h-7 rounded-full shrink-0" style="background: linear-gradient(180deg,#0ea5e9,#0284c7)"></div>
          <h2 class="text-base font-black text-gray-900 tracking-tight whitespace-nowrap"><%= I18n.locale == :hi ? "ताज़ी नौकरियां" : "Latest Jobs" %></h2>
          <div class="flex-1 h-px mx-1" style="background: linear-gradient(90deg,#bae6fd,transparent)"></div>
          <%= link_to jobs_path, class: "shrink-0 inline-flex items-center gap-1 text-[11px] font-bold text-sky-700 bg-sky-100 hover:bg-sky-600 hover:text-white px-2.5 py-1 rounded-lg transition-all" do %>
            <%= I18n.locale == :hi ? "और देखें" : "View All" %>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
        <div class="space-y-2">
          <% @sidebar_jobs.each do |job| %>
            <%= link_to job_path(job), class: "group flex items-center gap-3 p-3 rounded-2xl border border-gray-200/50 bg-white hover:bg-sky-50/40 hover:border-sky-200/60 transition-all no-underline" do %>
              <% if job.cover_image.attached? %>
                <div class="shrink-0 overflow-hidden rounded-xl border border-gray-200/30">
                  <%= optimized_image_tag job.cover_image, variant: :thumb, class: "w-14 h-10 object-cover", loading: "lazy" %>
                </div>
              <% else %>
                <div class="w-14 h-10 rounded-xl bg-sky-50 border border-sky-100 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
              <% end %>
              <div class="min-w-0 flex-1">
                <p class="text-[13px] font-bold text-gray-900 line-clamp-1 group-hover:text-sky-700 transition-colors leading-snug"><%= job.display_title %></p>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <span class="text-[10px] font-semibold text-sky-600"><%= job.category_label %></span>
                  <span class="text-gray-300 text-[10px]">·</span>
                </div>
              </div>
              <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-sky-400 shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </article>

  <%# ════ Sidebar — related news ═══════════════════════════════════════════════ %>
  <aside class="lg:w-80 shrink-0 animate-fade-in">
    <div class="lg:sticky lg:top-28">
      <div class="card-premium !rounded-3xl border border-gray-200/40 shadow-2xl shadow-stone-900/10">
        <div class="px-6 py-5 border-b border-stone-100/90 bg-gradient-to-br from-white via-stone-50/50 to-orange-50/20">
          <h3 class="text-sm font-black text-stone-900 tracking-tight flex items-center gap-3">
            <span class="flex h-8 w-8 items-center justify-center rounded-xl gradient-brand shadow-md shadow-orange-500/20">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            </span>
            <%= t("article.more_from", name: @news_item.region.display_name) %>
          </h3>
        </div>
        <% if @related.any? %>
          <div class="divide-y divide-stone-100/80">
            <% @related.each do |rel| %>
              <%= link_to news_path(rel), class: "block px-5 py-5 hover:bg-gradient-to-r hover:from-orange-50/60 hover:to-amber-50/40 transition-colors group border-b-0 last:border-0" do %>
                <div class="flex gap-4">
                  <% if rel.cover_image.attached? %>
                    <div class="shrink-0 overflow-hidden rounded-2xl border border-gray-200/40 shadow-md">
                      <%= optimized_image_tag rel.cover_image, variant: :thumb, class: "w-[5.25rem] h-14 object-cover img-zoom", loading: "lazy" %>
                    </div>
                  <% else %>
                    <div class="w-[5.25rem] h-14 rounded-2xl gradient-brand-soft border border-orange-100/60 flex items-center justify-center shrink-0 shadow-inner">
                      <span class="text-orange-300 font-black text-xs"><%= t("brand.logo_letter") %></span>
                    </div>
                  <% end %>
                  <div class="min-w-0">
                    <p class="text-sm font-bold text-stone-900 line-clamp-2 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-orange-600 group-hover:to-red-600 transition-all leading-snug tracking-tight"><%= rel.display_title %></p>
                    <div class="flex items-center gap-2 mt-2">
                      <span class="badge badge-category border border-gray-200/40 !py-0.5 !text-[0.65rem] text-stone-500">
                        <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background-color:#f97316"></span>
                        <%= rel.category.display_name %>
                      </span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-10 text-center">
            <p class="text-sm text-stone-500"><%= t("article.no_related") %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# Sidebar ad %>
    <%= render "shared/billboard_feed" %>

    <%# ताज़ी खबरें widget %>
    <% if @sidebar_news.any? %>
      <div class="mt-4 rounded-3xl border border-gray-200/40 shadow-xl shadow-stone-900/[0.06] overflow-hidden bg-white">
        <div class="px-5 py-4 border-b border-stone-100/90 bg-gradient-to-br from-white via-stone-50/50 to-orange-50/20">
          <h3 class="text-sm font-black text-stone-900 tracking-tight flex items-center gap-2.5">
            <span class="flex h-7 w-7 items-center justify-center rounded-xl gradient-brand shadow-md shadow-orange-500/20">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </span>
            <%= I18n.locale == :hi ? "ताज़ी खबरें" : "Latest News" %>
          </h3>
        </div>
        <div class="divide-y divide-stone-100/70">
          <% @sidebar_news.each do |item| %>
            <%= link_to news_path(item), class: "flex gap-3 px-4 py-3.5 hover:bg-orange-50/40 transition-colors group" do %>
              <% if item.cover_image.attached? %>
                <div class="shrink-0 overflow-hidden rounded-xl border border-gray-200/30">
                  <%= optimized_image_tag item.cover_image, variant: :thumb, class: "w-14 h-10 object-cover img-zoom", loading: "lazy" %>
                </div>
              <% else %>
                <div class="w-14 h-10 rounded-xl gradient-brand-soft border border-orange-100/60 flex items-center justify-center shrink-0">
                  <span class="text-orange-300 font-black text-[10px]"><%= t("brand.logo_letter") %></span>
                </div>
              <% end %>
              <div class="min-w-0 flex-1">
                <p class="text-xs font-bold text-stone-800 line-clamp-2 leading-snug group-hover:text-orange-700 transition-colors"><%= item.display_title %></p>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </aside>

</div>
