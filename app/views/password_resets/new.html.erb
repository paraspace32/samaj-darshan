<%# ── Mobile logo ──────────────────────────────────────────────────────── %>
<div class="lg:hidden text-center mb-8 fade-up">
  <div class="relative inline-block mb-4">
    <div class="absolute inset-0 rounded-2xl bg-orange-300/30 blur-xl scale-110"></div>
    <img src="/icon-login.png" alt="Samaj Darshan"
         class="relative w-20 h-20 mx-auto rounded-2xl shadow-[0_8px_32px_-4px_rgba(220,50,50,0.3)]">
  </div>
  <% if I18n.locale == :hi %>
    <h1 class="text-base font-extrabold text-gray-800 tracking-tight leading-snug">अंतर्राष्ट्रीय असाटी समाज दर्शन</h1>
  <% else %>
    <h1 class="text-base font-extrabold text-gray-800 tracking-tight leading-snug">Antarrashtriya Asati Samaj Darshan</h1>
  <% end %>
</div>

<%# ── Heading ────────────────────────────────────────────────────────────── %>
<div class="mb-7 fade-up-d1">
  <h2 class="text-[2rem] font-black tracking-tight text-gray-900 leading-none" id="reset-heading">
    <%= t("password_reset.title") %>
    <span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>
  </h2>
  <p class="text-sm text-gray-500 mt-2.5 leading-relaxed" id="reset-subtitle"><%= t("password_reset.subtitle") %></p>
</div>

<%# ── Form card ──────────────────────────────────────────────────────────── %>
<div class="fade-up-d2">
  <div class="h-1.5 w-full rounded-t-2xl" style="background: linear-gradient(90deg, #b91c1c, #ea580c, #d97706);"></div>

  <div class="form-card rounded-b-2xl px-8 py-8">

    <%# ═══ Step 1: Phone number ═══ %>
    <div id="step-phone">
      <div class="mb-5">
        <label for="reset-phone" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("auth.phone_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <input type="tel" id="reset-phone" required autofocus autocomplete="tel"
                 placeholder="<%= t('auth.phone_placeholder') %>" maxlength="10" pattern="[6-9][0-9]{9}"
                 class="input-auth">
        </div>
      </div>

      <div id="recaptcha-container"></div>

      <div class="pt-1">
        <button type="button" id="btn-send-otp" class="btn-auth" onclick="sendOTP()">
          <%= t("password_reset.send_otp") %> &nbsp;→
        </button>
      </div>
    </div>

    <%# ═══ Step 2: OTP verification ═══ %>
    <div id="step-otp" class="hidden">
      <p class="text-sm text-gray-600 mb-4"><%= t("password_reset.otp_sent") %></p>
      <div class="mb-5">
        <label for="otp-code" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("password_reset.otp_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <input type="text" id="otp-code" required inputmode="numeric" pattern="[0-9]{6}"
                 placeholder="<%= t('password_reset.otp_placeholder') %>" maxlength="6" autocomplete="one-time-code"
                 class="input-auth">
        </div>
      </div>
      <div class="pt-1">
        <button type="button" id="btn-verify-otp" class="btn-auth" onclick="verifyOTP()">
          <%= t("password_reset.verify_otp") %> &nbsp;→
        </button>
      </div>
    </div>

    <%# ═══ Step 3: New password ═══ %>
    <div id="step-password" class="hidden">
      <%= form_with url: password_reset_path, method: :post, id: "reset-form" do %>
        <input type="hidden" name="phone" id="hidden-phone">
        <input type="hidden" name="firebase_id_token" id="hidden-token">

        <div class="mb-5">
          <label for="new-password" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("password_reset.new_password_label") %></label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            <input type="password" name="password" id="new-password" required minlength="6"
                   placeholder="<%= t('password_reset.new_password_placeholder') %>"
                   class="input-auth pr-12">
            <button type="button" tabindex="-1"
                    onclick="(function(btn){var i=document.getElementById('new-password');var show=i.type==='password';i.type=show?'text':'password';btn.querySelector('.eye-open').classList.toggle('hidden',show);btn.querySelector('.eye-shut').classList.toggle('hidden',!show);})(this)"
                    class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-orange-500 transition-colors">
              <svg class="eye-open w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              <svg class="eye-shut hidden w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="pt-1">
          <button type="submit" class="btn-auth">
            <%= t("password_reset.set_password") %> &nbsp;→
          </button>
        </div>
      <% end %>
    </div>

    <%# ── Error display ── %>
    <div id="reset-error" class="hidden mt-4 rounded-2xl border border-red-200/80 bg-red-50 px-4 py-3 text-sm text-red-800 flex items-center gap-2">
      <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      <span id="reset-error-text"></span>
    </div>

  </div>
</div>

<%# ── Back to login ──────────────────────────────────────────────────────── %>
<p class="text-center text-sm text-gray-500 mt-6 fade-up-d3">
  <%= link_to t("password_reset.back_to_login"), login_path, class: "font-bold text-orange-600 hover:text-orange-700 transition-colors underline underline-offset-2 decoration-orange-300" %>
</p>

<%# ── Bottom bar ─────────────────────────────────────────────────────────── %>
<div class="mt-8 flex items-center justify-between fade-up-d3">
  <%= link_to root_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-700 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    <%= t("nav.home") %>
  <% end %>
  <%= link_to t("nav.language_switch"), switch_locale_path,
      class: "text-xs font-bold text-gray-500 hover:text-orange-600 bg-gray-50 hover:bg-orange-50 border border-gray-200 hover:border-orange-200 rounded-full px-4 py-2 shadow-sm transition-all" %>
</div>

<%# ── Firebase Phone Auth Script ─────────────────────────────────────────── %>
<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
import { getAuth, RecaptchaVerifier, signInWithPhoneNumber } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js';

var firebaseConfig = <%= raw firebase_js_config_json %>;
var app = initializeApp(firebaseConfig);
var auth = getAuth(app);
auth.languageCode = '<%= I18n.locale %>';

var confirmationResult = null;

var strings = {
  sending:       '<%= j t("password_reset.sending") %>',
  send_otp:      '<%= j t("password_reset.send_otp") %>',
  verifying:     '<%= j t("password_reset.verifying") %>',
  verify_otp:    '<%= j t("password_reset.verify_otp") %>',
  phone_invalid: '<%= j t("password_reset.phone_invalid") %>',
  otp_invalid:   '<%= j t("password_reset.otp_invalid") %>',
  send_failed:   '<%= j t("password_reset.send_failed") %>',
  verify_failed: '<%= j t("password_reset.verify_failed") %>',
  title_otp:     '<%= j t("password_reset.title_otp") %>',
  sub_otp:       '<%= j t("password_reset.sub_otp") %>',
  title_newpw:   '<%= j t("password_reset.title_newpw") %>',
  sub_newpw:     '<%= j t("password_reset.sub_newpw") %>'
};

function showError(msg) {
  var el = document.getElementById('reset-error');
  document.getElementById('reset-error-text').textContent = msg;
  el.classList.remove('hidden');
  setTimeout(function() { el.classList.add('hidden'); }, 5000);
}

window.sendOTP = function() {
  var phone = document.getElementById('reset-phone').value.replace(/\D/g, '');
  if (phone.length !== 10 || !/^[6-9]/.test(phone)) {
    showError(strings.phone_invalid);
    return;
  }

  var btn = document.getElementById('btn-send-otp');
  btn.disabled = true;
  btn.innerHTML = strings.sending + ' &nbsp;⏳';

  try {
    if (window.recaptchaVerifier) {
      try { window.recaptchaVerifier.clear(); } catch(_) {}
      window.recaptchaVerifier = null;
    }
    var oldEl = document.getElementById('recaptcha-container');
    var newEl = document.createElement('div');
    newEl.id = 'recaptcha-container';
    oldEl.replaceWith(newEl);
    window.recaptchaVerifier = new RecaptchaVerifier(auth, 'recaptcha-container', { size: 'invisible' });
  } catch (e) {
    console.error('reCAPTCHA init error:', e);
    showError(strings.send_failed + ' (' + (e.code || e.message) + ')');
    btn.disabled = false;
    btn.innerHTML = strings.send_otp + ' &nbsp;→';
    return;
  }

  signInWithPhoneNumber(auth, '+91' + phone, window.recaptchaVerifier)
    .then(function(result) {
      confirmationResult = result;
      document.getElementById('step-phone').classList.add('hidden');
      document.getElementById('step-otp').classList.remove('hidden');
      document.getElementById('reset-heading').innerHTML = strings.title_otp + '<span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>';
      document.getElementById('reset-subtitle').textContent = strings.sub_otp;
      document.getElementById('otp-code').focus();
    })
    .catch(function(error) {
      console.error('sendOTP error:', error);
      showError(strings.send_failed + ' (' + (error.code || error.message) + ')');
      btn.disabled = false;
      btn.innerHTML = strings.send_otp + ' &nbsp;→';
    });
};

window.verifyOTP = function() {
  var code = document.getElementById('otp-code').value.replace(/\D/g, '');
  if (code.length !== 6) {
    showError(strings.otp_invalid);
    return;
  }

  if (!confirmationResult) {
    showError(strings.verify_failed);
    return;
  }

  var btn = document.getElementById('btn-verify-otp');
  btn.disabled = true;
  btn.innerHTML = strings.verifying + ' &nbsp;⏳';

  confirmationResult.confirm(code)
    .then(function(result) {
      return result.user.getIdToken();
    })
    .then(function(idToken) {
      document.getElementById('hidden-phone').value = document.getElementById('reset-phone').value.replace(/\D/g, '');
      document.getElementById('hidden-token').value = idToken;
      document.getElementById('step-otp').classList.add('hidden');
      document.getElementById('step-password').classList.remove('hidden');
      document.getElementById('reset-heading').innerHTML = strings.title_newpw + '<span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>';
      document.getElementById('reset-subtitle').textContent = strings.sub_newpw;
      document.getElementById('new-password').focus();
    })
    .catch(function(error) {
      console.error('verifyOTP error:', error);
      showError(strings.verify_failed);
      btn.disabled = false;
      btn.innerHTML = strings.verify_otp + ' &nbsp;→';
    });
};
</script>
