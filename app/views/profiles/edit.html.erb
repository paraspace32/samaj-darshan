<% content_for(:title, "#{t('profile.edit_title')} — #{t('brand.name')}") %>

<div class="max-w-xl mx-auto py-8 px-4">

  <%# Header %>
  <div class="flex items-center gap-4 mb-8">
    <div class="w-16 h-16 rounded-2xl gradient-brand flex items-center justify-center shadow-lg shadow-orange-200 shrink-0">
      <span class="text-white font-black text-2xl"><%= current_user.name[0].upcase %></span>
    </div>
    <div>
      <h1 class="text-2xl font-black text-stone-900 tracking-tight"><%= t("profile.edit_title") %></h1>
      <p class="text-sm text-stone-400 mt-0.5"><%= t("profile.edit_subtitle") %></p>
    </div>
  </div>

  <%# Flash %>
  <% if flash[:notice] %>
    <div class="flex items-center gap-3 rounded-2xl border border-green-200 bg-green-50 px-5 py-4 mb-6 shadow-sm">
      <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p class="text-sm font-semibold text-green-800"><%= flash[:notice] %></p>
    </div>
  <% end %>

  <% if @user.errors.any? %>
    <div class="rounded-2xl border border-red-200 bg-red-50 px-5 py-4 mb-6 shadow-sm">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <ul class="text-sm text-red-800 space-y-1">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <%# Form card %>
  <div class="rounded-3xl border border-gray-200/60 overflow-hidden shadow-lg shadow-stone-900/[0.06]">
    <div class="h-1.5" style="background:linear-gradient(90deg,#f97316,#dc2626,#d97706)"></div>

    <%= form_with model: @user, url: profile_path, method: :patch, class: "px-6 sm:px-8 py-8 space-y-6 bg-white" do |f| %>

      <%# Name %>
      <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">
          <%= t("profile.name_label") %>
        </label>
        <%= f.text_field :name, required: true,
              class: "block w-full rounded-2xl border-2 border-gray-200 bg-gray-50 px-4 py-3 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-50 focus:outline-none transition-all" %>
      </div>

      <%# Phone %>
      <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">
          <%= t("profile.phone_label") %>
        </label>
        <%= f.telephone_field :phone, required: true, maxlength: 10,
              class: "block w-full rounded-2xl border-2 border-gray-200 bg-gray-50 px-4 py-3 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-50 focus:outline-none transition-all" %>
      </div>

      <%# Email %>
      <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">
          <%= t("profile.email_label") %>
        </label>
        <%= f.email_field :email,
              class: "block w-full rounded-2xl border-2 border-gray-200 bg-gray-50 px-4 py-3 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-50 focus:outline-none transition-all" %>
      </div>

      <%# Divider %>
      <div class="relative">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
        <div class="relative flex justify-center">
          <span class="bg-white px-3 text-xs font-semibold text-gray-400 uppercase tracking-widest"><%= t("profile.change_password") %></span>
        </div>
      </div>

      <%# New Password %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">
            <%= t("profile.new_password_label") %>
          </label>
          <div class="relative">
            <%= f.password_field :password, id: "profile_password", autocomplete: "new-password",
                  placeholder: t("profile.password_placeholder"),
                  class: "block w-full rounded-2xl border-2 border-gray-200 bg-gray-50 px-4 py-3 pr-12 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-50 focus:outline-none transition-all" %>
            <button type="button" tabindex="-1"
                    onclick="(function(btn){var i=document.getElementById('profile_password');var show=i.type==='password';i.type=show?'text':'password';btn.querySelector('.eye-open').classList.toggle('hidden',show);btn.querySelector('.eye-shut').classList.toggle('hidden',!show);})(this)"
                    class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-orange-500 transition-colors">
              <svg class="eye-open w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <svg class="eye-shut hidden w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
            </button>
          </div>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">
            <%= t("profile.confirm_password_label") %>
          </label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                placeholder: t("profile.password_placeholder"),
                class: "block w-full rounded-2xl border-2 border-gray-200 bg-gray-50 px-4 py-3 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-50 focus:outline-none transition-all" %>
        </div>
      </div>
      <p class="text-xs text-stone-400 -mt-3"><%= t("profile.password_hint") %></p>

      <%# Submit %>
      <div class="pt-2">
        <%= f.submit t("profile.save_button"),
              class: "w-full cursor-pointer rounded-2xl py-3.5 text-sm font-black text-white transition-all hover:brightness-110 active:scale-[0.98]",
              style: "background:linear-gradient(135deg,#f97316,#dc2626); box-shadow:0 4px 20px -4px rgba(234,88,12,0.5)" %>
      </div>

    <% end %>
  </div>

  <%# Back link %>
  <div class="mt-6 text-center">
    <%= link_to root_path, class: "inline-flex items-center gap-1.5 text-sm text-stone-400 hover:text-stone-700 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      <%= t("nav.home") %>
    <% end %>
  </div>

</div>
