<div class="lg:hidden text-center mb-8">
  <img src="/icon-login.png" alt="<%= t('brand.name') %>" class="w-28 h-28 mx-auto mb-4" style="filter: drop-shadow(0 4px 20px rgba(0,0,0,0.12));">
  <h1 class="text-lg font-extrabold text-gray-900 mt-1"><%= t("signup.title", default: "Create an account") %></h1>
  <div class="mt-2 w-16 h-0.5 bg-gradient-to-r from-transparent via-orange-400/50 to-transparent rounded-full mx-auto"></div>
</div>

<div class="mb-8">
  <h2 class="text-xl font-extrabold text-gray-900"><%= t("signup.header", default: "Sign up") %></h2>
  <p class="text-sm text-gray-400 mt-1"><%= t("signup.sub", default: "Create your account with phone and password") %></p>
</div>

<%= form_with model: @user, url: signup_path, local: true, class: "space-y-5" do |f| %>
  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-2">Full name</label>
    <%= f.text_field :name, required: true, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-white" %>
  </div>

  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-2">Phone</label>
    <%= f.telephone_field :phone, required: true, maxlength: 10, placeholder: "9876543210", class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-white" %>
  </div>

  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-2">Email (optional)</label>
    <%= f.email_field :email, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-white" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
      <%= f.password_field :password, required: true, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-white" %>
    </div>
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-2">Confirm Password</label>
      <%= f.password_field :password_confirmation, required: true, class: "block w-full rounded-xl border border-gray-200 px-4 py-3 text-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none bg-white" %>
    </div>
  </div>

  <div>
    <%= f.submit "Create account", class: "w-full rounded-xl gradient-brand px-4 py-3 text-sm font-bold text-white shadow-md shadow-orange-200 hover:shadow-lg hover:shadow-orange-200 transition-all cursor-pointer" %>
  </div>
<% end %>

<div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-100">
  <%= link_to t("nav.sign_in"), login_path, class: "text-sm font-medium text-gray-500 hover:text-orange-600" %>
  <%= link_to root_path, class: "text-sm text-gray-400 hover:text-gray-600" do %>
    &larr; <%= t("nav.home") %>
  <% end %>
</div>

