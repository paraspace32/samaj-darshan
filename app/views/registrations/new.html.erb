<div class="lg:hidden text-center mb-10 animate-fade-in">
  <div class="relative inline-block">
    <div class="absolute -inset-6 rounded-full bg-gradient-to-br from-orange-200/30 via-amber-100/20 to-transparent blur-2xl pointer-events-none" aria-hidden="true"></div>
    <img src="/icon-login.png" alt="<%= t('brand.name') %>" class="relative w-28 h-28 mx-auto mb-5 rounded-2xl shadow-[0_12px_40px_-8px_rgba(0,0,0,0.15)]" style="filter: drop-shadow(0 4px 20px rgba(0,0,0,0.12));">
  </div>
  <h1 class="text-lg font-extrabold text-gray-900 mt-1 tracking-tight leading-snug"><%= t("signup.title", default: "Create an account") %></h1>
  <div class="mt-3 w-20 h-px section-divider mx-auto opacity-80"></div>
</div>

<div class="mb-8">
  <h2 class="text-2xl font-extrabold tracking-tight text-gradient"><%= t("signup.header", default: "Sign up") %></h2>
  <p class="text-sm text-gray-500 mt-2 leading-relaxed"><%= t("signup.sub", default: "Create your account with phone and password") %></p>
</div>

<% if flash[:alert] %>
  <div class="rounded-2xl border border-amber-200/80 bg-gradient-to-br from-amber-50 via-white to-orange-50/40 p-5 mb-6 animate-fade-in shadow-[0_12px_40px_-12px_rgba(217,119,6,0.15)] ring-1 ring-amber-100/50">
    <div class="flex gap-3">
      <div class="shrink-0 w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center shadow-inner">
        <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-bold text-amber-900 tracking-tight"><%= flash[:alert] %></p>
        <p class="mt-1 text-sm text-amber-800/80"><%= link_to t("nav.sign_in"), login_path, class: "font-semibold text-orange-600 hover:text-orange-700 underline transition-colors" %></p>
      </div>
    </div>
  </div>
<% end %>

<% if @user.errors.any? %>
  <div class="rounded-2xl border border-red-200/80 bg-gradient-to-br from-red-50 via-white to-orange-50/40 p-5 mb-6 animate-fade-in shadow-[0_12px_40px_-12px_rgba(220,38,38,0.15)] ring-1 ring-red-100/50">
    <div class="flex gap-3">
      <div class="shrink-0 w-10 h-10 rounded-xl bg-red-100 flex items-center justify-center shadow-inner">
        <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-bold text-red-900 tracking-tight"><%= @user.errors.count %> <%= @user.errors.count == 1 ? t("signup.error_singular", default: "error") : t("signup.errors_plural", default: "errors") %> <%= t("signup.errors_found", default: "found:") %></p>
        <ul class="mt-2 space-y-1.5 text-sm text-red-800/90 leading-snug">
          <% @user.errors.full_messages.each do |msg| %>
            <li class="flex gap-2">
              <span class="text-red-400 shrink-0 mt-1.5 w-1 h-1 rounded-full bg-red-400" aria-hidden="true"></span>
              <span><%= msg %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>

<div class="surface-elevated rounded-2xl overflow-hidden shadow-[0_24px_64px_-16px_rgba(0,0,0,0.12),0_8px_24px_-8px_rgba(234,88,12,0.08)] border border-black/[0.06] animate-fade-in">
  <div class="h-1 gradient-brand" aria-hidden="true"></div>
  <div class="p-8 sm:p-10">
  <%= form_with model: @user, url: signup_path, local: true, class: "space-y-6" do |f| %>
    <div>
      <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2"><%= t("signup.name_label", default: "Full name") %></label>
      <%= f.text_field :name, required: true, class: "block w-full input-premium rounded-xl" %>
    </div>

    <div>
      <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2"><%= t("signup.phone_label", default: "Phone") %></label>
      <%= f.telephone_field :phone, required: true, maxlength: 10, placeholder: "9876543210", class: "block w-full input-premium rounded-xl" %>
    </div>

    <div>
      <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2"><%= t("signup.email_label", default: "Email (optional)") %></label>
      <%= f.email_field :email, class: "block w-full input-premium rounded-xl" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2"><%= t("signup.password_label", default: "Password") %></label>
        <%= f.password_field :password, required: true, class: "block w-full input-premium rounded-xl" %>
      </div>
      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2"><%= t("signup.password_confirm_label", default: "Confirm Password") %></label>
        <%= f.password_field :password_confirmation, required: true, class: "block w-full input-premium rounded-xl" %>
      </div>
    </div>

    <div class="pt-1">
      <%= f.submit t("signup.submit", default: "Create account"), class: "w-full btn-primary justify-center py-3.5 !rounded-2xl text-base shadow-[0_8px_24px_-4px_rgba(234,88,12,0.35)] hover:shadow-[0_12px_32px_-4px_rgba(234,88,12,0.4)] cursor-pointer" %>
    </div>
  <% end %>
  </div>
</div>

<div class="mt-8">
  <div class="section-divider mb-6"></div>
  <div class="flex items-center justify-between">
    <%= link_to t("nav.sign_in"), login_path, class: "text-sm font-semibold text-gray-600 hover:text-orange-600 transition-colors" %>
    <%= link_to root_path, class: "text-sm text-gray-500 hover:text-gray-800 transition-colors" do %>
      &larr; <%= t("nav.home") %>
    <% end %>
  </div>
</div>
