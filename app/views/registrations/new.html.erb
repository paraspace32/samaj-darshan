<%# ── Mobile logo ──────────────────────────────────────────────────────────── %>
<div class="lg:hidden text-center mb-8 fade-up">
  <div class="relative inline-block mb-4">
    <div class="absolute inset-0 rounded-2xl bg-orange-300/30 blur-xl scale-110"></div>
    <img src="/icon-login.png" alt="<%= t('brand.name') %>"
         class="relative w-20 h-20 mx-auto rounded-2xl shadow-[0_8px_32px_-4px_rgba(220,50,50,0.3)]">
  </div>
  <h1 class="text-base font-extrabold text-gray-800 tracking-tight"><%= t("brand.name") %></h1>
</div>

<%# ── Heading ──────────────────────────────────────────────────────────────── %>
<div class="mb-7 fade-up-d1">
  <h2 class="text-[2rem] font-black tracking-tight text-gray-900 leading-none">
    <%= t("signup.header", default: "Sign up") %>
    <span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>
  </h2>
  <p class="text-sm text-gray-500 mt-2.5 leading-relaxed"><%= t("signup.sub", default: "Create your account with phone and password") %></p>
</div>

<%# ── Alerts ───────────────────────────────────────────────────────────────── %>
<% if flash[:alert] %>
  <div class="rounded-2xl border border-amber-200/80 bg-amber-50 px-5 py-4 mb-5 fade-up flex items-start gap-3 shadow-sm">
    <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <p class="text-sm font-semibold text-amber-900">
      <%= flash[:alert] %> &mdash;
      <%= link_to t("nav.sign_in"), login_path, class: "text-orange-600 hover:text-orange-700 underline underline-offset-2" %>
    </p>
  </div>
<% end %>

<% if @user.errors.any? %>
  <div class="rounded-2xl border border-red-200/80 bg-red-50 px-5 py-4 mb-5 fade-up shadow-sm">
    <div class="flex items-start gap-3">
      <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      <div>
        <p class="text-sm font-bold text-red-900 mb-1.5"><%= @user.errors.count %> <%= @user.errors.count == 1 ? t("signup.error_singular", default: "error") : t("signup.errors_plural", default: "errors") %></p>
        <ul class="space-y-1 text-sm text-red-800/90">
          <% @user.errors.full_messages.each do |msg| %>
            <li class="flex gap-2 items-start"><span class="text-red-400 mt-1.5 shrink-0">•</span> <%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>

<%# ── Form card ────────────────────────────────────────────────────────────── %>
<div class="fade-up-d2">
  <div class="h-1.5 w-full rounded-t-2xl" style="background: linear-gradient(90deg, #b91c1c, #ea580c, #d97706);"></div>
  <div class="bg-white rounded-b-2xl shadow-[0_20px_60px_-12px_rgba(0,0,0,0.12),0_4px_16px_-4px_rgba(234,88,12,0.08)] border border-gray-100/80 px-8 py-8">
    <%= form_with model: @user, url: signup_path, local: true, class: "space-y-5" do |f| %>

      <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("signup.name_label", default: "Full name") %></label>
        <%= f.text_field :name, required: true, class: "input-auth" %>
      </div>

      <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("signup.phone_label", default: "Phone") %></label>
        <%= f.telephone_field :phone, required: true, maxlength: 10, placeholder: "9876543210", class: "input-auth" %>
      </div>

      <div>
        <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("signup.email_label", default: "Email (optional)") %></label>
        <%= f.email_field :email, class: "input-auth" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("signup.password_label", default: "Password") %></label>
          <%= f.password_field :password, required: true, class: "input-auth" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("signup.password_confirm_label", default: "Confirm") %></label>
          <%= f.password_field :password_confirmation, required: true, class: "input-auth" %>
        </div>
      </div>

      <div class="pt-1">
        <%= f.submit t("signup.submit", default: "Create account →"), class: "btn-auth cursor-pointer" %>
      </div>

    <% end %>
  </div>
</div>

<%# ── Sign in link ─────────────────────────────────────────────────────────── %>
<p class="text-center text-sm text-gray-500 mt-6 fade-up-d3">
  <%= t("nav.already_have_account", default: "Already have an account?") %>
  <%= link_to t("nav.sign_in"), login_path, class: "font-bold text-orange-600 hover:text-orange-700 transition-colors underline underline-offset-2 decoration-orange-300" %>
</p>

<%# ── Bottom bar ───────────────────────────────────────────────────────────── %>
<div class="mt-8 flex items-center justify-between fade-up-d3">
  <%= link_to root_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-700 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    <%= t("nav.home") %>
  <% end %>
  <%= link_to t("nav.language_switch"), switch_locale_path,
      class: "text-xs font-bold text-gray-500 hover:text-orange-600 bg-gray-50 hover:bg-orange-50 border border-gray-200 hover:border-orange-200 rounded-full px-4 py-2 shadow-sm transition-all" %>
</div>
