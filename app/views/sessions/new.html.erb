<%# Mobile logo (hidden on desktop — the left panel shows branding) %>
<div class="lg:hidden text-center mb-8">
  <img src="/icon-login.png" alt="अंतर्राष्ट्रीय असाटी समाज दर्शन" class="w-32 h-32 mx-auto mb-4" style="filter: drop-shadow(0 4px 20px rgba(220, 50, 50, 0.25));">
  <% if I18n.locale == :hi %>
    <h1 class="text-lg font-extrabold text-gray-900 mt-1">अंतर्राष्ट्रीय असाटी समाज दर्शन</h1>
  <% else %>
    <h1 class="text-lg font-extrabold text-gray-900 mt-1">Antarrashtriya Asati Samaj Darshan</h1>
  <% end %>
  <div class="mt-2 w-16 h-0.5 bg-gradient-to-r from-transparent via-red-400/50 to-transparent rounded-full mx-auto"></div>
</div>

<%# Login heading %>
<div class="mb-8">
  <h2 class="text-xl font-extrabold text-gray-900"><%= t("login.title") %></h2>
  <p class="text-sm text-gray-400 mt-1"><%= t("login.footer") %></p>
</div>

<%= form_with url: login_path, method: :post, class: "space-y-5" do |f| %>
  <div>
    <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2"><%= t("login.phone_label") %></label>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      </div>
      <input type="tel" name="phone" id="phone" required autofocus
             placeholder="<%= t('login.phone_placeholder') %>" maxlength="10" pattern="[6-9][0-9]{9}"
             class="block w-full rounded-xl border border-gray-200 pl-11 pr-4 py-3 text-sm shadow-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none transition-all bg-white">
    </div>
  </div>

  <div>
    <label for="password" class="block text-sm font-semibold text-gray-700 mb-2"><%= t("login.password_label") %></label>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      </div>
      <input type="password" name="password" id="password" required
             placeholder="<%= t('login.password_placeholder') %>"
             class="block w-full rounded-xl border border-gray-200 pl-11 pr-4 py-3 text-sm shadow-sm placeholder:text-gray-400 focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:outline-none transition-all bg-white">
    </div>
  </div>

  <button type="submit"
          class="w-full rounded-xl gradient-brand px-4 py-3 text-sm font-bold text-white shadow-md shadow-orange-200 hover:shadow-lg hover:shadow-orange-200 transition-all cursor-pointer">
    <%= t("login.submit") %>
  </button>
<% end %>

<p class="text-center text-sm text-gray-500 mt-6">
  <%= t("login.no_account", default: "Don't have an account?") %>
  <%= link_to t("nav.sign_up"), signup_path, class: "font-semibold text-orange-600 hover:text-orange-700 transition-colors" %>
</p>

<div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-100">
  <%= link_to root_path, class: "text-sm text-gray-400 hover:text-gray-600 transition-colors" do %>
    &larr; <%= t("nav.home") %>
  <% end %>
  <%= link_to t("nav.language_switch"), switch_locale_path, class: "text-sm font-medium text-gray-500 hover:text-orange-600 bg-gray-50 hover:bg-orange-50 rounded-full px-3.5 py-1.5 transition-all" %>
</div>
