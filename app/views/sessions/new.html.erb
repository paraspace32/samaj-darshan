<%# ── Mobile logo (hidden on desktop) ──────────────────────────────────── %>
<div class="lg:hidden text-center mb-8 fade-up">
  <div class="relative inline-block mb-4">
    <div class="absolute inset-0 rounded-2xl bg-orange-300/30 blur-xl scale-110"></div>
    <img src="/icon-login.png" alt="Samaj Darshan"
         class="relative w-20 h-20 mx-auto rounded-2xl shadow-[0_8px_32px_-4px_rgba(220,50,50,0.3)]">
  </div>
  <% if I18n.locale == :hi %>
    <h1 class="text-base font-extrabold text-gray-800 tracking-tight leading-snug">अंतर्राष्ट्रीय असाटी समाज दर्शन</h1>
  <% else %>
    <h1 class="text-base font-extrabold text-gray-800 tracking-tight leading-snug">Antarrashtriya Asati Samaj Darshan</h1>
  <% end %>
</div>

<%# ── Heading ────────────────────────────────────────────────────────────── %>
<div class="mb-7 fade-up-d1">
  <h2 class="text-[2rem] font-black tracking-tight text-gray-900 leading-none" id="auth-heading">
    <%= t("auth.title") %>
    <span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>
  </h2>
  <p class="text-sm text-gray-500 mt-2.5 leading-relaxed" id="auth-subtitle"><%= t("auth.subtitle") %></p>
</div>

<%# ── Form card ──────────────────────────────────────────────────────────── %>
<div class="fade-up-d2">
  <div class="h-1.5 w-full rounded-t-2xl" style="background: linear-gradient(90deg, #b91c1c, #ea580c, #d97706);"></div>

  <div class="form-card rounded-b-2xl px-8 py-8">

    <%# ═══ Step 1: Phone number ═══ %>
    <div id="step-phone">
      <div class="mb-5">
        <label for="auth-phone" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("auth.phone_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <input type="tel" id="auth-phone" required autofocus autocomplete="tel"
                 placeholder="<%= t('auth.phone_placeholder') %>" maxlength="10" pattern="[6-9][0-9]{9}"
                 class="input-auth">
        </div>
      </div>

      <div id="recaptcha-container"></div>

      <div class="pt-1">
        <button type="button" id="btn-send-otp" class="btn-auth" onclick="sendOTP()">
          <%= t("auth.send_otp") %> &nbsp;→
        </button>
      </div>
    </div>

    <%# ═══ Step 2: OTP verification ═══ %>
    <div id="step-otp" class="hidden">
      <p class="text-sm text-gray-600 mb-4"><%= t("auth.otp_sent") %></p>
      <div class="mb-5">
        <label for="otp-code" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("auth.otp_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <input type="text" id="otp-code" required inputmode="numeric" pattern="[0-9]{6}"
                 placeholder="<%= t('auth.otp_placeholder') %>" maxlength="6" autocomplete="one-time-code"
                 class="input-auth">
        </div>
      </div>
      <div class="pt-1">
        <button type="button" id="btn-verify-otp" class="btn-auth" onclick="verifyOTP()">
          <%= t("auth.verify_otp") %> &nbsp;→
        </button>
      </div>
    </div>

    <%# ═══ Step 3: Name (new users only) ═══ %>
    <div id="step-name" class="hidden">
      <p class="text-sm text-gray-600 mb-4"><%= t("auth.welcome_new") %></p>
      <div class="mb-5">
        <label for="user-name" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("auth.name_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <input type="text" id="user-name" required autocomplete="name"
                 placeholder="<%= t('auth.name_placeholder') %>"
                 class="input-auth">
        </div>
      </div>
      <div class="pt-1">
        <button type="button" id="btn-set-name" class="btn-auth" onclick="submitName()">
          <%= t("auth.continue") %> &nbsp;→
        </button>
      </div>
    </div>

    <%# ── Error display ── %>
    <div id="auth-error" class="hidden mt-4 rounded-2xl border border-red-200/80 bg-red-50 px-4 py-3 text-sm text-red-800 flex items-center gap-2">
      <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      <span id="auth-error-text"></span>
    </div>

  </div>
</div>

<%# ── Bottom bar ─────────────────────────────────────────────────────────── %>
<div class="mt-8 flex items-center justify-between fade-up-d3">
  <%= link_to root_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-700 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    <%= t("nav.home") %>
  <% end %>
  <%= link_to t("nav.language_switch"), switch_locale_path,
      class: "text-xs font-bold text-gray-500 hover:text-orange-600 bg-gray-50 hover:bg-orange-50 border border-gray-200 hover:border-orange-200 rounded-full px-4 py-2 shadow-sm transition-all" %>
</div>

<%# ── Firebase Phone Auth Script ─────────────────────────────────────────── %>
<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
import { getAuth, RecaptchaVerifier, signInWithPhoneNumber } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js';

var firebaseConfig = <%= raw firebase_js_config_json %>;
var app = initializeApp(firebaseConfig);
var auth = getAuth(app);
auth.languageCode = '<%= I18n.locale %>';

var confirmationResult = null;

var strings = {
  sending:       '<%= j t("auth.sending") %>',
  send_otp:      '<%= j t("auth.send_otp") %>',
  verifying:     '<%= j t("auth.verifying") %>',
  verify_otp:    '<%= j t("auth.verify_otp") %>',
  logging_in:    '<%= j t("auth.logging_in") %>',
  creating:      '<%= j t("auth.creating_account") %>',
  continue:      '<%= j t("auth.continue") %>',
  phone_invalid: '<%= j t("auth.phone_invalid") %>',
  otp_invalid:   '<%= j t("auth.otp_invalid") %>',
  send_failed:   '<%= j t("auth.send_failed") %>',
  verify_failed: '<%= j t("auth.verify_failed") %>',
  login_failed:  '<%= j t("auth.login_failed") %>',
  name_required: '<%= j t("auth.name_required") %>',
  title_otp:     '<%= j t("auth.title_otp") %>',
  sub_otp:       '<%= j t("auth.sub_otp") %>',
  title_name:    '<%= j t("auth.title_name") %>',
  sub_name:      '<%= j t("auth.sub_name") %>'
};

function showError(msg) {
  var el = document.getElementById('auth-error');
  document.getElementById('auth-error-text').textContent = msg;
  el.classList.remove('hidden');
  setTimeout(function() { el.classList.add('hidden'); }, 5000);
}

window.sendOTP = function() {
  var phone = document.getElementById('auth-phone').value.replace(/\D/g, '');
  if (phone.length !== 10 || !/^[6-9]/.test(phone)) {
    showError(strings.phone_invalid);
    return;
  }

  var btn = document.getElementById('btn-send-otp');
  btn.disabled = true;
  btn.innerHTML = strings.sending + ' &nbsp;⏳';

  try {
    if (window.recaptchaVerifier) {
      try { window.recaptchaVerifier.clear(); } catch(_) {}
      window.recaptchaVerifier = null;
    }
    var oldEl = document.getElementById('recaptcha-container');
    var newEl = document.createElement('div');
    newEl.id = 'recaptcha-container';
    oldEl.replaceWith(newEl);
    window.recaptchaVerifier = new RecaptchaVerifier(auth, 'recaptcha-container', { size: 'invisible' });
  } catch (e) {
    console.error('reCAPTCHA init error:', e);
    showError(strings.send_failed);
    btn.disabled = false;
    btn.innerHTML = strings.send_otp + ' &nbsp;→';
    return;
  }

  signInWithPhoneNumber(auth, '+91' + phone, window.recaptchaVerifier)
    .then(function(result) {
      confirmationResult = result;
      document.getElementById('step-phone').classList.add('hidden');
      document.getElementById('step-otp').classList.remove('hidden');
      document.getElementById('auth-heading').innerHTML = strings.title_otp + '<span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>';
      document.getElementById('auth-subtitle').textContent = strings.sub_otp;
      document.getElementById('otp-code').focus();
    })
    .catch(function(error) {
      console.error('sendOTP error:', error);
      showError(strings.send_failed);
      btn.disabled = false;
      btn.innerHTML = strings.send_otp + ' &nbsp;→';
    });
};

window.verifyOTP = function() {
  var code = document.getElementById('otp-code').value.replace(/\D/g, '');
  if (code.length !== 6) {
    showError(strings.otp_invalid);
    return;
  }

  if (!confirmationResult) {
    showError(strings.verify_failed);
    return;
  }

  var btn = document.getElementById('btn-verify-otp');
  btn.disabled = true;
  btn.innerHTML = strings.verifying + ' &nbsp;⏳';

  confirmationResult.confirm(code)
    .then(function(result) {
      return result.user.getIdToken();
    })
    .then(function(idToken) {
      btn.innerHTML = strings.logging_in + ' &nbsp;⏳';

      var phone = document.getElementById('auth-phone').value.replace(/\D/g, '');
      var csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

      return fetch('<%= login_path %>', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        body: JSON.stringify({ phone: phone, firebase_id_token: idToken })
      });
    })
    .then(function(response) {
      return response.json().then(function(data) {
        if (response.ok && data.redirect_to) {
          window.location.href = data.redirect_to;
        } else if (response.ok && data.needs_name) {
          document.getElementById('step-otp').classList.add('hidden');
          document.getElementById('step-name').classList.remove('hidden');
          document.getElementById('auth-heading').innerHTML = strings.title_name + '<span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>';
          document.getElementById('auth-subtitle').textContent = strings.sub_name;
          document.getElementById('user-name').focus();
        } else {
          showError(data.error || strings.login_failed);
          btn.disabled = false;
          btn.innerHTML = strings.verify_otp + ' &nbsp;→';
        }
      });
    })
    .catch(function(error) {
      console.error('verifyOTP error:', error);
      showError(strings.verify_failed);
      btn.disabled = false;
      btn.innerHTML = strings.verify_otp + ' &nbsp;→';
    });
};

window.submitName = function() {
  var name = document.getElementById('user-name').value.trim();
  if (!name) {
    showError(strings.name_required);
    return;
  }

  var btn = document.getElementById('btn-set-name');
  btn.disabled = true;
  btn.innerHTML = strings.creating + ' &nbsp;⏳';

  var csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

  fetch('<%= set_name_path %>', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': csrfToken
    },
    body: JSON.stringify({ name: name })
  })
  .then(function(response) {
    return response.json().then(function(data) {
      if (response.ok && data.redirect_to) {
        window.location.href = data.redirect_to;
      } else {
        showError(data.error || strings.login_failed);
        btn.disabled = false;
        btn.innerHTML = strings.continue + ' &nbsp;→';
      }
    });
  })
  .catch(function(error) {
    console.error('submitName error:', error);
    showError(strings.login_failed);
    btn.disabled = false;
    btn.innerHTML = strings.continue + ' &nbsp;→';
  });
};
</script>
