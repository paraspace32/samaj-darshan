<%# Mobile logo (hidden on desktop — the left panel shows branding) %>
<div class="lg:hidden text-center mb-10 animate-fade-in">
  <div class="relative inline-block">
    <div class="absolute -inset-6 rounded-full bg-gradient-to-br from-orange-200/30 via-amber-100/20 to-transparent blur-2xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-24 h-1 rounded-full bg-gradient-to-r from-transparent via-orange-300/40 to-transparent pointer-events-none" aria-hidden="true"></div>
    <img src="/icon-login.png" alt="अंतर्राष्ट्रीय असाटी समाज दर्शन" class="relative w-32 h-32 mx-auto mb-5 rounded-2xl shadow-[0_12px_40px_-8px_rgba(220,50,50,0.2)]" style="filter: drop-shadow(0 4px 20px rgba(220, 50, 50, 0.25));">
  </div>
  <% if I18n.locale == :hi %>
    <h1 class="text-lg font-extrabold text-gray-900 mt-1 tracking-tight leading-snug">अंतर्राष्ट्रीय असाटी समाज दर्शन</h1>
  <% else %>
    <h1 class="text-lg font-extrabold text-gray-900 mt-1 tracking-tight leading-snug">Antarrashtriya Asati Samaj Darshan</h1>
  <% end %>
  <div class="mt-3 w-20 h-px section-divider mx-auto opacity-80"></div>
</div>

<%# Login heading %>
<div class="mb-8">
  <h2 class="text-2xl font-extrabold tracking-tight text-gradient"><%= t("login.title") %></h2>
  <p class="text-sm text-gray-500 mt-2 leading-relaxed"><%= t("login.footer") %></p>
</div>

<div class="surface-elevated rounded-2xl overflow-hidden shadow-[0_24px_64px_-16px_rgba(0,0,0,0.12),0_8px_24px_-8px_rgba(234,88,12,0.08)] border border-black/[0.06] animate-fade-in">
  <div class="h-1 gradient-brand" aria-hidden="true"></div>
  <div class="p-8 sm:p-10">
  <%= form_with url: login_path, method: :post, class: "space-y-6" do |f| %>
    <div>
      <label for="phone" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2"><%= t("login.phone_label") %></label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
        <input type="tel" name="phone" id="phone" required autofocus
               placeholder="<%= t('login.phone_placeholder') %>" maxlength="10" pattern="[6-9][0-9]{9}"
               class="block w-full input-premium pl-11 pr-4 placeholder:text-gray-400 rounded-xl">
      </div>
    </div>

    <div>
      <label for="password" class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2"><%= t("login.password_label") %></label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <input type="password" name="password" id="password" required
               placeholder="<%= t('login.password_placeholder') %>"
               class="block w-full input-premium pl-11 pr-4 placeholder:text-gray-400 rounded-xl">
      </div>
    </div>

    <button type="submit"
            class="w-full btn-primary justify-center py-3.5 !rounded-2xl text-base shadow-[0_8px_24px_-4px_rgba(234,88,12,0.35)] hover:shadow-[0_12px_32px_-4px_rgba(234,88,12,0.4)]">
      <%= t("login.submit") %>
    </button>
  <% end %>
  </div>
</div>

<p class="text-center text-sm text-gray-500 mt-8">
  <%= t("login.no_account", default: "Don't have an account?") %>
  <%= link_to t("nav.sign_up"), signup_path, class: "font-semibold text-orange-600 hover:text-orange-700 transition-colors" %>
</p>

<div class="mt-8">
  <div class="section-divider mb-6"></div>
  <div class="flex items-center justify-between">
    <%= link_to root_path, class: "text-sm text-gray-500 hover:text-gray-800 transition-colors" do %>
      &larr; <%= t("nav.home") %>
    <% end %>
    <%= link_to t("nav.language_switch"), switch_locale_path, class: "text-sm font-semibold text-gray-600 hover:text-orange-600 bg-white/80 hover:bg-orange-50/90 border border-gray-200/80 hover:border-orange-200/60 rounded-full px-4 py-2 shadow-sm transition-all" %>
  </div>
</div>
