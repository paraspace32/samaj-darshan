<%# ── Mobile logo (hidden on desktop) ──────────────────────────────────── %>
<div class="lg:hidden text-center mb-8 fade-up">
  <div class="relative inline-block mb-4">
    <div class="absolute inset-0 rounded-2xl bg-orange-300/30 blur-xl scale-110"></div>
    <img src="/icon-login.png" alt="Samaj Darshan"
         class="relative w-20 h-20 mx-auto rounded-2xl shadow-[0_8px_32px_-4px_rgba(220,50,50,0.3)]">
  </div>
  <% if I18n.locale == :hi %>
    <h1 class="text-base font-extrabold text-gray-800 tracking-tight leading-snug">अंतर्राष्ट्रीय असाटी समाज दर्शन</h1>
  <% else %>
    <h1 class="text-base font-extrabold text-gray-800 tracking-tight leading-snug">Antarrashtriya Asati Samaj Darshan</h1>
  <% end %>
</div>

<%# ── Heading ────────────────────────────────────────────────────────────── %>
<div class="mb-7 fade-up-d1">
  <h2 class="text-[2rem] font-black tracking-tight text-gray-900 leading-none" id="auth-heading">
    <%= t("auth.title") %>
    <span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>
  </h2>
  <p class="text-sm text-gray-500 mt-2.5 leading-relaxed" id="auth-subtitle"><%= t("auth.subtitle") %></p>
</div>

<%# ── Form card ──────────────────────────────────────────────────────────── %>
<div class="fade-up-d2">
  <%# Gradient top stripe %>
  <div class="h-1.5 w-full rounded-t-2xl" style="background: linear-gradient(90deg, #b91c1c, #ea580c, #d97706);"></div>

  <div class="form-card rounded-b-2xl px-8 py-8">
    <%= form_with url: login_path, method: :post, id: "auth-form", class: "space-y-5" do |f| %>

      <%# Phone %>
      <div>
        <label for="phone" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("auth.phone_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <input type="tel" name="phone" id="phone" required autofocus autocomplete="tel"
                 placeholder="<%= t('auth.phone_placeholder') %>" maxlength="10" pattern="[6-9][0-9]{9}"
                 class="input-auth">
        </div>
      </div>

      <%# Name (only for new users — hidden initially) %>
      <div id="name-field" class="hidden">
        <label for="name" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("auth.name_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <input type="text" name="name" id="name" autocomplete="name"
                 placeholder="<%= t('auth.name_placeholder') %>"
                 class="input-auth">
        </div>
      </div>

      <%# Password (hidden until phone check) %>
      <div id="password-field" class="hidden">
        <label for="password" class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2.5"><%= t("auth.password_label") %></label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <input type="password" name="password" id="password"
                 placeholder="<%= t('auth.password_placeholder') %>"
                 class="input-auth pr-12">
          <%# Show / hide toggle %>
          <button type="button" tabindex="-1"
                  aria-label="<%= t('login.show_password') %>"
                  onclick="(function(btn){var i=document.getElementById('password');var show=i.type==='password';i.type=show?'text':'password';btn.querySelector('.eye-open').classList.toggle('hidden',show);btn.querySelector('.eye-shut').classList.toggle('hidden',!show);})(this)"
                  class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-orange-500 transition-colors">
            <svg class="eye-open w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg class="eye-shut hidden w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>

      <%# Submit — changes label based on mode %>
      <div class="pt-1">
        <button type="submit" id="auth-submit" class="btn-auth">
          <span id="submit-text"><%= t("auth.continue") %></span> &nbsp;→
        </button>
      </div>

    <% end %>

    <%# ── JS Error display ── %>
    <div id="auth-error" class="hidden mt-4 rounded-2xl border border-red-200/80 bg-red-50 px-4 py-3 text-sm text-red-800 flex items-center gap-2">
      <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      <span id="auth-error-text"></span>
    </div>
  </div>
</div>

<%# ── Forgot password ─────────────────────────────────────────────────────── %>
<p class="text-center text-sm text-gray-500 mt-6 fade-up-d3">
  <%= link_to t("password_reset.forgot_password"), password_reset_path, class: "font-semibold text-orange-600 hover:text-orange-700 transition-colors underline underline-offset-2 decoration-orange-300" %>
</p>

<%# ── Bottom bar ─────────────────────────────────────────────────────────── %>
<div class="mt-6 flex items-center justify-between fade-up-d3">
  <%= link_to root_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-700 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    <%= t("nav.home") %>
  <% end %>
  <%= link_to t("nav.language_switch"), switch_locale_path,
      class: "text-xs font-bold text-gray-500 hover:text-orange-600 bg-gray-50 hover:bg-orange-50 border border-gray-200 hover:border-orange-200 rounded-full px-4 py-2 shadow-sm transition-all" %>
</div>

<script>
(function() {
  var phoneInput = document.getElementById('phone');
  var nameField  = document.getElementById('name-field');
  var nameInput  = document.getElementById('name');
  var passField  = document.getElementById('password-field');
  var passInput  = document.getElementById('password');
  var heading    = document.getElementById('auth-heading');
  var subtitle   = document.getElementById('auth-subtitle');
  var submitText = document.getElementById('submit-text');
  var form       = document.getElementById('auth-form');
  var checkUrl   = '<%= login_check_path %>';
  var csrf       = document.querySelector('meta[name="csrf-token"]').content;

  var mode = null;
  var checking = false;

  function showError(msg) {
    var el = document.getElementById('auth-error');
    document.getElementById('auth-error-text').textContent = msg;
    el.classList.remove('hidden');
    setTimeout(function() { el.classList.add('hidden'); }, 5000);
  }

  var strings = {
    title_enter:  '<%= j t("auth.title") %>',
    sub_enter:    '<%= j t("auth.subtitle") %>',
    title_login:  '<%= j t("auth.title_login") %>',
    sub_login:    '<%= j t("auth.sub_login") %>',
    title_signup: '<%= j t("auth.title_signup") %>',
    sub_signup:   '<%= j t("auth.sub_signup") %>',
    btn_continue: '<%= j t("auth.continue") %>',
    btn_login:    '<%= j t("auth.btn_login") %>',
    btn_signup:   '<%= j t("auth.btn_signup") %>'
  };

  function setMode(newMode) {
    mode = newMode;
    if (mode === 'login') {
      nameField.classList.add('hidden');
      nameInput.removeAttribute('required');
      passField.classList.remove('hidden');
      passInput.setAttribute('required', '');
      passInput.focus();
      heading.innerHTML = strings.title_login + '<span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>';
      subtitle.textContent = strings.sub_login;
      submitText.textContent = strings.btn_login;
    } else if (mode === 'signup') {
      nameField.classList.remove('hidden');
      nameInput.setAttribute('required', '');
      passField.classList.remove('hidden');
      passInput.setAttribute('required', '');
      nameInput.focus();
      heading.innerHTML = strings.title_signup + '<span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>';
      subtitle.textContent = strings.sub_signup;
      submitText.textContent = strings.btn_signup;
    }
  }

  function checkPhone() {
    var phone = phoneInput.value.replace(/\D/g, '');
    if (phone.length !== 10 || !/^[6-9]/.test(phone)) return;
    if (checking) return;
    checking = true;

    fetch(checkUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify({ phone: phone })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      setMode(data.exists ? 'login' : 'signup');
    })
    .catch(function() {
      showError('<%= j t("auth.network_error") %>');
    })
    .finally(function() { checking = false; });
  }

  phoneInput.addEventListener('input', function() {
    var phone = this.value.replace(/\D/g, '');
    if (phone.length === 10) {
      checkPhone();
    } else if (mode !== null) {
      // Reset to phone-only step if user changes phone
      mode = null;
      nameField.classList.add('hidden');
      passField.classList.add('hidden');
      nameInput.removeAttribute('required');
      passInput.removeAttribute('required');
      heading.innerHTML = strings.title_enter + '<span class="inline-block w-1.5 h-1.5 rounded-full bg-orange-500 mb-1 ml-0.5"></span>';
      subtitle.textContent = strings.sub_enter;
      submitText.textContent = strings.btn_continue;
    }
  });

  // If phone already has 10 digits (e.g. browser autofill), check immediately
  if (phoneInput.value.replace(/\D/g, '').length === 10) {
    checkPhone();
  }

  // Intercept form submit on phone-only step to trigger check instead of submitting
  form.addEventListener('submit', function(e) {
    if (mode === null) {
      e.preventDefault();
      checkPhone();
    }
  });
})();
</script>
