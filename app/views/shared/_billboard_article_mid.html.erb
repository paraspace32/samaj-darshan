<% bb = billboard_for(:article_mid) %>
<% if bb&.image&.attached? %>
  <% bb.track_impression! %>
  <div class="my-8 rounded-2xl overflow-hidden border border-gray-200/60 shadow-sm relative bg-gray-50">
    <span class="absolute top-2 right-2 z-10 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-black/40 text-white/80 backdrop-blur-sm">Ad</span>
    <% if bb.link_url.present? %>
      <%= link_to billboard_click_path(bb), class: "block" do %>
        <%= optimized_image_tag bb.image, variant: :card, class: "w-full h-auto object-cover max-h-48 sm:max-h-60", loading: "lazy" %>
      <% end %>
    <% else %>
      <%= optimized_image_tag bb.image, variant: :card, class: "w-full h-auto object-cover max-h-48 sm:max-h-60", loading: "lazy" %>
    <% end %>
  </div>
<% end %>
