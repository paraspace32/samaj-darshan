<% marriage_ads = billboards_for(:marriage_ad).first(10) %>
<% marriage_ads = (marriage_ads * 10).first(10) if marriage_ads.size.between?(1, 9) %>
<% if marriage_ads.any? %>
  <div class="mb-4">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center gap-2">
        <span class="relative flex h-2.5 w-2.5 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background:#f97316"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5" style="background:linear-gradient(135deg,#f97316,#ea580c)"></span>
        </span>
        <div>
          <h2 class="text-base sm:text-lg font-black text-gray-900 tracking-tight"><%= t("feed.marriage_ads") %></h2>
          <p class="text-[11px] text-gray-400 mt-0.5 hidden sm:block"><%= t("feed.marriage_ads_subtitle") %></p>
        </div>
      </div>
    </div>

    <div class="relative rounded-2xl overflow-hidden border border-rose-100 shadow-sm group"
         data-controller="carousel" data-carousel-autoplay-value="true">
      <div class="overflow-hidden">
        <div class="flex transition-transform duration-500 ease-out" data-carousel-target="track">
          <% marriage_ads.each_with_index do |bb, i| %>
            <% bb.track_impression! %>
            <div class="w-full shrink-0 relative bg-white" style="height: 384px;" data-carousel-target="slide">
              <% if bb.link_url.present? %>
                <%= link_to billboard_click_path(bb), class: "block w-full h-full" do %>
                  <% if bb.image.attached? %>
                    <%= optimized_image_tag bb.image, variant: :splash, class: "w-full h-full object-contain", loading: i == 0 ? "eager" : "lazy" %>
                  <% else %>
                    <div class="w-full h-full bg-gradient-to-br from-rose-50 to-pink-100 flex items-center justify-center">
                      <span class="text-rose-400 text-lg font-semibold"><%= bb.title %></span>
                    </div>
                  <% end %>
                <% end %>
              <% else %>
                <% if bb.image.attached? %>
                  <%= optimized_image_tag bb.image, variant: :splash, class: "w-full h-full object-contain", loading: i == 0 ? "eager" : "lazy" %>
                <% else %>
                  <div class="w-full h-full bg-gradient-to-br from-rose-50 to-pink-100 flex items-center justify-center">
                    <span class="text-rose-400 text-lg font-semibold"><%= bb.title %></span>
                  </div>
                <% end %>
              <% end %>
              <span class="absolute top-2 right-2 z-10 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-black/40 text-white/80 backdrop-blur-sm">Ad</span>
            </div>
          <% end %>
        </div>
      </div>

      <% if marriage_ads.size > 1 %>
        <%# Prev / Next arrows — always visible, pointer-events isolated so ad clicks still work %>
        <button data-action="click->carousel#prev" onclick="event.preventDefault(); event.stopPropagation();"
                class="absolute left-2 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full text-white flex items-center justify-center cursor-pointer shadow-lg"
                style="background:linear-gradient(135deg,#f97316,#ea580c);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button data-action="click->carousel#next" onclick="event.preventDefault(); event.stopPropagation();"
                class="absolute right-2 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full text-white flex items-center justify-center cursor-pointer shadow-lg"
                style="background:linear-gradient(135deg,#f97316,#ea580c);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
        </button>

        <%# Dot indicators %>
        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-10 flex items-center gap-1.5">
          <% marriage_ads.each_with_index do |_, i| %>
            <button data-carousel-target="dot" data-action="carousel#goToSlide" data-index="<%= i %>"
                    class="h-2 rounded-full transition-all duration-300 cursor-pointer <%= i == 0 ? 'bg-white w-6' : 'bg-white/45 w-2 hover:bg-white/70' %>"></button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
