<% marriage_ads = billboards_for(:marriage_ad).first(10) %>
<% marriage_ads = (marriage_ads * 10).first(10) if marriage_ads.size.between?(1, 9) %>
<% if marriage_ads.any? %>
  <%#
    Ornate wedding picture frame:
    - Full width on mobile (no side margins)
    - sm+: rounded corners with gradient border
    - Badge sits ON the top border of the frame (not inside image)
    - Frame size is FIXED via aspect-[3/4] — never grows with image dimensions
  %>
  <div class="mb-4 relative -mx-4 sm:mx-0">

    <%# 💍 Ring decoration — top-right corner of frame %>
    <div class="absolute -top-2.5 -right-0 sm:-right-2.5 z-30 w-9 h-9 rounded-full flex items-center justify-center text-base select-none"
         style="background: linear-gradient(135deg, #fb7185, #f43f5e); box-shadow: 0 2px 10px rgba(244,63,94,0.5)">
      💍
    </div>

    <%# Gradient border frame — full-width mobile, rounded on sm+ %>
    <div class="sm:rounded-[18px]"
         style="padding: 4px; background: linear-gradient(135deg, #fda4af 0%, #fde68a 25%, #f9a8d4 50%, #fde68a 75%, #fda4af 100%);">
      <%# White mat inner border %>
      <div class="sm:rounded-[15px]" style="padding: 3px; background: white;">

        <%# Carousel — no bottom bar %>
        <div class="relative overflow-hidden sm:rounded-[13px]"
             data-controller="carousel"
             data-carousel-autoplay-value="true"
             data-carousel-fixed-height-value="true">

          <%# Slides track %>
          <div class="flex items-start transition-transform duration-500 ease-out" data-carousel-target="track">
            <% marriage_ads.each_with_index do |bb, i| %>
              <% bb.track_impression! %>
              <%# Fixed-ratio frame — always aspect-[3/4] regardless of image dimensions %>
              <div class="w-full shrink-0 relative aspect-[3/4] overflow-hidden" data-carousel-target="slide">
                <% if bb.link_url.present? %>
                  <%= link_to billboard_click_path(bb), class: "absolute inset-0 w-full h-full block" do %>
                    <% if bb.image.attached? %>
                      <%= optimized_image_tag bb.image, variant: :marriage_ad,
                            class: "w-full h-full object-cover block",
                            loading: i == 0 ? "eager" : "lazy" %>
                    <% else %>
                      <div class="w-full h-full bg-gradient-to-br from-rose-50 to-pink-100 flex items-center justify-center">
                        <span class="text-rose-400 text-lg font-semibold"><%= bb.title %></span>
                      </div>
                    <% end %>
                  <% end %>
                <% else %>
                  <% if bb.image.attached? %>
                    <%= optimized_image_tag bb.image, variant: :marriage_ad,
                          class: "absolute inset-0 w-full h-full object-cover block",
                          loading: i == 0 ? "eager" : "lazy" %>
                  <% else %>
                    <div class="absolute inset-0 w-full h-full bg-gradient-to-br from-rose-50 to-pink-100 flex items-center justify-center">
                      <span class="text-rose-400 text-lg font-semibold"><%= bb.title %></span>
                    </div>
                  <% end %>
                <% end %>
                <span class="absolute top-2 right-2 z-10 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-black/40 text-white/80 backdrop-blur-sm">Ad</span>
              </div>
            <% end %>
          </div>

          <%# Dot indicators at bottom of image (autoplay only — no manual arrows) %>
          <div class="absolute bottom-2.5 left-1/2 -translate-x-1/2 z-20 flex items-center gap-1">
            <% (0...(marriage_ads.size / 2)).each do |i| %>
              <button data-carousel-target="dot" data-action="carousel#goToSlide" data-index="<%= i %>"
                      class="h-1 rounded-full transition-all duration-300 cursor-pointer <%= i == 0 ? 'bg-white w-4' : 'bg-white/45 w-1.5' %>"></button>
            <% end %>
          </div>

        </div>
      </div>
    </div>
  </div>
<% end %>
