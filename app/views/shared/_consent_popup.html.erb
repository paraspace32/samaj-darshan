<% biodata = @consent_pending_biodata %>
<div data-controller="consent-popup">
  <%# Overlay %>
  <div data-consent-popup-target="overlay"
       class="hidden fixed inset-0 z-50 items-center justify-center p-4 transition-opacity duration-250"
       style="background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);">

    <div class="relative w-full max-w-md bg-white rounded-3xl shadow-2xl overflow-hidden animate-fade-up">

      <%# Top accent bar %>
      <div class="h-1.5 w-full gradient-brand"></div>

      <div class="p-6 sm:p-8">
        <%# Icon + heading %>
        <div class="flex items-start gap-4 mb-5">
          <div class="w-12 h-12 rounded-2xl bg-orange-50 border border-orange-200/60 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-black tracking-tight text-gray-900"><%= t("biodata.consent_popup_title") %></h2>
            <p class="text-sm text-gray-500 mt-0.5"><%= t("biodata.consent_popup_subtitle") %></p>
          </div>
        </div>

        <%# Biodata preview card %>
        <div class="rounded-2xl border border-gray-200/60 bg-gray-50/60 p-4 mb-6 flex items-center gap-3">
          <div class="w-12 h-14 rounded-xl overflow-hidden bg-gradient-to-br from-orange-100 to-rose-100 flex items-center justify-center shrink-0 border border-gray-200/40">
            <% if biodata.photo.attached? %>
              <%= optimized_image_tag biodata.photo, variant: :thumb, class: "w-full h-full object-cover" %>
            <% else %>
              <span class="text-orange-500 font-black text-lg"><%= biodata.avatar_initial %></span>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-gray-900 truncate"><%= biodata.full_name %></p>
            <p class="text-xs text-gray-500 mt-0.5">
              <%= biodata.age %> <%= t("biodata.years") %>
              <% if biodata.city.present? %>&middot; <%= biodata.city %><% end %>
            </p>
            <p class="text-xs text-orange-600 font-semibold mt-1"><%= t("biodata.consent_popup_created_by", name: biodata.created_by&.name.presence || "Admin") %></p>
          </div>
        </div>

        <%# Description %>
        <p class="text-sm text-gray-600 mb-6 leading-relaxed"><%= t("biodata.consent_popup_body") %></p>

        <%# Actions %>
        <div class="space-y-2.5">
          <%= button_to consent_my_biodata_path(biodata), method: :patch,
                class: "w-full inline-flex items-center justify-center gap-2 rounded-2xl gradient-brand px-5 py-3 text-sm font-bold text-white shadow-lg shadow-orange-500/25 hover:shadow-xl hover:shadow-orange-500/30 transition-all cursor-pointer" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M5 13l4 4L19 7"/></svg>
            <%= t("biodata.consent_accept") %>
          <% end %>

          <%= link_to my_biodata_path(biodata), class: "w-full inline-flex items-center justify-center gap-2 rounded-2xl border border-gray-200 bg-white px-5 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <%= t("biodata.consent_popup_review") %>
          <% end %>

          <%= button_to decline_consent_my_biodata_path(biodata), method: :patch,
                data: { turbo_confirm: t("biodata.consent_decline_confirm") },
                class: "w-full inline-flex items-center justify-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-medium text-red-500 hover:text-red-700 hover:bg-red-50 transition-colors cursor-pointer" do %>
            <%= t("biodata.consent_decline") %>
          <% end %>
        </div>

        <%# Dismiss note %>
        <button data-action="consent-popup#dismiss"
                class="mt-4 w-full text-center text-xs text-gray-400 hover:text-gray-600 transition-colors cursor-pointer">
          <%= t("biodata.consent_popup_remind_later") %>
        </button>
      </div>
    </div>
  </div>
</div>
