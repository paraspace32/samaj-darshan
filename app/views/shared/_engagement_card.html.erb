<%# Locals: item, liked, toggle_path, comments_path, comments, share_text %>

<div id="comments" class="mb-10 animate-fade-up rounded-3xl overflow-hidden"
     style="border:1px solid rgba(249,115,22,0.12); box-shadow:0 4px 24px -6px rgba(249,115,22,0.08); background:linear-gradient(135deg,#fffbf5,#fff7ed,#fffbf5)">

  <%# ═══ Action bar ══════════════════════════════════════════════════════ %>
  <div class="flex items-center gap-2.5 px-5 py-4">

    <%# ── Like ─────────────────────────────────────────────────────────── %>
    <% if current_user %>
      <%= button_to toggle_path, method: :post,
            form: { style: "display:contents" },
            class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm font-bold cursor-pointer transition-all duration-200 hover:scale-[1.04] active:scale-95",
            style: liked ? "background:#fef2f2; color:#ef4444; border:1.5px solid #fca5a5; box-shadow:0 2px 8px -2px rgba(239,68,68,0.25)" : "background:#fff1f2; color:#f43f5e; border:1.5px solid #fecdd3" do %>
        <svg class="w-[18px] h-[18px] <%= liked ? 'drop-shadow-[0_0_4px_rgba(239,68,68,0.5)]' : '' %>"
             fill="<%= liked ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="<%= liked ? '0' : '2' %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span class="tabular-nums"><%= item.likes_count %></span>
      <% end %>
    <% else %>
      <%= link_to login_path,
            class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm font-bold transition-all duration-200 hover:scale-[1.04]",
            style: "background:#fff1f2; color:#f43f5e; border:1.5px solid #fecdd3" do %>
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span class="tabular-nums"><%= item.likes_count %></span>
      <% end %>
    <% end %>

    <%# ── Comments ──────────────────────────────────────────────────────── %>
    <a href="#comment-form"
       class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm font-bold transition-all duration-200 hover:scale-[1.04]"
       style="background:#eff6ff; color:#3b82f6; border:1.5px solid #bfdbfe">
      <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <span class="tabular-nums"><%= item.comments_count %></span>
    </a>

    <%# ── Spacer ─────────────────────────────────────────────────────── %>
    <div class="flex-1"></div>

    <%# ── WhatsApp ───────────────────────────────────────────────────────── %>
    <a href="https://wa.me/?text=<%= ERB::Util.url_encode(share_text) %>"
       target="_blank" rel="noopener"
       class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm font-bold transition-all duration-200 hover:scale-[1.04]"
       style="background:#f0fdf4; color:#16a34a; border:1.5px solid #86efac">
      <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="hidden sm:inline"><%= I18n.locale == :hi ? "शेयर" : "Share" %></span>
    </a>

    <%# ── Copy link ─────────────────────────────────────────────────────── %>
    <button data-controller="copy-link" data-copy-link-url-value="<%= local_assigns[:share_url] || request.original_url %>" data-action="copy-link#copy"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm font-bold transition-all duration-200 hover:scale-[1.04] cursor-pointer"
            style="background:#fff7ed; color:#ea580c; border:1.5px solid #fed7aa">
      <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      <span class="hidden sm:inline"><%= I18n.locale == :hi ? "कॉपी" : "Copy" %></span>
    </button>

  </div>

  <%# ═══ Comment section ══════════════════════════════════════════════════ %>
  <div id="comment-form" class="border-t border-stone-100 px-5 py-4">

    <% if current_user %>
      <%# ── Logged-in: comment form ─────────────────────────────────────── %>
      <%= form_with model: Comment.new, url: comments_path do |f| %>
        <div class="flex gap-3 items-start">
          <div class="w-8 h-8 rounded-full gradient-brand flex items-center justify-center shrink-0 shadow-sm ring-1 ring-white mt-0.5">
            <span class="text-white font-bold text-[11px]"><%= current_user.name[0].upcase %></span>
          </div>
          <div class="flex-1 min-w-0">
            <%= f.text_area :body,
                  placeholder: t("comments.write_placeholder"),
                  rows: 2,
                  class: "block w-full rounded-2xl border border-stone-200 bg-stone-50 px-4 pt-3 pb-3 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-300 focus:ring-2 focus:ring-orange-100 focus:outline-none resize-none transition-all" %>
            <div class="flex justify-end mt-2">
              <%= f.submit t("comments.submit"),
                    class: "cursor-pointer rounded-xl px-5 py-2 text-xs font-bold text-white transition-all hover:scale-[1.02] active:scale-95 shadow-sm",
                    style: "background:linear-gradient(135deg,#f97316,#ea580c)" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <%# ── Guest: login prompt ─────────────────────────────────────────── %>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
             style="background:#ffedd5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="2">
            <path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <p class="flex-1 text-sm text-stone-500">
          <%= I18n.locale == :hi ? "टिप्पणी करने के लिए" : "To comment," %>
        </p>
        <%= link_to login_path,
              class: "shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-xs font-bold text-white transition-all hover:scale-[1.02] shadow-sm",
              style: "background:linear-gradient(135deg,#f97316,#ea580c)" do %>
          <%= t("comments.login_to_comment_short", default: I18n.locale == :hi ? "लॉगिन करें" : "Log in") %>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ── Comments list (only if any) ──────────────────────────────────── %>
  <% if comments.any? %>
    <div class="border-t border-stone-100 px-5 py-4 space-y-4">
      <%= render partial: "comments/comment", collection: comments %>
    </div>
  <% end %>

</div>
