<%#
  Locals:
    item           – the news/education record
    liked          – boolean
    toggle_path    – path for the like toggle
    comments_path  – path to POST new comment
    comments       – collection
    share_text     – pre-built share string
%>

<div id="comments" class="rounded-3xl border border-gray-100 overflow-hidden mb-10 shadow-lg bg-white">

  <%# ── Action bar: all four actions in one row ───────────────────────── %>
  <div class="grid grid-cols-4 divide-x divide-gray-100 border-b border-gray-100">

    <%# Like %>
    <% if current_user %>
      <%= button_to toggle_path, method: :post,
            class: "group flex flex-col items-center justify-center gap-1 py-3.5 px-2 cursor-pointer transition-colors #{liked ? 'bg-red-50 text-red-500' : 'bg-white text-stone-400 hover:bg-red-50 hover:text-red-500'}" do %>
        <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="<%= liked ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span class="text-[11px] font-bold leading-none"><%= item.likes_count %> <%= liked ? t("likes.liked") : t("likes.like") %></span>
      <% end %>
    <% else %>
      <%= link_to login_path,
            class: "flex flex-col items-center justify-center gap-1 py-3.5 px-2 bg-white text-stone-400 hover:bg-red-50 hover:text-red-500 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span class="text-[11px] font-bold leading-none"><%= item.likes_count %> <%= t("likes.like") %></span>
      <% end %>
    <% end %>

    <%# Comments count (scroll anchor) %>
    <a href="#comment-form" class="flex flex-col items-center justify-center gap-1 py-3.5 px-2 bg-white text-stone-400 hover:bg-stone-50 hover:text-stone-600 transition-colors">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <span class="text-[11px] font-bold leading-none"><%= item.comments_count %> <%= t("comments.title") %></span>
    </a>

    <%# WhatsApp %>
    <a href="https://wa.me/?text=<%= ERB::Util.url_encode(share_text) %>"
       target="_blank" rel="noopener"
       class="flex flex-col items-center justify-center gap-1 py-3.5 px-2 bg-white text-stone-400 hover:bg-emerald-50 hover:text-emerald-600 transition-colors">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span class="text-[11px] font-bold leading-none">WhatsApp</span>
    </a>

    <%# Copy link %>
    <button data-controller="copy-link" data-copy-link-url-value="<%= request.original_url %>" data-action="copy-link#copy"
            class="flex flex-col items-center justify-center gap-1 py-3.5 px-2 bg-white text-stone-400 hover:bg-stone-50 hover:text-stone-600 transition-colors cursor-pointer">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      <span class="text-[11px] font-bold leading-none">Copy Link</span>
    </button>
  </div>

  <%# ── Comment form ───────────────────────────────────────────────────── %>
  <div class="px-5 sm:px-6" id="comment-form">
    <% if current_user %>
      <%= form_with model: Comment.new, url: comments_path, class: "pt-5 pb-4 border-b border-gray-100" do |f| %>
        <div class="flex gap-3 items-start">
          <div class="w-9 h-9 rounded-full gradient-brand flex items-center justify-center shrink-0 shadow-sm ring-2 ring-white mt-0.5">
            <span class="text-white font-bold text-xs"><%= current_user.name[0].upcase %></span>
          </div>
          <div class="flex-1 min-w-0 relative">
            <%= f.text_area :body,
                  placeholder: t("comments.write_placeholder"),
                  rows: 2,
                  class: "block w-full rounded-2xl border border-gray-200 bg-gray-50 px-4 pt-3 pb-10 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-300 focus:ring-4 focus:ring-orange-50 focus:outline-none resize-none transition-all" %>
            <div class="absolute bottom-2.5 right-3">
              <%= f.submit t("comments.submit"),
                    class: "cursor-pointer rounded-xl bg-orange-500 hover:bg-orange-600 px-4 py-1.5 text-xs font-bold text-white shadow-sm transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="py-5 flex items-center justify-center border-b border-gray-100">
        <%= link_to login_path,
              class: "inline-flex items-center gap-2 rounded-2xl border border-orange-200 bg-orange-50 hover:bg-orange-100 px-5 py-2.5 text-sm font-bold text-orange-600 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
          </svg>
          <%= t("comments.login_to_comment") %>
        <% end %>
      </div>
    <% end %>

    <%# ── Comments list ─────────────────────────────────────────────────── %>
    <% if comments.any? %>
      <div class="divide-y divide-gray-100 pb-2">
        <%= render partial: "comments/comment", collection: comments %>
      </div>
    <% else %>
      <div class="flex flex-col items-center gap-2 py-10">
        <div class="w-11 h-11 rounded-2xl bg-gray-100 flex items-center justify-center">
          <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <p class="text-sm text-stone-400 font-medium"><%= t("comments.no_comments") %></p>
      </div>
    <% end %>
  </div>

</div>
