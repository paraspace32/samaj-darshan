<%# Locals: item, liked, toggle_path, comments_path, comments, share_text %>

<div id="comments" class="mb-10 rounded-3xl overflow-hidden"
     style="border:1px solid rgba(0,0,0,0.07); box-shadow:0 4px 24px -4px rgba(0,0,0,0.08), 0 1px 4px -1px rgba(0,0,0,0.04); background:#fff">

  <%# ═══ Action row ════════════════════════════════════════════════════════ %>
  <div class="grid grid-cols-4 border-b border-stone-100">

    <%# ── Like ─────────────────────────────────────────────────────────── %>
    <% if current_user %>
      <%= button_to toggle_path, method: :post,
            form: { style: "display:contents" },
            class: "group flex flex-col items-center gap-1.5 py-4 cursor-pointer transition-all duration-200
                    #{liked ? 'text-red-500' : 'text-stone-500 hover:text-red-500'}" do %>
        <div class="w-14 h-11 rounded-2xl flex items-center justify-center transition-all duration-200
                    <%= liked ? 'shadow-md shadow-red-200' : 'group-hover:shadow-md group-hover:shadow-red-100' %>"
             style="<%= liked ? 'background:linear-gradient(135deg,#fef2f2,#fee2e2); border:1.5px solid #fca5a5' : 'background:linear-gradient(135deg,#fff1f2,#fff5f5); border:1.5px solid #fecdd3' %>">
          <svg class="w-5 h-5 transition-transform duration-200 group-hover:scale-125 <%= liked ? 'drop-shadow-[0_0_6px_rgba(239,68,68,0.6)]' : '' %>"
               fill="<%= liked ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="<%= liked ? 'none' : '#f43f5e' %>" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
        <span class="text-xs font-black tabular-nums <%= liked ? 'text-red-500' : 'text-rose-400' %>"><%= item.likes_count %></span>
      <% end %>
    <% else %>
      <%= link_to login_path, class: "group flex flex-col items-center gap-1.5 py-4 text-stone-500 hover:text-red-500 transition-all duration-200" do %>
        <div class="w-14 h-11 rounded-2xl flex items-center justify-center transition-all duration-200 group-hover:shadow-md group-hover:shadow-red-100"
             style="background:linear-gradient(135deg,#fff1f2,#fff5f5); border:1.5px solid #fecdd3">
          <svg class="w-5 h-5 group-hover:scale-125 transition-transform" fill="none" viewBox="0 0 24 24" stroke="#f43f5e" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
        <span class="text-xs font-black tabular-nums text-rose-400"><%= item.likes_count %></span>
      <% end %>
    <% end %>

    <%# ── Comments ──────────────────────────────────────────────────────── %>
    <a href="#comment-form"
       class="group flex flex-col items-center gap-1.5 py-4 text-stone-500 hover:text-sky-600 transition-all duration-200">
      <div class="w-14 h-11 rounded-2xl flex items-center justify-center transition-all duration-200 group-hover:shadow-md group-hover:shadow-sky-100"
           style="background:linear-gradient(135deg,#f0f9ff,#e0f2fe); border:1.5px solid #bae6fd">
        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="#0ea5e9" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
      </div>
      <span class="text-xs font-black tabular-nums text-sky-400"><%= item.comments_count %></span>
    </a>

    <%# ── WhatsApp ───────────────────────────────────────────────────────── %>
    <a href="https://wa.me/?text=<%= ERB::Util.url_encode(share_text) %>"
       target="_blank" rel="noopener"
       class="group flex flex-col items-center gap-1.5 py-4 text-stone-500 hover:text-green-600 transition-all duration-200">
      <div class="w-14 h-11 rounded-2xl flex items-center justify-center transition-all duration-200 group-hover:shadow-md group-hover:shadow-green-100"
           style="background:linear-gradient(135deg,#f0fdf4,#dcfce7); border:1.5px solid #86efac">
        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="#22c55e" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </div>
      <span class="text-xs font-black text-green-500"><%= I18n.locale == :hi ? "शेयर" : "Share" %></span>
    </a>

    <%# ── Copy link ─────────────────────────────────────────────────────── %>
    <button data-controller="copy-link" data-copy-link-url-value="<%= request.original_url %>" data-action="copy-link#copy"
            class="group flex flex-col items-center gap-1.5 py-4 text-stone-500 hover:text-orange-500 transition-all duration-200 cursor-pointer">
      <div class="w-14 h-11 rounded-2xl flex items-center justify-center transition-all duration-200 group-hover:shadow-md group-hover:shadow-orange-100"
           style="background:linear-gradient(135deg,#fff7ed,#ffedd5); border:1.5px solid #fed7aa">
        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="2">
          <path stroke-linecap="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
        </svg>
      </div>
      <span class="text-xs font-black text-orange-400"><%= I18n.locale == :hi ? "कॉपी" : "Copy" %></span>
    </button>

  </div>

  <%# ═══ Comment form ══════════════════════════════════════════════════════ %>
  <div class="px-4 sm:px-5" id="comment-form">
    <% if current_user %>
      <%= form_with model: Comment.new, url: comments_path, class: "py-4 border-b border-stone-100" do |f| %>
        <div class="flex gap-3 items-start">
          <div class="w-9 h-9 rounded-full gradient-brand flex items-center justify-center shrink-0 shadow-md shadow-orange-200 ring-2 ring-white mt-0.5">
            <span class="text-white font-black text-xs"><%= current_user.name[0].upcase %></span>
          </div>
          <div class="flex-1 min-w-0 relative">
            <%= f.text_area :body,
                  placeholder: t("comments.write_placeholder"),
                  rows: 2,
                  class: "block w-full rounded-2xl border-2 border-gray-200 bg-gray-50 px-4 pt-3 pb-11 text-sm text-stone-800 placeholder-stone-400 focus:bg-white focus:border-orange-400 focus:ring-4 focus:ring-orange-50 focus:outline-none resize-none transition-all" %>
            <div class="absolute bottom-3 right-3">
              <%= f.submit t("comments.submit"),
                    class: "cursor-pointer rounded-xl px-4 py-1.5 text-xs font-black text-white transition-all hover:scale-105 active:scale-95",
                    style: "background:linear-gradient(135deg,#f97316,#dc2626); box-shadow:0 4px 12px -2px rgba(234,88,12,0.45)" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="py-5 border-b border-stone-100 flex justify-center">
        <%= link_to login_path,
              class: "inline-flex items-center gap-2 rounded-2xl px-6 py-2.5 text-sm font-black text-white transition-all hover:scale-[1.02] hover:brightness-110",
              style: "background:linear-gradient(135deg,#f97316,#dc2626); box-shadow:0 4px 16px -4px rgba(234,88,12,0.45)" do %>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
          </svg>
          <%= t("comments.login_to_comment") %>
        <% end %>
      </div>
    <% end %>

    <%# ── Comments list ──────────────────────────────────────────────────── %>
    <% if comments.any? %>
      <div class="divide-y divide-stone-100 pb-2">
        <%= render partial: "comments/comment", collection: comments %>
      </div>
    <% else %>
      <div class="flex flex-col items-center gap-3 py-10">
        <div class="w-14 h-11 rounded-2xl flex items-center justify-center text-2xl"
             style="background:linear-gradient(135deg,#fff7ed,#fef3c7)">
          💬
        </div>
        <p class="text-sm font-semibold text-stone-400"><%= t("comments.no_comments") %></p>
      </div>
    <% end %>
  </div>

</div>
