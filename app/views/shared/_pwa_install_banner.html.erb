<div data-controller="pwa-install"
     data-ios-title="<%= t('pwa.ios_safari_title') %>"
     data-ios-other-title="<%= t('pwa.ios_other_title') %>"
     data-android-title="<%= t('pwa.android_title') %>"
     data-ios-safari1="<%= t('pwa.ios_safari_step1') %>"
     data-ios-safari2="<%= t('pwa.ios_safari_step2') %>"
     data-ios-safari3="<%= t('pwa.ios_safari_step3') %>"
     data-ios-other1="<%= t('pwa.ios_other_step1') %>"
     data-firefox-android1="<%= t('pwa.firefox_android_step1') %>"
     data-firefox-android2="<%= t('pwa.firefox_android_step2') %>"
     data-samsung-android1="<%= t('pwa.samsung_android_step1') %>"
     data-samsung-android2="<%= t('pwa.samsung_android_step2') %>"
     data-opera-android1="<%= t('pwa.opera_android_step1') %>"
     data-opera-android2="<%= t('pwa.opera_android_step2') %>"
     class="fixed inset-0 z-[200] pointer-events-none">

  <%# ── Full-screen overlay ─────────────────────────── %>
  <div data-pwa-install-target="banner"
       class="hidden pointer-events-auto inset-0 fixed bg-black/60 backdrop-blur-sm flex items-end sm:items-center justify-center transition-opacity duration-300 opacity-0"
       data-action="click->pwa-install#dismissOverlay">

    <div class="bg-white w-full sm:max-w-sm sm:rounded-3xl rounded-t-3xl shadow-2xl overflow-hidden animate-slide-up"
         data-action="click->pwa-install#stopPropagation">

      <%# Top visual — phone icon + app icon ───────── %>
      <div class="gradient-brand px-6 pt-8 pb-6 text-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-white/20"></div>
          <div class="absolute -bottom-10 -left-10 w-32 h-32 rounded-full bg-white/20"></div>
        </div>
        <div class="relative">
          <div class="w-20 h-20 mx-auto mb-4 bg-white rounded-2xl shadow-lg flex items-center justify-center">
            <img src="/icon-192.png" alt="<%= t('brand.name') %>" class="w-14 h-14 rounded-xl">
          </div>
          <h2 class="text-xl font-black text-white mb-1"><%= t("brand.short_name") %></h2>
          <p class="text-sm text-white/80 font-medium"><%= t("pwa.simple_tagline") %></p>
        </div>
      </div>

      <%# Benefits — simple visual list ────────────── %>
      <div class="px-6 py-5 space-y-3">
        <div class="flex items-center gap-3">
          <span class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </span>
          <p class="text-sm text-gray-700 font-medium"><%= t("pwa.benefit_fast") %></p>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </span>
          <p class="text-sm text-gray-700 font-medium"><%= t("pwa.benefit_homescreen") %></p>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-10 h-10 rounded-xl bg-orange-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </span>
          <p class="text-sm text-gray-700 font-medium"><%= t("pwa.benefit_notification") %></p>
        </div>
      </div>

      <%# Browser-specific steps (iOS/non-Chrome) ──── %>
      <div data-pwa-install-target="instructions" class="hidden px-6 pb-2"></div>

      <%# Action buttons ───────────────────────────── %>
      <div class="px-6 pb-6 space-y-2.5">
        <button data-pwa-install-target="nativeButton"
                data-action="pwa-install#install"
                class="hidden w-full py-3.5 rounded-2xl text-base font-bold text-white gradient-brand shadow-lg shadow-orange-500/25 hover:shadow-xl active:scale-[0.98] transition-all cursor-pointer">
          <%= t("pwa.install_now") %> 📲
        </button>

        <button data-action="pwa-install#remindLater"
                class="w-full py-3 rounded-2xl text-sm font-semibold text-gray-500 hover:text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer">
          <%= t("pwa.remind_later") %>
        </button>
      </div>
    </div>
  </div>
</div>
