<div data-controller="pwa-install"
     data-pwa-install-ios-title-value="<%= t('pwa.ios_safari_title') %>"
     data-pwa-install-ios-other-title-value="<%= t('pwa.ios_other_title') %>"
     data-pwa-install-android-title-value="<%= t('pwa.android_title') %>"
     data-ios-title="<%= t('pwa.ios_safari_title') %>"
     data-ios-other-title="<%= t('pwa.ios_other_title') %>"
     data-android-title="<%= t('pwa.android_title') %>"
     data-ios-safari1="<%= t('pwa.ios_safari_step1') %>"
     data-ios-safari2="<%= t('pwa.ios_safari_step2') %>"
     data-ios-safari3="<%= t('pwa.ios_safari_step3') %>"
     data-ios-other1="<%= t('pwa.ios_other_step1') %>"
     data-firefox-android1="<%= t('pwa.firefox_android_step1') %>"
     data-firefox-android2="<%= t('pwa.firefox_android_step2') %>"
     data-samsung-android1="<%= t('pwa.samsung_android_step1') %>"
     data-samsung-android2="<%= t('pwa.samsung_android_step2') %>"
     data-opera-android1="<%= t('pwa.opera_android_step1') %>"
     data-opera-android2="<%= t('pwa.opera_android_step2') %>"
     class="fixed bottom-0 inset-x-0 z-[100] pointer-events-none">

  <div data-pwa-install-target="banner"
       class="hidden pwa-install-banner pointer-events-auto mx-4 mb-4 sm:mx-auto sm:max-w-md rounded-2xl bg-white border border-gray-200/80 shadow-2xl shadow-black/10 overflow-hidden transition-all duration-300 ease-out">

    <%# Header %>
    <div class="flex items-center gap-3 p-4 pb-2">
      <img src="/icon-192.png" alt="<%= t('brand.name') %>" class="w-12 h-12 rounded-xl shadow-sm">
      <div class="flex-1 min-w-0">
        <p class="text-sm font-bold text-gray-900 truncate"><%= t("brand.name") %></p>
        <p class="text-xs text-gray-500"><%= t("pwa.install_tagline") %></p>
      </div>
      <button data-action="pwa-install#dismiss"
              class="shrink-0 p-1.5 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100 transition-colors cursor-pointer"
              aria-label="Close">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <%# Browser-specific instructions (populated by JS) %>
    <div data-pwa-install-target="instructions" class="hidden px-4 pb-2"></div>

    <%# Native install button (shown only when beforeinstallprompt fires) %>
    <div class="px-4 pb-4">
      <button data-pwa-install-target="nativeButton"
              data-action="pwa-install#install"
              class="hidden w-full py-2.5 rounded-xl text-sm font-semibold text-white gradient-brand shadow-sm shadow-orange-200 hover:shadow-md transition-shadow cursor-pointer">
        <%= t("pwa.install_button") %>
      </button>
    </div>
  </div>
</div>
