<%# ── Sticky bottom install bar ─────────────────────────────── %>
<div data-controller="pwa-install"
     data-ios-title="<%= t('pwa.ios_safari_title') %>"
     data-ios-safari1="<%= t('pwa.ios_safari_step1') %>"
     data-ios-safari2="<%= t('pwa.ios_safari_step2') %>"
     data-ios-safari3="<%= t('pwa.ios_safari_step3') %>"
     data-ios-other-title="<%= t('pwa.ios_other_title') %>"
     data-ios-other1="<%= t('pwa.ios_other_step1') %>"
     data-android-title="<%= t('pwa.android_title') %>"
     data-firefox-android1="<%= t('pwa.firefox_android_step1') %>"
     data-firefox-android2="<%= t('pwa.firefox_android_step2') %>"
     data-samsung-android1="<%= t('pwa.samsung_android_step1') %>"
     data-samsung-android2="<%= t('pwa.samsung_android_step2') %>"
     data-opera-android1="<%= t('pwa.opera_android_step1') %>"
     data-opera-android2="<%= t('pwa.opera_android_step2') %>"
     class="fixed bottom-0 inset-x-0 z-[100]">

  <%# ── STICKY BAR — always visible at bottom ──────────── %>
  <div data-pwa-install-target="stickyBar"
       class="hidden bg-white/95 backdrop-blur-md border-t border-gray-200/60 shadow-[0_-4px_20px_rgba(0,0,0,0.08)] safe-bottom">
    <div class="max-w-lg mx-auto flex items-center gap-3 px-4 py-2.5">
      <img src="/icon-192.png" alt="" class="w-10 h-10 rounded-xl shadow-sm shrink-0">
      <div class="flex-1 min-w-0">
        <p class="text-sm font-bold text-gray-900 truncate"><%= t("brand.short_name") %></p>
        <p class="text-[11px] text-gray-500 truncate"><%= t("pwa.simple_tagline") %></p>
      </div>
      <button data-action="pwa-install#install"
              class="shrink-0 gradient-brand text-white text-sm font-bold px-5 py-2.5 rounded-xl shadow-md shadow-orange-500/20 active:scale-95 transition-transform cursor-pointer">
        📲 <%= t("pwa.install_now") %>
      </button>
      <button data-action="pwa-install#remindLater"
              class="shrink-0 text-gray-400 hover:text-gray-600 p-1.5 cursor-pointer" aria-label="Close">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <%# ── iOS/non-Chrome instructions overlay ────────────── %>
  <div data-pwa-install-target="overlay"
       class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-end justify-center z-[200] transition-opacity duration-300"
       data-action="click->pwa-install#closeOverlay">
    <div class="bg-white w-full sm:max-w-sm rounded-t-3xl sm:rounded-3xl sm:mb-8 shadow-2xl overflow-hidden animate-slide-up"
         data-action="click->pwa-install#stopPropagation">
      <div class="gradient-brand px-6 pt-6 pb-4 text-center">
        <div class="w-16 h-16 mx-auto mb-3 bg-white rounded-2xl shadow-lg flex items-center justify-center">
          <img src="/icon-192.png" alt="" class="w-11 h-11 rounded-xl">
        </div>
        <p class="text-base font-bold text-white"><%= t("pwa.simple_tagline") %></p>
      </div>
      <div data-pwa-install-target="instructions" class="px-6 py-4"></div>
      <div class="px-6 pb-5">
        <button data-action="pwa-install#closeOverlay"
                class="w-full py-2.5 rounded-xl text-sm font-semibold text-gray-500 hover:bg-gray-50 cursor-pointer">
          <%= t("pwa.remind_later") %>
        </button>
      </div>
    </div>
  </div>
</div>
