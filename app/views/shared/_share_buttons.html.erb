<%# Locals: share_text %>
<div class="flex items-center gap-3 mb-8">
  <%# WhatsApp %>
  <a href="https://wa.me/?text=<%= ERB::Util.url_encode(share_text) %>"
     target="_blank" rel="noopener"
     class="group flex items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-bold text-green-700 transition-all hover:shadow-md hover:shadow-green-100"
     style="background:linear-gradient(135deg,#f0fdf4,#dcfce7); border:1.5px solid #86efac">
    <svg class="w-5 h-5 group-hover:scale-110 transition-transform shrink-0" fill="#22c55e" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <%= I18n.locale == :hi ? "WhatsApp पर शेयर करें" : "Share on WhatsApp" %>
  </a>

  <%# Copy link %>
  <button data-controller="copy-link" data-copy-link-url-value="<%= request.original_url %>" data-action="copy-link#copy"
          class="group flex items-center gap-2 rounded-2xl px-5 py-2.5 text-sm font-bold text-orange-700 transition-all hover:shadow-md hover:shadow-orange-100 cursor-pointer"
          style="background:linear-gradient(135deg,#fff7ed,#ffedd5); border:1.5px solid #fed7aa">
    <svg class="w-5 h-5 group-hover:scale-110 transition-transform shrink-0" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="2">
      <path stroke-linecap="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
    </svg>
    <%= I18n.locale == :hi ? "लिंक कॉपी करें" : "Copy Link" %>
  </button>
</div>
