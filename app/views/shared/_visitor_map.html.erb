<%# Locals: realtime (hash), reporting (hash) %>
<%
  total_users  = reporting&.dig(:total_users).to_i
  live_total   = realtime&.dig(:total).to_i
  live_points  = realtime&.dig(:countries) || []

  # For the map: use realtime locations if available, else fall back to historical
  map_points = if live_points.any?
    live_points.filter_map do |c|
      centroid = GoogleAnalyticsService::COUNTRY_CENTROIDS[c[:code]]
      centroid ? c.merge(lat: centroid[0], lng: centroid[1]) : nil
    end
  else
    reporting&.dig(:map_points) || []
  end
  use_live = live_points.any?
  map_points_json = map_points.to_json
%>

<div class="mb-10 rounded-3xl overflow-hidden border border-gray-200/40 shadow-xl shadow-stone-900/10"
     style="background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%)">

  <%# ── Header ──────────────────────────────────────────────────────────── %>
  <div class="px-5 sm:px-7 pt-6 pb-4 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-0 sm:justify-between">
    <div>
      <h3 class="text-white font-black text-lg tracking-tight flex items-center gap-2.5">
        <span class="text-2xl">🌍</span>
        <%= t("feed.visitors_worldwide") %>
      </h3>
      <p class="text-white/40 text-xs mt-0.5"><%= t("feed.visitors_subtitle") %></p>
    </div>

    <%# Stats pills %>
    <div class="flex items-center gap-3 flex-wrap">
      <%# All-time total %>
      <div class="flex items-center gap-2 rounded-2xl px-4 py-2"
           style="background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1)">
        <svg class="w-4 h-4 text-indigo-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span class="text-white font-black text-sm tabular-nums"><%= total_users > 0 ? number_with_delimiter(total_users) : "—" %></span>
        <span class="text-white/50 text-xs"><%= t("feed.total_visitors") %></span>
      </div>

      <%# Live now %>
      <div class="flex items-center gap-2 rounded-2xl px-4 py-2"
           style="background:rgba(74,222,128,0.1); border:1px solid rgba(74,222,128,0.2)">
        <span class="relative flex h-2 w-2 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
        </span>
        <span class="text-green-400 font-black text-sm tabular-nums"><%= live_total > 0 ? live_total : "—" %></span>
        <span class="text-green-400/60 text-xs"><%= t("feed.active_now") %></span>
      </div>
    </div>
  </div>

  <%# ── Map ─────────────────────────────────────────────────────────────── %>
  <div id="visitor-map" class="w-full" style="height:280px; z-index:0"></div>

  <%# ── Country list ─────────────────────────────────────────────────────── %>
  <% display_countries = live_points.any? ? live_points.first(8) : (reporting&.dig(:countries) || []).first(8) %>
  <% if display_countries.any? %>
    <div class="px-5 sm:px-7 py-4 flex flex-wrap gap-2 border-t border-white/[0.06]">
      <% display_countries.each do |c| %>
        <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold text-white/70"
              style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08)">
          <%= c[:flag] %> <%= c[:name] %>
          <span class="text-white/30 font-normal"><%= number_with_delimiter(c[:count]) %></span>
        </span>
      <% end %>
    </div>
  <% end %>

</div>

<%# ── Leaflet map init ──────────────────────────────────────────────────── %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLs=" crossorigin=""></script>

<script>
(function() {
  var useLive  = <%= raw(use_live.to_json) %>;
  var points   = <%= raw(map_points_json) %>;

  function initMap() {
    var mapEl = document.getElementById('visitor-map');
    if (!mapEl) return;
    if (mapEl._leaflet_id) {
      // Already initialised — just return (Turbo cache hit)
      return;
    }

    var map = L.map('visitor-map', {
      center: [20, 0],
      zoom: 2,
      zoomControl: false,
      attributionControl: false,
      scrollWheelZoom: false,
      dragging: false,
      doubleClickZoom: false
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
      maxZoom: 19
    }).addTo(map);

    var maxCount = points.reduce(function(m, p) { return Math.max(m, p.count || 1); }, 1);

    points.forEach(function(p) {
      if (!p.lat || !p.lng) return;
      var radius = Math.max(6, Math.min(24, Math.sqrt((p.count || 1) / maxCount) * 24));

      if (useLive) {
        L.circleMarker([p.lat, p.lng], {
          radius: radius + 8,
          fillColor: '#4ade80',
          color: '#4ade80',
          weight: 0,
          fillOpacity: 0.12
        }).addTo(map);
        L.circleMarker([p.lat, p.lng], {
          radius: radius,
          fillColor: '#4ade80',
          color: '#fff',
          weight: 1.5,
          fillOpacity: 0.85
        }).bindTooltip('🟢 ' + p.name + ': ' + (p.count || 1) + ' reading now', { sticky: true }).addTo(map);
      } else {
        L.circleMarker([p.lat, p.lng], {
          radius: radius,
          fillColor: '#6366f1',
          color: '#818cf8',
          weight: 1,
          fillOpacity: 0.4,
          opacity: 0.5
        }).bindTooltip(p.name + ': ' + (p.count || 0).toLocaleString() + ' visitors', { sticky: true }).addTo(map);
      }
    });
  }

  // Run on initial load and on every Turbo navigation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
  document.addEventListener('turbo:render', initMap);
})();
</script>
