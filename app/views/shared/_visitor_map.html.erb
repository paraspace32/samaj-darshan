<%# Locals: realtime (hash), reporting (hash) %>
<%
  total_users      = reporting&.dig(:total_users).to_i
  total_events     = reporting&.dig(:total_events).to_i
  live_total       = realtime&.dig(:total).to_i
  live_city_points = realtime&.dig(:map_points) || []
  live_countries   = realtime&.dig(:countries)  || []

  # Prefer city-level realtime dots; fall back to historical city dots
  map_points = live_city_points.any? ? live_city_points : (reporting&.dig(:map_points) || [])
  use_live   = live_city_points.any?
  map_points_json = map_points.to_json
%>

<div class="mb-10 rounded-3xl overflow-hidden border border-gray-200 shadow-xl shadow-stone-900/10"
     style="background:#f8fafc">

  <%# ── Header ──────────────────────────────────────────────────────────── %>
  <div class="px-5 sm:px-7 pt-6 pb-4 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-0 sm:justify-between">
    <div>
      <h3 class="text-gray-900 font-black text-lg tracking-tight flex items-center gap-2.5">
        <span class="text-2xl">🌍</span>
        <%= t("feed.visitors_worldwide") %>
      </h3>
      <p class="text-gray-400 text-xs mt-0.5"><%= t("feed.visitors_subtitle") %></p>
    </div>

    <%# Stats pills %>
    <div class="flex items-center gap-3 flex-wrap">
      <%# All-time total %>
      <div class="flex items-center gap-2 rounded-2xl px-4 py-2"
           style="background:#f1f5f9; border:1px solid #e2e8f0">
        <svg class="w-4 h-4 text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span class="text-gray-900 font-black text-sm tabular-nums"><%= total_users > 0 ? number_with_delimiter(total_users) : "—" %></span>
        <span class="text-gray-400 text-xs"><%= t("feed.total_visitors") %></span>
      </div>

      <%# Total events %>
      <% if total_events > 0 %>
        <div class="flex items-center gap-2 rounded-2xl px-4 py-2"
             style="background:#fdf4ff; border:1px solid #e9d5ff">
          <svg class="w-4 h-4 text-purple-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <span class="text-gray-900 font-black text-sm tabular-nums"><%= number_with_delimiter(total_events) %></span>
          <span class="text-gray-400 text-xs"><%= t("feed.total_events") %></span>
        </div>
      <% end %>

      <%# Live now %>
      <div class="flex items-center gap-2 rounded-2xl px-4 py-2"
           style="background:#f0fdf4; border:1px solid #bbf7d0">
        <span class="relative flex h-2 w-2 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
        </span>
        <span class="text-green-700 font-black text-sm tabular-nums"><%= live_total > 0 ? live_total : "—" %></span>
        <span class="text-green-600/70 text-xs"><%= t("feed.active_now") %></span>
      </div>
    </div>
  </div>

  <%# ── Map ─────────────────────────────────────────────────────────────── %>
  <div id="visitor-map" class="w-full" style="height:320px; z-index:0; cursor:grab"></div>

  <%# ── Country list ─────────────────────────────────────────────────────── %>
  <% display_countries = live_countries.any? ? live_countries.first(8) : (reporting&.dig(:countries) || []).first(8) %>
  <% if display_countries.any? %>
    <div class="px-5 sm:px-7 py-4 flex flex-wrap gap-2 border-t border-gray-100">
      <% display_countries.each do |c| %>
        <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold text-gray-600"
              style="background:#f1f5f9; border:1px solid #e2e8f0">
          <%= c[:flag] %> <%= c[:name] %>
          <span class="text-gray-400 font-normal"><%= number_with_delimiter(c[:count]) %></span>
        </span>
      <% end %>
    </div>
  <% end %>

</div>

<%# ── Leaflet map init ──────────────────────────────────────────────────── %>
<script>
(function() {
  var useLive  = <%= raw(use_live.to_json) %>;
  var points   = <%= raw(map_points_json) %>;
  var _map     = null;

  function destroyMap() {
    if (_map) { try { _map.remove(); } catch(e) {} _map = null; }
    var el = document.getElementById('visitor-map');
    if (el) el._leaflet_id = null;
  }

  function initMap() {
    if (typeof L === 'undefined') return;
    var mapEl = document.getElementById('visitor-map');
    if (!mapEl) return;

    // Destroy any stale Leaflet instance before re-creating
    destroyMap();

    _map = L.map('visitor-map', {
      center: [20, 0],
      zoom: 2,
      zoomControl: true,
      attributionControl: false,
      scrollWheelZoom: false,
      dragging: true,
      doubleClickZoom: true,
      tap: true
    });

    // Light map tiles like Google Analytics
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png', {
      maxZoom: 19
    }).addTo(_map);

    var maxCount = points.reduce(function(m, p) { return Math.max(m, p.count || 1); }, 1);
    var bounds   = [];

    points.forEach(function(p) {
      if (!p.lat || !p.lng) return;
      bounds.push([p.lat, p.lng]);
      var ratio  = (p.count || 1) / maxCount;
      var radius = Math.max(14, Math.min(40, ratio * 40));

      // Outer glow (like GA's filled circle)
      L.circleMarker([p.lat, p.lng], {
        radius: radius,
        fillColor: '#4285f4',
        color: 'transparent',
        weight: 0,
        fillOpacity: 0.18
      }).addTo(_map);
      // Inner solid dot
      L.circleMarker([p.lat, p.lng], {
        radius: Math.max(7, radius * 0.45),
        fillColor: '#1a73e8',
        color: '#fff',
        weight: 2,
        fillOpacity: 0.95
      }).bindTooltip(p.name + ': ' + (p.count || 1) + (useLive ? ' अभी पढ़ रहे हैं' : ' visitors'), { sticky: true }).addTo(_map);
    });

    // Auto-fit to all data points worldwide
    if (bounds.length === 0) {
      _map.setView([20, 0], 2);
    } else if (bounds.length === 1) {
      _map.setView(bounds[0], 5);
    } else {
      _map.fitBounds(bounds, { padding: [50, 50] });
    }
  }

  // Destroy before Turbo caches the page so the snapshot is clean
  document.addEventListener('turbo:before-cache', destroyMap);
  // Re-init on every render (initial load + Turbo navigations)
  document.addEventListener('turbo:load', initMap);
  document.addEventListener('turbo:render', initMap);

  // Fallback for non-Turbo / direct load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
})();
</script>
