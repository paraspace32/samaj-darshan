<% content_for(:title, t("webinar.title")) %>

<% next_webinar = @upcoming.first %>
<% other_upcoming = @upcoming.drop(1) %>

<%# ═══════════════════════════════════════════════════════════════════
    SCHEDULED WEBINAR — always visible at top
    ═══════════════════════════════════════════════════════════════════ %>
<section class="mb-10 sm:mb-14 animate-fade-in">
  <% if next_webinar %>
    <%# Hero card for next scheduled webinar %>
    <div class="rounded-3xl border border-gray-200/40 overflow-hidden shadow-lg bg-white">
      <%= link_to webinar_path(next_webinar), class: "group block relative" do %>
        <div class="relative w-full overflow-hidden">
          <% if next_webinar.cover_image.attached? %>
            <%= optimized_image_tag next_webinar.cover_image, variant: :hero, class: "w-full h-auto sm:max-h-[18rem] sm:w-auto sm:object-contain group-hover:scale-[1.02] transition-transform duration-700 mx-auto", loading: "eager" %>
          <% end %>

        </div>
      <% end %>

      <div class="p-5 sm:p-8">
        <div class="flex items-center gap-2.5 mb-4">
          <% if next_webinar.live_now? %>
            <span class="relative flex items-center justify-center h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
            </span>
            <span class="text-[10px] font-bold px-2.5 py-0.5 rounded-md text-white uppercase tracking-wider bg-red-500"><%= t("webinar.live") %></span>
          <% else %>
            <span class="relative flex items-center justify-center h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-[10px] font-bold px-2.5 py-0.5 rounded-md text-white uppercase tracking-wider bg-emerald-500"><%= t("webinar.upcoming_badge") %></span>
          <% end %>
        </div>

        <h1 class="text-xl sm:text-3xl lg:text-4xl font-black text-gray-900 leading-tight tracking-tight group-hover:text-orange-600 transition-colors line-clamp-2 mb-6">
          <%= link_to next_webinar.display_title, webinar_path(next_webinar) %>
        </h1>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-500 mb-6">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="font-bold text-gray-700"><%= next_webinar.speaker_name %></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <span class="font-semibold"><%= next_webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= next_webinar.duration_minutes %> min</span>
          </div>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-orange-50 text-orange-700 font-semibold text-xs border border-orange-200/50">
            <%= next_webinar.platform_label %>
          </span>
        </div>

        <% if next_webinar.speaker_bio.present? %>
          <p class="text-sm text-gray-600 leading-relaxed mb-4 line-clamp-2"><%= next_webinar.speaker_bio %></p>
        <% end %>

        <% if next_webinar.display_description.present? %>
          <p class="text-sm text-gray-500 leading-relaxed mb-6 line-clamp-3"><%= truncate(strip_tags(next_webinar.display_description), length: 250) %></p>
        <% end %>

        <div class="text-center">
          <%= link_to webinar_path(next_webinar),
              class: "btn-primary !inline-flex !items-center !gap-3 !px-10 !py-4 !text-lg !rounded-2xl !shadow-xl" do %>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <%= t("webinar.register_and_watch") %>
          <% end %>
        </div>
      </div>
    </div>

    <%# Other upcoming webinars %>
    <% if other_upcoming.any? %>
      <div class="mt-8">
        <h2 class="text-lg sm:text-xl font-black tracking-tight text-gray-900 mb-5 flex items-center gap-2.5">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <%= t("webinar.more_upcoming") %>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          <% other_upcoming.each do |webinar| %>
            <%= link_to webinar_path(webinar), class: "group card-premium rounded-2xl border border-gray-200/40 block overflow-hidden" do %>
              <div class="aspect-video bg-gradient-to-br from-orange-100/90 via-amber-50 to-violet-100/80 relative overflow-hidden">
                <% if webinar.cover_image.attached? %>
                  <%= optimized_image_tag webinar.cover_image, variant: :card, class: "img-zoom w-full h-full object-cover", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="w-12 h-12 text-orange-300/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                  </div>
                <% end %>
              </div>
              <div class="p-4 sm:p-5">
                <span class="badge badge-upcoming shadow-sm mb-2"><%= t("webinar.upcoming_badge") %></span>
                <h3 class="font-black tracking-tight text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 text-base leading-snug mb-2"><%= webinar.display_title %></h3>
                <div class="text-xs text-gray-500">
                  <span class="font-semibold text-gray-600"><%= webinar.speaker_name %></span>
                  <span class="mx-1.5 text-gray-300">&middot;</span>
                  <span><%= webinar.starts_at.strftime("%d %b %Y") %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  <% else %>
    <%# No scheduled webinar — small message %>
    <div class="rounded-2xl border border-dashed border-gray-200 bg-gray-50/50 px-6 py-8 text-center">
      <div class="flex items-center justify-center gap-2 mb-2">
        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        <h2 class="text-base font-bold text-gray-600"><%= t("webinar.no_scheduled") %></h2>
      </div>
      <p class="text-sm text-gray-400"><%= t("webinar.no_scheduled_subtitle") %></p>
    </div>
  <% end %>
</section>

<%# ═══════════════════════════════════════════════════════════════════
    PAST WEBINARS — YouTube recordings grid
    ═══════════════════════════════════════════════════════════════════ %>
<% if @past.any? %>
  <section class="animate-fade-up">
    <div class="mb-6 sm:mb-8">
      <h2 class="text-xl sm:text-2xl font-black tracking-tight text-gray-900 flex items-center gap-3">
        <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        <%= t("webinar.past_recordings") %>
      </h2>
      <p class="text-sm text-gray-500 mt-2"><%= t("webinar.past_recordings_subtitle") %></p>
      <div class="section-divider mt-5"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      <% @past.each do |webinar| %>
        <div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm hover:shadow-lg transition-all group">
          <% if webinar.embeddable? %>
            <div class="relative w-full bg-black" style="padding-bottom: 56.25%;">
              <iframe
                src="<%= webinar.youtube_embed_url %>?rel=0"
                class="absolute inset-0 w-full h-full"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy">
              </iframe>
            </div>
          <% else %>
            <%= link_to webinar_path(webinar), class: "block" do %>
              <div class="aspect-video bg-gradient-to-br from-gray-100 to-stone-100 relative overflow-hidden">
                <% if webinar.cover_image.attached? %>
                  <%= optimized_image_tag webinar.cover_image, variant: :card, class: "w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500", loading: "lazy" %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center">
                    <svg class="w-12 h-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                  </div>
                <% end %>
                <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors">
                  <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 text-gray-800 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>

          <div class="p-4">
            <%= link_to webinar_path(webinar), class: "block" do %>
              <h3 class="font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 text-sm leading-snug mb-2"><%= webinar.display_title %></h3>
            <% end %>
            <div class="flex items-center flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500">
              <span class="font-semibold text-gray-600"><%= webinar.speaker_name %></span>
              <span class="text-gray-300">&middot;</span>
              <span><%= webinar.starts_at.strftime("%d %b %Y") %></span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
