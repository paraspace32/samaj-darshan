<% content_for(:title, t("webinar.title")) %>

<%# Header %>
<div class="mb-10 sm:mb-12 animate-fade-in">
  <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-gray-900"><span class="text-gradient"><%= t("webinar.title") %></span></h1>
  <p class="text-sm sm:text-base text-gray-500 mt-3 max-w-2xl leading-relaxed"><%= t("webinar.subtitle") %></p>
</div>

<%# Upcoming Webinars %>
<% if @upcoming.any? %>
  <section class="mb-14 sm:mb-16 animate-fade-up">
    <div class="mb-6 sm:mb-8">
      <h2 class="text-xl sm:text-2xl font-black tracking-tight text-gray-900 flex items-center gap-3">
        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse shadow-lg shadow-emerald-500/30"></span>
        <%= t("webinar.upcoming") %>
      </h2>
      <div class="section-divider mt-5"></div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-7">
      <% @upcoming.each do |webinar| %>
        <%= link_to webinar_path(webinar), class: "group card-premium rounded-3xl border border-gray-200/40 block" do %>
          <%# Cover image %>
          <div class="aspect-video bg-gradient-to-br from-orange-100/90 via-amber-50 to-violet-100/80 relative overflow-hidden">
            <% if webinar.cover_image.attached? %>
              <%= optimized_image_tag webinar.cover_image, variant: :card, class: "img-zoom w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-14 h-14 text-orange-300/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              </div>
            <% end %>
            <% if webinar.live_now? %>
              <span class="absolute top-4 left-4 badge badge-live shadow-xl">
                <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
                <%= t("webinar.live") %>
              </span>
            <% else %>
              <span class="absolute top-4 left-4 badge badge-upcoming shadow-lg">
                <%= t("webinar.upcoming_badge") %>
              </span>
            <% end %>
          </div>

          <div class="p-5 sm:p-6">
            <h3 class="font-black tracking-tight text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 mb-3 text-base sm:text-lg leading-snug"><%= webinar.display_title %></h3>
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-2.5">
              <svg class="w-3.5 h-3.5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <span class="font-semibold text-gray-600"><%= webinar.speaker_name %></span>
            </div>
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
              <svg class="w-3.5 h-3.5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <span><%= webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></span>
            </div>
            <div class="flex items-center gap-3 text-xs text-gray-400 pt-1 border-t border-gray-100">
              <span class="inline-flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= webinar.duration_minutes %> min
              </span>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-gray-100/90 text-gray-600 font-semibold border border-gray-200/40">
                <%= webinar.platform_label %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<%# Past Webinars %>
<% if @past.any? %>
  <section class="animate-fade-up">
    <div class="mb-6 sm:mb-8">
      <h2 class="text-xl sm:text-2xl font-black tracking-tight text-gray-900"><%= t("webinar.past") %></h2>
      <div class="section-divider mt-5"></div>
    </div>
    <div class="space-y-4">
      <% @past.each do |webinar| %>
        <%= link_to webinar_path(webinar), class: "group flex items-center gap-5 surface-raised rounded-3xl border border-gray-200/40 p-4 sm:p-5 transition-all hover:border-orange-200/80 hover:shadow-lg" do %>
          <div class="w-24 h-16 sm:w-28 sm:h-[4.5rem] rounded-2xl bg-gradient-to-br from-gray-100 to-stone-100 flex items-center justify-center shrink-0 overflow-hidden border border-gray-200/40 shadow-inner">
            <% if webinar.cover_image.attached? %>
              <%= optimized_image_tag webinar.cover_image, variant: :thumb, class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <svg class="w-7 h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <% end %>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold tracking-tight text-gray-900 group-hover:text-orange-600 transition-colors truncate text-base"><%= webinar.display_title %></h3>
            <div class="flex items-center flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500 mt-1.5">
              <span><%= webinar.speaker_name %></span>
              <span class="text-gray-300">&middot;</span>
              <span><%= webinar.starts_at.strftime("%d %b %Y") %></span>
              <span class="text-gray-300">&middot;</span>
              <span><%= webinar.platform_label %></span>
            </div>
          </div>
          <span class="badge shrink-0 bg-stone-100 text-stone-600 border border-stone-200/60 uppercase tracking-wider text-[10px] py-1.5 px-3"><%= t("webinar.ended") %></span>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<%# Empty state %>
<% if @upcoming.empty? && @past.empty? %>
  <div class="surface-elevated rounded-3xl border border-gray-200/40 px-8 py-20 sm:py-24 text-center shadow-xl animate-fade-in">
    <div class="w-20 h-20 rounded-3xl bg-gradient-to-br from-gray-100 to-stone-100 flex items-center justify-center mx-auto mb-6 border border-gray-200/40 shadow-inner">
      <svg class="w-10 h-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
    </div>
    <p class="text-gray-500 font-medium"><%= t("webinar.no_webinars") %></p>
  </div>
<% end %>
