<% content_for(:title, t("webinar.title")) %>

<%# Header %>
<div class="mb-8">
  <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900"><%= t("webinar.title") %></h1>
  <p class="text-sm text-gray-500 mt-1"><%= t("webinar.subtitle") %></p>
</div>

<%# Upcoming Webinars %>
<% if @upcoming.any? %>
  <section class="mb-12">
    <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
      <%= t("webinar.upcoming") %>
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @upcoming.each do |webinar| %>
        <%= link_to webinar_path(webinar), class: "group bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm hover:shadow-md hover:border-orange-200 transition-all" do %>
          <%# Cover image %>
          <div class="aspect-video bg-gradient-to-br from-orange-100 to-purple-100 relative overflow-hidden">
            <% if webinar.cover_image.attached? %>
              <%= image_tag url_for(webinar.cover_image.variant(:card)), class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center">
                <svg class="w-12 h-12 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              </div>
            <% end %>
            <% if webinar.live_now? %>
              <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-red-600 text-white shadow-lg">
                <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
                <%= t("webinar.live") %>
              </span>
            <% else %>
              <span class="absolute top-3 left-3 inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-emerald-600 text-white shadow">
                <%= t("webinar.upcoming_badge") %>
              </span>
            <% end %>
          </div>

          <div class="p-4">
            <h3 class="font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 mb-2"><%= webinar.display_title %></h3>
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <span class="font-medium"><%= webinar.speaker_name %></span>
            </div>
            <div class="flex items-center gap-2 text-xs text-gray-500 mb-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <span><%= webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></span>
            </div>
            <div class="flex items-center gap-3 text-xs text-gray-400">
              <span class="inline-flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= webinar.duration_minutes %> min
              </span>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-100 text-gray-600 font-medium">
                <%= webinar.platform_label %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<%# Past Webinars %>
<% if @past.any? %>
  <section>
    <h2 class="text-lg font-bold text-gray-900 mb-4"><%= t("webinar.past") %></h2>
    <div class="space-y-3">
      <% @past.each do |webinar| %>
        <%= link_to webinar_path(webinar), class: "group flex items-center gap-4 bg-white rounded-2xl border border-gray-200/60 p-4 shadow-sm hover:shadow-md hover:border-orange-200 transition-all" do %>
          <div class="w-20 h-14 rounded-xl bg-gray-100 flex items-center justify-center shrink-0 overflow-hidden">
            <% if webinar.cover_image.attached? %>
              <%= image_tag url_for(webinar.cover_image.variant(:thumb)), class: "w-full h-full object-cover", loading: "lazy" %>
            <% else %>
              <svg class="w-6 h-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <% end %>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="font-semibold text-gray-900 group-hover:text-orange-600 transition-colors truncate"><%= webinar.display_title %></h3>
            <div class="flex items-center gap-3 text-xs text-gray-400 mt-1">
              <span><%= webinar.speaker_name %></span>
              <span>&middot;</span>
              <span><%= webinar.starts_at.strftime("%d %b %Y") %></span>
              <span>&middot;</span>
              <span><%= webinar.platform_label %></span>
            </div>
          </div>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gray-100 text-gray-500 shrink-0"><%= t("webinar.ended") %></span>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<%# Empty state %>
<% if @upcoming.empty? && @past.empty? %>
  <div class="bg-white rounded-2xl border border-gray-200/60 px-6 py-16 text-center shadow-sm">
    <div class="w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
    </div>
    <p class="text-gray-400"><%= t("webinar.no_webinars") %></p>
  </div>
<% end %>
