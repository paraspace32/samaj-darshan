<% content_for(:title, @webinar.display_title) %>
<% content_for(:mobile_bar_share_text) { "#{@webinar.display_title}\n\n#{request.original_url}" } %>

<div class="max-w-5xl mx-auto animate-fade-in">

  <%# ── VIDEO — YouTube or Zoho meeting embed ── %>
  <% if @webinar.embeddable? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border-2 border-gray-200/50 bg-black shadow-2xl ring-1 ring-black/10">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          src="<%= @webinar.youtube_embed_url %>?autoplay=0&rel=0"
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  <% elsif @webinar.meeting_url.present? && @webinar.live_now? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white">
      <iframe
        src="<%= @webinar.meeting_url %>"
        class="w-full border-0"
        style="min-height: 75vh;"
        loading="eager"
        allow="camera; microphone; clipboard-write; fullscreen">
      </iframe>
    </div>
  <% end %>

  <%# ── REGISTRATION FORM — Native form + Zoho API ── %>
  <% if @webinar.zoho_session_id.present? && @webinar.upcoming? %>
    <div class="rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white p-6 sm:p-10">
      <h2 class="text-xl sm:text-2xl font-black text-gray-900 mb-2 text-center">
        <%= t("webinar.register_for_webinar") %>
      </h2>
      <p class="text-sm text-gray-500 mb-8 text-center">
        <%= @webinar.display_title %> &middot; <%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %>
      </p>

      <% if flash[:alert] %>
        <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm font-medium text-center">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-medium text-center">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <%= form_tag register_webinar_path(@webinar), method: :post, class: "max-w-md mx-auto space-y-5" do %>
        <div>
          <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5"><%= t("webinar.name") %> <span class="text-red-500">*</span></label>
          <input type="text" name="name" id="name" required
                 class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition-colors text-gray-900"
                 placeholder="<%= t('webinar.name') %>" value="<%= params[:name] %>">
        </div>

        <div>
          <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5"><%= t("webinar.phone") %> <span class="text-red-500">*</span></label>
          <input type="tel" name="phone" id="phone" required
                 class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition-colors text-gray-900"
                 placeholder="<%= t('webinar.phone') %>" value="<%= params[:phone] %>">
        </div>

        <div class="pt-2">
          <button type="submit" class="btn-primary w-full !py-4 !text-lg !rounded-2xl !shadow-xl flex items-center justify-center gap-3">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <%= t("webinar.register_now") %>
          </button>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
