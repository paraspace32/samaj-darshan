<% content_for(:title, @webinar.display_title) %>

<div class="max-w-3xl mx-auto animate-fade-in">
  <div class="surface-elevated rounded-3xl border border-gray-200/40 p-6 sm:p-8 lg:p-10 shadow-2xl shadow-gray-900/5">
    <%# Back link %>
    <div class="mb-8">
      <%= link_to webinars_path, class: "btn-ghost !py-2 !px-3 !text-sm text-gray-600 hover:text-orange-600" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
        <%= t("webinar.back_to_webinars") %>
      <% end %>
    </div>

    <%# Status badge %>
    <div class="flex flex-wrap items-center gap-2.5 mb-6">
      <% if @webinar.live_now? %>
        <span class="badge badge-live pulse-glow shadow-xl">
          <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
          <%= t("webinar.live") %>
        </span>
      <% elsif @webinar.upcoming? %>
        <span class="badge badge-upcoming shadow-lg"><%= t("webinar.upcoming_badge") %></span>
      <% else %>
        <span class="badge bg-stone-200/90 text-stone-700 border border-stone-300/50 shadow-sm"><%= t("webinar.ended") %></span>
      <% end %>
      <span class="badge badge-category text-gray-600 border border-gray-200/50"><%= @webinar.platform_label %></span>
    </div>

    <%# Title %>
    <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-gray-900 mb-6 leading-[1.15]"><%= @webinar.display_title %></h1>

    <%# Meta row %>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-200/40">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        <span class="font-bold text-gray-700"><%= @webinar.speaker_name %></span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span><%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span><%= @webinar.duration_minutes %> min</span>
      </div>
    </div>

    <%# Embedded video (YouTube Live) %>
    <% if @webinar.embeddable? %>
      <div class="mb-10 rounded-3xl overflow-hidden border-2 border-gray-200/50 bg-black shadow-2xl ring-1 ring-black/10">
        <div class="relative w-full bg-gradient-to-b from-gray-900 to-black" style="padding-bottom: 56.25%;">
          <iframe
            src="<%= @webinar.youtube_embed_url %>?autoplay=0&rel=0"
            class="absolute inset-0 w-full h-full"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>
      </div>
    <% elsif @webinar.cover_image.attached? %>
      <div class="mb-10 rounded-3xl overflow-hidden border border-gray-200/40 shadow-xl group">
        <%= optimized_image_tag @webinar.cover_image, variant: :hero, class: "img-zoom w-full object-cover", loading: "lazy" %>
      </div>
    <% end %>

    <%# Join button — only for non-embedded platforms (Zoom, Google Meet, etc.) %>
    <% if @webinar.meeting_url.present? && !@webinar.ended? && !@webinar.embeddable? %>
      <div class="text-center mb-10">
        <%= link_to sanitize_url(@webinar.meeting_url), target: "_blank", rel: "noopener noreferrer",
            class: "btn-primary !inline-flex !items-center !gap-3 !px-10 !py-4 !text-lg !rounded-2xl !shadow-xl #{@webinar.live_now? ? 'pulse-glow !shadow-red-500/25' : ''}" do %>
          <% if @webinar.live_now? %>
            <span class="w-2.5 h-2.5 rounded-full bg-white animate-pulse"></span>
            <%= t("webinar.join_now") %>
          <% else %>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <%= t("webinar.join_webinar") %>
          <% end %>
        <% end %>
      </div>
    <% elsif @webinar.ended? %>
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2.5 rounded-2xl surface-raised border border-gray-200/40 px-8 py-4 text-gray-500 font-semibold shadow-inner">
          <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= t("webinar.webinar_ended") %>
        </div>
      </div>
    <% end %>

    <%# Speaker bio %>
    <% if @webinar.speaker_bio.present? %>
      <div class="card-premium rounded-3xl border border-gray-200/40 p-6 sm:p-7 mb-10 bg-gradient-to-br from-white via-orange-50/30 to-amber-50/20 shadow-lg">
        <p class="text-[11px] font-black text-orange-600 uppercase tracking-widest mb-3"><%= t("webinar.about_speaker") %></p>
        <p class="text-sm sm:text-base text-gray-700 leading-relaxed"><%= @webinar.speaker_bio %></p>
      </div>
    <% end %>

    <%# Share buttons %>
    <%= render "shared/share_buttons",
          share_text: "#{@webinar.display_title} – #{request.original_url}" %>

    <%# Description %>
    <div class="rounded-3xl border border-gray-200/40 bg-white/80 p-6 sm:p-8 shadow-inner">
      <div class="prose prose-sm max-w-none text-gray-700 prose-headings:tracking-tight">
        <%= simple_format(@webinar.display_description) %>
      </div>
    </div>
  </div>
</div>
