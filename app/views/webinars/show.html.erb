<% content_for(:title, @webinar.display_title) %>
<% content_for(:mobile_bar_share_text) { "#{@webinar.display_title}\n\n#{request.original_url}" } %>

<div class="max-w-5xl mx-auto animate-fade-in">

  <%# ── VIDEO — YouTube embed or live meeting ── %>
  <% if @webinar.embeddable? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border-2 border-gray-200/50 bg-black shadow-2xl ring-1 ring-black/10">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          src="<%= @webinar.youtube_embed_url %>?autoplay=0&rel=0"
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  <% elsif @webinar.meeting_url.present? && @webinar.live_now? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white">
      <iframe
        src="<%= @webinar.meeting_url %>"
        class="w-full border-0"
        style="min-height: 75vh;"
        loading="eager"
        allow="camera; microphone; clipboard-write; fullscreen">
      </iframe>
    </div>
  <% end %>

  <%# ── COVER IMAGE + REGISTER BUTTON OVERLAY ── %>
  <% if !@webinar.embeddable? && !@webinar.live_now? %>
    <% if @webinar.cover_image.attached? && @webinar.meeting_url.present? %>
      <div class="rounded-2xl sm:rounded-3xl overflow-hidden shadow-lg">
        <%= optimized_image_tag @webinar.cover_image, variant: :hero, class: "w-full h-auto", loading: "eager" %>
      </div>
      <div class="mt-4 flex justify-center">
        <%= link_to sanitize_url(@webinar.meeting_url), class: "btn-primary !inline-flex !items-center !gap-3 !px-10 !py-4 !text-lg !rounded-2xl !shadow-xl hover:!scale-105 transition-transform" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <%= t("webinar.register_now") %>
        <% end %>
      </div>
    <% elsif @webinar.cover_image.attached? %>
      <div class="rounded-2xl sm:rounded-3xl overflow-hidden shadow-lg">
        <%= optimized_image_tag @webinar.cover_image, variant: :hero, class: "w-full h-auto", loading: "eager" %>
      </div>
    <% elsif @webinar.meeting_url.present? %>
      <div class="rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white p-8 sm:p-12 text-center">
        <h1 class="text-2xl sm:text-3xl font-black text-gray-900 mb-4"><%= @webinar.display_title %></h1>
        <p class="text-sm text-gray-500 mb-6"><%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></p>
        <%= link_to sanitize_url(@webinar.meeting_url), class: "btn-primary !inline-flex !items-center !gap-3 !px-10 !py-4 !text-lg !rounded-2xl !shadow-xl" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <%= t("webinar.register_now") %>
        <% end %>
      </div>
    <% end %>
  <% end %>

</div>
