<% content_for(:title, @webinar.display_title) %>
<% content_for(:mobile_bar_share_text) { "#{@webinar.display_title}\n\n#{request.original_url}" } %>

<div class="animate-fade-in">

  <%# ── VIDEO — YouTube embed or live meeting ── %>
  <% if @webinar.embeddable? %>
    <div class="max-w-5xl mx-auto mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border-2 border-gray-200/50 bg-black shadow-2xl ring-1 ring-black/10">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          src="<%= @webinar.youtube_embed_url %>?autoplay=0&rel=0"
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  <% elsif @webinar.meeting_url.present? && @webinar.live_now? %>
    <div class="max-w-5xl mx-auto mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white">
      <iframe
        src="<%= @webinar.meeting_url %>"
        class="w-full border-0"
        style="min-height: 75vh;"
        loading="eager"
        allow="camera; microphone; clipboard-write; fullscreen">
      </iframe>
    </div>
  <% end %>

  <%# ── COVER IMAGE + JOIN BUTTON ── %>
  <% if !@webinar.embeddable? && !@webinar.live_now? %>
    <% if @webinar.cover_image.attached? %>
      <div class="flex flex-col items-center" style="height: calc(100vh - 120px);">
        <div class="flex-1 min-h-0 flex justify-center w-full">
          <%= optimized_image_tag @webinar.cover_image, variant: :hero, class: "max-w-full max-h-full object-contain rounded-2xl sm:rounded-3xl shadow-lg", loading: "eager" %>
        </div>
        <% if @webinar.meeting_url.present? %>
          <div class="py-4 shrink-0">
            <%= link_to sanitize_url(@webinar.meeting_url), class: "btn-primary !inline-flex !items-center !gap-3 !px-10 !py-4 !text-lg !rounded-2xl !shadow-xl hover:!scale-105 transition-transform" do %>
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              <%= t("webinar.register_now") %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% elsif @webinar.meeting_url.present? %>
      <div class="flex justify-center py-8">
        <%= link_to sanitize_url(@webinar.meeting_url), class: "btn-primary !inline-flex !items-center !gap-3 !px-10 !py-4 !text-lg !rounded-2xl !shadow-xl hover:!scale-105 transition-transform" do %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <%= t("webinar.register_now") %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ── PAST RECORDINGS (only shown on upcoming/live webinar page) ── %>
  <% past_with_video = @webinar.upcoming? || @webinar.live_now? ? @past_recordings.select(&:embeddable?) : [] %>
  <% if past_with_video.any? %>
    <section class="mt-10 sm:mt-14 max-w-6xl mx-auto px-4 sm:px-0">
      <div class="mb-6 sm:mb-8">
        <h2 class="text-xl sm:text-2xl font-black tracking-tight text-gray-900 flex items-center gap-3">
          <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <%= t("webinar.past_recordings") %>
        </h2>
        <p class="text-sm text-gray-500 mt-1"><%= t("webinar.past_recordings_subtitle") %></p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
        <% past_with_video.each do |webinar| %>
          <div class="bg-white rounded-2xl border border-gray-200/60 overflow-hidden shadow-sm hover:shadow-lg transition-all group">
            <div class="relative w-full bg-black" style="padding-bottom: 56.25%;">
              <iframe
                src="<%= webinar.youtube_embed_url %>?rel=0"
                class="absolute inset-0 w-full h-full"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy">
              </iframe>
            </div>
            <div class="p-4">
              <h3 class="font-bold text-gray-900 line-clamp-2 text-sm leading-snug mb-2"><%= webinar.display_title %></h3>
              <div class="flex items-center flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500">
                <span class="font-semibold text-gray-600"><%= webinar.speaker_name %></span>
                <span class="text-gray-300">&middot;</span>
                <span><%= webinar.starts_at.strftime("%d %b %Y") %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

</div>
