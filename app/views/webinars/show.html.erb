<% content_for(:title, @webinar.display_title) %>

<div class="max-w-3xl mx-auto">
  <%# Back link %>
  <div class="mb-6">
    <%= link_to webinars_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-orange-600 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 19l-7-7 7-7"/></svg>
      <%= t("webinar.back_to_webinars") %>
    <% end %>
  </div>

  <%# Status badge %>
  <div class="flex items-center gap-2 mb-4">
    <% if @webinar.live_now? %>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-red-600 text-white">
        <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
        <%= t("webinar.live") %>
      </span>
    <% elsif @webinar.upcoming? %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-emerald-600 text-white"><%= t("webinar.upcoming_badge") %></span>
    <% else %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-gray-200 text-gray-600"><%= t("webinar.ended") %></span>
    <% end %>
    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= @webinar.platform_label %></span>
  </div>

  <%# Title %>
  <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-4 leading-tight"><%= @webinar.display_title %></h1>

  <%# Meta row %>
  <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 mb-6">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      <span class="font-semibold text-gray-700"><%= @webinar.speaker_name %></span>
    </div>
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      <span><%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></span>
    </div>
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span><%= @webinar.duration_minutes %> min</span>
    </div>
  </div>

  <%# Embedded video (YouTube Live) %>
  <% if @webinar.embeddable? %>
    <div class="mb-8 rounded-2xl overflow-hidden border border-gray-200/60 shadow-sm bg-black">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          src="<%= @webinar.youtube_embed_url %>?autoplay=0&rel=0"
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  <% elsif @webinar.cover_image.attached? %>
    <div class="mb-8">
      <%= image_tag url_for(@webinar.cover_image.variant(:hero)), class: "w-full rounded-2xl object-cover border border-gray-200/60 shadow-sm", loading: "lazy" %>
    </div>
  <% end %>

  <%# Join button — only for non-embedded platforms (Zoom, Google Meet, etc.) %>
  <% if @webinar.meeting_url.present? && !@webinar.ended? && !@webinar.embeddable? %>
    <div class="text-center mb-8">
      <%= link_to @webinar.meeting_url, target: "_blank", rel: "noopener noreferrer",
          class: "inline-flex items-center gap-3 rounded-2xl #{@webinar.live_now? ? 'bg-red-600 shadow-red-200 hover:bg-red-700' : 'gradient-brand shadow-orange-200'} px-10 py-4 text-lg font-bold text-white shadow-lg hover:shadow-xl transition-all" do %>
        <% if @webinar.live_now? %>
          <span class="w-2.5 h-2.5 rounded-full bg-white animate-pulse"></span>
          <%= t("webinar.join_now") %>
        <% else %>
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <%= t("webinar.join_webinar") %>
        <% end %>
      <% end %>
    </div>
  <% elsif @webinar.ended? %>
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-2 rounded-2xl bg-gray-100 px-8 py-4 text-gray-500 font-semibold">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= t("webinar.webinar_ended") %>
      </div>
    </div>
  <% end %>

  <%# Speaker bio %>
  <% if @webinar.speaker_bio.present? %>
    <div class="bg-orange-50 rounded-2xl border border-orange-200/60 p-5 mb-8">
      <p class="text-xs font-bold text-orange-600 uppercase tracking-wider mb-1"><%= t("webinar.about_speaker") %></p>
      <p class="text-sm text-gray-700"><%= @webinar.speaker_bio %></p>
    </div>
  <% end %>

  <%# Description %>
  <div class="bg-white rounded-2xl border border-gray-200/60 p-6 mb-8 shadow-sm">
    <div class="prose prose-sm max-w-none text-gray-700">
      <%= simple_format(@webinar.display_description) %>
    </div>
  </div>
</div>
