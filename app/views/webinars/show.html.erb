<% content_for(:title, @webinar.display_title) %>
<% content_for(:mobile_bar_share_text) { "#{@webinar.display_title}\n\n#{request.original_url}" } %>

<div class="max-w-5xl mx-auto animate-fade-in">

  <%# ── VIDEO — YouTube or Zoho meeting embed ── %>
  <% if @webinar.embeddable? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border-2 border-gray-200/50 bg-black shadow-2xl ring-1 ring-black/10">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          src="<%= @webinar.youtube_embed_url %>?autoplay=0&rel=0"
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  <% elsif @webinar.meeting_url.present? && @webinar.live_now? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white">
      <iframe
        src="<%= @webinar.meeting_url %>"
        class="w-full border-0"
        style="min-height: 75vh;"
        loading="eager"
        allow="camera; microphone; clipboard-write; fullscreen">
      </iframe>
    </div>
  <% end %>

  <%# ── REGISTRATION FORM — Zoho embed ── %>
  <% if @webinar.registration_url.present? && @webinar.upcoming? %>
    <!-- DEBUG: registration_url = <%= @webinar.registration_url %> -->
    <!-- DEBUG: registration_embed_url = <%= @webinar.registration_embed_url %> -->
    <div class="rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white">
      <iframe
        id="zoho-reg-iframe"
        src="<%= @webinar.registration_embed_url %>"
        class="w-full border-0"
        style="min-height: 70vh;"
        loading="eager"
        allow="clipboard-write"
        sandbox="allow-scripts allow-forms allow-same-origin">
      </iframe>
    </div>
    <script>
      (function() {
        var iframe = document.getElementById('zoho-reg-iframe');
        var src = iframe.getAttribute('src');
        var sandbox = iframe.getAttribute('sandbox');
        console.log('[Zoho Debug] iframe src:', src);
        console.log('[Zoho Debug] sandbox:', sandbox);

        iframe.addEventListener('load', function() {
          console.log('[Zoho Debug] iframe loaded, current src:', iframe.src);
          try {
            var doc = iframe.contentDocument || iframe.contentWindow.document;
            console.log('[Zoho Debug] Can access iframe document (same-origin)');
            console.log('[Zoho Debug] iframe title:', doc.title);
            console.log('[Zoho Debug] iframe URL:', doc.location.href);

            // Find all forms and log their targets
            var forms = doc.querySelectorAll('form');
            forms.forEach(function(f, i) {
              console.log('[Zoho Debug] Form ' + i + ':', {action: f.action, method: f.method, target: f.target});
            });

            // Find all links and log targets
            var links = doc.querySelectorAll('a[target]');
            links.forEach(function(a, i) {
              console.log('[Zoho Debug] Link ' + i + ':', {href: a.href, target: a.target, text: a.textContent.trim()});
            });

            // Find buttons
            var buttons = doc.querySelectorAll('button, input[type="submit"]');
            buttons.forEach(function(b, i) {
              console.log('[Zoho Debug] Button ' + i + ':', {type: b.type, text: b.textContent.trim(), onclick: b.getAttribute('onclick')});
            });
          } catch(e) {
            console.log('[Zoho Debug] Cannot access iframe document (cross-origin):', e.message);
          }
        });

        // Listen for blocked popup/navigation attempts
        window.addEventListener('message', function(event) {
          console.log('[Zoho Debug] postMessage from:', event.origin, 'data:', JSON.stringify(event.data).substring(0, 500));
        });
      })();
    </script>
  <% end %>

</div>
