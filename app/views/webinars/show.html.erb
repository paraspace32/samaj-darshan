<% content_for(:title, @webinar.display_title) %>
<% content_for(:mobile_bar_share_text) { "#{@webinar.display_title}\n\n#{request.original_url}" } %>

<div class="max-w-5xl mx-auto animate-fade-in">

  <%# ── VIDEO — YouTube or Zoho meeting embed ── %>
  <% if @webinar.embeddable? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border-2 border-gray-200/50 bg-black shadow-2xl ring-1 ring-black/10">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          src="<%= @webinar.youtube_embed_url %>?autoplay=0&rel=0"
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen>
        </iframe>
      </div>
    </div>
  <% elsif @webinar.meeting_url.present? && @webinar.live_now? %>
    <div class="mb-6 rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white">
      <iframe
        src="<%= @webinar.meeting_url %>"
        class="w-full border-0"
        style="min-height: 75vh;"
        loading="eager"
        allow="camera; microphone; clipboard-write; fullscreen">
      </iframe>
    </div>
  <% end %>

  <%# ── COVER IMAGE (when no video embed) ── %>
  <% if !@webinar.embeddable? && @webinar.cover_image.attached? %>
    <div class="mb-6">
      <%= optimized_image_tag @webinar.cover_image, variant: :hero, class: "w-full h-auto rounded-2xl sm:rounded-3xl shadow-lg", loading: "eager" %>
    </div>
  <% end %>

  <%# ── WEBINAR DETAILS ── %>
  <div class="rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white p-6 sm:p-8 mb-6">
    <%# Status badge %>
    <div class="flex items-center gap-2 mb-4">
      <% if @webinar.live_now? %>
        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold px-3 py-1 rounded-full text-white uppercase tracking-wider bg-red-500 shadow-sm">
          <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
          <%= t("webinar.live") %>
        </span>
      <% elsif @webinar.upcoming? %>
        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold px-3 py-1 rounded-full text-white uppercase tracking-wider bg-emerald-500 shadow-sm">
          <%= t("webinar.upcoming_badge") %>
        </span>
      <% else %>
        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold px-3 py-1 rounded-full text-gray-600 uppercase tracking-wider bg-gray-100">
          <%= t("webinar.ended") %>
        </span>
      <% end %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-blue-100 text-blue-700"><%= @webinar.platform_label %></span>
    </div>

    <%# Title %>
    <h1 class="text-2xl sm:text-3xl font-black text-gray-900 mb-4"><%= @webinar.display_title %></h1>

    <%# Meta info %>
    <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-600 mb-5">
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        <span class="font-semibold text-gray-900"><%= @webinar.speaker_name %></span>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span><%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></span>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span><%= @webinar.duration_minutes %> min</span>
      </div>
    </div>

    <%# Meeting link — only show when live or ended (not for upcoming, since we have our own registration) %>
    <% if @webinar.meeting_url.present? && !@webinar.upcoming? %>
      <div class="flex flex-col sm:flex-row sm:items-center gap-3 p-4 rounded-xl bg-orange-50 border border-orange-200/60 mb-5">
        <div class="flex items-center gap-2 flex-1 min-w-0">
          <svg class="w-5 h-5 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          <div class="min-w-0">
            <p class="text-xs font-semibold text-orange-700 uppercase tracking-wider mb-0.5"><%= t("webinar.meeting_link") %></p>
            <%= link_to truncate(@webinar.meeting_url, length: 50), sanitize_url(@webinar.meeting_url), target: "_blank", rel: "noopener noreferrer", class: "text-sm text-orange-600 hover:text-orange-700 font-medium break-all" %>
          </div>
        </div>
        <% if @webinar.live_now? %>
          <%= link_to sanitize_url(@webinar.meeting_url), target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center justify-center gap-2 rounded-xl bg-orange-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-orange-700 transition-colors shadow-sm shrink-0" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <%= t("webinar.join_now") %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Platform info for upcoming webinars %>
    <% if @webinar.upcoming? && @webinar.meeting_url.present? %>
      <div class="flex items-center gap-2 p-4 rounded-xl bg-blue-50 border border-blue-200/60 mb-5">
        <svg class="w-5 h-5 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="text-sm text-blue-700"><%= t("webinar.will_be_on_platform", platform: @webinar.platform_label) %> · <%= t("webinar.join_available_before") %></p>
      </div>
    <% end %>

    <%# Description %>
    <div class="prose prose-sm text-gray-600 max-w-none">
      <%= simple_format(@webinar.display_description) %>
    </div>

    <%# Speaker bio %>
    <% if @webinar.speaker_bio.present? %>
      <div class="mt-5 pt-5 border-t border-gray-100">
        <h3 class="text-sm font-bold text-gray-900 mb-2 flex items-center gap-1.5">
          <svg class="w-4 h-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <%= t("webinar.about_speaker") %>
        </h3>
        <p class="text-sm text-gray-600"><%= @webinar.speaker_bio %></p>
      </div>
    <% end %>
  </div>

  <%# ── REGISTRATION / JOIN SECTION ── %>
  <% if @webinar.upcoming? %>
    <% if params[:registered].present? && @webinar.meeting_url.present? %>
      <%# After successful registration — show meeting link %>
      <div class="rounded-2xl sm:rounded-3xl overflow-hidden border border-emerald-200 shadow-lg bg-white p-6 sm:p-10">
        <div class="text-center mb-6">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-100 mb-4">
            <svg class="w-8 h-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="text-xl sm:text-2xl font-black text-gray-900 mb-2"><%= t("webinar.registration_success").split("!").first %>!</h2>
          <p class="text-sm text-gray-500"><%= @webinar.display_title %> &middot; <%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %></p>
        </div>

        <div class="max-w-md mx-auto">
          <%= link_to sanitize_url(@webinar.meeting_url), target: "_blank", rel: "noopener noreferrer", class: "btn-primary w-full !py-4 !text-lg !rounded-2xl !shadow-xl flex items-center justify-center gap-3" do %>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            <%= t("webinar.join_webinar") %>
          <% end %>

          <p class="text-xs text-gray-400 text-center mt-3"><%= t("webinar.join_available_before") %></p>
        </div>
      </div>
    <% else %>
      <%# Registration form %>
      <div class="rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200/60 shadow-lg bg-white p-6 sm:p-10">
        <h2 class="text-xl sm:text-2xl font-black text-gray-900 mb-2 text-center">
          <%= t("webinar.register_for_webinar") %>
        </h2>
        <p class="text-sm text-gray-500 mb-8 text-center">
          <%= @webinar.display_title %> &middot; <%= @webinar.starts_at.strftime("%d %b %Y, %I:%M %p") %>
        </p>

        <% if flash[:alert] %>
          <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm font-medium text-center">
            <%= flash[:alert] %>
          </div>
        <% end %>

        <% if flash[:notice] %>
          <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-medium text-center">
            <%= flash[:notice] %>
          </div>
        <% end %>

        <%= form_tag register_webinar_path(@webinar), method: :post, class: "max-w-md mx-auto space-y-5" do %>
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5"><%= t("webinar.name") %> <span class="text-red-500">*</span></label>
            <input type="text" name="name" id="name" required
                   class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition-colors text-gray-900"
                   placeholder="<%= t('webinar.name') %>" value="<%= params[:name] %>">
          </div>

          <div>
            <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5"><%= t("webinar.phone") %> <span class="text-red-500">*</span></label>
            <input type="tel" name="phone" id="phone" required
                   class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 transition-colors text-gray-900"
                   placeholder="<%= t('webinar.phone') %>" value="<%= params[:phone] %>">
          </div>

          <div class="pt-2">
            <button type="submit" class="btn-primary w-full !py-4 !text-lg !rounded-2xl !shadow-xl flex items-center justify-center gap-3">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              <%= t("webinar.register_now") %>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

</div>
